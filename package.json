{
  "name": "digitalcheck-dito",
  "private": true,
  "homepage": "https://digitalcheck.bund.de/",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "audit:licences": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow 'MIT;BSD-3-Clause;BSD-2-Clause;0BSD;ISC;Apache-2.0;MPL-2.0;BlueOak-1.0.0;Custom: LICENSE;Unlicense' --summary",
    "build": "react-router build",
    "build:preview": "PREVIEW_BUILD=true react-router build",
    "clean": "rm -rf build/",
    "dev": "react-router dev",
    "dev:preview": "PREVIEW_BUILD=true PREVIEW_BASE_PATH=/preview/ pnpm dev",
    "docker": "docker compose up --build",
    "format:check": "prettier --check",
    "format:fix": "pnpm run format:fix-selected .",
    "format:fix-selected": "prettier --write --ignore-unknown",
    "lint:check": "react-router typegen && eslint --cache",
    "lint:fix": "react-router typegen && eslint --cache --fix",
    "pre-commit": "pnpm run build && pnpm run style:fix && pnpm run test && pnpm run typecheck",
    "preinstall": "echo 'Please disable script execution for security reasons: pnpm install --ignore-scripts' && exit 1",
    "start": "export $(grep -v '^#' .env | xargs) && react-router-serve build/server/index.js",
    "style:check": "pnpm run format:check && pnpm run lint:check",
    "style:fix": "pnpm run format:fix && pnpm run lint:fix",
    "test": "vitest run",
    "test:a11y": "playwright test tests/a11y --config=tests/playwright.config.ts --project=\"Desktop Chrome\"",
    "test:a11y-nightly": "playwright test tests/a11y --config=tests/playwright-nightly.config.ts",
    "test:e2e": "NODE_OPTIONS='--trace-warnings' playwright test tests/e2e/ --config=tests/playwright.config.ts",
    "test:e2e-onlineDocumentationV2": "NODE_OPTIONS='--trace-warnings' playwright test --config=tests/playwright-onlineDocumentationV2.config.ts",
    "test:e2e-nightly": "playwright test tests/e2e/ --config=tests/playwright-nightly.config.ts",
    "test:snapshots": "playwright test tests/snapshots --config=tests/playwright-snapshots.config.ts",
    "test:update-snapshots": "playwright test tests/snapshots --config=tests/playwright-snapshots.config.ts --update-snapshots",
    "tests": "vitest run && pnpm run test:e2e && pnpm run test:e2e-onlineDocumentationV2 && pnpm run test:a11y",
    "tests-nightly": "vitest run && pnpm run test:e2e-nightly && pnpm run test:e2e-onlineDocumentationV2 && pnpm run test:a11y-nightly",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@digitalservice4germany/angie": "^2.4.0",
    "@digitalservice4germany/style-dictionary": "^2.0.0",
    "@digitalservicebund/icons": "^2.1.0",
    "@headlessui/react": "^2.2.10",
    "@posthog/core": "^1.25.2",
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "@rvf/react": "^8.1.1",
    "@rvf/react-router": "^8.1.1",
    "@rvf/zod": "^7.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "isbot": "^5.1.37",
    "marked": "^17.0.5",
    "mime-types": "^3.0.2",
    "msw": "^2.13.2",
    "node-cache": "^5.1.2",
    "pdf-lib": "^1.17.1",
    "picomatch": "^4.0.4",
    "posthog-js": "^1.367.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "zod": "~4.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "^7.14.1",
    "@react-router/fs-routes": "^7.14.1",
    "@standard-schema/spec": "^1.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "license-checker-rseidelsohn": "^4.4.2",
    "mammoth": "^1.12.0",
    "playwright-core": "^1.59.1",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "undici": "^8.0.3",
    "vite": "^7.3.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "glob": "^11.1.0",
    "qs": "^6.14.1"
  }
}
