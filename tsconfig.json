{
  "extends": "astro/tsconfigs/strict",
  "exclude": [
    "dist",
    "build",
    "tests/playwright-report",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "include": [".astro/types.d.ts", "**/*"],
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./app/*"],
      "react-router": ["./app/utils/routerCompat.tsx"]
    }
  }
}
