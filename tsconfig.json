{
  "extends": "astro/tsconfigs/strict",
  "exclude": ["dist", "build", "tests/playwright-report"],
  "include": [".astro/types.d.ts", "**/*"],
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./app/*"]
    }
  }
}
