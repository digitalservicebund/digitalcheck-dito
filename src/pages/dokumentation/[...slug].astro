---
import Layout from "@/layouts/Layout.astro";
import DokumentationApp from "~/components/DokumentationApp";
import {
  fetchStrapiData,
  GET_PRINZIPS_WITH_EXAMPLES_QUERY,
} from "~/utils/strapiData.server";

export async function getStaticPaths() {
  const staticPaths = [
    "hinweise",
    "regelungsvorhaben-titel",
    "beteiligungsformate",
    "zusammenfassung",
    "absenden",
  ];

  const result = await fetchStrapiData(GET_PRINZIPS_WITH_EXAMPLES_QUERY);
  const prinzips = "error" in result ? [] : result.prinzips;

  const prinzipPaths = prinzips.flatMap((p: { URLBezeichnung: string }) => [
    { params: { slug: p.URLBezeichnung }, props: { prinzips } },
    {
      params: { slug: `${p.URLBezeichnung}/erlaeuterung` },
      props: { prinzips },
    },
  ]);

  return [
    ...staticPaths.map((slug) => ({ params: { slug }, props: { prinzips } })),
    ...prinzipPaths,
  ];
}

const { prinzips } = Astro.props;
---

<Layout showProgressBar={true}>
  <DokumentationApp client:load prinzips={prinzips} />
</Layout>
