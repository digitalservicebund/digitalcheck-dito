---
import Layout from "@/layouts/Layout.astro";
import { VerbindlicheAnforderungenPage } from "~/routes/dokumentation._documentationNavigation.verbindliche-anforderungen";
import { fetchPrinzipsWithExamples } from "~/utils/strapiData.server";

export const frontmatter = {
  title: "Verbindliche Anforderungen",
  sitemap: false,
};

const prinzips = await fetchPrinzipsWithExamples();
---

<Layout title={`Dokumentation: ${frontmatter.title}`} showProgressBar>
  <VerbindlicheAnforderungenPage
    client:load
    prinzips={prinzips}
    currentUrl={Astro.url.pathname}
  />
</Layout>
