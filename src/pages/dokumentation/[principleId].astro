---
import Layout from "@/layouts/Layout.astro";
import { PrinciplePage } from "~/routes/dokumentation._documentationNavigation.$principleId";
import { getPrincipleIdStaticPaths } from "~/utils/strapiData.server";
import { DocumentationRouter } from "~/routes/dokumentation.$page.tsx";
import LoadingPage from "@/components/LoadingPage.astro";
import ClientRouterLayout from "@/layouts/ClientRouterLayout.astro";

export const getStaticPaths = getPrincipleIdStaticPaths;

const { prinzips, principleName } = Astro.props;
const { principleId } = Astro.params;
---

<ClientRouterLayout title={`Dokumentation: ${principleName}`} showProgressBar>
  <DocumentationRouter
    client:only="react"
    prinzips={prinzips}
    path={Astro.url.pathname}
    transition:persist={"documentation"}
    principleId={principleId}
    ><LoadingPage slot="fallback" />
  </DocumentationRouter>
</ClientRouterLayout>
