---
import Layout from "@/layouts/Layout.astro";
import { PrinciplePage } from "~/routes/dokumentation._documentationNavigation.$principleId";
import {
  fetchStrapiData,
  GET_PRINZIPS_WITH_EXAMPLES_QUERY,
} from "~/utils/strapiData.server";
import type { PrinzipWithAspekteAndExample } from "~/utils/strapiData.types";

export const frontmatter = {
  title: "Dokumentation",
};

export async function getStaticPaths() {
  const result = await fetchStrapiData<{
    prinzips: PrinzipWithAspekteAndExample[];
  }>(GET_PRINZIPS_WITH_EXAMPLES_QUERY);
  const prinzips = "error" in result ? [] : result.prinzips;

  return prinzips.map((p: { URLBezeichnung: string }) => ({
    params: { principleId: p.URLBezeichnung },
    props: { prinzips },
  }));
}

const { prinzips } = Astro.props;
const { principleId } = Astro.params;
---

<Layout title={frontmatter.title} showProgressBar>
  <PrinciplePage
    client:load
    prinzips={prinzips}
    currentUrl={Astro.url.pathname}
    principleId={principleId}
  />
</Layout>
