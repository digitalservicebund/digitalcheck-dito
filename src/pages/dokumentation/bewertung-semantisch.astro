---
import Layout from "@/layouts/Layout.astro";
import { BewertungSemantischPage } from "~/routes/dokumentation._documentationNavigation.bewertung-semantisch";
import { fetchPrinzipsWithExamples } from "~/utils/strapiData.server";

export const frontmatter = {
  title: "Semantische Interoperabilität",
  sitemap: false,
};

const prinzips = await fetchPrinzipsWithExamples();
---

<Layout title={`Dokumentation: ${frontmatter.title}`} showProgressBar>
  <BewertungSemantischPage
    client:load
    prinzips={prinzips}
    currentUrl={Astro.url.pathname}
  />
</Layout>
