---
import Layout from "@/layouts/Layout.astro";
import { EuInteroperabilitaetsbezugPage } from "~/routes/dokumentation._documentationNavigation.eu-interoperabilitaetsbezug";
import { fetchPrinzipsWithExamples } from "~/utils/strapiData.server";

export const frontmatter = {
  title: "Interoperabilitäts-Bezug",
  sitemap: false,
};

const prinzips = await fetchPrinzipsWithExamples();
---

<Layout title={`Dokumentation: ${frontmatter.title}`} showProgressBar>
  <EuInteroperabilitaetsbezugPage
    client:load
    prinzips={prinzips}
    currentUrl={Astro.url.pathname}
  />
</Layout>
