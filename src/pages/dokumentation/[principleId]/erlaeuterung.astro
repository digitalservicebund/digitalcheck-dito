---
import Layout from "@/layouts/Layout.astro";
import { ErlaeuterungPage } from "~/routes/dokumentation._documentationNavigation.$principleId_.erlaeuterung";
import { getPrincipleIdStaticPaths } from "~/utils/strapiData.server";

export const frontmatter = {
  title: "Erläuterung",
};

export const getStaticPaths = getPrincipleIdStaticPaths;

const { prinzips } = Astro.props;
const { principleId } = Astro.params;
---

<Layout title={frontmatter.title} showProgressBar>
  <ErlaeuterungPage
    client:load
    prinzips={prinzips}
    currentUrl={Astro.url.pathname}
    principleId={principleId}
  />
</Layout>
