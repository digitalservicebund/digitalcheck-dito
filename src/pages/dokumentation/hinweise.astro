---
import Layout from "@/layouts/Layout.astro";
import { HinweisePage } from "~/routes/dokumentation._documentationNavigation.hinweise";
import {
  fetchStrapiData,
  GET_PRINZIPS_WITH_EXAMPLES_QUERY,
} from "~/utils/strapiData.server";
import type { PrinzipWithAspekteAndExample } from "~/utils/strapiData.types";

export const frontmatter = {
  title: "Hinweise",
};

const result = await fetchStrapiData<{
  prinzips: PrinzipWithAspekteAndExample[];
}>(GET_PRINZIPS_WITH_EXAMPLES_QUERY);
if ("error" in result)
  throw new Error(`Failed to fetch Strapi data: ${result.error}`);
const prinzips = result.prinzips;
---

<Layout title={frontmatter.title} showProgressBar>
  <HinweisePage
    client:load
    prinzips={prinzips}
    currentUrl={Astro.url.pathname}
  />
</Layout>
