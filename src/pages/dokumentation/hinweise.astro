---
import Layout from "@/layouts/Layout.astro";
import { HinweisePage } from "~/routes/dokumentation._documentationNavigation.hinweise";
import { fetchPrinzipsWithExamples } from "~/utils/strapiData.server";

export const frontmatter = {
  title: "Hinweise",
};

const prinzips = await fetchPrinzipsWithExamples();
---

<Layout title={frontmatter.title} showProgressBar>
  <HinweisePage
    client:load
    prinzips={prinzips}
    currentUrl={Astro.url.pathname}
  />
</Layout>
