---
import Layout from "@/layouts/Layout.astro";
import { BeteiligungsformatePage } from "~/routes/dokumentation._documentationNavigation.beteiligungsformate";
import { fetchPrinzipsWithExamples } from "~/utils/strapiData.server";

export const frontmatter = {
  title: "Beteiligungsformate",
};

const prinzips = await fetchPrinzipsWithExamples();
---

<Layout title={`Dokumentation: ${frontmatter.title}`} showProgressBar>
  <BeteiligungsformatePage
    client:load
    prinzips={prinzips}
    currentUrl={Astro.url.pathname}
  />
</Layout>
