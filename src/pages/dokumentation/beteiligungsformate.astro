---
import Layout from "@/layouts/Layout.astro";
import { BeteiligungsformatePage } from "~/routes/dokumentation._documentationNavigation.beteiligungsformate";
import { fetchPrinzipsWithExamples } from "~/utils/strapiData.server";
import {
  dokumentation_beteiligungsformate,
  dokumentation_hinweise,
} from "@/config/routes.ts";
import { DocumentationRouter } from "~/routes/dokumentation.$page.tsx";
import ClientRouterLayout from "@/layouts/ClientRouterLayout.astro";

export const frontmatter = {
  title: "Beteiligungsformate",
  sitemap: false,
};

const prinzips = await fetchPrinzipsWithExamples();
---

<ClientRouterLayout
  title={`Dokumentation: ${frontmatter.title}`}
  showProgressBar
>
  <DocumentationRouter
    client:only="react"
    prinzips={prinzips}
    path={dokumentation_beteiligungsformate.path}
    transition:persist={"documentation"}>Slot</DocumentationRouter
  >
</ClientRouterLayout>
