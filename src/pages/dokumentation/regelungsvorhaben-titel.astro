---
import Layout from "@/layouts/Layout.astro";
import { TitelPage } from "~/routes/dokumentation._documentationNavigation.regelungsvorhaben-titel";
import { fetchPrinzipsWithExamples } from "~/utils/strapiData.server";
import {
  dokumentation_hinweise,
  dokumentation_regelungsvorhabenTitel,
} from "@/config/routes.ts";
import { DocumentationRouter } from "~/routes/dokumentation.$page.tsx";
import { ClientRouter } from "astro:transitions";
import ClientRouterLayout from "@/layouts/ClientRouterLayout.astro";

export const frontmatter = {
  title: "Regelungsvorhaben",
  sitemap: false,
};

const prinzips = await fetchPrinzipsWithExamples();
---

<ClientRouterLayout
  title={`Dokumentation: ${frontmatter.title}`}
  showProgressBar
>
  <DocumentationRouter
    client:only="react"
    prinzips={prinzips}
    path={dokumentation_regelungsvorhabenTitel.path}
    transition:persist={"documentation"}
  />
</ClientRouterLayout>
