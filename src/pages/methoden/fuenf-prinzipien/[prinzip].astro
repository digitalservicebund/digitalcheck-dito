---
import Layout from "@/layouts/Layout.astro";
import { Prinzip } from "~/routes/methoden.fuenf-prinzipien.$prinzip/route";
import {
  aspektBeispielFields,
  aspektCommonFields,
  fetchStrapiData,
  prinzipBeispielFields,
} from "~/utils/strapiData.server";
import type { PrinzipWithAspekteAndExample } from "~/utils/strapiData.types";

export const frontmatter = {
  title: "Fünf Prinzipien",
  sitemap: false,
};

// Like GET_PRINZIPS_WITH_EXAMPLES_QUERY, but additionally fetches the Aspekt
// Nummer and the Anwendung subtree which only this page renders. Kept here
// (rather than shared) so the documentation pages don't ship Anwendung data to
// the client during hydration.
const PRINZIPS_ASPEKTE_QUERY = `
query Prinzips {
  prinzips(sort: "order") {
    documentId
    Name
    Beschreibung
    order
    Nummer
    URLBezeichnung
    Beispiel {
      ${prinzipBeispielFields}
    }
    Aspekte {
      Nummer
      ${aspektCommonFields}
      Anwendung {
        Titel
        Erklaerung
        Formulierungsbeispiel
        Beispiel {
          documentId
          Nummer
          Text
          Auszug
          Paragraph {
            Nummer
            Gesetz
            Titel
          }
        }
      }
      Beispiel {
        ${aspektBeispielFields}
      }
    }
  }
}`;

export async function getStaticPaths() {
  const { prinzips } = await fetchStrapiData<{
    prinzips: PrinzipWithAspekteAndExample[];
  }>(PRINZIPS_ASPEKTE_QUERY);

  const prinzipList = prinzips.map(({ Name, URLBezeichnung, order }) => ({
    Name,
    URLBezeichnung,
    order,
  }));

  return prinzips.map((prinzip) => ({
    params: { prinzip: prinzip.URLBezeichnung },
    props: { prinzip, prinzipList },
  }));
}

const { prinzip, prinzipList } = Astro.props;

const title = prinzip ? `Prinzip: ${prinzip.Name}` : "Fünf Prinzipien";
---

<Layout title={title} showProgressBar>
  <Prinzip prinzip={prinzip} prinzipList={prinzipList} client:load />
</Layout>
