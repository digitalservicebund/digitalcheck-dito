---
import Layout from "@/layouts/Layout.astro";
import {
  aspektBeispielFields,
  aspektCommonFields,
  fetchStrapiData,
  prinzipBeispielFields,
} from "@/utils/strapiData.server";
import Badge from "@/components/Badge.tsx";
import { BlocksRenderer } from "@/components/BlocksRenderer.tsx";
import Hero from "@/components/Hero.astro";
import ToC from "@/components/TableOfContentsInteractive.tsx";
import SidebarContainer from "@/components/SidebarContainer.astro";
import type { PrinzipWithAspekteAndExample } from "@/utils/strapiData.types";
import { slugify } from "@/utils/utilFunctions";
import Aspect from "./_Aspect.astro";
import PrincipleNavigation from "./_PrincipleNavigation.astro";

export const frontmatter = {
  title: "Fünf Prinzipien",
  sitemap: false,
};

export async function getStaticPaths() {
  // Like GET_PRINZIPS_WITH_EXAMPLES_QUERY, but additionally fetches the Aspekt
  // Nummer and the Anwendung subtree which only this page renders. Kept here
  // (rather than shared) so the documentation pages don't ship Anwendung data to
  // the client during hydration.
  const PRINZIPS_ASPEKTE_QUERY = `
  query Prinzips {
    prinzips(sort: "order") {
      documentId
      Name
      Beschreibung
      order
      Nummer
      URLBezeichnung
      Beispiel {
        ${prinzipBeispielFields}
      }
      Aspekte {
        Nummer
        ${aspektCommonFields}
        Anwendung {
          Titel
          Erklaerung
          Formulierungsbeispiel
          Beispiel {
            documentId
            Nummer
            Text
            Auszug
            Paragraph {
              Nummer
              Gesetz
              Titel
            }
          }
        }
        Beispiel {
          ${aspektBeispielFields}
        }
      }
    }
  }`;
  const { prinzips } = await fetchStrapiData<{
    prinzips: PrinzipWithAspekteAndExample[];
  }>(PRINZIPS_ASPEKTE_QUERY);

  const prinzipList = prinzips.map(({ Name, URLBezeichnung, order }) => ({
    Name,
    URLBezeichnung,
    order,
  }));

  return prinzips.map((prinzip) => ({
    params: { principleId: prinzip.URLBezeichnung },
    props: { prinzip, prinzipList },
  }));
}

const { prinzip, prinzipList } = Astro.props;

const title = prinzip ? `Prinzip: ${prinzip.Name}` : "Fünf Prinzipien";
---

<Layout title={title} showProgressBar>
  <main>
    <div class="breakout-grid-toc">
      <Hero>
        <div>
          <Badge className={`bg-principle-${prinzip.Nummer} -mb-16`}>
            Prinzip {prinzip.order}
          </Badge>
        </div>
        <h1>{prinzip.Name}</h1>
        <BlocksRenderer
          className="ds-subhead mt-16 space-y-16"
          content={prinzip.Beschreibung}
        />
      </Hero>
    </div>
    <SidebarContainer>
      <ToC slot="sidebar" client:load title={"Inhalt"} selector="section[id]">
        <ToC.List className="list-unstyled list-none">
          {
            prinzip.Aspekte.map((aspect) => (
              <ToC.Item
                href={`#${slugify(aspect.Kurzbezeichnung)}`}
                title={(aspect.Nummer ?? "") + " " + aspect.Kurzbezeichnung}
              />
            ))
          }
        </ToC.List>
      </ToC>
      {
        prinzip.Aspekte.map((aspect) => (
          <Aspect aspect={aspect} prinzip={prinzip} />
        ))
      }
    </SidebarContainer>
    <div class="breakout-grid-toc my-80">
      <PrincipleNavigation principles={prinzipList} current={prinzip} />
    </div>
  </main>
</Layout>
