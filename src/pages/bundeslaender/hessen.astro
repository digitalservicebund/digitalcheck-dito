---
import LaenderLayout from "@/layouts/LaenderLayout.astro";
import AccordionItem from "~/components/AccordionItem";
import { LinkButton } from "~/components/Button";
import { Image } from "astro:assets";
import hessenLogo from "./_assets/hessen-logo.jpg";

export const frontmatter = {
  title: "Hessen",
  isStagingOnly: true,
};
---

<LaenderLayout title={frontmatter.title}>
  <p slot="subtitle">
    Die Landesregierung {frontmatter.title} verfolgt das Ziel, bürokratische Belastungen
    für Bürgerinnen und Bürger, Unternehmen sowie die Verwaltung auf das zwingend
    erforderliche Maß zu reduzieren.
  </p>
  <div slot="intro" class="space-y-16">
    <h2>Überblick</h2>
    <p>
      Die Landesregierung {frontmatter.title} verfolgt das Ziel, bürokratische Belastungen
      für Bürgerinnen und Bürger, Unternehmen sowie die Verwaltung auf das zwingend
      erforderliche Maß zu reduzieren.
    </p>
    <div class="mt-[18px]">
      <LinkButton>Mehr dazu erfahren</LinkButton>
    </div>
  </div>
  <section class="py-80 space-y-40">
    <div class="flex gap-32 items-center">
      <Image src={hessenLogo} alt="Logo von Hessen" class="w-[268px]" />
      <div>
        <h2>Zentralstelle Hessen</h2>
        <p>
          Der bestehende Normenbestand soll verschlankt, Personal-, Sach- und
          Verfahrensstandards sollen flexibilisiert und die digitale
          Transformation der Verwaltung soll aktiv unterstützt werden.
        </p>
      </div>
    </div>
    <div>
      <h2>Supportangebote</h2>
      <p>
        Lorem Ipsum is simply dummy text of the printing and typesetting
        industry. Lorem Ipsum has been the industry's standard dummy text ever
        since the 1500s, when an unknown printer took a galley of type and
        scrambled it to make a type specimen book.
      </p>
      <p>
        Lorem Ipsum is simply dummy text of the printing and typesetting
        industry. Lorem Ipsum has been the industry's standard dummy text ever
        since the 1500s, when an unknown printer took a galley of type and
        scrambled it to make a type specimen book.
      </p>
    </div>
    <div>
      <AccordionItem headline="Umsetzbarkeit" client:load>
        <p>
          Lorem Ipsum is simply dummy text of the printing and typesetting
          industry. Lorem Ipsum has been the industry's standard dummy text ever
          since the 1500s, when an unknown printer took a galley of type and
          scrambled it to make a type specimen book.
        </p>
      </AccordionItem>
      <AccordionItem headline="Digitale Relevanz" client:load>
