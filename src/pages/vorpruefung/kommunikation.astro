---
import Layout from "@/layouts/Layout.astro";
import PreCheckNavigation from "~/routes/vorpruefung._preCheckNavigation";
import QuestionPage from "~/routes/vorpruefung._preCheckNavigation.$questionId";

export const frontmatter = {
  title: "Digitale Kommunikation — Vorprüfung",
};
---

<Layout title={frontmatter.title} showProgressBar={true}>
  <PreCheckNavigation client:load>
    <QuestionPage client:load questionId="kommunikation" />
  </PreCheckNavigation>
</Layout>
