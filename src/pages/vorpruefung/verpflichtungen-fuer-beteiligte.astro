---
import VorpruefungLayout from "@/layouts/VorpruefungLayout.astro";
import { PreCheckQuestion } from "~/routes/vorpruefung._preCheckNavigation.$questionId";
import { getQuestion } from "./_getQuestion";

export const frontmatter = {
  title: "Verpflichtungen für Beteiligte",
};

const { questionIdx, question } = getQuestion(
  "verpflichtungen-fuer-beteiligte",
);
---

<VorpruefungLayout title={frontmatter.title}>
  <PreCheckQuestion client:load questionIdx={questionIdx} question={question} />
</VorpruefungLayout>
