---
import Layout from "@/layouts/Layout.astro";
import VorpruefungNavigation from "@/components/VorpruefungNavigation";
import { PreCheckQuestion } from "~/routes/vorpruefung._preCheckNavigation.$questionId";
import { getQuestion } from "./_getQuestion";

export const frontmatter = {
  title: "Verpflichtungen für Beteiligte — Vorprüfung",
};

const { questionIdx, question } = getQuestion(
  "verpflichtungen-fuer-beteiligte",
);
---

<Layout title={frontmatter.title} showProgressBar={true}>
  <VorpruefungNavigation client:load>
    <PreCheckQuestion
      client:load
      questionIdx={questionIdx}
      question={question}
    />
  </VorpruefungNavigation>
</Layout>
