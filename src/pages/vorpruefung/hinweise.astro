---
import Layout from "@/layouts/Layout.astro";
import VorpruefungNavigation from "@/pages/vorpruefung/_VorpruefungNavigation";
import HinweisePage from "~/routes/vorpruefung._preCheckNavigation.hinweise";

export const frontmatter = {
  title: "Allgemeine Hinweise zur Vorprüfung",
};
---

<Layout title={frontmatter.title} showProgressBar>
  <VorpruefungNavigation client:load pathname={Astro.url.pathname}>
    <HinweisePage client:load />
  </VorpruefungNavigation>
</Layout>
