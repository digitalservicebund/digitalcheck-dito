---
import { ClientRouter } from "astro:transitions";
import Layout from "@/layouts/Layout.astro";

interface Props {
  title?: string;
  description?: string;
  /** Pass true for routes that have a progress bar (vorpruefung, dokumentation). */
  showProgressBar?: boolean;
}
---

<Layout {...Astro.props}>
  <ClientRouter />
  <slot />
</Layout>
