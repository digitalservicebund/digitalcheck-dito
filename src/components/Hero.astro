---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const hasSubtitle = Astro.slots.has("subtitle");
---

<div class:list={["breakout bg-blue-100", className]}>
  <div class="space-y-16 py-40 pb-48 [&_h1]:sm:hyphens-none">
    <slot />
    {
      hasSubtitle && (
        <div class="ds-subhead mt-16 space-y-8">
          <slot name="subtitle" />
        </div>
      )
    }
  </div>
</div>
