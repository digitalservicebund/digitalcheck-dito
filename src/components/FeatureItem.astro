---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  title: string;
  body?: string;
}

const { icon, title, body } = Astro.props;
---

<div class="flex flex-col gap-16 md:flex-1 md:pr-32">
  <Icon class="text-ds-yellow-700 size-80 flex-none" name={icon} />
  <h3 class="m-0 font-bold max-w-[250px]">{title}</h3>
  {body && <p>{body}</p>}
  <slot />
</div>
