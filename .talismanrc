fileignoreconfig:
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - secret-scan
      - "password: \\${{ secrets.GITHUB_TOKEN }}"
  - filename: .github/workflows/scan.yml
    allowed_patterns:
      - TRIVY_PASSWORD
  - filename: .env.example
    ignore_detectors: [filename]
  - filename: .env.test
    ignore_detectors: [filename]
  - filename: src/env.d.ts
    ignore_detectors: [filename]
  - filename: src/config/posthog.ts
    checksum: bfa6e5b573b6a00e9ca64d34be9c4cc9e35d91cf6753d751a3f4df7f334ea9c3
  - filename: src/utils/localStorageVersioned.ts
    allowed_patterns:
      - storageKey
  - filename: src/utils/localStorageVersioned.spec.ts
    allowed_patterns:
      - testKey
  - filename: src/routes/dokumentation/DocumentationDataProvider.tsx
    allowed_patterns:
      - STORAGE_KEY
      - testKey
  - filename: src/routes/dokumentation/DocumentationDataProvider.spec.tsx
    allowed_patterns:
      - STORAGE_KEY
  - filename: src/routes/vorpruefung/preCheckDataService.ts
    allowed_patterns:
      - STORAGE_KEY
  - filename: src/resources/content/das-ist-neu.ts
    ignore_detectors: [filecontent]
  - filename: src/layouts/BeispieleLayout.astro # Google Forms link misinterpreted as base64
    ignore_detectors: [filecontent]
  - filename: src/resources/content/vorpruefung.ts # German text content misidentified as secret pattern
    ignore_detectors: [filecontent]
  - filename: src/resources/content/vorpruefung-ergebnis.ts # German text content misidentified as secret pattern
    checksum: 356e2177cff6c4579cbae0c4321d9d6e4752ba93bdf17fb7b7d99e105ff99cff
  - filename: src/resources/content/interoperabel-nationale-kontaktstelle.ts # German text content misidentified as secret pattern
    ignore_detectors: [filecontent]
  - filename: src/resources/content/methode-zustaendige-akteurinnen-auflisten.ts # German text content misidentified as secret pattern
    checksum: 957c92add9454aefd5145b48757ce39e277819d9775c68fe3e6dc1a73226db3e
  - filename: public/documents/interview-leitfaden/Akteurlandschaft_Analyse.pptx # Power Point
    ignore_detectors: [filecontent]
  - filename: scripts/nkr-data/uv.lock # autogenerated lock file
    ignore_detectors: [filecontent]
  - filename: scripts/nkr-data/.env.example
    ignore_detectors: [filename]
  - filename: public/documents/BundeslaenderInfoPage.pdf
    checksum: b5034dcbaa91c8cddcb4d75843b211b4a4cea87fb78b64ad327705d1f91b25cf
  - filename: nginx.template.conf
    allowed_patterns: [proxy_pass]
  - filename: src/pages/interoperabel/nationale-kontaktstelle/_content.ts
    ignore_detectors: [filename]

allowed_patterns:
  - key
  - onKey
  - handleKey
  - cacheKey
  - CacheKey
  - passen
  - Anpassungen
  - Pass\s # Allow "Pass " followed by a space
  - \@[a-z0-9]{40} # Allow fixing action hashes
  - "secrets: inherit"
  - "key: \\${{ runner.os }}"
  - GITOPS_DIGITALCHECK_APP_PRIVATE_KEY
  - ARGOCD_PIPELINE_PASSWORD
  - "pass: true"
  - activeKey
  - getSelectedIndexByKey
  - https://ec.europa.eu/.* # URL misidentified as secret pattern
  - posthogKey
  - POSTHOG_KEY
  - firstKey
  - tabKey
  - btnKey

scopeconfig:
  - scope: node # ignores files such as package-lock.json
