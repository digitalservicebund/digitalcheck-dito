fileignoreconfig:
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - secret-scan
      - "password: \\${{ secrets.GITHUB_TOKEN }}"
  - filename: .github/workflows/scan.yml
    allowed_patterns:
      - TRIVY_PASSWORD
  - filename: .env.example
    ignore_detectors: [filename]
  - filename: .env.test
    ignore_detectors: [filename]
  - filename: nginx/nginx.template.conf
    allowed_patterns:
      - proxy_pass
  - filename: src/components/Posthog.astro
    checksum: 29d1f7cc9a752975ec3954d5c56aca0f310f07d9f5a3227b7abe169015589a10
  - filename: app/root.tsx
    allowed_patterns: [posthogKey]
  - filename: app/utils/localStorageVersioned.ts
    allowed_patterns:
      - storageKey
  - filename: app/utils/localStorageVersioned.spec.ts
    allowed_patterns:
      - testKey
  - filename: app/routes/dokumentation/DocumentationDataProvider.tsx
    allowed_patterns:
      - STORAGE_KEY
      - testKey
  - filename: app/routes/dokumentation/DocumentationDataProvider.spec.tsx
    allowed_patterns:
      - STORAGE_KEY
  - filename: app/routes/vorpruefung/preCheckDataService.ts
    allowed_patterns:
      - STORAGE_KEY
  - filename: app/resources/content/das-ist-neu.ts
    ignore_detectors: [filecontent]
  - filename: app/resources/content/beispiele-regelungen.ts # Google Forms link misinterpreted as base64
    ignore_detectors: [filecontent]
  - filename: app/resources/content/vorpruefung.ts # German text content misidentified as secret pattern
    ignore_detectors: [filecontent]
  - filename: app/resources/content/interoperabel-nationale-kontaktstelle.ts # German text content misidentified as secret pattern
    ignore_detectors: [filecontent]
  - filename: public/documents/interview-leitfaden/Akteurlandschaft_Analyse.pptx # Power Point
    ignore_detectors: [filecontent]
  - filename: app/vite-env.d.ts
    checksum: f3fd561d4d951b8b328e6e40e389372a99ed98975a21d96ee0cf479b4470998b
  - filename: app/resources/content/methode-zustaendige-akteurinnen-auflisten.ts
    checksum: 0ae338c5f5e7aefb9ba34d7b8d17619c5b5c14112bae75a5a81389982ec41e06
  - filename: integrations/routeGeneration/extractRouteMeta.ts
    checksum: d648a63fdada9fc02cc3063bfb4835a4f69365c2faa8c31db2f2873bd0939449
  - filename: integrations/routeGenerator.test.ts
    checksum: 7c220b43d9f876f4e033937b3188aa320c9cbce4c32a88c7959fc22190342c7e
  - filename: integrations/routeGenerator.ts
    checksum: cf84ab1cfc87a6a303ce735703b9d8b355919e2cd1d52291820c7349144c1943
  - filename: package.json
    checksum: d3c57cb658650f943c5b85ff30593971a0be9a42bd9d5c0953d00f8d55b1c292
allowed_patterns:
  - key
  - onKey
  - handleKey
  - cacheKey
  - CacheKey
  - passen
  - Anpassungen
  - Pass\s # Allow "Pass " followed by a space
  - \@[a-z0-9]{40} # Allow fixing action hashes
  - "secrets: inherit"
  - "key: \\${{ runner.os }}"
  - GITOPS_DIGITALCHECK_APP_PRIVATE_KEY
  - ARGOCD_PIPELINE_PASSWORD
  - "pass: true"
  - activeKey
  - getSelectedIndexByKey
  - https://ec.europa.eu/.* # URL misidentified as secret pattern

scopeconfig:
  - scope: node # ignores files such as package-lock.json
