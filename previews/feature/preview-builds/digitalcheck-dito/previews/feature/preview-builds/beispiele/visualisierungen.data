[{"_1":2,"_20":21,"_174":175},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_18":19},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":8,"_13":8,"_14":8,"_15":8,"_16":8,"_17":8},"showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":22},[23,67,87,106,149],{"_24":25,"_26":27,"_28":29,"_30":31,"_62":63,"_64":65,"_66":27},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[32,40,44],{"_33":34,"_35":36},"type","paragraph","children",[37],{"_38":39,"_33":38},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_33":34,"_35":41},[42],{"_38":43,"_33":38},"Erfahren Sie in diesem Abschnitt,",{"_33":45,"_46":47,"_35":48},"list","format","unordered",[49,54,58],{"_33":50,"_35":51},"list-item",[52],{"_38":53,"_33":38},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_33":50,"_35":55},[56],{"_38":57,"_33":38},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_33":50,"_35":59},[60],{"_38":61,"_33":38},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_24":68,"_26":69,"_28":70,"_30":71,"_62":85,"_64":86,"_66":69},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[72],{"_33":34,"_35":73},[74,76,83],{"_38":75,"_33":38},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_77":78,"_33":79,"_35":80},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[81],{"_38":82,"_33":38},"Once-Only-Prinzip",{"_38":84,"_33":38}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_24":88,"_26":89,"_28":90,"_30":91,"_62":103,"_64":104,"_66":105},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[92],{"_33":34,"_35":93},[94,96,101],{"_38":95,"_33":38},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_77":97,"_33":79,"_35":98},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[99],{"_38":100,"_33":38},"Sicherheit der Angebote",{"_38":102,"_33":38}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_24":107,"_26":108,"_28":109,"_30":110,"_62":146,"_64":147,"_66":148},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[111,129],{"_33":34,"_35":112},[113,115,120,122,127],{"_38":114,"_33":38},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_77":116,"_33":79,"_35":117},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[118],{"_38":119,"_33":38},"GGO",{"_38":121,"_33":38}," und das ",{"_77":123,"_33":79,"_35":124},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[125],{"_38":126,"_33":38},"Handbuch der Rechtsförmlichkeit",{"_38":128,"_33":38}," vorgeschrieben.",{"_33":34,"_35":130},[131,133,137,139,144],{"_38":132,"_33":38},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_38":134,"_33":38,"_135":136},"Verwaltungsakt","italic",true,{"_38":138,"_33":38}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_77":140,"_33":79,"_35":141},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[142],{"_38":143,"_33":38},"§ 35a VwVfG",{"_38":145,"_33":38},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_24":150,"_26":105,"_28":151,"_30":152,"_62":172,"_64":173,"_66":108},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[153,164,168],{"_33":34,"_35":154},[155,157,162],{"_38":156,"_33":38},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_77":158,"_33":79,"_35":159},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[160],{"_38":161,"_33":38},"DSGVO",{"_38":163,"_33":38}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_33":34,"_35":165},[166],{"_38":167,"_33":38},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_33":34,"_35":169},[170],{"_38":171,"_33":38},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.visualisierungen",{"_3":176},[177,226,258,291,323,359,388,448,496,525,567,612,660],{"_24":178,"_179":180,"_30":181,"_210":211,"_212":213,"_214":215,"_216":217,"_218":219,"_225":-5},"a9m4ramlxkpbhoem6a7niuyc","Titel","Beratungs- und Erfassungsprozess",[182,186,201,206],{"_33":34,"_35":183},[184],{"_38":185,"_33":38},"Darstellung des Beratungsprozesses in der Antidiskriminierungsstelle",{"_33":45,"_46":187,"_35":188},"ordered",[189,193,197],{"_33":50,"_35":190},[191],{"_38":192,"_33":38},"Digitalisiert den Status Quo des Beratungs- und Erfassungsprozesses.",{"_33":50,"_35":194},[195],{"_38":196,"_33":38},"Macht den gesamten Anfrageprozess einer ratsuchenden Person sichtbar.",{"_33":50,"_35":198},[199],{"_38":200,"_33":38},"Zeigt Potenziale für Vereinfachungen und die Digitalisierung einzelner, manueller Prozessschritte auf.",{"_33":202,"_35":203},"quote",[204],{"_38":205,"_33":38},"Eine Visualisierung des IST-Zustands und des Zielbilds ist eine super — ich würde sogar sagen: notwendige — Ausgangslage für Transformationsvorhaben!",{"_33":34,"_35":207},[208],{"_38":209,"_33":38},"– Referentin Antidiskriminierungsstelle","Visualisierungsart","Entscheidungsbaum","Visualisierungstool","Miro / digitales Whiteboard","Aufwand","5h","Ressort","BMBFSFJ","Bild",{"_24":220,"_77":221,"_222":-5,"_223":224},"d0vc9katfp53r6b4iz702ear","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Ausschnitt_Visualisierung_Reg_Beg_7fcf14c131.png","previewUrl","alternativeText","Ein Flussdiagramm, welches den Beratungsprozesses in der Antidiskriminierungsstelle darstellt. Es zeigt die Interaktion zwischen einer ratsuchenden Person, Verantwortlichem für den Briefkasten und allen anderen Sachbearbeitenden.","Beispielvorhaben",{"_24":227,"_179":228,"_30":229,"_210":211,"_212":-5,"_214":-5,"_216":-5,"_218":248,"_225":252},"dv16mmtbauw4vddjc2dxofcf","Akteure und ihre Handlungsschritte",[230],{"_33":45,"_46":47,"_35":231},[232,236,240,244],{"_33":50,"_35":233},[234],{"_38":235,"_33":38},"Identifiziert die relevanten Akteure (Tierärztin/Tierarzt, Apotheken, Tierhalter/in) durch klare Icons und ordnet ihnen die spezifischen Handlungsschritte zu.",{"_33":50,"_35":237},[238],{"_38":239,"_33":38},"Macht den komplexen rechtlichen Prüfprozess sofort nachvollziehbar, indem die gesetzlichen Voraussetzungen in eindeutige binäre Entscheidungspunkten (\"ja\"/\"nein\") übersetzt werden",{"_33":50,"_35":241},[242],{"_38":243,"_33":38},"Konsolidiert die verschiedenen rechtlichen Zugangswege (über Apotheke oder Tierarzt) in einen einzigen, übersichtlichen Gesamtfluss, der transparent zum Ergebnis (\"Versand erlaubt\" oder \"Versand verboten\") führt.",{"_33":50,"_35":245},[246],{"_38":247,"_33":38},"Legt die festen Prüfregeln offen und macht sichtbar, wo standardisierte Abfragen  im Prozess ansetzen können.",{"_24":249,"_77":250,"_222":-5,"_223":251},"qvjia4vodjv9phd7p9pkddi6","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/7563_Prozessvisualisierung_GE_Aend_G_TAMG_Apo_G_Seite_1_edf2c06154.jpg","Flussdiagramm, das den Entscheidungsprozess für den Versand verschreibungspflichtiger Tierarzneimittel gemäß § 44a visualisiert. Es zeigt die unterschiedlichen Prüfwege für Tierärzte und Apotheken, die je nach Erfüllung der gesetzlichen Voraussetzungen zu einem erlaubten oder verbotenen Versand an den Tierhalter führen.",{"_62":253,"_254":-5,"_255":-5,"_179":256,"_216":257},"entwurf-eines-gesetzes-zur-aenderung-des-tierarzneimittelgesetzes-und-des-apothekengesetzes","VeroeffentlichungsDatum","Rechtsgebiet","Entwurf eines Gesetzes zur Änderung des Tierarzneimittelgesetzes und des Apothekengesetzes","BMELH",{"_24":259,"_179":260,"_30":261,"_210":280,"_212":281,"_214":-5,"_216":-5,"_218":282,"_225":286},"ke0mi4xdxi85e90goqixz2bh","Ablauf einer Datenanalyse",[262],{"_33":45,"_46":47,"_35":263},[264,268,272,276],{"_33":50,"_35":265},[266],{"_38":267,"_33":38},"Bietet eine detaillierte visuelle Darstellung des gesamten Datenanalyse-Ablaufs, inklusive des aktuellen Entwicklungsstands und der Struktur der Risikoanalyse.",{"_33":50,"_35":269},[270],{"_38":271,"_33":38},"Ordnet Analyseschritte direkt den jeweiligen Rechtsgrundlagen zu und unterstützt die einheitliche Nutzung von Fachbegriffen.",{"_33":50,"_35":273},[274],{"_38":275,"_33":38}," Ermöglicht das schnelle Identifizieren von Anpassungsbedarfen und das Durchspielen von Lösungsansätzen im Modell.",{"_33":50,"_35":277},[278],{"_38":279,"_33":38},"Erleichtert die Darstellung der komplexen Risikoanalyse gegenüber Dritten, wie z.B. Zusammenarbeitsbehörden.","Schaubild","MS Visio",{"_24":283,"_77":284,"_222":-5,"_223":285},"wv6aedcye2aoepm3ebpof9ye","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Visualisierung_OIDA_Stand_12_11_25_bd3555ce4a.jpg","Ein komplexes Flussdiagramm, das das \"operative Informations- und Datenanalysesystem (OIDA)\" zur Risikoanalyse im Bereich Schwarzarbeit visualisiert. Es zeigt die Datenflüsse zwischen verschiedenen Behörden und Systemen, Verarbeitungsschritte, Entscheidungswege sowie die zugrundeliegenden Rechtsgrundlagen.",{"_62":287,"_254":288,"_255":-5,"_179":289,"_216":290},"entwurf-eines-gesetzes-zur-modernisierung-und-digitalisierung-der-schwarzarbeitsbekaempfung","2025-12-18","Entwurf eines Gesetzes zur Modernisierung und Digitalisierung der Schwarzarbeitsbekämpfung","BMF",{"_24":292,"_179":293,"_30":294,"_210":313,"_212":314,"_214":-5,"_216":-5,"_218":315,"_225":319},"xvtg21ye68vdd2fmh07enhgj","Visualisierung unterschiedlicher Handlungsoptionen",[295],{"_33":45,"_46":47,"_35":296},[297,301,305,309],{"_33":50,"_35":298},[299],{"_38":300,"_33":38},"Visualisiert unterschiedliche rechtliche Handlungsoptionen als klare Verzweigungen im Ablauf.",{"_33":50,"_35":302},[303],{"_38":304,"_33":38},"Grenzt die Rollen der Beteiligten und des Notars durch \"Schwimmbahnen\" voneinander ab.",{"_33":50,"_35":306},[307],{"_38":308,"_33":38},"Verknüpft jeden Handlungsschritt direkt mit dem konkreten Absatz-Verweis zur einfachen Überprüfbarkeit.",{"_33":50,"_35":310},[311],{"_38":312,"_33":38},"Zeigt den vollständigen \"End-to-End\"-Prozess von der Initiierung bis zur final signierten Niederschrift.","Flussdiagramm","Bizagi",{"_24":316,"_77":317,"_222":-5,"_223":318},"avdz9w5qo9tufkncvu1y0pr8","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/250624_NKR_7621_Vorschlag_fbed061e1f.PNG","Das vorliegende Diagramm veranschaulicht zwei alternative Optionen für die Signatur durch Beteiligte, nämlich eine qualifizierte elektronische Signatur oder eine eigenhändige Signatur auf einem Gerät. Zudem wird der abschließende Schritt der qualifizierten elektronischen Signatur durch den Notar dargestellt. ",{"_62":320,"_254":-5,"_255":-5,"_179":321,"_216":322},"entwurf-eines-gesetzes-zur-einfuehrung-einer-elektronischen-praesenzbeurkundung","Entwurf eines Gesetzes zur Einführung einer elektronischen Präsenzbeurkundung","BMJV",{"_24":324,"_179":325,"_30":326,"_210":313,"_212":351,"_214":-5,"_216":-5,"_218":352,"_225":356},"a9ahymocw7c5krpdpd29tp6h","Grenzüberschreitender Ablauf",[327,331,345],{"_33":34,"_35":328},[329],{"_38":330,"_33":38,"_135":136},"Ablauf zur grenzüberschreitenden Herausgabe von e-Evidence innerhalb der EU",{"_33":45,"_46":47,"_35":332},[333,337,341],{"_33":50,"_35":334},[335],{"_38":336,"_33":38},"Grenzt die Rollen der verschiedenen nationalen und europäischen Akteure durch „Schwimmbahnen“ eindeutig voneinander ab.",{"_33":50,"_35":338},[339],{"_38":340,"_33":38},"Macht den gesamten logischen und zeitlichen Ablauf von der Anordnung bis zur Vollstreckung nachvollziehbar.",{"_33":50,"_35":342},[343],{"_38":344,"_33":38},"Differenziert zu Beginn klar zwischen den unterschiedlichen Datenkategorien für den weiteren Verfahrensweg.",{"_33":45,"_46":47,"_35":346},[347],{"_33":50,"_35":348},[349],{"_38":350,"_33":38},"Verdeutlicht die notwendigen Interaktionen zwischen Justizbehörden und privaten Dienstanbietern im grenzüberschreitenden Kontext.","Miro",{"_24":353,"_77":354,"_222":-5,"_223":355},"mgra0jbvuddj7agq010y1v5y","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Herausgabe_E_Evidence_290d25817e.png","Flussdiagramm, das den Ablauf für die Herausgabe von elektronischen Beweismitteln (E-Evidence) aus dem EU-Ausland an Deutschland visualisiert. Es zeigt die Schritte und Zuständigkeiten zwischen EU-Behörden, der deutschen Justiz und den betroffenen Dienstanbietern.",{"_62":357,"_254":-5,"_255":-5,"_179":358,"_216":322},"entwurf-zum-gesetz-ueber-die-grenzueberschreitende-herausgabe-elektronischer-beweismittel-in-strafverfahren-innerhalb-der-eu","Entwurf zum Gesetz über die grenzüberschreitende Herausgabe elektronischer Beweismittel in Strafverfahren innerhalb der EU",{"_24":360,"_179":361,"_30":362,"_210":280,"_212":-5,"_214":-5,"_216":-5,"_218":381,"_225":385},"p2pp79qa780sk2l0thggnoxd","Vorher-Nachher-Vergleich komplexer Regelungen",[363],{"_33":45,"_46":47,"_35":364},[365,369,373,377],{"_33":50,"_35":366},[367],{"_38":368,"_33":38},"Bereitet die komplexen steuerrechtlichen Regelungen zum Einsatz von Energieerzeugnissen zur Stromerzeugung strukturiert und übersichtlich auf. ",{"_33":50,"_35":370},[371],{"_38":372,"_33":38},"Unterstützt die Prüfung einzelner Fallkonstellationen durch klar nachvollziehbare Entscheidungsschritte.",{"_33":50,"_35":374},[375],{"_38":376,"_33":38},"Stellt die Unterschiede zwischen der bisherigen Rechtslage und der Rechtslage ab dem 1. Januar 2026 übersichtlich dar.",{"_33":50,"_35":378},[379],{"_38":380,"_33":38},"Verknüpft gesetzliche Grundlagen mit den jeweiligen Prozessschritten und erleichtert eine einheitliche Anwendung der Regelungen.",{"_24":382,"_77":383,"_222":-5,"_223":384},"j8hoeynu4ftspby7p5hs3d3i","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/7747_Anlage_Digi_Check_Anhang5_6b48c77525.jpg","Das übersichtliche Schaubild zeigt Schritt für Schritt, wann Energieerzeugnisse zur Stromerzeugung steuerfrei oder steuerlich entlastet sind. Dazu erfolgt ein Vergleich zwischen der bisherigen Rechtslage und den ab dem 1. Januar 2026 geltenden Regeln.",{"_62":386,"_254":-5,"_255":-5,"_179":387,"_216":290},"umsetzung-der-energiesteuerrichtlinie-beim-einsatz-von-energieerzeugnissen-zur-stromerzeugung","Umsetzung der Energiesteuerrichtlinie beim Einsatz von Energieerzeugnissen zur Stromerzeugung",{"_24":389,"_179":390,"_30":391,"_210":280,"_212":351,"_214":-5,"_216":-5,"_218":441,"_225":445},"ojroa1bzd8an6m44ge5c08ln","Übersicht verschiedener Prozesse im Rahmen eines Förderverfahrens",[392],{"_33":45,"_46":47,"_35":393},[394,411,421,433],{"_33":50,"_35":395},[396,398,401,403,405,407,409],{"_38":397,"_33":38},"Zeigt eine ",{"_399":136,"_38":400,"_33":38},"bold","vereinfachte",{"_38":402,"_33":38}," und ",{"_399":136,"_38":404,"_33":38},"beispielhafte",{"_38":406,"_33":38}," ",{"_399":136,"_38":408,"_33":38},"Darstellung der Prozesse",{"_38":410,"_33":38},", die sich im Kontext eines Förderverfahrens für Ganztagsbetreuung aus Sicht eines öffentlichen Schulträgers (Empfänger des Förderprogramms) abspielen.",{"_33":50,"_35":412},[413,415,417,419],{"_399":136,"_38":414,"_33":38},"Hebt die Verantwortlichkeiten",{"_38":416,"_33":38}," von Bund, Ländern und Kommunen ",{"_399":136,"_38":418,"_33":38},"farblich hervor",{"_38":420,"_33":38}," und macht so auf einen Blick sichtbar, wer welchen Schritt übernimmt.",{"_33":50,"_35":422},[423,425,427,429,431],{"_38":424,"_33":38},"Stellt die ",{"_399":136,"_38":426,"_33":38},"Phasen eines Bauvorhabens",{"_38":428,"_33":38}," von der Konzeption bis zur Evaluation ",{"_399":136,"_38":430,"_33":38},"schrittweise dar ",{"_38":432,"_33":38},"und zeigt, welche Prozesse einmalig und welche mehrfach durchlaufen werden. Dadurch ist der Gesamtprozess leicht nachvollziehbar.",{"_33":50,"_35":434},[435,437,439],{"_399":136,"_38":436,"_33":38},"Macht Herausforderungen",{"_38":438,"_33":38}," in der Umsetzung (rot) und Digitalisierungspotenziale (blau)",{"_399":136,"_38":440,"_33":38}," visuell deutlich und bietet Handlungsempfehlungen für die Praxis.",{"_24":442,"_77":443,"_222":-5,"_223":444},"abi9z49we5c3pptr90xgopxc","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Digitalcheck_BMBFSFJ_Unterstuetzung_Geteilt_Journey_1_6431aa2170.jpg","Die Visualisierung zeigt eine vereinfachte und beispielhafte Darstellung der Prozesse, die sich im Kontext eines Förderverfahrens für Ganztagsbetreuung aus Sicht eines öffentlichen Schulträgers abspielen. ",{"_62":446,"_254":-5,"_255":-5,"_179":447,"_216":217},"foerderung-des-ganztagsausbaus-aus-sicht-eines-oeffentlichen-schultraegers","Förderung des Ganztagsausbaus aus Sicht eines öffentlichen Schulträgers nach GaFöG ",{"_24":449,"_179":450,"_30":451,"_210":313,"_212":487,"_214":-5,"_216":-5,"_218":488,"_225":492},"e92syjtajombxqgan8ygq9i7","Ablauf eines Online-Verfahrens",[452,456],{"_33":34,"_35":453},[454],{"_38":455,"_33":38,"_135":136},"Ablauf eines Online-Verfahrens in der Zivilgerichtsbarkeit nach ZPO",{"_33":45,"_46":47,"_35":457},[458,464,470,476],{"_33":50,"_35":459},[460,462],{"_399":136,"_38":461,"_33":38},"Unterteilt den Gesamtprozess in drei abgegrenzte Bereiche ",{"_38":463,"_33":38},"und erleichtert so die Orientierung im Prozess.",{"_33":50,"_35":465},[466,468],{"_38":467,"_33":38},"Erleichtert das Auffinden der relevanten Textpassagen durch ",{"_399":136,"_38":469,"_33":38},"explizite Nennung der Regelungen, Paragraphen, Absätze und Sätze.",{"_33":50,"_35":471},[472,474],{"_399":136,"_38":473,"_33":38},"Markiert den Kernaspekt der Regelung",{"_38":475,"_33":38}," durch Verwendung einheitlicher Symbole. ",{"_33":50,"_35":477},[478,480,482,484,485],{"_38":479,"_33":38},"Verwendet Rauten als ",{"_399":136,"_38":481,"_33":38},"geläufige Darstellung für Entscheidungen in Flussdiagrammen, ",{"_38":483,"_33":38},"um",{"_399":136,"_38":406,"_33":38},{"_38":486,"_33":38},"schnelles Verständnis zu gewährleisten.","draw.io",{"_24":489,"_77":490,"_222":-5,"_223":491},"mfnncvpa89wdjbd4k1wcvky3","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/BMJ_7065_Visualisierung_OV_Erp_G_DB_3_BMJ_0c71f91453.png","Die Abbildung zeigt das Online-Verfahren in der Zivilgerichtsbarkeit, welches nach § 1124 I ZPO eröffnet ist.",{"_62":493,"_254":494,"_255":-5,"_179":495,"_216":322},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","2024-09-30","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit",{"_24":497,"_179":498,"_30":499,"_210":280,"_212":-5,"_214":-5,"_216":-5,"_218":516,"_225":520},"b7us17xq6zc3c66yxm6av6gm","Übersicht verantwortlicher Akteure",[500],{"_33":45,"_46":47,"_35":501},[502,510],{"_33":50,"_35":503},[504,506,508],{"_38":505,"_33":38},"Macht die Regelung leichter verständlich, indem sie ",{"_399":136,"_38":507,"_33":38},"die verantwortlichen Akteure für die Umsetzung und Überwachung darstellt ",{"_38":509,"_33":38},"und wie diese mit der neu eingerichteten Koordinierungsstelle interagieren.",{"_33":50,"_35":511},[512,514],{"_38":513,"_33":38},"Erleichtert das Auffinden der relevanten Textpassagen, aus welchen sich die jeweiligen Verantwortlichkeiten ergeben, durch ",{"_399":136,"_38":515,"_33":38},"explizite Nennung der Paragraphen.",{"_24":517,"_77":518,"_222":-5,"_223":519},"drewf3y70uxnm8ycy9s5q4k2","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Visualisierung_DDG_dd77dac88c.jpg","Flussdiagramm zur Koordinierungsstelle für digitale Dienste, das Zuständigkeiten und Zusammenarbeit mit Bundesnetzagentur, BfDI, Bundeskriminalamt und weiteren Akteuren zeigt.",{"_62":521,"_254":522,"_255":-5,"_179":523,"_216":524},"digitale-dienste-gesetz","2024-05-13","Digitale-Dienste-Gesetz","BMV",{"_24":526,"_179":527,"_30":528,"_210":313,"_212":558,"_214":-5,"_216":-5,"_218":559,"_225":563},"tkqvdwq669c7nkqrflqvzb5s","Vorher-Nachher-Vergleich",[529,533],{"_33":34,"_35":530},[531],{"_38":532,"_33":38},"Nach §3a URV",{"_33":45,"_46":47,"_35":534},[535,545,551],{"_33":50,"_35":536},[537,539,540,541,543],{"_38":538,"_33":38},"Macht Auswirkungen der Änderungen – den Wegfall von Extraschritt bei Nutzergruppe – durch einen ",{"_399":136,"_38":527,"_33":38},{"_38":406,"_33":38},{"_399":136,"_38":542,"_33":38},"nachvollziehbar",{"_38":544,"_33":38},".",{"_33":50,"_35":546},[547,549],{"_399":136,"_38":548,"_33":38},"Abstrahiert die inhaltliche Komplexität zu einer schematischen Darstellung",{"_38":550,"_33":38}," und ist damit verständlich für Fachleute und Laien.",{"_33":50,"_35":552},[553,555,557],{"_38":554,"_33":38},"Fördert eine schnelle Orientierung durch",{"_399":136,"_38":556,"_33":38}," Verknüpfung des Paragraphen mit der Visualisierung",{"_38":544,"_33":38},"PowerPoint",{"_24":560,"_77":561,"_222":-5,"_223":562},"rnvl92pn9drorwlvgar3nhd0","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/visualisierung_Unternehmensregisterverordnung_791d12038d.jpg","Das Bild zeigt zwei Flussdiagramme, die den Prozess der Identifizierung und Speicherung von Steuerberatern vor und nach einer Gesetzesänderung darstellen.",{"_62":564,"_254":565,"_255":-5,"_179":566,"_216":322},"identifikation-der-nutzer-unternehmensregisterverordnung-urv","2024-10-08","Identifikation der Nutzer Unternehmensregisterverordnung – URV",{"_24":568,"_179":569,"_30":570,"_210":313,"_212":351,"_214":-5,"_216":-5,"_218":604,"_225":608},"e5g1grgvgteh9idbowd7vqcc","Abstrahierter Antragsprozess",[571,575],{"_33":34,"_35":572},[573],{"_38":574,"_33":38},"Vereinfachter Zielprozess Antragstellung nach §9b StromStG",{"_33":45,"_46":47,"_35":576},[577,583,590,598],{"_33":50,"_35":578},[579,581],{"_399":136,"_38":580,"_33":38},"Abstrahiert den Antragsprozess und stellt ihn strukturiert dar",{"_38":582,"_33":38},", um bei verschiedenen Akteurinnen und Akteuren ein gemeinsames Verständnis zu schaffen. ",{"_33":50,"_35":584},[585,587,589],{"_38":586,"_33":38},"Zeigt die Aufteilung der Verantwortlichkeiten zwischen Unternehmen und Behörden durch ",{"_399":136,"_38":588,"_33":38},"klare visuelle Abgrenzung",{"_38":544,"_33":38},{"_33":50,"_35":591},[592,594,596],{"_38":593,"_33":38},"Macht durch die ",{"_399":136,"_38":595,"_33":38},"Kennzeichnung automatisierter Prüfungen",{"_38":597,"_33":38}," Digitalisierungspotenziale sichtbar.",{"_33":50,"_35":599},[600,602],{"_399":136,"_38":601,"_33":38},"Markiert optionale Schritte und Risiken",{"_38":603,"_33":38},", um komplexe Abläufe verständlich zu machen und Gestaltungsspielraum aufzuzeigen.",{"_24":605,"_77":606,"_222":-5,"_223":607},"j2l8q6b7wrxp53joe00s1bam","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Flussdiagramm_fuer_9b_Antrag_auf_Entlastung_46fef47656.jpg","Ein reduzierter, prozessualer Ablauf des Antrags auf Entlastung von der Stromsteuer",{"_62":609,"_254":610,"_255":-5,"_179":611,"_216":290},"gesetz-zur-modernisierung-und-zum-buerokratieabbau-im-strom-und-energiesteuerrecht","2024-04-12","Gesetz zur Modernisierung und zum Bürokratieabbau im Strom- und Energiesteuerrecht",{"_24":613,"_179":614,"_30":615,"_210":211,"_212":351,"_214":-5,"_216":-5,"_218":655,"_225":659},"m56ezco1mlzcci3sa6n53rzj","Gesamtprozess über Gesetz und Verordnungen",[616,620],{"_33":34,"_35":617},[618],{"_38":619,"_33":38},"Voraussetzungen für Entlastung nach §9b StromStG",{"_33":45,"_46":47,"_35":621},[622,630,636,642,649],{"_33":50,"_35":623},[624,626,628],{"_38":625,"_33":38},"Macht rechtliche Logik nachvollziehbar und leichter überprüfbar, indem ",{"_399":136,"_38":627,"_33":38},"Voraussetzungen eindeutig und strukturiert dargestellt",{"_38":629,"_33":38}," werden.",{"_33":50,"_35":631},[632,634],{"_399":136,"_38":633,"_33":38},"Führt Gesetz und Verordnung zusammen",{"_38":635,"_33":38}," und ermöglicht damit das Erfassen des Gesamtprozesses.",{"_33":50,"_35":637},[638,640],{"_399":136,"_38":639,"_33":38},"Hebt den Ursprung der Voraussetzungen farblich hervor ",{"_38":641,"_33":38},"um eine schnelle Orientierung zu gewährleisten.",{"_33":50,"_35":643},[644,646,648],{"_38":645,"_33":38},"Verdeutlicht Digitalisierungspotenziale durch die ",{"_399":136,"_38":647,"_33":38},"Unterscheidung automatisierter und manueller Schritte",{"_38":544,"_33":38},{"_33":50,"_35":650},[651,653],{"_399":136,"_38":652,"_33":38},"Verbindet rechtliche Voraussetzungen mit Umsetzungsschritten",{"_38":654,"_33":38}," und dient damit als Orientierung für beteiligte Akteurinnen und Akteure.",{"_24":656,"_77":657,"_222":-5,"_223":658},"iviqs5nqir0dch8aiy4c4p80","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Rulemap_fuer_9b_regelt_Antragsstellung_0d5d381327.jpg","Eine große, komplexe Übersicht der Entscheidungen und Logiken im §9b",{"_62":609,"_254":610,"_255":-5,"_179":611,"_216":290},{"_24":661,"_179":662,"_30":663,"_210":313,"_212":701,"_214":-5,"_216":-5,"_218":702,"_225":706},"qyh09ifld7r3a8z8h2pyhgom","Verknüpfung von Paragraphen und Prozessschitten",[664,668],{"_33":34,"_35":665},[666],{"_38":667,"_33":38},"UAS-Betreiberregistrierung nach §66a LuftVG",{"_33":45,"_46":47,"_35":669},[670,678,685,693],{"_33":50,"_35":671},[672,674,676],{"_38":673,"_33":38},"Stellt den ",{"_399":136,"_38":675,"_33":38},"Prozess klar und strukturiert",{"_38":677,"_33":38}," dar, sodass alle Schritte logisch aufeinander aufbauen und leicht nachvollziehbar sind.",{"_33":50,"_35":679},[680,682,684],{"_38":681,"_33":38},"Fördert eine schnelle Orientierung, indem",{"_399":136,"_38":683,"_33":38}," sie Paragraphen mit den Prozessschritten verknüpft",{"_38":544,"_33":38},{"_33":50,"_35":686},[687,689,691],{"_38":688,"_33":38},"Hebt ",{"_399":136,"_38":690,"_33":38},"Verantwortlichkeiten farblich",{"_38":692,"_33":38}," hervor, wodurch schnell erkennbar ist, welche Schritte von Antragstellenden, Behördenmitarbeitenden oder durch Automatisierung durchgeführt werden.",{"_33":50,"_35":694},[695,697,699],{"_38":696,"_33":38},"Erleichtert das Erkennen von Digitalisierungspotenzialen, indem ",{"_399":136,"_38":698,"_33":38},"automatisierte Schritte sichtbar",{"_38":700,"_33":38}," gemacht werden und Bereiche identifiziert werden können, die weiter digitalisiert werden könnten.","Conceptboard",{"_24":703,"_77":704,"_222":-5,"_223":705},"s5qc4bl08qk5h9a0judwan3e","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/7083_Visualisierung_Luft_VG_pages_to_jpg_0001_ac5b358394.jpg","Diagramm, das die Registrierung als UAS-Betreiber beschreibt",{"_62":707,"_254":708,"_255":-5,"_179":709,"_216":524},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","2024-07-25","Register über Betreiber von unbemannten Fluggeräten – LuftVG"]
