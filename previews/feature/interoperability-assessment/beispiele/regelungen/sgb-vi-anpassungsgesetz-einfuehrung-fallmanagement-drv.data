[{"_1":2,"_3":4,"_5":6},"root",{"_7":358},"routes/beispiele",{"_7":267},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":-5,"_14":-5,"_15":16,"_17":18,"_19":-5,"_20":21,"_22":23,"_24":25,"_26":27,"_28":29,"_30":31},"documentId","pr0wygso9gfpl1w2n2aw9wyy","Titel","SGB VI-Anpassungsgesetz – Einführung Fallmanagement DRV","NKRNummer","Rechtsgebiet","Ressort","BMAS","URLBezeichnung","sgb-vi-anpassungsgesetz-einfuehrung-fallmanagement-drv","VeroeffentlichungsDatum","LinkRegelungstext","https://dserver.bundestag.de/brd/2025/0423-25.pdf#page=8","NKRStellungnahmeLink","https://dserver.bundestag.de/brd/2025/0423-25.pdf#page=93","GesetzStatus","Text_im_Parlament","Paragraphen",[32],"Visualisierungen",[],"Digitalchecks",[],{"_9":33,"_34":35,"_11":-5,"_36":37,"_38":-5,"_39":40},"bzgq2ra9m59ho4v47c7j463w","Nummer","13a","Gesetz","SGB VI-AnpG","Artikel","Absaetze",[41,42,43,44,45,46],{"_9":260,"_48":261,"_34":219,"_51":262},{"_9":178,"_48":179,"_34":180,"_51":181},{"_9":145,"_48":146,"_34":147,"_51":148},{"_9":69,"_48":70,"_34":71,"_51":72},{"_9":61,"_48":62,"_34":63,"_51":64},{"_9":47,"_48":49,"_34":50,"_51":52},"ns7110jjy753fe6jq5q46q6s","Text",[53],6,"PrinzipErfuellungen",[],{"_54":55,"_56":57},"type","paragraph","children",[58],{"_59":60,"_54":59},"text","Führt ein Träger der Rentenversicherung ein Fallmanagement durch, werden die Bedarfsermittlung und, sofern die Voraussetzungen für ein Teilhabeplanverfahren nach Teil 1 Kapitel 2 bis 4 des Neunten Buches vorliegen, das Teilhabeplanverfahren als Bestandteil des Fallmanagements erbracht.","t7owi2bmnaj8ynqv5no3c5fs",[65],5,[],{"_54":55,"_56":66},[67],{"_59":68,"_54":59},"Sind bei der Durchführung des Fallmanagements spezifische Anforderungen erforderlich, so können die Träger der Rentenversicherung Dritte damit beauftragen, das Fallmanagement als Leistung durchzuführen. Die spezifischen Anforderungen dieser Leistung bestimmt die Deutsche Rentenversicherung Bund in einem gemeinsamen Rahmenkonzept der Träger der Rentenversicherung.","xbg6ti3hebt0xc0dp4iqfvcr",[140],4,[73],{"_74":75,"_76":77,"_78":79},"id","1434","Erklaerung",[126],"Prinzip",{"_9":80,"_34":63,"_81":82,"_83":84,"_17":85,"_86":87,"_88":71},"got436pv8femeqmv6ee8wlm1","Name","Automatisierung basiert auf eindeutigen Regelungen","Beschreibung",[89,90],"automatisierung-basiert-auf-eindeutigen-regelungen","Kurzbezeichnung","Automatisierung","order",{"_54":55,"_56":109},{"_54":55,"_56":91},[92,93,94,95,96],{"_59":108,"_54":59},{"_59":105,"_54":59,"_106":107},{"_59":104,"_54":59},{"_98":99,"_54":100,"_56":101},{"_59":97,"_54":59},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","url","https://www.gesetze-im-internet.de/vwvfg/__35a.html","link",[102],{"_59":103,"_54":59},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic",true,"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[110,111,112,113,114],{"_59":125,"_54":59},{"_98":121,"_54":100,"_56":122},{"_59":120,"_54":59},{"_98":116,"_54":100,"_56":117},{"_59":115,"_54":59}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[118],{"_59":119,"_54":59},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[123],{"_59":124,"_54":59},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_54":127,"_128":129,"_56":130},"list","format","unordered",[131,132],{"_54":133,"_56":137},{"_54":133,"_56":134},"list-item",[135],{"_59":136,"_54":59},"Die betroffene Vollzugsbehörde kann sich je nach Kompetenz- und Ressourcenausstattung von Dritten entlasten lassen.",[138],{"_59":139,"_54":59},"Die Regelung geht auf die Bedürfnisse der betroffenen Vollzugsbehörde ein.",{"_54":55,"_56":141},[142],{"_59":143,"_54":59,"_144":107},"Das Fallmanagement kann vollständig oder in Teilen durch die Träger der Rentenversicherung oder durch beauftragte Dritte durchgeführt werden.[5]","underline","gntx5sev60gkil9gwne73y44",[149,150],3,[],{"_54":55,"_56":175},{"_54":127,"_128":151,"_56":152},"ordered",[153,154,155,156,157],{"_54":133,"_56":172},{"_54":133,"_56":169},{"_54":133,"_56":164},{"_54":133,"_56":161},{"_54":133,"_56":158},[159],{"_59":160,"_54":59},"die begleitende Bewertung und mögliche Anpassung des individuellen Rehabilitationsprozesses gemeinsam mit den Versicherten.",[162],{"_59":163,"_54":59},"die Begleitung der Versicherten mit dem Ziel des Erhalts zügiger und aufeinander abgestimmter Leistungen, soweit die Versicherten Ansprüche gegen Träger von Sozialleistungen haben oder haben könnten, die die berufliche Wiedereingliederung fördern und unterstützen können,",[165,166],{"_59":168,"_54":59},{"_59":167,"_54":59,"_144":107},",","die rechtskreisübergreifende Unterstützung der Versicherten bei der Beantragung von in Betracht kommenden Sozialleistungen und bei der Inanspruchnahme weiterer unterstützender Angebote",[170],{"_59":171,"_54":59},"die Entwicklung und Koordinierung eines individuellen Rehabilitationsprozesses gemeinsam mit den Versicherten und unter Einbindung weiterer Beteiligter sowie die Erstellung eines individuellen Teilhabeplans nach § 19 des Neunten Buches soweit die gesetzlichen Voraussetzungen vorliegen,",[173],{"_59":174,"_54":59},"die Erkennung, Ermittlung und Feststellung des individuellen Rehabilitationsbedarfs nach § 13 des Neunten Buches einschließlich der Dokumentation des Bedarfs,",[176],{"_59":177,"_54":59},"Das Fallmanagement kann Folgendes umfassen:","vprp8kkrc02n0wj6f5yc9k5q",[250],2,[182,183],{"_74":215,"_76":216,"_78":217},{"_74":184,"_76":185,"_78":186},"1445",[211],{"_9":187,"_34":147,"_81":188,"_83":189,"_17":190,"_86":191,"_88":63},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[192,193,194],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz",{"_54":55,"_56":201},{"_54":55,"_56":198},{"_54":55,"_56":195},[196],{"_59":197,"_54":59},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[199],{"_59":200,"_54":59},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[202,203,204],{"_59":210,"_54":59},{"_98":206,"_54":100,"_56":207},{"_59":205,"_54":59}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[208],{"_59":209,"_54":59},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_54":55,"_56":212},[213],{"_59":214,"_54":59},"Erforderliche Daten werden nur im Rahmen der DSGVO und mit Zustimmung der Betroffenen verarbeitet.","1439",[246],{"_9":218,"_34":219,"_81":220,"_83":221,"_17":222,"_86":223,"_88":219},"r57rc9d82ulv2bsc3gdbnj73",1,"Digitale Angebote für alle nutzbar gestalten",[224,225,226],"digitale-angebote-fuer-alle-nutzbar-gestalten","Digitale Angebote",{"_54":55,"_56":243},{"_54":55,"_56":240},{"_54":127,"_128":129,"_56":227},[228,229,230],{"_54":133,"_56":237},{"_54":133,"_56":234},{"_54":133,"_56":231},[232],{"_59":233,"_54":59},"wie Barrierefreiheit zu bedenken ist.",[235],{"_59":236,"_54":59},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[238],{"_59":239,"_54":59},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[241],{"_59":242,"_54":59},"Erfahren Sie in diesem Abschnitt,",[244],{"_59":245,"_54":59},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_54":55,"_56":247},[248],{"_59":249,"_54":59},"Die Art der Dokumentation ist technologieoffen formuliert. So können bestehende IT-Verfahren weiterhin genutzt und weiterentwickelt werden. ",{"_54":55,"_56":251},[252,253,254,255],{"_59":259,"_54":59},{"_59":258,"_54":59,"_144":107},{"_59":257,"_54":59},{"_59":256,"_54":59,"_144":107},"Für die Durchführung des Fallmanagements erforderliche Datenverarbeitungen dürfen nur mit dem Einverständnis des Versicherten erfolgen.[3]"," ","Die Einwilligung ist zu dokumentieren.[1]","Zur frühzeitigen Erkennung eines Rehabilitationsbedarfs nach § 13 des Neunten Buches können die Träger der Rentenversicherung bereits vor der Entscheidung über die Durchführung eines Fallmanagements Kontakt mit Versicherten aufnehmen. Das Fallmanagement ist nur mit Einwilligung der Versicherten zulässig. ","qwo941h8neny30kalf2rg3rz",[263],[],{"_54":55,"_56":264},[265],{"_59":266,"_54":59},"Die Träger der Rentenversicherung können Versicherte mit gesundheitlichen Beeinträchtigungen und besonderem Unterstützungsbedarf in Bezug auf die berufliche Teilhabe, die die versicherungsrechtlichen Voraussetzungen nach § 11 Absatz 1 oder 2 erfüllen, mit einem Fallmanagement aktivierend und koordinierend bei ihrer beruflichen Wiedereingliederung begleiten und unterstützen.",[268,269,270,271,272],{"_9":218,"_34":219,"_81":220,"_83":340,"_17":222,"_86":223,"_88":219},{"_9":324,"_34":180,"_81":325,"_83":326,"_17":327,"_86":328,"_88":180},{"_9":308,"_34":50,"_81":309,"_83":310,"_17":311,"_86":312,"_88":147},{"_9":80,"_34":63,"_81":82,"_83":287,"_17":85,"_86":87,"_88":71},{"_9":187,"_34":147,"_81":188,"_83":273,"_17":190,"_86":191,"_88":63},[274,275,276],{"_54":55,"_56":281},{"_54":55,"_56":279},{"_54":55,"_56":277},[278],{"_59":197,"_54":59},[280],{"_59":200,"_54":59},[282,283,284],{"_59":210,"_54":59},{"_98":206,"_54":100,"_56":285},{"_59":205,"_54":59},[286],{"_59":209,"_54":59},[288,289],{"_54":55,"_56":298},{"_54":55,"_56":290},[291,292,293,294,295],{"_59":108,"_54":59},{"_59":105,"_54":59,"_106":107},{"_59":104,"_54":59},{"_98":99,"_54":100,"_56":296},{"_59":97,"_54":59},[297],{"_59":103,"_54":59},[299,300,301,302,303],{"_59":125,"_54":59},{"_98":121,"_54":100,"_56":306},{"_59":120,"_54":59},{"_98":116,"_54":100,"_56":304},{"_59":115,"_54":59},[305],{"_59":119,"_54":59},[307],{"_59":124,"_54":59},"habu0yjh39lc5wug5mqsqzaj","Etablierte Technologien ermöglichen effiziente Umsetzung",[313],"etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",{"_54":55,"_56":314},[315,316,317],{"_59":323,"_54":59},{"_98":319,"_54":100,"_56":320},{"_59":318,"_54":59}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[321],{"_59":322,"_54":59},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ","s18bibg9sdf0jt8up7h8btup","Datenwiederverwendung benötigt einheitliches Recht",[329],"datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_54":55,"_56":330},[331,332,333],{"_59":339,"_54":59},{"_98":335,"_54":100,"_56":336},{"_59":334,"_54":59}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[337],{"_59":338,"_54":59},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",[341,342,343],{"_54":55,"_56":356},{"_54":55,"_56":354},{"_54":127,"_128":129,"_56":344},[345,346,347],{"_54":133,"_56":352},{"_54":133,"_56":350},{"_54":133,"_56":348},[349],{"_59":233,"_54":59},[351],{"_59":236,"_54":59},[353],{"_59":239,"_54":59},[355],{"_59":242,"_54":59},[357],{"_59":245,"_54":59},{"_359":360,"_361":362,"_363":362,"_364":365,"_366":367},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_368":107,"_369":107,"_370":107,"_371":107,"_372":107},"posthogKey","","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
