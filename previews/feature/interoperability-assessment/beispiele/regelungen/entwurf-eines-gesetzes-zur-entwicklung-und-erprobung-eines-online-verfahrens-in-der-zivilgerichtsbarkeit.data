[{"_1":2,"_3":4,"_5":6},"root",{"_7":1074},"routes/beispiele",{"_7":999},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":14,"_15":-5,"_16":17,"_18":19,"_20":21,"_22":23,"_24":-5,"_25":26,"_27":28,"_29":30,"_31":32},"documentId","zvgbik091narl46uko7syc67","Titel","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit","NKRNummer",7065,"Rechtsgebiet","Ressort","BMJV","URLBezeichnung","entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","VeroeffentlichungsDatum","2024-09-30","LinkRegelungstext","https://dip.bundestag.de/vorgang/gesetz-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit/315283","NKRStellungnahmeLink","GesetzStatus","Text_im_Parlament","Paragraphen",[109,110,111,112,113,114],"Visualisierungen",[42],"Digitalchecks",[33],{"_9":34,"_11":12,"_35":36,"_37":36,"_38":36,"_39":-5,"_40":36,"_41":-5},"nd0p9jrzh3amn085aqpu8g4z","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",{"_9":43,"_11":44,"_45":46,"_47":48,"_49":50,"_51":-5,"_16":-5,"_52":53,"_54":55},"e92syjtajombxqgan8ygq9i7","Ablauf eines Online-Verfahrens","Beschreibung",[62,63],"Visualisierungsart","Flussdiagramm","Visualisierungstool","draw.io","Aufwand","Bild",{"_9":56,"_57":58,"_59":-5,"_60":61},"Beispielvorhaben",{"_18":19,"_20":21,"_15":-5,"_11":12,"_16":17},"mfnncvpa89wdjbd4k1wcvky3","url","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/BMJ_7065_Visualisierung_OV_Erp_G_DB_3_BMJ_0c71f91453.png","previewUrl","alternativeText","Die Abbildung zeigt das Online-Verfahren in der Zivilgerichtsbarkeit, welches nach § 1124 I ZPO eröffnet ist.",{"_64":104,"_68":105},{"_64":65,"_66":67,"_68":69},"type","list","format","unordered","children",[70,71,72,73],{"_64":74,"_68":99},{"_64":74,"_68":94},{"_64":74,"_68":89},{"_64":74,"_68":75},"list-item",[76,77,78,79,80],{"_81":88,"_64":81},{"_83":84,"_81":87,"_64":81},{"_81":86,"_64":81},{"_83":84,"_81":85,"_64":81},{"_81":82,"_64":81},"text","schnelles Verständnis zu gewährleisten.","bold",true," ","um","geläufige Darstellung für Entscheidungen in Flussdiagrammen, ","Verwendet Rauten als ",[90,91],{"_83":84,"_81":93,"_64":81},{"_81":92,"_64":81}," durch Verwendung einheitlicher Symbole. ","Markiert den Kernaspekt der Regelung",[95,96],{"_81":98,"_64":81},{"_83":84,"_81":97,"_64":81},"explizite Nennung der Regelungen, Paragraphen, Absätze und Sätze.","Erleichtert das Auffinden der relevanten Textpassagen durch ",[100,101],{"_83":84,"_81":103,"_64":81},{"_81":102,"_64":81},"und erleichtert so die Orientierung im Prozess.","Unterteilt den Gesamtprozess in drei abgegrenzte Bereiche ","paragraph",[106],{"_81":107,"_64":81,"_108":84},"Ablauf eines Online-Verfahrens in der Zivilgerichtsbarkeit nach ZPO","italic",{"_9":857,"_116":858,"_11":859,"_119":120,"_121":-5,"_122":860},{"_9":767,"_116":768,"_11":769,"_119":120,"_121":-5,"_122":770},{"_9":671,"_116":672,"_11":673,"_119":120,"_121":-5,"_122":674},{"_9":487,"_116":488,"_11":489,"_119":120,"_121":-5,"_122":490},{"_9":180,"_116":181,"_11":182,"_119":120,"_121":-5,"_122":183},{"_9":115,"_116":117,"_11":118,"_119":120,"_121":-5,"_122":123},"vdbj7ukv75e2m8qj8n5k52m4","Nummer","1134","Umfang der Erprobung","Gesetz","ZPO","Artikel","Absaetze",[124,125],{"_9":136,"_127":137,"_116":138,"_130":139},{"_9":126,"_127":128,"_116":129,"_130":131},"kvqblclxkwodab6ffl3qexid","Text",[132],2,"PrinzipErfuellungen",[],{"_64":104,"_68":133},[134],{"_81":135,"_64":81},"§ 1125 Absatz 2 bis 4 gilt entsprechend.","u3sg1zismobz1t707uo3xav8",[173],1,[140],{"_141":142,"_143":144,"_145":146},"id","1423","Erklaerung",[169],"Prinzip",{"_9":147,"_116":148,"_149":150,"_45":151,"_18":152,"_153":154,"_155":156},"habu0yjh39lc5wug5mqsqzaj",6,"Name","Etablierte Technologien ermöglichen effiziente Umsetzung",[157],"etablierte-technologien-ermoeglichen-effiziente-umsetzung","Kurzbezeichnung","Etablierte Technologien","order",3,{"_64":104,"_68":158},[159,160,161],{"_81":168,"_64":81},{"_57":163,"_64":164,"_68":165},{"_81":162,"_64":81}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen","link",[166],{"_81":167,"_64":81},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_64":104,"_68":170},[171],{"_81":172,"_64":81},"Durch die Entwicklung und bundeseinheitliche Bereitstellung von Referenzimplementierungen kann eine standardisierte Lösung zur Nachnutzung bereitgestellt werden.",{"_64":104,"_68":174},[175,176],{"_81":178,"_64":81,"_179":84},{"_81":177,"_64":81}," Satz 1 gilt nicht im Anwendungsbereich des Online-Verfahrens nach Abschnitt 2 dieses Buchs.","Das Bundesministerium der Justiz kann digitale Eingabesysteme als Referenzimplementierung entwickeln und bundeseinheitlich zur Erprobung bereitstellen, soweit diese dem elektronischen Erstellen von Anträgen oder Erklärungen nach § 129a Absatz 1 dienen.[6]","underline","vqxve0zgrejbf0za0x2ye8gn","1131","Kommunikations-, Austausch- und Übermittlungsformen",[184,185,186,187,188],{"_9":416,"_127":417,"_116":138,"_130":418},{"_9":298,"_127":299,"_116":129,"_130":300},{"_9":259,"_127":260,"_116":156,"_130":261},{"_9":248,"_127":249,"_116":202,"_130":250},{"_9":189,"_127":190,"_116":191,"_130":192},"sbmjz7pqq3o5va1wjxgdyc5z",[240],5,[193],{"_141":194,"_143":195,"_145":196},"1341",[236],{"_9":197,"_116":191,"_149":198,"_45":199,"_18":200,"_153":201,"_155":202},"got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[203,204],"automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_64":104,"_68":219},{"_64":104,"_68":205},[206,207,208,209,210],{"_81":218,"_64":81},{"_81":217,"_64":81,"_108":84},{"_81":216,"_64":81},{"_57":212,"_64":164,"_68":213},{"_81":211,"_64":81},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[214],{"_81":215,"_64":81},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[220,221,222,223,224],{"_81":235,"_64":81},{"_57":231,"_64":164,"_68":232},{"_81":230,"_64":81},{"_57":226,"_64":164,"_68":227},{"_81":225,"_64":81}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[228],{"_81":229,"_64":81},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[233],{"_81":234,"_64":81},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_64":104,"_68":237},[238],{"_81":239,"_64":81},"Schreibt automatisierte Bestätigung der Zustellung und des Abrufs vor.",{"_64":104,"_68":241},[242,243,244],{"_81":247,"_64":81},{"_81":246,"_64":81,"_179":84},{"_81":245,"_64":81}," § 173 Absatz 4 Satz 4 und 5 ist entsprechend anzuwenden.","Die Zeitpunkte der Bereitstellung und des Abrufs sind dem Empfänger und dem Gericht automatisiert zu bestätigen.[5]","Mit Zustimmung des Empfängers, die für das jeweilige Verfahren erteilt wird und nur mit Wirkung für die Zukunft widerruflich ist, kann abweichend von § 173 Absatz 1 ein elektronisches Dokument auch zugestellt werden, indem es zum Datenabruf über die Kommunikationsplattform bereitgestellt wird. Der Empfänger hat sich beim Datenabruf zu authentisieren. ","tjm6vubta7iq89gcl5qi9kws",[251,252],[],{"_64":104,"_68":256},{"_64":104,"_68":253},[254],{"_81":255,"_64":81},"",[257],{"_81":258,"_64":81},"Bei der Bereitstellung eines elektronischen Dokuments über die Kommunikationsplattform ist der Empfänger über das von ihm zu diesem Zweck angegebene Postfach oder die von ihm zu diesem Zweck angegebene Adresse spätestens am Tag der Bereitstellung des elektronischen Dokuments darüber zu benachrichtigen, dass dieses abgerufen werden kann. Satz 1 gilt entsprechend für die weitere digitale Kommunikation zwischen dem Gericht und den Verfahrensbeteiligten über die Kommunikationsplattform.","mwwaz6co63k51t39bytz8p98",[294],[262],{"_141":263,"_143":264,"_145":265},"1339",[290],{"_9":266,"_116":156,"_149":267,"_45":268,"_18":269,"_153":270,"_155":191},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[271,272,273],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz",{"_64":104,"_68":280},{"_64":104,"_68":277},{"_64":104,"_68":274},[275],{"_81":276,"_64":81},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[278],{"_81":279,"_64":81},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[281,282,283],{"_81":289,"_64":81},{"_57":285,"_64":164,"_68":286},{"_81":284,"_64":81}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[287],{"_81":288,"_64":81},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_64":104,"_68":291},[292],{"_81":293,"_64":81},"Sichere Übermittlungswege und Verfahren gewährleisten, dass die Daten authentisch sind und nicht verändert wurden.",{"_64":104,"_68":295},[296],{"_81":297,"_64":81,"_179":84},"Die Gerichte haben bei der digitalen Kommunikation mit den Verfahrensbeteiligten und bei der Bereitstellung von elektronischen Dokumenten zum Abruf ein sicheres Verfahren zu verwenden, das die Authentizität und Integrität der Daten gewährleistet.[3]","fvj31s0fav5aw2vlu65q0arw",[395,396],[301,302,303],{"_141":355,"_143":356,"_145":357},{"_141":325,"_143":326,"_145":327},{"_141":304,"_143":305,"_145":306},"1335",[321],{"_9":266,"_116":156,"_149":267,"_45":307,"_18":269,"_153":270,"_155":191},[308,309,310],{"_64":104,"_68":315},{"_64":104,"_68":313},{"_64":104,"_68":311},[312],{"_81":276,"_64":81},[314],{"_81":279,"_64":81},[316,317,318],{"_81":289,"_64":81},{"_57":285,"_64":164,"_68":319},{"_81":284,"_64":81},[320],{"_81":288,"_64":81},{"_64":104,"_68":322},[323],{"_81":324,"_64":81},"Stellt die Informationssicherheit sicher, indem sie die Anforderung eines sicheren Verfahrens stellt, das die Authentizität und Integrität der Daten gewährleistet.","1334",[349],{"_9":197,"_116":191,"_149":198,"_45":328,"_18":200,"_153":201,"_155":202},[329,330],{"_64":104,"_68":339},{"_64":104,"_68":331},[332,333,334,335,336],{"_81":218,"_64":81},{"_81":217,"_64":81,"_108":84},{"_81":216,"_64":81},{"_57":212,"_64":164,"_68":337},{"_81":211,"_64":81},[338],{"_81":215,"_64":81},[340,341,342,343,344],{"_81":235,"_64":81},{"_57":231,"_64":164,"_68":347},{"_81":230,"_64":81},{"_57":226,"_64":164,"_68":345},{"_81":225,"_64":81},[346],{"_81":229,"_64":81},[348],{"_81":234,"_64":81},{"_64":65,"_66":67,"_68":350},[351],{"_64":74,"_68":352},[353],{"_81":354,"_64":81},"Geht von einer automatisierten Bearbeitung der Daten aus.","1333",[385],{"_9":358,"_116":138,"_149":359,"_45":360,"_18":361,"_153":362,"_155":138},"r57rc9d82ulv2bsc3gdbnj73","Digitale Angebote für alle nutzbar gestalten",[363,364,365],"digitale-angebote-fuer-alle-nutzbar-gestalten","Digitale Angebote",{"_64":104,"_68":382},{"_64":104,"_68":379},{"_64":65,"_66":67,"_68":366},[367,368,369],{"_64":74,"_68":376},{"_64":74,"_68":373},{"_64":74,"_68":370},[371],{"_81":372,"_64":81},"wie Barrierefreiheit zu bedenken ist.",[374],{"_81":375,"_64":81},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[377],{"_81":378,"_64":81},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[380],{"_81":381,"_64":81},"Erfahren Sie in diesem Abschnitt,",[383],{"_81":384,"_64":81},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_64":65,"_66":67,"_68":386},[387,388],{"_64":74,"_68":392},{"_64":74,"_68":389},[390],{"_81":391,"_64":81},"Schriftformerfordernisse werden durch die digitale Übermittlung ersetzt.",[393],{"_81":394,"_64":81},"Die digitale Übermittlung von Dokumenten ermöglicht eine Kommunikation über die digitale Kommunikationsplattform.",{"_64":104,"_68":411},{"_64":65,"_66":397,"_68":398},"ordered",[399,400,401],{"_64":74,"_68":408},{"_64":74,"_68":405},{"_64":74,"_68":402},[403],{"_81":404,"_64":81,"_179":84},"für die elektronischen Dokumente oder strukturierten Datensätze auf der Kommunikationsplattform eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[5]",[406],{"_81":407,"_64":81,"_179":84},"bei der Datenübermittlung ein sicheres Verfahren verwendet wird, das die Authentizität und Integrität der Daten gewährleistet, und [3]",[409],{"_81":410,"_64":81},"ein Identifizierungsverfahren nach Absatz 1 genutzt wird,",[412,413],{"_81":415,"_64":81,"_179":84},{"_81":414,"_64":81},", sofern","Eine in diesem Gesetz angeordnete Schriftform kann auch durch Übermittlung elektronischer Dokumente oder strukturierter Datensätze über die Kommunikationsplattform ersetzt werden[1]","g6pdcvhx2a4cleuywyb0fbuu",[467,468,469],[419,420],{"_141":452,"_143":453,"_145":454},{"_141":421,"_143":422,"_145":423},"1324",[442],{"_9":358,"_116":138,"_149":359,"_45":424,"_18":361,"_153":362,"_155":138},[425,426,427],{"_64":104,"_68":440},{"_64":104,"_68":438},{"_64":65,"_66":67,"_68":428},[429,430,431],{"_64":74,"_68":436},{"_64":74,"_68":434},{"_64":74,"_68":432},[433],{"_81":372,"_64":81},[435],{"_81":375,"_64":81},[437],{"_81":378,"_64":81},[439],{"_81":381,"_64":81},[441],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":443},[444,445],{"_64":74,"_68":449},{"_64":74,"_68":446},[447],{"_81":448,"_64":81},"Diese Ersetzung erfolgt durch die Eingabe von Anträgen und Erklärungen der Verfahrensbeteiligten.",[450],{"_81":451,"_64":81},"Ermöglicht die Ersetzung angeordneter Schriftformerfordernisse durch die Kommunikationsplattform. ","1323",[463],{"_9":147,"_116":148,"_149":150,"_45":455,"_18":152,"_153":154,"_155":156},[456],{"_64":104,"_68":457},[458,459,460],{"_81":168,"_64":81},{"_57":163,"_64":164,"_68":461},{"_81":162,"_64":81},[462],{"_81":167,"_64":81},{"_64":104,"_68":464},[465],{"_81":466,"_64":81},"Mit dem elektronischen Anwaltspostfach und den OZG-Nutzerkonten können bewährte Identifizierungsverfahren und bestehende Systeme genutzt werden.",{"_64":104,"_68":482},{"_64":65,"_66":397,"_68":473},{"_64":104,"_68":470},[471],{"_81":472,"_64":81},"Wurde der Nachweis der Identität nach Satz 1 erbracht, so kann die spätere Authentisierung des Inhabers des Identitätsnachweises auch durch andere geeignete Authentisierungsmittel erfolgen.",[474,475],{"_64":74,"_68":479},{"_64":74,"_68":476},[477],{"_81":478,"_64":81,"_179":84},"für die Identifizierung anderer Verfahrensbeteiligter: ein Verfahren über ein Nutzerkonto nach § 2 Absatz 5 in Verbindung mit § 3 Absatz 4 des Onlinezugangsgesetzes.[6]",[480],{"_81":481,"_64":81,"_179":84},"für die Identifizierung von Rechtsanwälten: das Verfahren zum Zugang zum besonderen elektronischen Anwaltspostfach nach § 31a Absatz 3 Satz 1 der Bundesrechtsanwaltsordnung;",[483,484],{"_81":486,"_64":81,"_179":84},{"_81":485,"_64":81},", sofern hierfür digitale Eingabesysteme zur Verfügung stehen und eines der folgenden Identifizierungsverfahren genutzt wird:","Eine in diesem Gesetz angeordnete Schriftform kann durch unmittelbare Eingabe von Anträgen und Erklärungen der Verfahrensbeteiligten über die Kommunikationsplattform nach § 1130 ersetzt werden[1]","frp23027s2orsp17fxi5owym","1130","Entwicklung und Bereitstellung; Verordnungsermächtigungen",[491,492,493,494,495],{"_9":630,"_127":631,"_116":138,"_130":632},{"_9":605,"_127":606,"_116":129,"_130":607},{"_9":564,"_127":565,"_116":156,"_130":566},{"_9":527,"_127":528,"_116":202,"_130":529},{"_9":496,"_127":497,"_116":191,"_130":498},"fwmioex4hhujydsvsveiw9h7",[523],[499],{"_141":500,"_143":501,"_145":502},"1375",[519],{"_9":503,"_116":129,"_149":504,"_45":505,"_18":506,"_153":507,"_155":129},"s18bibg9sdf0jt8up7h8btup","Datenwiederverwendung benötigt einheitliches Recht",[508],"datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_64":104,"_68":509},[510,511,512],{"_81":518,"_64":81},{"_57":514,"_64":164,"_68":515},{"_81":513,"_64":81}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[516],{"_81":517,"_64":81},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_64":104,"_68":520},[521],{"_81":522,"_64":81},"Ermöglicht die Festlegung von Standards für die Datenübermittlung der Kommunikationsplattform durch Rechtsverordnung. Dadurch werden Interoperabilität und Datenaustausch begünstigt.",{"_64":104,"_68":524},[525],{"_81":526,"_64":81,"_179":84},"Das Bundesministerium der Justiz wird ermächtigt, durch Rechtsverordnung mit Zustimmung des Bundesrates die für die Datenübermittlung geltenden Standards und Dateiformate und die Ausgestaltung des Datenschutzes bei Nutzung der Kommunikationsplattform festzulegen.[2]","lwppx62h2r3ci8i26jighqp5",[558],[530],{"_141":531,"_143":532,"_145":533},"1367",[548],{"_9":266,"_116":156,"_149":267,"_45":534,"_18":269,"_153":270,"_155":191},[535,536,537],{"_64":104,"_68":542},{"_64":104,"_68":540},{"_64":104,"_68":538},[539],{"_81":276,"_64":81},[541],{"_81":279,"_64":81},[543,544,545],{"_81":289,"_64":81},{"_57":285,"_64":164,"_68":546},{"_81":284,"_64":81},[547],{"_81":288,"_64":81},{"_64":65,"_66":67,"_68":549},[550,551],{"_64":74,"_68":555},{"_64":74,"_68":552},[553],{"_81":554,"_64":81},"Schreibt die Löschung personenbezogener Daten vor, was die Privatsphäre der Nutzer schützt und die Speicherung von Daten minimiert.",[556],{"_81":557,"_64":81},"Legt die Zwecke fest, wann personenbezogene Daten verarbeitet werden können.",{"_64":104,"_68":559},[560,561],{"_81":563,"_64":81,"_179":84},{"_81":562,"_64":81}," Elektronische Dokumente, Datensätze und sonstige Informationen aus dem über die Kommunikationsplattform geführten Verfahren sind zu den elektronisch geführten Prozessakten nach § 298a zu nehmen.","Die Stelle, die die Kommunikationsplattform nach Absatz 2 bereitstellt, darf personenbezogene Daten nur verarbeiten, soweit dies für die Zwecke nach Absatz 1 erforderlich ist. Die Daten sind spätestens nach rechtskräftigem Abschluss oder nach sonstiger Beendigung des Verfahrens von der Kommunikationsplattform zu löschen.[3]","yaa803r10yjs4h9ay4srsb84",[599],[567],{"_141":568,"_143":569,"_145":570},"1373",[589],{"_9":358,"_116":138,"_149":359,"_45":571,"_18":361,"_153":362,"_155":138},[572,573,574],{"_64":104,"_68":587},{"_64":104,"_68":585},{"_64":65,"_66":67,"_68":575},[576,577,578],{"_64":74,"_68":583},{"_64":74,"_68":581},{"_64":74,"_68":579},[580],{"_81":372,"_64":81},[582],{"_81":375,"_64":81},[584],{"_81":378,"_64":81},[586],{"_81":381,"_64":81},[588],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":590},[591,592],{"_64":74,"_68":596},{"_64":74,"_68":593},[594],{"_81":595,"_64":81},"Schreibt Nutzerfreundlichkeit für die Kommunikationsplattform vor.",[597],{"_81":598,"_64":81},"Die digitale Eingabesysteme und die Kommunikationsplattform werden gemäß der Barrierefreie-Informationstechnik-Verordnung barrierefrei gestaltet, um die Inklusivität digitaler Angebote zu gewährleisten.",{"_64":104,"_68":600},[601,602],{"_81":604,"_64":81},{"_81":603,"_64":81,"_179":84},"Sie ist nach Maßgabe der Barrierefreie-Informationstechnik-Verordnung barrierefrei zu gestalten. Ferner ist bei der Gestaltung der Kommunikationsplattform deren Nutzerfreundlichkeit sowie eine einfache und intuitive Bedienbarkeit sicherzustellen.[1]","Die nach Absatz 2 entwickelte Kommunikationsplattform ist über ein Justizportal des Bundes und der Länder für die Nutzer bereitzustellen. ","km96qmspgbqzjcnyds8bywmv",[624],[608],{"_141":609,"_143":610,"_145":611},"1371",[620],{"_9":147,"_116":148,"_149":150,"_45":612,"_18":152,"_153":154,"_155":156},[613],{"_64":104,"_68":614},[615,616,617],{"_81":168,"_64":81},{"_57":163,"_64":164,"_68":618},{"_81":162,"_64":81},[619],{"_81":167,"_64":81},{"_64":104,"_68":621},[622],{"_81":623,"_64":81},"Die Entwicklung und bundeseinheitliche Bereitstellung von Referenzimplementierungen fördert die Nutzung etablierter und standardisierter Lösungen.",{"_64":104,"_68":625},[626,627],{"_81":629,"_64":81,"_179":84},{"_81":628,"_64":81}," Das Bundesministerium der Justiz regelt durch Rechtsverordnung mit Zustimmung des Bundesrates die technischen, organisatorischen und datenschutzrechtlichen Rahmenbedingungen für Entwicklung, Betrieb, Pflege und Weiterentwicklung der Kommunikationsplattform nach Satz 2 und ihrer Anwendungsmodule.","Die Kommunikationsplattform wird vom Bundesministerium der Justiz als Referenzimplementierung entwickelt und den Ländern zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitgestellt. Die Länder können die Entwicklung und die bundeseinheitliche Bereitstellung der Kommunikationsplattform nach Satz 1 zur Anwendung bei den nach § 1123 bestimmten Gerichten übernehmen; entsprechendes gilt für die Bereitstellung weiterer Anwendungsmodule für die Zwecke nach Absatz 1.[6]","ya20w3ujaqacq8tl254r8q5g",[665],[633],{"_141":634,"_143":635,"_145":636},"1369",[655],{"_9":358,"_116":138,"_149":359,"_45":637,"_18":361,"_153":362,"_155":138},[638,639,640],{"_64":104,"_68":653},{"_64":104,"_68":651},{"_64":65,"_66":67,"_68":641},[642,643,644],{"_64":74,"_68":649},{"_64":74,"_68":647},{"_64":74,"_68":645},[646],{"_81":372,"_64":81},[648],{"_81":375,"_64":81},[650],{"_81":378,"_64":81},[652],{"_81":381,"_64":81},[654],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":656},[657,658],{"_64":74,"_68":662},{"_64":74,"_68":659},[660],{"_81":661,"_64":81},"Nicht nur für die Verfahrensbeteiligten, sondern auch für die Gerichte wird ein digitales Verfahren geschaffen.",[663],{"_81":664,"_64":81},"Es wird die strukturierte Datenübermittlung und die gemeinsame digitale Bearbeitung von Dokumenten ermöglicht, wodurch Verwaltungsprozesse effizienter werden und manuelle Arbeitsschritte entfallen.",{"_64":104,"_68":666},[667,668],{"_81":670,"_64":81},{"_81":669,"_64":81,"_179":84}," Die Kommunikationsplattform kann auch zur Bereitstellung oder gemeinschaftlichen Bearbeitung elektronischer Dokumente durch die Verfahrensbeteiligten und das Gericht genutzt werden. Das Gericht kann in entsprechender Anwendung des § 1126 Maßnahmen der Prozessleitung ergreifen, um den Streitstoff unter Nutzung der Kommunikationsplattform zu strukturieren.[1]","Im Online-Verfahren kann eine Kommunikationsplattform genutzt werden, die der bundeseinheitlichen Erprobung digitaler Kommunikations-, Austausch- und Übermittlungsformen zwischen den Verfahrensbeteiligten und mit dem Gericht dient.","ee2edmkcxhrx7nz62ocyi4wx","1128","Beweisaufnahme",[675,676,677],{"_9":726,"_127":727,"_116":138,"_130":728},{"_9":685,"_127":686,"_116":129,"_130":687},{"_9":678,"_127":679,"_116":156,"_130":680},"l9zscmsi39oase3o43o3uypr",[681],[],{"_64":104,"_68":682},[683],{"_81":684,"_64":81},"Für die Parteivernehmung gilt Absatz 2 Satz 1 und 3 entsprechend. Eines Beweisbeschlusses nach § 450 in Verbindung mit § 495 bedarf es nicht.","g6gde7i5hb4827m0zfobti44",[720],[688],{"_141":689,"_143":690,"_145":691},"1415",[710],{"_9":358,"_116":138,"_149":359,"_45":692,"_18":361,"_153":362,"_155":138},[693,694,695],{"_64":104,"_68":708},{"_64":104,"_68":706},{"_64":65,"_66":67,"_68":696},[697,698,699],{"_64":74,"_68":704},{"_64":74,"_68":702},{"_64":74,"_68":700},[701],{"_81":372,"_64":81},[703],{"_81":375,"_64":81},[705],{"_81":378,"_64":81},[707],{"_81":381,"_64":81},[709],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":711},[712,713],{"_64":74,"_68":717},{"_64":74,"_68":714},[715],{"_81":716,"_64":81},"Erlaubt weiterhin nicht digitale Alternativen, um allen Menschen die Teilnahme zu ermöglichen",[718],{"_81":719,"_64":81},"Erlaubt digitale Kommunikationsmittel für Aussagen",{"_64":104,"_68":721},[722,723],{"_81":725,"_64":81,"_179":84},{"_81":724,"_64":81}," Eines Beweisbeschlusses nach § 358 bis § 360 in Verbindung mit § 495 bedarf es nicht. Den Parteien ist Gelegenheit zu geben, zu dem Ergebnis der Beweisaufnahme Stellung zu nehmen.","Das Gericht kann abweichend von § 357 Absatz 1 in Verbindung mit § 495 entscheidungserhebliche Tatsachen auch durch Aussagen von Zeugen und Auskünfte von Sachverständigen feststellen, die mittels Bild- und Tonübertragung, schriftlich, elektronisch, telefonisch oder mithilfe anderer geeigneter digitaler Kommunikationsmittel erfolgen.[1]","b13utzg69rjc3esc0x9d7xgj",[761],[729],{"_141":730,"_143":731,"_145":732},"1413",[751],{"_9":358,"_116":138,"_149":359,"_45":733,"_18":361,"_153":362,"_155":138},[734,735,736],{"_64":104,"_68":749},{"_64":104,"_68":747},{"_64":65,"_66":67,"_68":737},[738,739,740],{"_64":74,"_68":745},{"_64":74,"_68":743},{"_64":74,"_68":741},[742],{"_81":372,"_64":81},[744],{"_81":375,"_64":81},[746],{"_81":378,"_64":81},[748],{"_81":381,"_64":81},[750],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":752},[753,754],{"_64":74,"_68":758},{"_64":74,"_68":755},[756],{"_81":757,"_64":81},"Gewährleistet Technologieoffenheit durch die Verwendung breiter Begriffe wie „andere geeignete digitale Kommunikationsmittel” anstelle spezifischer Technologien.",[759],{"_81":760,"_64":81},"Beweisaufnahme wird durch digitale Kommunikationsmittel ermöglicht. ",{"_64":104,"_68":762},[763,764],{"_81":766,"_64":81,"_179":84},{"_81":765,"_64":81}," oder anordnen. § 284 Absatz 2 Satz 2 bis 5 und Absatz 3 in Verbindung mit § 495 bleibt unberührt.","In geeigneten Fällen kann das Gericht auf Antrag oder von Amts wegen abweichend von § 284 Absatz 2 Satz 1 in Verbindung mit § 495 die Beweisaufnahme auch durch Tonübertragung oder mithilfe anderer geeigneter digitaler Kommunikationsmittel gestatten[1]","ykl903yprafl57twhoivw8gi","1126","Digitale Strukturierung",[771,772],{"_9":820,"_127":821,"_116":138,"_130":822},{"_9":773,"_127":774,"_116":129,"_130":775},"bbeox0j5wu1lo0vl6fze2f5h",[804,805],[776],{"_141":777,"_143":778,"_145":779},"1427",[798],{"_9":358,"_116":138,"_149":359,"_45":780,"_18":361,"_153":362,"_155":138},[781,782,783],{"_64":104,"_68":796},{"_64":104,"_68":794},{"_64":65,"_66":67,"_68":784},[785,786,787],{"_64":74,"_68":792},{"_64":74,"_68":790},{"_64":74,"_68":788},[789],{"_81":372,"_64":81},[791],{"_81":375,"_64":81},[793],{"_81":378,"_64":81},[795],{"_81":381,"_64":81},[797],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":799},[800],{"_64":74,"_68":801},[802],{"_81":803,"_64":81},"Erlaubt den Gerichten, digitale Kommunikation anzuordnen.",{"_64":104,"_68":817},{"_64":65,"_66":397,"_68":806},[807,808],{"_64":74,"_68":812},{"_64":74,"_68":809},[810],{"_81":811,"_64":81},"den Parteien die Ergänzung oder Erläuterung ihres Vortrags durch Zuordnung von Eingabefeldern zum jeweiligen Streitstoff aufgeben; hiermit kann eine Frist zur Erklärung über bestimmte klärungsbedürftige Punkte verbunden werden.",[813,814],{"_81":816,"_64":81,"_179":84},{"_81":815,"_64":81},", und","anordnen, dass die Parteien ihren jeweiligen weiteren Vortrag demjenigen der anderen Partei in digitaler Form gegenüberstellen[1]",[818],{"_81":819,"_64":81},"Das Gericht kann insbesondere","bvmw4a7bjjekz9auqjg0p02k",[851],[823],{"_141":824,"_143":825,"_145":826},"1421",[845],{"_9":358,"_116":138,"_149":359,"_45":827,"_18":361,"_153":362,"_155":138},[828,829,830],{"_64":104,"_68":843},{"_64":104,"_68":841},{"_64":65,"_66":67,"_68":831},[832,833,834],{"_64":74,"_68":839},{"_64":74,"_68":837},{"_64":74,"_68":835},[836],{"_81":372,"_64":81},[838],{"_81":375,"_64":81},[840],{"_81":378,"_64":81},[842],{"_81":381,"_64":81},[844],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":846},[847],{"_64":74,"_68":848},[849],{"_81":850,"_64":81},"Ermöglicht den Einsatz digitaler Eingabesysteme zur Aufbereitung des Streitstoffs.",{"_64":104,"_68":852},[853,854],{"_81":856,"_64":81},{"_81":855,"_64":81,"_179":84},"Für die Strukturierung nach Satz 1 können digitale Eingabesysteme nach § 1124 Absatz 2, strukturierte Datensätze oder elektronische Dokumente genutzt werden.[1]","Das Gericht kann Maßnahmen der Prozessleitung ergreifen, um den Streitstoff zu strukturieren. ","asey83r4r5lquyulmqrcht5m","1125","Digitale Eingabesysteme im Online-Verfahren; Verordnungsermächtigung",[861,862,863,864],{"_9":975,"_127":976,"_116":138,"_130":977},{"_9":936,"_127":937,"_116":129,"_130":938},{"_9":903,"_127":904,"_116":156,"_130":905},{"_9":865,"_127":866,"_116":202,"_130":867},"gjn22iuco2wjihcrtefxcvdr",[899],[868],{"_141":869,"_143":870,"_145":871},"1361",[890],{"_9":358,"_116":138,"_149":359,"_45":872,"_18":361,"_153":362,"_155":138},[873,874,875],{"_64":104,"_68":888},{"_64":104,"_68":886},{"_64":65,"_66":67,"_68":876},[877,878,879],{"_64":74,"_68":884},{"_64":74,"_68":882},{"_64":74,"_68":880},[881],{"_81":372,"_64":81},[883],{"_81":375,"_64":81},[885],{"_81":378,"_64":81},[887],{"_81":381,"_64":81},[889],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":891},[892,893],{"_64":74,"_68":896},{"_64":74,"_68":894},[895],{"_81":661,"_64":81},[897],{"_81":898,"_64":81},"Ermöglicht die strukturierte Datenübermittlung und die gemeinsame digitale Bearbeitung von Dokumenten, wodurch Verwaltungsprozesse effizienter werden und manuelle Arbeitsschritte entfallen.",{"_64":104,"_68":900},[901],{"_81":902,"_64":81,"_179":84},"Elektronische Dokumente, die mithilfe digitaler Eingabesysteme erzeugt wurden, können abweichend von § 2 Absatz 1 der Elektronischer-Rechtsverkehr-Verordnung als strukturierter Datensatz übermittelt werden, sofern für diesen im Online-Verfahren eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[1]","hxksok3ze7ao3bvrxgiei5nx",[932],[906],{"_141":907,"_143":908,"_145":909},"1359",[924],{"_9":266,"_116":156,"_149":267,"_45":910,"_18":269,"_153":270,"_155":191},[911,912,913],{"_64":104,"_68":918},{"_64":104,"_68":916},{"_64":104,"_68":914},[915],{"_81":276,"_64":81},[917],{"_81":279,"_64":81},[919,920,921],{"_81":289,"_64":81},{"_57":285,"_64":164,"_68":922},{"_81":284,"_64":81},[923],{"_81":288,"_64":81},{"_64":65,"_66":67,"_68":925},[926,927],{"_64":74,"_68":930},{"_64":74,"_68":928},[929],{"_81":554,"_64":81},[931],{"_81":557,"_64":81},{"_64":104,"_68":933},[934],{"_81":935,"_64":81,"_179":84},"Die Stelle, die digitale Eingabesysteme nach Absatz 1 bereitstellt, darf personenbezogene Daten nur verarbeiten, soweit dies für die Zwecke der Unterstützung der digitalen Kommunikation nach § 1124 Absatz 1 und 2 erforderlich ist. Die Daten dürfen in den digitalen Eingabesystemen zwischengespeichert werden, um dem Nutzer zu ermöglichen, sie zu einem späteren Zeitpunkt zu vervollständigen, zu korrigieren oder zu löschen. Die zwischengespeicherten Daten sind spätestens 30 Tage nach der letzten Bearbeitung der digitalen Eingabesysteme automatisch zu löschen.[3]","u0ckfjpr9xr37um16815aq9u",[969],[939],{"_141":940,"_143":941,"_145":942},"1365",[961],{"_9":358,"_116":138,"_149":359,"_45":943,"_18":361,"_153":362,"_155":138},[944,945,946],{"_64":104,"_68":959},{"_64":104,"_68":957},{"_64":65,"_66":67,"_68":947},[948,949,950],{"_64":74,"_68":955},{"_64":74,"_68":953},{"_64":74,"_68":951},[952],{"_81":372,"_64":81},[954],{"_81":375,"_64":81},[956],{"_81":378,"_64":81},[958],{"_81":381,"_64":81},[960],{"_81":384,"_64":81},{"_64":65,"_66":67,"_68":962},[963,964],{"_64":74,"_68":967},{"_64":74,"_68":965},[966],{"_81":595,"_64":81},[968],{"_81":598,"_64":81},{"_64":104,"_68":970},[971,972],{"_81":974,"_64":81},{"_81":973,"_64":81,"_179":84},"Sie sind nach Maßgabe der Barrierefreie-Informationstechnik-Verordnung barrierefrei zu gestalten. Ferner ist bei der Gestaltung der digitalen Eingabesysteme deren Nutzerfreundlichkeit sowie eine einfache und intuitive Bedienbarkeit sicherzustellen.[1]","Die nach Absatz 1 entwickelten digitalen Eingabesysteme sind über ein Justizportal des Bundes und der Länder für die Nutzer bereitzustellen. ","qa6whcwveoqofa32go7qv776",[993],[978],{"_141":979,"_143":980,"_145":981},"1357",[990],{"_9":147,"_116":148,"_149":150,"_45":982,"_18":152,"_153":154,"_155":156},[983],{"_64":104,"_68":984},[985,986,987],{"_81":168,"_64":81},{"_57":163,"_64":164,"_68":988},{"_81":162,"_64":81},[989],{"_81":167,"_64":81},{"_64":104,"_68":991},[992],{"_81":623,"_64":81},{"_64":104,"_68":994},[995,996],{"_81":998,"_64":81,"_179":84},{"_81":997,"_64":81}," Das Bundesministerium der Justiz regelt durch Rechtsverordnung mit Zustimmung des Bundesrates die technischen, organisatorischen und datenschutzrechtlichen Rahmenbedingungen für Entwicklung, Betrieb, Pflege und Weiterentwicklung der digitalen Eingabesysteme nach Satz 2.","Die digitalen Eingabesysteme nach § 1124 Absatz 1 und 2 werden vom Bundesministerium der Justiz als Referenzimplementierung entwickelt und den Ländern zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitgestellt. Die Länder können weitere digitale Eingabesysteme entwickeln und zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitstellen.[6]",[1000,1001,1002,1003,1004],{"_9":358,"_116":138,"_149":359,"_45":1056,"_18":361,"_153":362,"_155":138},{"_9":503,"_116":129,"_149":504,"_45":1048,"_18":506,"_153":507,"_155":129},{"_9":147,"_116":148,"_149":150,"_45":1040,"_18":152,"_153":154,"_155":156},{"_9":197,"_116":191,"_149":198,"_45":1019,"_18":200,"_153":201,"_155":202},{"_9":266,"_116":156,"_149":267,"_45":1005,"_18":269,"_153":270,"_155":191},[1006,1007,1008],{"_64":104,"_68":1013},{"_64":104,"_68":1011},{"_64":104,"_68":1009},[1010],{"_81":276,"_64":81},[1012],{"_81":279,"_64":81},[1014,1015,1016],{"_81":289,"_64":81},{"_57":285,"_64":164,"_68":1017},{"_81":284,"_64":81},[1018],{"_81":288,"_64":81},[1020,1021],{"_64":104,"_68":1030},{"_64":104,"_68":1022},[1023,1024,1025,1026,1027],{"_81":218,"_64":81},{"_81":217,"_64":81,"_108":84},{"_81":216,"_64":81},{"_57":212,"_64":164,"_68":1028},{"_81":211,"_64":81},[1029],{"_81":215,"_64":81},[1031,1032,1033,1034,1035],{"_81":235,"_64":81},{"_57":231,"_64":164,"_68":1038},{"_81":230,"_64":81},{"_57":226,"_64":164,"_68":1036},{"_81":225,"_64":81},[1037],{"_81":229,"_64":81},[1039],{"_81":234,"_64":81},[1041],{"_64":104,"_68":1042},[1043,1044,1045],{"_81":168,"_64":81},{"_57":163,"_64":164,"_68":1046},{"_81":162,"_64":81},[1047],{"_81":167,"_64":81},[1049],{"_64":104,"_68":1050},[1051,1052,1053],{"_81":518,"_64":81},{"_57":514,"_64":164,"_68":1054},{"_81":513,"_64":81},[1055],{"_81":517,"_64":81},[1057,1058,1059],{"_64":104,"_68":1072},{"_64":104,"_68":1070},{"_64":65,"_66":67,"_68":1060},[1061,1062,1063],{"_64":74,"_68":1068},{"_64":74,"_68":1066},{"_64":74,"_68":1064},[1065],{"_81":372,"_64":81},[1067],{"_81":375,"_64":81},[1069],{"_81":378,"_64":81},[1071],{"_81":381,"_64":81},[1073],{"_81":384,"_64":81},{"_1075":1076,"_1077":1078,"_1079":1078,"_1080":1081,"_1082":255},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_1083":84,"_1084":84,"_1085":84,"_1086":84,"_1087":84,"_1088":84},"posthogKey","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
