[{"_1":2,"_3":4,"_5":6},"root",{"_7":418},"routes/beispiele",{"_7":316},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":14,"_15":-5,"_16":17,"_18":19,"_20":21,"_22":23,"_24":-5,"_25":26,"_27":28,"_29":30,"_31":32},"documentId","kgszoepavdh3zkfxehxx0zng","Titel","Identifikation der Nutzer Unternehmensregisterverordnung – URV","NKRNummer",6898,"Rechtsgebiet","Ressort","BMJV","URLBezeichnung","identifikation-der-nutzer-unternehmensregisterverordnung-urv","VeroeffentlichungsDatum","2024-10-08","LinkRegelungstext","https://www.gesetze-im-internet.de/urv/BJNR021700007.html","NKRStellungnahmeLink","GesetzStatus","Verkuendetes_Gesetz_aktuelle_Fassung","Paragraphen",[104],"Visualisierungen",[44],"Digitalchecks",[33],{"_9":34,"_11":35,"_36":37,"_38":37,"_39":40,"_41":37,"_42":37,"_43":-5},"r4usyeyo7xtb4a1665p3i9wx","Verordnung zur Änderung der Unternehmensregisterverordnung","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","Teilweise","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",{"_9":45,"_11":46,"_47":48,"_49":50,"_51":52,"_53":-5,"_16":-5,"_54":55,"_56":57},"tkqvdwq669c7nkqrflqvzb5s","Vorher-Nachher-Vergleich","Beschreibung",[64,65],"Visualisierungsart","Flussdiagramm","Visualisierungstool","PowerPoint","Aufwand","Bild",{"_9":58,"_59":60,"_61":-5,"_62":63},"Beispielvorhaben",{"_18":19,"_20":21,"_15":-5,"_11":12,"_16":17},"rnvl92pn9drorwlvgar3nhd0","url","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/visualisierung_Unternehmensregisterverordnung_791d12038d.jpg","previewUrl","alternativeText","Das Bild zeigt zwei Flussdiagramme, die den Prozess der Identifizierung und Speicherung von Steuerberatern vor und nach einer Gesetzesänderung darstellen.",{"_66":100,"_70":101},{"_66":67,"_68":69,"_70":71},"type","list","format","unordered","children",[72,73,74],{"_66":75,"_70":91},{"_66":75,"_70":86},{"_66":75,"_70":76},"list-item",[77,78,79],{"_80":85,"_66":80},{"_82":83,"_80":84,"_66":80},{"_80":81,"_66":80},"text",".","bold",true," Verknüpfung des Paragraphen mit der Visualisierung","Fördert eine schnelle Orientierung durch",[87,88],{"_82":83,"_80":90,"_66":80},{"_80":89,"_66":80}," und ist damit verständlich für Fachleute und Laien.","Abstrahiert die inhaltliche Komplexität zu einer schematischen Darstellung",[92,93,94,95,96],{"_80":99,"_66":80},{"_82":83,"_80":46,"_66":80},{"_80":98,"_66":80},{"_82":83,"_80":97,"_66":80},{"_80":81,"_66":80},"nachvollziehbar"," ","Macht Auswirkungen der Änderungen – den Wegfall von Extraschritt bei Nutzergruppe – durch einen ","paragraph",[102],{"_80":103,"_66":80},"Nach §3a URV",{"_9":105,"_106":107,"_11":108,"_109":110,"_111":-5,"_112":113},"icj7tfownt5q9dk34m2hgrv5","Nummer","3a","Identifikation der Nutzer","Gesetz","URV","Artikel","Absaetze",[114,115,116,117],{"_9":246,"_119":247,"_106":248,"_122":249},{"_9":177,"_119":178,"_106":132,"_122":179},{"_9":169,"_119":170,"_106":171,"_122":172},{"_9":118,"_119":120,"_106":121,"_122":123},"lzd173a3z6lkm3jdxdna9b1v","Text",[156],4,"PrinzipErfuellungen",[124],{"_125":126,"_127":128,"_129":130},"id","1381","Erklaerung",[152],"Prinzip",{"_9":131,"_106":132,"_133":134,"_47":135,"_18":136,"_137":138,"_139":132},"s18bibg9sdf0jt8up7h8btup",2,"Name","Datenwiederverwendung benötigt einheitliches Recht",[140],"datenwiederverwendung-benoetigt-einheitliches-recht","Kurzbezeichnung","Datenwiederverwendung","order",{"_66":100,"_70":141},[142,143,144],{"_80":151,"_66":80},{"_59":146,"_66":147,"_70":148},{"_80":145,"_66":80}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[149],{"_80":150,"_66":80},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_66":100,"_70":153},[154],{"_80":155,"_66":80},"Reduziert den Aufwand für die Nutzergruppe, indem bereits erhobene Daten der Steuerberaterplattform wiederverwendet werden.",{"_66":100,"_70":157},[158,159,160,161,162],{"_80":168,"_66":80},{"_80":167,"_66":80,"_165":83},{"_80":166,"_66":80},{"_80":164,"_66":80,"_165":83},{"_80":163,"_66":80}," Die registerführende Stelle ist befugt, die übermittelten Identifizierungsdaten und die Daten der SAFE-Visitenkarte zu verarbeiten. Absatz 2 Satz 1 bis 3 gilt entsprechend. Die registerführende Stelle ist berechtigt, sich auf die Richtigkeit und Vollständigkeit der ihr übermittelten Daten zu verlassen, es sei denn, an deren Richtigkeit oder Vollständigkeit bestehen ernstliche Zweifel; in diesem Fall ist sie verpflichtet, vom Betreiber der Steuerberaterplattform die erforderlichen Nachweise über eine erfolgte Identifizierung zu verlangen.","vom Betreiber der Steuerberaterplattform verlangen, ihr die dort erhobenen Identifizierungsdaten über die Schnittstelle zu übermitteln.[2]","underline"," In diesen Fällen kann die registerführende Stelle ","nach ihren technischen Vorgaben eine Schnittstelle zur Steuerberaterplattform nach § 86c des Steuerberatungsgesetzes einzurichten. Ist eine solche Schnittstelle eingerichtet, so müssen sich Nutzer, die bereits über die Steuerberaterplattform identifiziert sind, für die Registrierung nach § 3 nicht nach Absatz 1 identifizieren.[2]","Die registerführende Stelle ist befugt, ","v18moh4ayoao8wrjkboiyp28",[173],3,[],{"_66":100,"_70":174},[175],{"_80":176,"_66":80},"Hat die registerführende Stelle im Rahmen der Registrierung oder der Datenübermittlung nach § 11 Absatz 2 Satz 1 ernstliche Zweifel an der Rechtsfähigkeit oder Geschäftsfähigkeit eines Nutzers oder an seiner Berechtigung zur Datenübermittlung, so kann die registerführende Stelle von ihm oder dem für ihn handelnden Berechtigten die Übermittlung geeigneter Nachweise oder eine erneute Identifikation verlangen.","x08f0pfhfwc2hxhnhaqh51it",[213,214,215],[180],{"_125":181,"_127":182,"_129":183},"1385",[209],{"_9":184,"_106":171,"_133":185,"_47":186,"_18":187,"_137":188,"_139":189},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[190,191,192],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz",5,{"_66":100,"_70":199},{"_66":100,"_70":196},{"_66":100,"_70":193},[194],{"_80":195,"_66":80},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[197],{"_80":198,"_66":80},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[200,201,202],{"_80":208,"_66":80},{"_59":204,"_66":147,"_70":205},{"_80":203,"_66":80}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[206],{"_80":207,"_66":80},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_66":100,"_70":210},[211],{"_80":212,"_66":80},"Spezifiziert einen vergleichsweise geringen Umfang an Daten und verknüpft diese bereits mit einer Löschfrist.",{"_66":100,"_70":241},{"_66":67,"_68":219,"_70":220},{"_66":100,"_70":216},[217],{"_80":218,"_66":80},"Sofern keine Datenübermittlung erfolgt ist, sind die in Satz 2 genannten Daten acht Jahre nach Abschluss des Identifikationsvorganges zu löschen. Weitere im Rahmen der Identifizierung erhobene Daten sind drei Monate nach Abschluss des Identifikationsvorganges zu löschen. Bei erfolgloser Identifikation werden der Prozessnachweis, der Familienname und die Vornamen des Nutzers zusammen mit den Daten nach Satz 3 gelöscht.","ordered",[221,222,223,224,225],{"_66":75,"_70":238},{"_66":75,"_70":235},{"_66":75,"_70":232},{"_66":75,"_70":229},{"_66":75,"_70":226},[227],{"_80":228,"_66":80},"Zeitstempel.",[230],{"_80":231,"_66":80},"Dokumentenart des Ausweisdokuments,",[233],{"_80":234,"_66":80},"Anschrift,",[236],{"_80":237,"_66":80},"Tag der Geburt,",[239],{"_80":240,"_66":80},"Titel,",[242,243],{"_80":245,"_66":80},{"_80":244,"_66":80,"_165":83},"Die folgenden Identifizierungsdaten werden im Unternehmensregister gespeichert und sind acht Jahre nach der letzten Datenübermittlung zu löschen:[3]","Bei erfolgreicher Identifikation werden der Prozessnachweis, der Familienname und die Vornamen des Nutzers im Nutzerkonto gespeichert. ","yjvchqu3zrcpbd539g0qnjnr",[285,286],1,[250],{"_125":251,"_127":252,"_129":253},"1377",[281],{"_9":254,"_106":248,"_133":255,"_47":256,"_18":257,"_137":258,"_139":248},"r57rc9d82ulv2bsc3gdbnj73","Digitale Angebote für alle nutzbar gestalten",[259,260,261],"digitale-angebote-fuer-alle-nutzbar-gestalten","Digitale Angebote",{"_66":100,"_70":278},{"_66":100,"_70":275},{"_66":67,"_68":69,"_70":262},[263,264,265],{"_66":75,"_70":272},{"_66":75,"_70":269},{"_66":75,"_70":266},[267],{"_80":268,"_66":80},"wie Barrierefreiheit zu bedenken ist.",[270],{"_80":271,"_66":80},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[273],{"_80":274,"_66":80},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[276],{"_80":277,"_66":80},"Erfahren Sie in diesem Abschnitt,",[279],{"_80":280,"_66":80},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_66":100,"_70":282},[283],{"_80":284,"_66":80},"Führt zu ausschließlich digitaler Kommunikation, eine für die Nutzergruppe geeignete Form.",{"_66":100,"_70":311},{"_66":67,"_68":219,"_70":287},[288,289,290,291],{"_66":75,"_70":308},{"_66":75,"_70":305},{"_66":67,"_68":219,"_70":295,"_296":248},{"_66":75,"_70":292},[293],{"_80":294,"_66":80},"einer von der registerführenden Stelle zur Verfügung gestellten Identifizierungsmethode im Sinne des Artikels 24 Absatz 1 Unterabsatz 2 Buchstabe d Satz 1 der Verordnung (EU) Nr. 910/2014.",[297,298],"indentLevel",{"_66":75,"_70":302},{"_66":75,"_70":299},[300],{"_80":301,"_66":80},"dem Sicherheitsniveau „hoch“ im Sinne des Artikels 8 Absatz 2 Buchstabe c der Verordnung (EU) Nr. 910/2014 entspricht, oder",[303],{"_80":304,"_66":80},"für die Zwecke der grenzüberschreitenden Authentifizierung nach Artikel 6 der Verordnung (EU) Nr. 910/2014 des Europäischen Parlaments und des Rates vom 23. Juli 2014 über elektronische Identifizierung und Vertrauensdienste für elektronische Transaktionen im Binnenmarkt und zur Aufhebung der Richtlinie 1999/93/EG (ABl. L 257 vom 28.8.2014, S. 73; L 23 vom 29.1.2015, S. 19; L 155 vom 14.6.2016, S. 44), die durch die Richtlinie (EU) 2022/2555 (ABl. L 333 vom 27.12.2022, S. 80) geändert worden ist, anerkannt wird und",[306],{"_80":307,"_66":80},"eines elektronischen Identifizierungsmittels, das von einem anderen Mitgliedstaat der Europäischen Union ausgestellt wurde und das",[309],{"_80":310,"_66":80},"eines elektronischen Identitätsnachweises nach § 18 des Personalausweisgesetzes, nach § 12 des eID-Karte- Gesetzes oder nach § 78 Absatz 5 des Aufenthaltsgesetzes,",[312,313],{"_80":315,"_66":80,"_165":83},{"_80":314,"_66":80}," Nutzer ist diejenige natürliche Person, die eine Datenübermittlung nach § 11 Absatz 2 für Veröffentlichungs- und Offenlegungspflichtige tatsächlich vornehmen soll. Die elektronische Identifikation erfolgt anhand","Für eine Registrierung nach § 3 Absatz 2 hat eine elektronische Identifikation des Nutzers zu erfolgen.[1]",[317,318,319,320,321],{"_9":254,"_106":248,"_133":255,"_47":400,"_18":257,"_137":258,"_139":248},{"_9":131,"_106":132,"_133":134,"_47":392,"_18":136,"_137":138,"_139":132},{"_9":375,"_106":376,"_133":377,"_47":378,"_18":379,"_137":380,"_139":171},{"_9":336,"_106":189,"_133":337,"_47":338,"_18":339,"_137":340,"_139":121},{"_9":184,"_106":171,"_133":185,"_47":322,"_18":187,"_137":188,"_139":189},[323,324,325],{"_66":100,"_70":330},{"_66":100,"_70":328},{"_66":100,"_70":326},[327],{"_80":195,"_66":80},[329],{"_80":198,"_66":80},[331,332,333],{"_80":208,"_66":80},{"_59":204,"_66":147,"_70":334},{"_80":203,"_66":80},[335],{"_80":207,"_66":80},"got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[341,342],"automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",{"_66":100,"_70":358},{"_66":100,"_70":343},[344,345,346,347,348],{"_80":357,"_66":80},{"_80":355,"_66":80,"_356":83},{"_80":354,"_66":80},{"_59":350,"_66":147,"_70":351},{"_80":349,"_66":80},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[352],{"_80":353,"_66":80},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[359,360,361,362,363],{"_80":374,"_66":80},{"_59":370,"_66":147,"_70":371},{"_80":369,"_66":80},{"_59":365,"_66":147,"_70":366},{"_80":364,"_66":80}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fac