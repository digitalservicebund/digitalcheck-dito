[{"_1":2,"_3":4,"_5":6},"root",{"_7":595},"routes/beispiele",{"_7":512},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":14,"_15":16,"_17":18,"_19":20,"_21":22,"_23":24,"_25":-5,"_26":27,"_28":29,"_30":31,"_32":33},"documentId","wdb62i9iybimrbzxtfkm02v2","Titel","Elektronischer Rechtsverkehr mit dem Bundesverfassungsgericht – BVerfGG","NKRNummer",6773,"Rechtsgebiet","TBD","Ressort","BMJV","URLBezeichnung","elektronischer-rechtsverkehr-mit-dem-bundesverfassungsgericht-b-verf-g","VeroeffentlichungsDatum","2024-08-01","LinkRegelungstext","https://www.gesetze-im-internet.de/bverfgg/BJNR002430951.html","NKRStellungnahmeLink","GesetzStatus","Verkuendetes_Gesetz_aktuelle_Fassung","Paragraphen",[44,45,46,47,48],"Visualisierungen",[],"Digitalchecks",[34],{"_9":35,"_11":36,"_37":38,"_39":38,"_40":38,"_41":38,"_42":38,"_43":-5},"onf6a4hlnxmbq2nvf3mhdkkj","Zehntes Gesetz zur Änderung des Bundesverfassungsgerichtsgesetzes","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",{"_9":280,"_50":281,"_11":-5,"_52":119,"_54":-5,"_55":282},{"_9":229,"_50":230,"_11":-5,"_52":119,"_54":-5,"_55":231},{"_9":188,"_50":189,"_11":-5,"_52":119,"_54":-5,"_55":190},{"_9":117,"_50":118,"_11":-5,"_52":119,"_54":-5,"_55":120},{"_9":49,"_50":51,"_11":-5,"_52":53,"_54":-5,"_55":56},"ymmhasort2iyswlya1phwpvr","Nummer","23d","Gesetz","BverfGG","Artikel","Absaetze",[57,58,59,60],{"_9":109,"_62":110,"_50":111,"_65":112},{"_9":101,"_62":102,"_50":103,"_65":104},{"_9":75,"_62":76,"_50":77,"_65":78},{"_9":61,"_62":63,"_50":64,"_65":66},"l9ky7vbw13tb46ffdicfjlkp","Text",[67],4,"PrinzipErfuellungen",[],{"_68":69,"_70":71},"type","paragraph","children",[72],{"_73":74,"_68":73},"text","Ein eingereichtes elektronisches Dokument kann nach Ablauf von sechs Monaten gelöscht werden.","hrl9g1vby9ncan3nztre6qua",[79,80],3,[],{"_68":69,"_70":98},{"_68":81,"_82":83,"_70":84},"list","format","ordered",[85,86,87],{"_68":88,"_70":95},{"_68":88,"_70":92},{"_68":88,"_70":89},"list-item",[90],{"_73":91,"_68":73},"welchen Zeitpunkt die Signaturprüfung für die Anbringung der Signatur ausweist.",[93],{"_73":94,"_68":73},"wen die Signaturprüfung als Inhaber der Signatur ausweist,",[96],{"_73":97,"_68":73},"welches Ergebnis die Integritätsprüfung des Dokumentes ausweist,",[99],{"_73":100,"_68":73},"Ist das elektronische Dokument mit einer qualifizierten elektronischen Signatur versehen und nicht auf einem sicheren Übermittlungsweg eingereicht, muss der Ausdruck einen Vermerk darüber enthalten,","mqcc85hes13uxwovtogdzagp",[105],2,[],{"_68":69,"_70":106},[107],{"_73":108,"_68":73},"Wird das elektronische Dokument auf einem sicheren Übermittlungsweg eingereicht, so ist dies aktenkundig zu machen.","nj5nxhrkdsl6xmc5kcgqj12r",[113],1,[],{"_68":69,"_70":114},[115],{"_73":116,"_68":73},"Werden die Akten in Papierform geführt, ist von einem elektronischen Dokument ein Ausdruck für die Akte zu fertigen. Kann dies bei Anlagen nicht oder nur mit unverhältnismäßigem Aufwand erfolgen, so kann ein Ausdruck unterbleiben. Die Daten sind in diesem Fall dauerhaft zu speichern; der Speicherort ist aktenkundig zu machen.","j7phpdnr7iwnwqo8w69v2od1","23e","BVerfGG",[121,122],{"_9":181,"_62":182,"_50":111,"_65":183},{"_9":123,"_62":124,"_50":103,"_65":125},"n6mao42pkhqktfjibwx4lwae",[169],[126],{"_127":128,"_129":130,"_131":132},"id","1379","Erklaerung",[165],"Prinzip",{"_9":133,"_50":111,"_134":135,"_136":137,"_19":138,"_139":140,"_141":111},"r57rc9d82ulv2bsc3gdbnj73","Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[142,143,144],"digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_68":69,"_70":162},{"_68":69,"_70":159},{"_68":81,"_82":145,"_70":146},"unordered",[147,148,149],{"_68":88,"_70":156},{"_68":88,"_70":153},{"_68":88,"_70":150},[151],{"_73":152,"_68":73},"wie Barrierefreiheit zu bedenken ist.",[154],{"_73":155,"_68":73},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[157],{"_73":158,"_68":73},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[160],{"_73":161,"_68":73},"Erfahren Sie in diesem Abschnitt,",[163],{"_73":164,"_68":73},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_68":69,"_70":166},[167],{"_73":168,"_68":73},"Ermöglicht eine ganzheitliche digitale Aktenführung.",{"_68":69,"_70":170},[171,172,173,174],{"_73":180,"_68":73,"_177":178},{"_73":179,"_68":73},{"_73":176,"_68":73,"_177":178},{"_73":175,"_68":73}," Die in Papierform vorliegenden Schriftstücke und sonstigen Unterlagen können sechs Monate nach der Übertragung vernichtet werden, sofern sie nicht rückgabepflichtig sind.","Wird ein von den verantwortenden Personen handschriftlich unterzeichnetes gerichtliches Schriftstück übertragen, ist der Übertragungsnachweis mit einer qualifizierten elektronischen Signatur des Urkundsbeamten der Geschäftsstelle zu versehen.[1]","underline",true," Es ist sicherzustellen, dass das elektronische Dokument mit den vorliegenden Schriftstücken und sonstigen Unterlagen bildlich und inhaltlich übereinstimmt. Das elektronische Dokument ist mit einem Übertragungsnachweis zu versehen, der das bei der Übertragung angewandte Verfahren und die bildliche und inhaltliche Übereinstimmung dokumentiert. ","Werden die Verfahrensakten elektronisch geführt, sind in Papierform vorliegende Schriftstücke und sonstige Unterlagen nach dem Stand der Technik zur Ersetzung der Urschrift in ein elektronisches Dokument zu übertragen.[1]","vgja8ibdmx6adzyi6szkqq2k",[184],[],{"_68":69,"_70":185},[186],{"_73":187,"_68":73},"Die Verfahrensakten können elektronisch geführt werden. Sie können auch teilweise elektronisch geführt werden.","xnhtsk5lselwhds4vlaspi6j","23b",[191],{"_9":192,"_62":193,"_50":111,"_65":194},"l9hl26wi4tp25ggof4we95as",[221],[195],{"_127":196,"_129":197,"_131":198},"1317",[217],{"_9":133,"_50":111,"_134":135,"_136":199,"_19":138,"_139":140,"_141":111},[200,201,202],{"_68":69,"_70":215},{"_68":69,"_70":213},{"_68":81,"_82":145,"_70":203},[204,205,206],{"_68":88,"_70":211},{"_68":88,"_70":209},{"_68":88,"_70":207},[208],{"_73":152,"_68":73},[210],{"_73":155,"_68":73},[212],{"_73":158,"_68":73},[214],{"_73":161,"_68":73},[216],{"_73":164,"_68":73},{"_68":69,"_70":218},[219],{"_73":220,"_68":73},"Verhindert einen Medienbruch und erhöht die Nutzerfreundlichkeit durch das Ermöglichen von Alternativen zur handschriftlichen Unterzeichnung.",{"_68":69,"_70":222},[223,224,225],{"_73":228,"_68":73},{"_73":227,"_68":73,"_177":178},{"_73":226,"_68":73},", wenn die verantwortenden Personen am Ende des Dokuments ihren Namen hinzufügen und das Dokument mit einer qualifizierten elektronischen Signatur versehen. Der in Satz 1 genannten Form genügt auch ein elektronisches Dokument, in welches das handschriftlich unterzeichnete Schriftstück gemäß § 23e Absatz 2 Satz 4 übertragen worden ist.","genügt dieser Form die Aufzeichnung als elektronisches Dokument[1]","Soweit die handschriftliche Unterzeichnung durch den Richter, den Rechtspfleger oder den Urkundsbeamten der Geschäftsstelle vorgeschrieben ist, ","knqwnc9dpra9uq488n9ovzxe","23c",[232],{"_9":233,"_62":234,"_50":111,"_65":235},"b381cyonkcztn9jq5ujtp4de",[268],[236],{"_127":237,"_129":238,"_131":239},"1331",[258],{"_9":133,"_50":111,"_134":135,"_136":240,"_19":138,"_139":140,"_141":111},[241,242,243],{"_68":69,"_70":256},{"_68":69,"_70":254},{"_68":81,"_82":145,"_70":244},[245,246,247],{"_68":88,"_70":252},{"_68":88,"_70":250},{"_68":88,"_70":248},[249],{"_73":152,"_68":73},[251],{"_73":155,"_68":73},[253],{"_73":158,"_68":73},[255],{"_73":161,"_68":73},[257],{"_73":164,"_68":73},{"_68":81,"_82":145,"_70":259},[260,261],{"_68":88,"_70":265},{"_68":88,"_70":262},[263],{"_73":264,"_68":73},"Da der Normenadressat eine besonders befähigte Gruppe darstellt, kann hier im Regelfall komplett auf die Papierform verzichtet werden.",[266],{"_73":267,"_68":73},"Macht elektronische Datenübermittlung zum Regelfall.",{"_68":69,"_70":269},[270,271,272,273,274],{"_73":279,"_68":73},{"_73":278,"_68":73,"_177":178},{"_73":277,"_68":73},{"_73":276,"_68":73,"_177":178},{"_73":275,"_68":73},".","auf Anforderung ist ein elektronisches Dokument nachzureichen[1]",". Ist dies aus technischen Gründen vorübergehend nicht möglich, bleibt die Übermittlung nach den allgemeinen Vorschriften zulässig. Die vorübergehende Unmöglichkeit ist bei der Ersatzeinreichung oder unverzüglich danach glaubhaft zu machen; ","sind als elektronische Dokumente zu übermitteln[1]","Schriftlich einzureichende Anträge und Erklärungen sowie sonstige Schriftsätze und deren Anlagen, die durch einen Rechtsanwalt, durch eine Behörde oder durch eine juristische Person des öffentlichen Rechts einschließlich der von ihr zur Erfüllung ihrer öffentlichen Aufgaben gebildeten Zusammenschlüsse eingereicht werden, ","c2k4ab7v50lt2ox7hwm6m6uy","23a",[283,284,285,286,287,288],{"_9":479,"_62":480,"_50":111,"_65":481},{"_9":440,"_62":441,"_50":103,"_65":442},{"_9":393,"_62":394,"_50":77,"_65":395},{"_9":356,"_62":357,"_50":64,"_65":358},{"_9":297,"_62":298,"_50":299,"_65":300},{"_9":289,"_62":290,"_50":291,"_65":292},"ta578ilke4gqe4fh671a19xz",[293],6,[],{"_68":69,"_70":294},[295],{"_73":296,"_68":73},"Ist ein elektronisches Dokument für das Bundesverfassungsgericht zur Bearbeitung nicht geeignet, ist dies dem Absender unter Hinweis auf die Unwirksamkeit des Eingangs unverzüglich mitzuteilen. Das Dokument gilt als zum Zeitpunkt der früheren Einreichung eingegangen, sofern der Absender es unverzüglich in einer für das Bundesverfassungsgericht zur Bearbeitung geeigneten Form nachreicht und glaubhaft macht, dass es mit dem zuerst eingereichten Dokument inhaltlich übereinstimmt.","dkrepldx3f00evybq7hdz4na",[350],5,[301],{"_127":302,"_129":303,"_131":304},"1315",[346],{"_9":305,"_50":299,"_134":306,"_136":307,"_19":308,"_139":309,"_141":64},"got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[310,311],"automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",{"_68":69,"_70":329},{"_68":69,"_70":312},[313,314,315,316,317],{"_73":328,"_68":73},{"_73":326,"_68":73,"_327":178},{"_73":325,"_68":73},{"_319":320,"_68":321,"_70":322},{"_73":318,"_68":73},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","url","https://www.gesetze-im-internet.de/vwvfg/__35a.html","link",[323],{"_73":324,"_68":73},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[330,331,332,333,334],{"_73":345,"_68":73},{"_319":341,"_68":321,"_70":342},{"_73":340,"_68":73},{"_319":336,"_68":321,"_70":337},{"_73":335,"_68":73}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[338],{"_73":339,"_68":73},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[343],{"_73":344,"_68":73},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_68":69,"_70":347},[348],{"_73":349,"_68":73},"Entlastet die Verwaltung durch automatische Bestätigungen; eine Funktionalität, die von Nutzenden erwartet wird.",{"_68":69,"_70":351},[352,353],{"_73":355,"_68":73},{"_73":354,"_68":73,"_177":178},"Dem Absender ist eine automatisierte Bestätigung über den Zeitpunkt des Eingangs zu erteilen.[5]","Ein elektronisches Dokument ist eingegangen, sobald es auf der für den Empfang bestimmten Einrichtung des Bundesverfassungsgerichts gespeichert ist. ","pw00bksnv634vgzyivplxbyf",[359,360,361],[],{"_68":69,"_70":390},{"_68":81,"_82":83,"_70":365},{"_68":69,"_70":362},[363],{"_73":364,"_68":73,"_177":178},"Für die Übermittlungswege gemäß Satz 1 Nummer 3 bis 5 gelten die näheren Regelungen der Elektronischer-Rechtsverkehr-Verordnung entsprechend.[3]",[366,367,368,369,370,371],{"_68":88,"_70":387},{"_68":88,"_70":384},{"_68":88,"_70":381},{"_68":88,"_70":378},{"_68":88,"_70":375},{"_68":88,"_70":372},[373],{"_73":374,"_68":73},"sonstige bundeseinheitliche Übermittlungswege, die durch Rechtsverordnung der Bundesregierung mit Zustimmung des Bundesrates festgelegt werden, bei denen die Authentizität und Integrität der Daten sowie die Barrierefreiheit gewährleistet sind.",[376],{"_73":377,"_68":73},"der Übermittlungsweg zwischen einem nach Durchführung eines Identifizierungsverfahrens genutzten Postfach- und Versanddienst eines Nutzerkontos im Sinne des § 2 Absatz 5 des Onlinezugangsgesetzes und der elektronischen Poststelle des Bundesverfassungsgerichts,",[379],{"_73":380,"_68":73},"der Übermittlungsweg zwischen einem nach Durchführung eines Identifizierungsverfahrens eingerichteten elektronischen Postfach einer natürlichen oder juristischen Person oder einer sonstigen Vereinigung und der elektronischen Poststelle des Bundesverfassungsgerichts,",[382],{"_73":383,"_68":73},"der Übermittlungsweg zwischen einem nach Durchführung eines Identifizierungsverfahrens eingerichteten Postfach einer Behörde oder einer juristischen Person des öffentlichen Rechts und der elektronischen Poststelle des Bundesverfassungsgerichts,",[385],{"_73":386,"_68":73},"der Übermittlungsweg zwischen den besonderen elektronischen Anwaltspostfächern nach den §§ 31a und 31b der Bundesrechtsanwaltsordnung oder einem entsprechenden, auf gesetzlicher Grundlage errichteten elektronischen Postfach und der elektronischen Poststelle des Bundesverfassungsgerichts,",[388],{"_73":389,"_68":73},"der Postfach- und Versanddienst eines De-Mail-Kontos, wenn der Absender bei Versand der Nachricht sicher im Sinne des § 4 Absatz 1 Satz 2 des De-Mail-Gesetzes angemeldet ist und er sich die sichere Anmeldung gemäß § 5 Absatz 5 des De-Mail-Gesetzes bestätigen lässt,",[391],{"_73":392,"_68":73},"Sichere Übermittlungswege sind","kqsgu93abtz4s3i69gidyyps",[434],[396],{"_127":397,"_129":398,"_131":399},"1313",[424],{"_9":400,"_50":77,"_134":401,"_136":402,"_19":403,"_139":404,"_141":299},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[405,406,407],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz",{"_68":69,"_70":414},{"_68":69,"_70":411},{"_68":69,"_70":408},[409],{"_73":410,"_68":73},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[412],{"_73":413,"_68":73},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[415,416,417],{"_73":423,"_68":73},{"_319":419,"_68":321,"_70":420},{"_73":418,"_68":73}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[421],{"_73":422,"_68":73},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_68":81,"_82":145,"_70":425},[426,427],{"_68":88,"_70":431},{"_68":88,"_70":428},[429],{"_73":430,"_68":73},"Führt zu erhöhter Informationssicherheit durch die Nutzung eines sicheren Übermittlungsweges (siehe Absatz 3). Dies schützt die Daten vor Veränderung und unerlaubter Einsicht während der Übertragung.",[432],{"_73":433,"_68":73},"Steigert den Schutz vor Fälschungen durch Verwendung eines geeigneten kryptografischen Verfahrens (qualifizierte elektronische Signatur).",{"_68":69,"_70":435},[436,437],{"_73":439,"_68":73,"_177":178},{"_73":438,"_68":73}," Satz 1 gilt nicht für Anlagen. Soll ein schriftlich einzureichender Antrag oder eine schriftlich einzureichende Erklärung eines Beteiligten oder eines Dritten als elektronisches Dokument eingereicht werden, so kann der unterschriebene Antrag oder die unterschriebene Erklärung in ein elektronisches Dokument übertragen und durch den Bevollmächtigten, den Vertreter oder den Beistand nach Satz 1 übermittelt werden.","Das elektronische Dokument muss mit einer qualifizierten elektronischen Signatur der verantwortenden Person versehen sein oder von der verantwortenden Person signiert und auf einem sicheren Übermittlungsweg eingereicht werden.[3]","t0037mojhj4ibwqs1d5zleq9",[475],[443],{"_127":444,"_129":445,"_131":446},"1301",[463,464],{"_9":447,"_50":103,"_134":448,"_136":449,"_19":450,"_139":451,"_141":103},"s18bibg9sdf0jt8up7h8btup","Datenwiederverwendung benötigt einheitliches Recht",[452],"datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_68":69,"_70":453},[454,455,456],{"_73":462,"_68":73},{"_319":458,"_68":321,"_70":459},{"_73":457,"_68":73}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[460],{"_73":461,"_68":73},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_68":81,"_82":145,"_70":470},{"_68":81,"_82":145,"_70":465},[466],{"_68":88,"_70":467},[468],{"_73":469,"_68":73},"Verweist mit der Elektronischer-Rechtsverkehr-Verordnung auf eine Regelung, die technische und rechtliche Aspekte zentral steuert.",[471],{"_68":88,"_70":472},[473],{"_73":474,"_68":73},"Begünstigt eine effiziente technische Umsetzung, indem es die Nutzung oder Wiederverwendung eines geeigneten Datenstandards vorschreibt.",{"_68":69,"_70":476},[477],{"_73":478,"_68":73,"_177":178},"Das elektronische Dokument muss für die Bearbeitung durch das Bundesverfassungsgericht geeignet sein. Für die Übermittlung und die Eignung zur Bearbeitung durch das Bundesverfassungsgericht gelten die in der Elektronischer-Rechtsverkehr-Verordnung geregelten technischen Rahmenbedingungen des elektronischen Rechtsverkehrs entsprechend.[2]","rdfocmyt6wqirzqsmwjgz9vo",[508],[482],{"_127":483,"_129":484,"_131":485},"1311",[504],{"_9":133,"_50":111,"_134":135,"_136":486,"_19":138,"_139":140,"_141":111},[487,488,489],{"_68":69,"_70":502},{"_68":69,"_70":500},{"_68":81,"_82":145,"_70":490},[491,492,493],{"_68":88,"_70":498},{"_68":88,"_70":496},{"_68":88,"_70":494},[495],{"_73":152,"_68":73},[497],{"_73":155,"_68":73},[499],{"_73":158,"_68":73},[501],{"_73":161,"_68":73},[503],{"_73":164,"_68":73},{"_68":69,"_70":505},[506],{"_73":507,"_68":73},"Ermöglicht elektronisches Einreichen der Dokumente.",{"_68":69,"_70":509},[510],{"_73":511,"_68":73,"_177":178},"Schriftlich einzureichende Anträge und Erklärungen sowie sonstige Schriftsätze und deren Anlagen können nach Maßgabe der folgenden Absätze als elektronische Dokumente beim Bundesverfassungsgericht eingereicht werden.[1]",[513,514,515,516,517],{"_9":133,"_50":111,"_134":135,"_136":577,"_19":138,"_139":140,"_141":111},{"_9":447,"_50":103,"_134":448,"_136":569,"_19":450,"_139":451,"_141":103},{"_9":553,"_50":291,"_134":554,"_136":555,"_19":556,"_139":557,"_141":77},{"_9":305,"_50":299,"_134":306,"_136":532,"_19":308,"_139":309,"_141":64},{"_9":400,"_50":77,"_134":401,"_136":518,"_19":403,"_139":404,"_141":299},[519,520,521],{"_68":69,"_70":526},{"_68":69,"_70":524},{"_68":69,"_70":522},[523],{"_73":410,"_68":73},[525],{"_73":413,"_68":73},[527,528,529],{"_73":423,"_68":73},{"_319":419,"_68":321,"_70":530},{"_73":418,"_68":73},[531],{"_73":422,"_68":73},[533,534],{"_68":69,"_70":543},{"_68":69,"_70":535},[536,537,538,539,540],{"_73":328,"_68":73},{"_73":326,"_68":73,"_327":178},{"_73":325,"_68":73},{"_319":320,"_68":321,"_70":541},{"_73":318,"_68":73},[542],{"_73":324,"_68":73},[544,545,546,547,548],{"_73":345,"_68":73},{"_319":341,"_68":321,"_70":551},{"_73":340,"_68":73},{"_319":336,"_68":321,"_70":549},{"_73":335,"_68":73},[550],{"_73":339,"_68":73},[552],{"_73":344,"_68":73},"habu0yjh39lc5wug5mqsqzaj","Etablierte Technologien ermöglichen effiziente Umsetzung",[558],"etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",{"_68":69,"_70":559},[560,561,562],{"_73":568,"_68":73},{"_319":564,"_68":321,"_70":565},{"_73":563,"_68":73}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[566],{"_73":567,"_68":73},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",[570],{"_68":69,"_70":571},[572,573,574],{"_73":462,"_68":73},{"_319":458,"_68":321,"_70":575},{"_73":457,"_68":73},[576],{"_73":461,"_68":73