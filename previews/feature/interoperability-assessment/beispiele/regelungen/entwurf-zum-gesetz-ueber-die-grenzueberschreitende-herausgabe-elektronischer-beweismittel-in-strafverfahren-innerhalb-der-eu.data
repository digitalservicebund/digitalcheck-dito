[{"_1":2,"_3":4,"_5":6},"root",{"_7":233},"routes/beispiele",{"_7":95},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":14,"_15":-5,"_16":17,"_18":19,"_20":-5,"_21":22,"_23":-5,"_24":25,"_26":27,"_28":29,"_30":31},"documentId","ngpedj5jzal0ye3ayh56rgtb","Titel","Entwurf zum Gesetz über die grenzüberschreitende Herausgabe elektronischer Beweismittel in Strafverfahren innerhalb der EU","NKRNummer",7604,"Rechtsgebiet","Ressort","BMJV","URLBezeichnung","entwurf-zum-gesetz-ueber-die-grenzueberschreitende-herausgabe-elektronischer-beweismittel-in-strafverfahren-innerhalb-der-eu","VeroeffentlichungsDatum","LinkRegelungstext","https://dip.bundestag.de/vorgang/gesetz-zur-umsetzung-der-richtlinie-eu-2023-1544-und-zur-durchf%C3%BChrung/326831","NKRStellungnahmeLink","GesetzStatus","Regelungsentwurf","Paragraphen",[],"Visualisierungen",[41],"Digitalchecks",[32],{"_9":33,"_11":34,"_35":-5,"_36":-5,"_37":-5,"_38":-5,"_39":-5,"_40":-5},"ptehxl6dsy17v2g723ucquvs","Gesetzesentwurf zur grenzüberschreitenden Sicherung und Herausgabe elektronischer Beweismittel in Strafverfahren innerhalb der EU","EinschaetzungAutomatisierung","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",{"_9":42,"_11":43,"_44":45,"_46":47,"_48":49,"_50":-5,"_16":-5,"_51":52,"_53":54},"a9ahymocw7c5krpdpd29tp6h","Grenzüberschreitender Ablauf","Beschreibung",[61,62,63],"Visualisierungsart","Flussdiagramm","Visualisierungstool","Miro","Aufwand","Bild",{"_9":55,"_56":57,"_58":-5,"_59":60},"Beispielvorhaben",{"_18":19,"_20":-5,"_15":-5,"_11":12,"_16":17},"mgra0jbvuddj7agq010y1v5y","url","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Herausgabe_E_Evidence_290d25817e.png","previewUrl","alternativeText","Flussdiagramm, das den Ablauf für die Herausgabe von elektronischen Beweismitteln (E-Evidence) aus dem EU-Ausland an Deutschland visualisiert. Es zeigt die Schritte und Zuständigkeiten zwischen EU-Behörden, der deutschen Justiz und den betroffenen Dienstanbietern.",{"_64":89,"_68":90},{"_64":65,"_66":67,"_68":76},{"_64":65,"_66":67,"_68":69},"type","list","format","unordered","children",[70],{"_64":71,"_68":72},"list-item",[73],{"_74":75,"_64":74},"text","Verdeutlicht die notwendigen Interaktionen zwischen Justizbehörden und privaten Dienstanbietern im grenzüberschreitenden Kontext.",[77,78,79],{"_64":71,"_68":86},{"_64":71,"_68":83},{"_64":71,"_68":80},[81],{"_74":82,"_64":74},"Differenziert zu Beginn klar zwischen den unterschiedlichen Datenkategorien für den weiteren Verfahrensweg.",[84],{"_74":85,"_64":74},"Macht den gesamten logischen und zeitlichen Ablauf von der Anordnung bis zur Vollstreckung nachvollziehbar.",[87],{"_74":88,"_64":74},"Grenzt die Rollen der verschiedenen nationalen und europäischen Akteure durch „Schwimmbahnen“ eindeutig voneinander ab.","paragraph",[91],{"_74":92,"_64":74,"_93":94},"Ablauf zur grenzüberschreitenden Herausgabe von e-Evidence innerhalb der EU","italic",true,[96,97,98,99,100],{"_9":205,"_102":206,"_104":207,"_44":208,"_18":209,"_108":210,"_110":206},{"_9":188,"_102":189,"_104":190,"_44":191,"_18":192,"_108":193,"_110":189},{"_9":171,"_102":172,"_104":173,"_44":174,"_18":175,"_108":176,"_110":103},{"_9":132,"_102":111,"_104":133,"_44":134,"_18":135,"_108":136,"_110":137},{"_9":101,"_102":103,"_104":105,"_44":106,"_18":107,"_108":109,"_110":111},"bnx9lmblnceu1m3uy3rziy0i","Nummer",3,"Name","Datenschutz und Informationssicherheit schaffen Vertrauen",[112,113,114],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Kurzbezeichnung","Informationssicherheit und Datenschutz","order",5,{"_64":89,"_68":121},{"_64":89,"_68":118},{"_64":89,"_68":115},[116],{"_74":117,"_64":74},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[119],{"_74":120,"_64":74},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[122,123,124],{"_74":131,"_64":74},{"_56":126,"_64":127,"_68":128},{"_74":125,"_64":74}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de","link",[129],{"_74":130,"_64":74},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ","got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[138,139],"automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_64":89,"_68":154},{"_64":89,"_68":140},[141,142,143,144,145],{"_74":153,"_64":74},{"_74":152,"_64":74,"_93":94},{"_74":151,"_64":74},{"_56":147,"_64":127,"_68":148},{"_74":146,"_64":74},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[149],{"_74":150,"_64":74},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[155,156,157,158,159],{"_74":170,"_64":74},{"_56":166,"_64":127,"_68":167},{"_74":165,"_64":74},{"_56":161,"_64":127,"_68":162},{"_74":160,"_64":74}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[163],{"_74":164,"_64":74},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[168],{"_74":169,"_64":74},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ","habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[177],"etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",{"_64":89,"_68":178},[179,180,181],{"_74":187,"_64":74},{"_56":183,"_64":127,"_68":184},{"_74":182,"_64":74}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[185],{"_74":186,"_64":74},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ","s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[194],"datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_64":89,"_68":195},[196,197,198],{"_74":204,"_64":74},{"_56":200,"_64":127,"_68":201},{"_74":199,"_64":74}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[202],{"_74":203,"_64":74},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ","r57rc9d82ulv2bsc3gdbnj73",1,"Digitale Angebote für alle nutzbar gestalten",[211,212,213],"digitale-angebote-fuer-alle-nutzbar-gestalten","Digitale Angebote",{"_64":89,"_68":230},{"_64":89,"_68":227},{"_64":65,"_66":67,"_68":214},[215,216,217],{"_64":71,"_68":224},{"_64":71,"_68":221},{"_64":71,"_68":218},[219],{"_74":220,"_64":74},"wie Barrierefreiheit zu bedenken ist.",[222],{"_74":223,"_64":74},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[225],{"_74":226,"_64":74},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[228],{"_74":229,"_64":74},"Erfahren Sie in diesem Abschnitt,",[231],{"_74":232,"_64":74},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_234":235,"_236":237,"_238":237,"_239":240,"_241":242},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_243":94,"_244":94,"_245":94,"_246":94,"_247":94,"_248":94},"posthogKey","","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
