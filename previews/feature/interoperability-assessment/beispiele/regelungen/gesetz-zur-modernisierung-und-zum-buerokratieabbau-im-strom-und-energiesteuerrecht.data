[{"_1":2,"_3":4,"_5":6},"root",{"_7":562},"routes/beispiele",{"_7":447},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":14,"_15":-5,"_16":17,"_18":19,"_20":21,"_22":23,"_24":25,"_26":-5,"_27":28,"_29":30,"_31":32},"documentId","wqgbf29zc0oln0ew2qe0axh0","Titel","Gesetz zur Modernisierung und zum Bürokratieabbau im Strom- und Energiesteuerrecht","NKRNummer",7115,"Rechtsgebiet","Ressort","BMF","URLBezeichnung","gesetz-zur-modernisierung-und-zum-buerokratieabbau-im-strom-und-energiesteuerrecht","VeroeffentlichungsDatum","2024-04-12","LinkRegelungstext","https://dip.bundestag.de/vorgang/gesetz-zur-modernisierung-und-zum-b%C3%BCrokratieabbau-im-strom-und-energiesteuerrecht/312306","NKRStellungnahmeLink","https://www.normenkontrollrat.bund.de/Webs/NKR/SharedDocs/Stellungnahmen/DE/2024/nkr-nr-7115.html","GesetzStatus","Paragraphen",[188,189,190,191,192],"Visualisierungen",[83,84],"Digitalchecks",[33],{"_9":34,"_11":35,"_36":37,"_38":39,"_40":37,"_41":37,"_42":37,"_43":44},"pih3pkerjejrntdzoidu7uld","DC1 - Gesetz zur Modernisierung und zum Bürokratieabbau im Strom- und Energiesteuerrecht - Stromsteuerrecht","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","Nicht_Relevant","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",[45,46,47],{"_48":76,"_52":80},{"_48":76,"_52":77},{"_48":49,"_50":51,"_52":53},"type","list","format","unordered","children",[54,55,56,57,58],{"_48":59,"_52":73},{"_48":59,"_52":70},{"_48":59,"_52":67},{"_48":59,"_52":64},{"_48":59,"_52":60},"list-item",[61],{"_62":63,"_48":62},"text","Durch die Einführung einer Online-Antragspflicht sowie von Vorhalte- statt Vorlagepflichten werden Voraussetzungen für eine Automatisierung ermöglicht.",[65],{"_62":66,"_48":62},"Klare Regelungen für eine digitale Ausführung ergeben sich aus den hinzukommenden Begriffsbestimmungen im Stromsteuergesetz sowie der Klarstellung bei der Steuerentlastung für Unternehmen im Energiesteuergesetz.",[68],{"_62":69,"_48":62},"Die Regelung schafft nach Angaben des Ressorts die Voraussetzungen für eine Wiederverwendung von Daten und Standards, indem Vorhalte- statt Vorlagepflichten eingeführt werden.",[71],{"_62":72,"_48":62},"Die Regelung schafft laut Ressort die Voraussetzungen für eine digitale Kommunikation, da die Online-Beantragung bereits im Status Quo möglich ist. Zudem wird durch die Novelle die Onlineverpflichtung für die Steuerentlastung auf 2025 vorgezogen.",[74],{"_62":75,"_48":62},"Betroffene und der Vollzug wurden nach Angaben des Ressorts einbezogen, indem die Generalzolldirektion und die Hauptzollämter unter Mitarbeit der DigitalService GmbH des Bundes beteiligt wurden.","paragraph",[78],{"_62":79,"_48":62},"Zum Strompreispaket: ",[81],{"_62":82,"_48":62},"Das Ressort hat die Möglichkeiten zum digitalen Vollzug der Neuregelung geprüft und hierzu insgesamt zwei erweiterte Digitalchecks mit nachvollziehbaren Ergebnissen durchgeführt. Diese behandeln aufgrund der abgrenzbaren Regelungsbereiche die Umsetzung des Strompreispakets sowie die Vereinfachungen im Bereich E-Mobilität getrennt voneinander. Zudem wurden mehrere Visualisierungen der geplanten Vollzugsprozesse vorgelegt, was der NKR begrüßt. Zur Veröffentlichung freigegeben wurden vom Ressort die Prozessdarstellung (Rulemap) der Steuerentlastung für Unternehmen im Stromsteuergesetz sowie ein dazugehöriges Flussdiagramm. ",{"_9":140,"_11":141,"_87":142,"_89":143,"_91":92,"_93":-5,"_16":-5,"_94":144,"_96":145},{"_9":85,"_11":86,"_87":88,"_89":90,"_91":92,"_93":-5,"_16":-5,"_94":95,"_96":97},"e5g1grgvgteh9idbowd7vqcc","Abstrahierter Antragsprozess","Beschreibung",[104,105],"Visualisierungsart","Flussdiagramm","Visualisierungstool","Miro","Aufwand","Bild",{"_9":98,"_99":100,"_101":-5,"_102":103},"Beispielvorhaben",{"_18":19,"_20":21,"_15":-5,"_11":12,"_16":17},"j2l8q6b7wrxp53joe00s1bam","url","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Flussdiagramm_fuer_9b_Antrag_auf_Entlastung_46fef47656.jpg","previewUrl","alternativeText","Ein reduzierter, prozessualer Ablauf des Antrags auf Entlastung von der Stromsteuer",{"_48":76,"_52":137},{"_48":49,"_50":51,"_52":106},[107,108,109,110],{"_48":59,"_52":132},{"_48":59,"_52":125},{"_48":59,"_52":118},{"_48":59,"_52":111},[112,113],{"_115":116,"_62":117,"_48":62},{"_62":114,"_48":62},", um komplexe Abläufe verständlich zu machen und Gestaltungsspielraum aufzuzeigen.","bold",true,"Markiert optionale Schritte und Risiken",[119,120,121],{"_62":124,"_48":62},{"_115":116,"_62":123,"_48":62},{"_62":122,"_48":62}," Digitalisierungspotenziale sichtbar.","Kennzeichnung automatisierter Prüfungen","Macht durch die ",[126,127,128],{"_62":131,"_48":62},{"_115":116,"_62":130,"_48":62},{"_62":129,"_48":62},".","klare visuelle Abgrenzung","Zeigt die Aufteilung der Verantwortlichkeiten zwischen Unternehmen und Behörden durch ",[133,134],{"_115":116,"_62":136,"_48":62},{"_62":135,"_48":62},", um bei verschiedenen Akteurinnen und Akteuren ein gemeinsames Verständnis zu schaffen. ","Abstrahiert den Antragsprozess und stellt ihn strukturiert dar",[138],{"_62":139,"_48":62},"Vereinfachter Zielprozess Antragstellung nach §9b StromStG","m56ezco1mlzcci3sa6n53rzj","Gesamtprozess über Gesetz und Verordnungen",[149,150],"Entscheidungsbaum",{"_9":146,"_99":147,"_101":-5,"_102":148},{"_18":19,"_20":21,"_15":-5,"_11":12,"_16":17},"iviqs5nqir0dch8aiy4c4p80","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Rulemap_fuer_9b_regelt_Antragsstellung_0d5d381327.jpg","Eine große, komplexe Übersicht der Entscheidungen und Logiken im §9b",{"_48":76,"_52":185},{"_48":49,"_50":51,"_52":151},[152,153,154,155,156],{"_48":59,"_52":178},{"_48":59,"_52":173},{"_48":59,"_52":168},{"_48":59,"_52":162},{"_48":59,"_52":157},[158,159],{"_115":116,"_62":161,"_48":62},{"_62":160,"_48":62}," und dient damit als Orientierung für beteiligte Akteurinnen und Akteure.","Verbindet rechtliche Voraussetzungen mit Umsetzungsschritten",[163,164,165],{"_62":167,"_48":62},{"_115":116,"_62":166,"_48":62},{"_62":129,"_48":62},"Unterscheidung automatisierter und manueller Schritte","Verdeutlicht Digitalisierungspotenziale durch die ",[169,170],{"_115":116,"_62":172,"_48":62},{"_62":171,"_48":62},"um eine schnelle Orientierung zu gewährleisten.","Hebt den Ursprung der Voraussetzungen farblich hervor ",[174,175],{"_115":116,"_62":177,"_48":62},{"_62":176,"_48":62}," und ermöglicht damit das Erfassen des Gesamtprozesses.","Führt Gesetz und Verordnung zusammen",[179,180,181],{"_62":184,"_48":62},{"_115":116,"_62":183,"_48":62},{"_62":182,"_48":62}," werden.","Voraussetzungen eindeutig und strukturiert dargestellt","Macht rechtliche Logik nachvollziehbar und leichter überprüfbar, indem ",[186],{"_62":187,"_48":62},"Voraussetzungen für Entlastung nach §9b StromStG",{"_9":399,"_194":400,"_11":-5,"_196":197,"_198":401,"_199":402},{"_9":341,"_194":342,"_11":-5,"_196":343,"_198":-5,"_199":344},{"_9":297,"_194":298,"_11":-5,"_196":299,"_198":-5,"_199":300},{"_9":261,"_194":262,"_11":-5,"_196":263,"_198":-5,"_199":264},{"_9":193,"_194":195,"_11":-5,"_196":197,"_198":-5,"_199":200},"msy952dhk56gaqk1m63y0k22","Nummer","23c","Gesetz","Änderung der Stromsteuer-Durchführungsverordnung ","Artikel","Absaetze",[201],{"_9":202,"_203":204,"_194":205,"_206":207},"y66pps9ooeuh709d3ygqf9ag","Text",[240,241,242],1,"PrinzipErfuellungen",[208],{"_209":210,"_211":212,"_213":214},"id","1395","Erklaerung",[236],"Prinzip",{"_9":215,"_194":216,"_217":218,"_87":219,"_18":220,"_221":222,"_223":216},"s18bibg9sdf0jt8up7h8btup",2,"Name","Datenwiederverwendung benötigt einheitliches Recht",[224],"datenwiederverwendung-benoetigt-einheitliches-recht","Kurzbezeichnung","Datenwiederverwendung","order",{"_48":76,"_52":225},[226,227,228],{"_62":235,"_48":62},{"_99":230,"_48":231,"_52":232},{"_62":229,"_48":62}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[233],{"_62":234,"_48":62},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_48":76,"_52":237},[238],{"_62":239,"_48":62},"Die Wieder-/Weiterverwendung wird durch Einführung der Vorhalte- statt Vorlagepflichten verbessert, da auf bestehende Datenquellen wie das Marktstammdatenregister zurückgegriffen wird. Dies reduziert Doppelangaben, vereinfacht Verfahren und stärkt das Once-Only-Prinzip.",{"_48":76,"_52":258},{"_48":76,"_52":255},{"_48":76,"_52":243},[244,245,246,247,248],{"_62":254,"_48":62},{"_62":253,"_48":62,"_251":116},{"_62":252,"_48":62},{"_62":250,"_48":62,"_251":116},{"_62":249,"_48":62},"“ ","das Unternehmen einem Abschnitt oder einer Klasse der Klassifikation der Wirtschaftszweige zuzuordnen.[2]","underline"," vorzulegen. Die Beschreibung muss es dem Hauptzollamt ermöglichen, ","nach amtlich vorgeschriebenem Vordruck[2]","„(3) Der Antragsteller hat auf Verlangen des Hauptzollamtes eine Beschreibung seiner wirtschaftlichen Tätigkeiten im maßgebenden Zeitraum ",[256],{"_62":257,"_48":62},"Absatz 3 wird wie folgt gefasst: ",[259],{"_62":260,"_48":62},"§ 17b [StromStV-E] wird wie folgt geändert:","rqocb32ni2uljc9yjz5acddd","11","Änderung des Energiesteuergesetzes",[265],{"_9":266,"_203":267,"_194":205,"_206":268},"o2z4jj4w81i3ncs68p1ms3bd",[285,286],[269],{"_209":270,"_211":271,"_213":272},"1319",[281],{"_9":215,"_194":216,"_217":218,"_87":273,"_18":220,"_221":222,"_223":216},[274],{"_48":76,"_52":275},[276,277,278],{"_62":235,"_48":62},{"_99":230,"_48":231,"_52":279},{"_62":229,"_48":62},[280],{"_62":234,"_48":62},{"_48":76,"_52":282},[283],{"_62":284,"_48":62},"Schafft die generellen rechtlichen Voraussetzungen zum Datenaustausch.",{"_48":76,"_52":294},{"_48":76,"_52":287},[288,289,290],{"_62":293,"_48":62},{"_62":292,"_48":62,"_251":116},{"_62":291,"_48":62},", soweit die Bundesnetzagentur die Informationen zur Erfüllung ihrer gesetzlichen Aufgaben aus dem Energiewirtschaftsgesetz oder aus einer auf Grund dieser Gesetzes ergangenen Rechtsverordnung benötigt. Gleiches gilt für Informationen, einschließlich personenbezogener Daten sowie Betriebs- und Geschäftsgeheimnisse, die der Bundesnetzagentur vorliegen und die die Generalzolldirektion und die Hauptzollämter zur Erfüllung ihrer gesetzlichen Aufgaben aus der Abgabenordnung, dem Energiesteuergesetz und der Energiesteuer-Durchführungsverordnung benötigen.“ ","Soweit Energieerzeugnisse betroffen sind, auf welche dieses Kapitel des Gesetzes anwendbar ist, können Informationen, einschließlich personenbezogener Daten sowie Betriebs- und Geschäftsgeheimnisse, die in einem Steuerverfahren bekannt geworden sind, zwischen der Generalzolldirektion, den Hauptzollämtern und der Bundesnetzagentur ausgetauscht werden[2]","„",[295],{"_62":296,"_48":62},"Nach § 44 wird folgender § 44a eingefügt: ","lylvnv6km9tv8wlk24875t7j","9","Änderung des Stromsteuergesetzes",[301],{"_9":302,"_203":303,"_194":205,"_206":304},"dikvp0wx85stxikefmi1u8j0",[305,306,307,308,309,310,311,312,313],[],{"_48":76,"_52":338},{"_48":76,"_52":335},{"_48":76,"_52":332},{"_48":76,"_52":329},{"_48":76,"_52":326},{"_48":76,"_52":323},{"_48":76,"_52":320},{"_48":76,"_52":317},{"_48":76,"_52":314},[315],{"_62":316,"_48":62},"Die Übertragungsnetzbetreiber, die Bundesnetzagentur, das Umweltbundesamt sowie das Bundesamt für Wirtschaft und Ausfuhrkontrolle dürfen Informationen, einschließlich personenbezogener Daten sowie Betriebs- und Geschäftsgeheimnisse, die ihnen vorliegen an die Generalzolldirektion und die Hauptzollämter übermitteln, soweit dies zur Durchführung eines Steuerverfahrens nach der Abgabenordnung, dem Stromsteuergesetz und der Stromsteuer-Durchführungsverordnung erforderlich ist.“",[318],{"_62":319,"_48":62},"4. an das Bundesamt für Wirtschaft und Ausfuhrkontrolle für seine gesetzlichen Aufgaben im Zusammenhang mit der Begrenzung der Umlagen nach Teil 4 Abschnitt 4 des Energiefinanzierungsgesetzes sowie nach dem Kraft-Wärme-Kopplungsgesetz oder einer auf Grund dieses Gesetzes ergangenen Rechtsverordnung. ",[321],{"_62":322,"_48":62},"3. an das Umweltbundesamt für seine gesetzlichen Aufgaben im Zusammenhang mit der Stromkennzeichnung nach dem Energiewirtschaftsgesetz oder ",[324],{"_62":325,"_48":62},"2. an die Bundesnetzagentur für ihre gesetzlichen Aufgaben nach dem Energiewirtschaftsgesetz, dem Erneuerbare-Energien-Gesetz, dem Energiefinanzierungsgesetz, dem Kraft-Wärme-Kopplungsgesetz oder einer auf Grund dieser Gesetze ergangenen Rechtsverordnungen, ",[327],{"_62":328,"_48":62},"1. an die Übertragungsnetzbetreiber soweit sie öffentliche Aufgaben für den Betrieb und die Systemverantwortung der Energieversorgungsnetze nach dem Energiewirtschaftsgesetz, zur Erhebung der nach Teil 4 Abschnitt 4 des Energiefinanzierungsgesetzes begrenzten Umlagen, im Rahmen der Vermarktungspflichten nach dem Erneuerbare-Energien-Gesetz sowie auf Grund dieser Gesetze ergangenen Rechtsverordnungen wahrnehmen, ",[330],{"_62":331,"_48":62},"Die Generalzolldirektion sowie die Hauptzollämter dürfen Informationen, einschließlich personenbezogener Daten sowie Betriebs- und Geschäftsgeheimnisse, die ihnen in einem Steuerverfahren bekannt geworden sind, an folgende Stellen übermitteln, soweit dies für die Erfüllung der jeweiligen gesetzlichen Aufgaben erforderlich ist: ",[333],{"_62":334,"_48":62},"Datenübermittlung ",[336],{"_62":337,"_48":62},"„§ 10a ",[339],{"_62":340,"_48":62},"§ 10a wird wie folgt gefasst: ","c8d22cw81lfnxg77r8h8aa18","31a)bb)","Änderung der Energiesteuer-Durchführungsverordnung ",[345],{"_9":346,"_203":347,"_194":205,"_206":348},"is6yuequ2r2663cfpvt46h1l",[384,385,386],[349],{"_209":350,"_211":351,"_213":352},"1383",[380],{"_9":353,"_194":205,"_217":354,"_87":355,"_18":356,"_221":357,"_223":205},"r57rc9d82ulv2bsc3gdbnj73","Digitale Angebote für alle nutzbar gestalten",[358,359,360],"digitale-angebote-fuer-alle-nutzbar-gestalten","Digitale Angebote",{"_48":76,"_52":377},{"_48":76,"_52":374},{"_48":49,"_50":51,"_52":361},[362,363,364],{"_48":59,"_52":371},{"_48":59,"_52":368},{"_48":59,"_52":365},[366],{"_62":367,"_48":62},"wie Barrierefreiheit zu bedenken ist.",[369],{"_62":370,"_48":62},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[372],{"_62":373,"_48":62},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[375],{"_62":376,"_48":62},"Erfahren Sie in diesem Abschnitt,",[378],{"_62":379,"_48":62},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_48":76,"_52":381},[382],{"_62":383,"_48":62},"Die Digitalisierung der Datenübermittlung wird auf 2025 vorgezogen.",{"_48":76,"_52":396},{"_48":76,"_52":393},{"_48":76,"_52":387},[388,389,390],{"_62":392,"_48":62},{"_62":391,"_48":62,"_251":116},{"_62":249,"_48":62},"ist der Antrag ab dem 1. Januar 2025 nach amtlich vorgeschriebenen Datensatz durch Datenfernübertragung an das zuständige Hauptzollamt zu übermitteln (elektronische Datenübermittlung).[1]","„Abweichend von § 3 Absatz 4 der Verbrauch-und-LuftverkehrsteuerdatenÜbermittlungs-Verordnung vom 14. August 2020 (BGBl. I S. 1960, 1961), die durch Artikel 11 des Gesetzes vom 24. Oktober 2022 (BGBl. I S. 1838) geändert worden ist, ",[394],{"_62":395,"_48":62},"Folgender Satz wird angefügt: ",[397],{"_62":398,"_48":62},"§ 100 [EnergieStV-E)] wird wie folgt geändert: ","s1unmfoz6swapccr4ut6uj20","23a)bb)","Artikel 3",[403],{"_9":404,"_203":405,"_194":205,"_206":406},"qqkfznwzcg4y37jpi94swhfs",[433,434,435],[407],{"_209":408,"_211":409,"_213":410},"1387",[429],{"_9":353,"_194":205,"_217":354,"_87":411,"_18":356,"_221":357,"_223":205},[412,413,414],{"_48":76,"_52":427},{"_48":76,"_52":425},{"_48":49,"_50":51,"_52":415},[416,417,418],{"_48":59,"_52":423},{"_48":59,"_52":421},{"_48":59,"_52":419},[420],{"_62":367,"_48":62},[422],{"_62":370,"_48":62},[424],{"_62":373,"_48":62},[426],{"_62":376,"_48":62},[428],{"_62":379,"_48":62},{"_48":76,"_52":430},[431],{"_62":432,"_48":62},"Die Digitalisierung der Datenübertragung wird auf 2025 vorgezogen.",{"_48":76,"_52":444},{"_48":76,"_52":441},{"_48":76,"_52":436},[437,438],{"_62":440,"_48":62},{"_62":439,"_48":62,"_251":116},"ist der Antrag ab dem 1. Januar 2025 nach amtlich vorgeschriebenem Datensatz durch Datenfernübertragung an das zuständige Hauptzollamt zu übermitteln (elektronische Datenübermittlung).[1]","Abweichend von § 3 Absatz 4 der Verbrauch-und-Luftverkehrsteuerdaten-Übermittlungs-Verordnung vom 14. August 2020 (BGBl. I S. 1960, 1961), die durch Artikel 11 des Gesetzes vom 24. Oktober 2022 (BGBl. I S. 1838) geändert worden ist, ",[442],{"_62":443,"_48":62},"Nach Satz 3 wird folgender Satz angefügt: ",[445],{"_62":446,"_48":62},"§ 17b [StromStV] wird wie folgt geändert: ",[448,449,450,451,452],{"_9":353,"_194":205,"_217":354,"_87":544,"_18":356,"_221":357,"_223":205},{"_9":215,"_194":216,"_217":218,"_87":536,"_18":220,"_221":222,"_223":216},{"_9":519,"_194":520,"_217":521,"_87":522,"_18":523,"_221":524,"_223":454},{"_9":479,"_194":459,"_217":480,"_87":481,"_18":482,"_221":483,"_223":484},{"_9":453,"_194":454,"_217":455,"_87":456,"_18":457,"_221":458,"_223":459},"bnx9lmblnceu1m3uy3rziy0i",3,"Datenschutz und Informationssicherheit schaffen Vertrauen",[460,461,462],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz",5,{"_48":76,"_52":469},{"_48":76,"_52":466},{"_48":76,"_52":463},[464],{"_62":465,"_48":62},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[467],{"_62":468,"_48":62},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[470,471,472],{"_62":478,"_48":62},{"_99":474,"_48":231,"_52":475},{"_62":473,"_48":62}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[476],{"_62":477,"_48":62},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ","got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[485,486],"automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_48":76,"_52":502},{"_48":76,"_52":487},[488,489,490,491,492],{"_62":501,"_48":62},{"_62":499,"_48":62,"_500":116},{"_62":498,"_48":62},{"_99":494,"_48":231,"_52":495},{"_62":493,"_48":62},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[496],{"_62":497,"_48":62},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[503,504,505,506,507],{"_62":518,"_48":62},{"_99":514,"_48":231,"_52":515},{"_62":513,"_48":62},{"_99":509,"_48":231,"_52":510},{"_62":508,"_48":62}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[511],{"_62":512,"_48":62},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[516],{"_62":517,"_48":62},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ","habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[525],"etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",{"_48":76,"_52":526},[527,528,529],{"_62":535,"_48":62},{"_99":531,"_48":231,"_52":532},{"_62":530,"_48":62}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[533],{"_62":534,"_48":62},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",[537],{"_48":76,"_52":538},[539,540,541],{"_62":235,"_48":62},{"_99":230,"_48":231,"_52":542},{"_62":229,"_48":62},[543],{"_62":234,"_48":62},[545,546,547],{"_48":76,"_52":560},{"_48":76,"_52":558},{"_48":49,"_50":51,"_52":548},[549,550,551],{"_48":59,"_52":556},{"_48":59,"_52":554},{"_48":59,"_52":552},[553],{"_62":367,"_48":62},[555],{"_62":370,"_48":62},[557],{"_62":373,"_48":62},[559],{"_62":376,"_48":62},[561],{"_62":379,"_48":62},{"_563":564,"_565":566,"_567":566,"_568":569,"_570":571},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_572":116,"_573":116,"_574":116,"_57