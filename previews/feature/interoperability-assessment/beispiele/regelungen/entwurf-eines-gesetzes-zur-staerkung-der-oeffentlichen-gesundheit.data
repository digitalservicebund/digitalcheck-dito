[{"_1":2,"_3":4,"_5":6},"root",{"_7":362},"routes/beispiele",{"_7":259},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":14,"_15":-5,"_16":17,"_18":19,"_20":21,"_22":23,"_24":25,"_26":27,"_28":29,"_30":31,"_32":33},"documentId","zxsi0nin10qonxffc5ht0wy9","Titel","Entwurf eines Gesetzes zur Stärkung der Öffentlichen Gesundheit – BIPAM-ErrichtungsG","NKRNummer",7202,"Rechtsgebiet","Ressort","BMG","URLBezeichnung","entwurf-eines-gesetzes-zur-staerkung-der-oeffentlichen-gesundheit","VeroeffentlichungsDatum","2024-07-17","LinkRegelungstext","https://www.bundesgesundheitsministerium.de/service/gesetze-und-verordnungen/detail/gesetz-zur-staerkung-der-oeffentlichen-gesundheit","NKRStellungnahmeLink","https://www.normenkontrollrat.bund.de/Webs/NKR/SharedDocs/Stellungnahmen/DE/2024/nkr-nr-7202.html","GesetzStatus","Regelungsentwurf","Paragraphen",[62],"Visualisierungen",[],"Digitalchecks",[34],{"_9":35,"_11":36,"_37":38,"_39":40,"_41":38,"_42":40,"_43":40,"_44":45},"dzuhoz9isss8kzvk7nq5qcgo","Entwurf eines Gesetzes zur Stärkung der Öffentlichen Gesundheit","EinschaetzungAutomatisierung","Nicht_Relevant","EinschaetzungDatenschutz","Ja","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",[46,47,48],{"_49":50,"_51":59},{"_49":50,"_51":56},{"_49":50,"_51":52},"type","paragraph","children",[53],{"_54":55,"_49":54},"text","Hinsichtlich der Schaffung von Voraussetzungen für digitale Kommunikation wird weiterhin erklärt, dass dies durch Regelungen zum Zugang für Bürgerinnen und Bürger zu gut verständlichen und adressatengerecht gestalteten Gesundheitsinformationen erfüllt wurde. Hinsichtlich der Wiederverwendung von Daten und Standards stellt das Ressort dar, dass die Anforderungen nach §12a E-Government-Gesetz und dem Datennutzungsgesetz adressiert werden.",[57],{"_54":58,"_49":54},"Die Erkenntnisse daraus spiegeln sich nach Darstellung des Ressorts vor allem in der Organisationsstruktur, der Darstellung der Aufgabengebiete und den Regelungen zu Datenverarbeitungsfragen wider.",[60],{"_54":61,"_49":54},"Das Ressort hat Möglichkeiten zum digitalen Vollzug der Neuregelung (Digitaltauglichkeit) geprüft und hierzu einen Digitalcheck mit nachvollziehbarem Ergebnis durchgeführt. Das Ressort stellt dar, dass die Bedürfnisse der Betroffenen berücksichtigt worden sind, indem u. a. Verbände bereits vor der gesetzlichen Verbändebeteiligung sowie Expertengremien einbezogen wurden. Zudem wurde eine „Task Force“ mit dem betroffenen RKI und der BZgA eingerichtet.",{"_9":63,"_64":65,"_11":66,"_67":68,"_69":70,"_71":72},"g4h3dgsp9r8u4kiyjgpmqxxl","Nummer","2","Aufgaben des Bundesinstituts","Gesetz","BIPAM–ErrichtungsG","Artikel","1","Absaetze",[73,74,75],{"_9":252,"_77":253,"_64":100,"_80":254},{"_9":86,"_77":87,"_64":88,"_80":89},{"_9":76,"_77":78,"_64":79,"_80":81},"iz0dn69esvlecmyh7x0zogob","Text",[82],3,"PrinzipErfuellungen",[],{"_49":50,"_51":83},[84],{"_54":85,"_49":54},"Das Bundesinstitut erledigt, soweit keine andere Zuständigkeit gesetzlich festgelegt ist, in seinem Zuständigkeitsbereich weitere Aufgaben des Bundes, die mit den in den Absätzen 1 und 2 genannten Gebieten zusammenhängen und mit deren Durchführung es vom Bundesministerium für Gesundheit oder mit dessen Zustimmung von der sachlich zuständigen obersten Bundesbehörde beauftragt wird.","cf3uooinyhchvdcj0sy6e55e",[208,209,210],2,[90,91,92],{"_93":170,"_95":171,"_97":172},{"_93":139,"_95":140,"_97":141},{"_93":94,"_95":96,"_97":98},"id","1307","Erklaerung",[135],"Prinzip",{"_9":99,"_64":100,"_101":102,"_103":104,"_18":105,"_106":107,"_108":100},"r57rc9d82ulv2bsc3gdbnj73",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[109,110,111],"digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_49":50,"_51":132},{"_49":50,"_51":129},{"_49":112,"_113":114,"_51":115},"list","format","unordered",[116,117,118],{"_49":119,"_51":126},{"_49":119,"_51":123},{"_49":119,"_51":120},"list-item",[121],{"_54":122,"_49":54},"wie Barrierefreiheit zu bedenken ist.",[124],{"_54":125,"_49":54},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[127],{"_54":128,"_49":54},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[130],{"_54":131,"_49":54},"Erfahren Sie in diesem Abschnitt,",[133],{"_54":134,"_49":54},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_49":50,"_51":136},[137],{"_54":138,"_49":54},"Stellt sicher, dass Informationen effizient und barrierefrei zugänglich sind, indem es eine bedarfsorientierte und inklusive digitale Kommunikation vorschreibt.","1306",[160],{"_9":142,"_64":88,"_101":143,"_103":144,"_18":145,"_106":146,"_108":88},"s18bibg9sdf0jt8up7h8btup","Datenwiederverwendung benötigt einheitliches Recht",[147],"datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_49":50,"_51":148},[149,150,151],{"_54":159,"_49":54},{"_153":154,"_49":155,"_51":156},{"_54":152,"_49":54}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[157],{"_54":158,"_49":54},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_49":112,"_113":114,"_51":161},[162,163],{"_49":119,"_51":167},{"_49":119,"_51":164},[165],{"_54":166,"_49":54},"Ermöglicht den effizienten Austausch vorhandener Daten durch die Vernetzung und Kooperation mit Akteuren der Öffentlichen Gesundheit. Vermeidet Doppelarbeit und schont Ressourcen.",[168],{"_54":169,"_49":54},"Fördert die Wiederverwendung von Daten durch standardisierte Gesundheitsberichterstattung und einheitliches Monitoring. ","1305",[198],{"_9":173,"_64":79,"_101":174,"_103":175,"_18":176,"_106":177,"_108":178},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[179,180,181],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz",5,{"_49":50,"_51":188},{"_49":50,"_51":185},{"_49":50,"_51":182},[183],{"_54":184,"_49":54},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[186],{"_54":187,"_49":54},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[189,190,191],{"_54":197,"_49":54},{"_153":193,"_49":155,"_51":194},{"_54":192,"_49":54}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[195],{"_54":196,"_49":54},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_49":112,"_113":114,"_51":199},[200,201],{"_49":119,"_51":205},{"_49":119,"_51":202},[203],{"_54":204,"_49":54},"Konkretisiert die Art der personenbezogenen Daten (Gesundheitsdaten) und verweist darüber hinaus auf die dafür geltenden fachrechtlichen Bestimmungen.",[206],{"_54":207,"_49":54},"Nennt explizit die Verarbeitung personenbezogener Daten als Spezifizierung der Aufgaben von Absatz 1.",{"_49":50,"_51":245},{"_49":112,"_113":214,"_51":215},{"_49":50,"_51":211},[212],{"_54":213,"_49":54},"Besondere Vorschriften zur Bestimmung von Aufgaben bleiben hiervon unberührt, insbesondere die Aufgaben des Robert Koch-Instituts nach § 4 des Infektionsschutzgesetzes und nach § 2 Absatz 3 in Verbindung mit § 4 des BGA-Nachfolgegesetzes.","ordered",[216,217,218,219,220,221],{"_49":119,"_51":242},{"_49":119,"_51":239},{"_49":119,"_51":235},{"_49":119,"_51":228},{"_49":119,"_51":225},{"_49":119,"_51":222},[223],{"_54":224,"_49":54},"wissenschaftliche Forschung und Zusammenarbeit mit Institutionen auf nationaler, europäischer und internationaler Ebene, einschließlich der Unterstützung dieser Institutionen bei der Entwicklung von Leitlinien und Standards.",[226],{"_54":227,"_49":54},"Stärkung der Vorbeugung und Verhütung von Krankheiten sowie Stärkung der Gesundheitsförderung und der Gesundheitskompetenz in der Bevölkerung, jeweils im Rahmen der Zuständigkeit des Bundes,",[229,230],{"_54":232,"_49":54,"_233":234},{"_54":231,"_49":54},",","evidenzbasierte, zielgruppenspezifische, insbesondere auf vulnerable Bevölkerungsgruppen ausgerichtete Kommunikation im Zuständigkeitsbereich des Bundesministeriums für Gesundheit[1]","underline",true,[236,237],{"_54":238,"_49":54,"_233":234},{"_54":231,"_49":54},"Stärkung der Öffentlichen Gesundheit durch freiwillige Kooperation und Vernetzung mit Akteuren der Öffentlichen Gesundheit[2]",[240],{"_54":241,"_49":54,"_233":234},"Gesundheitsberichterstattung des Bundes, einschließlich Gesundheitsmonitoring[2],",[243],{"_54":244,"_49":54,"_233":234},"Beobachtung von gesundheitsrelevanten Faktoren und von gesundheitlichen Rahmenbedingungen[2],",[246,247,248],{"_54":251,"_49":54},{"_54":250,"_49":54,"_233":234},{"_54":249,"_49":54},", insbesondere auf folgenden Gebieten wahr:","einschließlich der damit verbundenen Verarbeitung personenbezogener Gesundheitsdaten im Umfang der jeweils einschlägigen fachrechtlichen Bestimmungen[3]","Das Bundesinstitut nimmt Aufgaben nach Absatz 1, ","im4exdj7qs5gmdi07im8n9uy",[255],[],{"_49":50,"_51":256},[257],{"_54":258,"_49":54},"Das Bundesinstitut nimmt Aufgaben des Bundes auf den Gebieten der Öffentlichen Gesundheit wahr, die ihm durch dieses Gesetz oder durch andere Bundesgesetze oder auf Grund dieser Gesetze zugewiesen werden. Die Aufgaben bestehender Einrichtungen des Bundes außerhalb des Geschäftsbereichs des Bundesministeriums für Gesundheit bleiben davon unberührt. Das Bundesinstitut übernimmt die Aufgaben der Bundeszentrale für gesundheitliche Aufklärung, einschließlich derer aus dem Geschäftsbereich des Bundesministeriums für Familie, Senioren, Frauen und Jugend.",[260,261,262,263,264],{"_9":99,"_64":100,"_101":102,"_103":344,"_18":105,"_106":107,"_108":100},{"_9":142,"_64":88,"_101":143,"_103":336,"_18":145,"_106":146,"_108":88},{"_9":319,"_64":320,"_101":321,"_103":322,"_18":323,"_106":324,"_108":79},{"_9":279,"_64":178,"_101":280,"_103":281,"_18":282,"_106":283,"_108":284},{"_9":173,"_64":79,"_101":174,"_103":265,"_18":176,"_106":177,"_108":178},[266,267,268],{"_49":50,"_51":273},{"_49":50,"_51":271},{"_49":50,"_51":269},[270],{"_54":184,"_49":54},[272],{"_54":187,"_49":54},[274,275,276],{"_54":197,"_49":54},{"_153":193,"_49":155,"_51":277},{"_54":192,"_49":54},[278],{"_54":196,"_49":54},"got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[285,286],"automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_49":50,"_51":302},{"_49":50,"_51":287},[288,289,290,291,292],{"_54":301,"_49":54},{"_54":299,"_49":54,"_300":234},{"_54":298,"_49":54},{"_153":294,"_49":155,"_51":295},{"_54":293,"_49":54},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[296],{"_54":297,"_49":54},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[303,304,305,306,307],{"_54":318,"_49":54},{"_153":314,"_49":155,"_51":315},{"_54":313,"_49":54},{"_153":309,"_49":155,"_51":310},{"_54":308,"_49":54}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[311],{"_54":312,"_49":54},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[316],{"_54":317,"_49":54},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ","habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[325],"etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",{"_49":50,"_51":326},[327,328,329],{"_54":335,"_49":54},{"_153":331,"_49":155,"_51":332},{"_54":330,"_49":54}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[333],{"_54":334,"_49":54},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",[337],{"_49":50,"_51":338},[339,340,341],{"_54":159,"_49":54},{"_153":154,"_49":155,"_51":342},{"_54":152,"_49":54},[343],{"_54":158,"_49":54},[345,346,347],{"_49":50,"_51":360},{"_49":50,"_51":358},{"_49":112,"_113":114,"_51":348},[349,350,351],{"_49":119,"_51":356},{"_49":119,"_51":354},{"_49":119,"_51":352},[353],{"_54":122,"_49":54},[355],{"_54":125,"_49":54},[357],{"_54":128,"_49":54},[359],{"_54":131,"_49":54},[361],{"_54":134,"_49":54},{"_363":364,"_365":366,"_367":366,"_368":369,"_370":371},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_372":234,"_373":234,"_374":234,"_375":234,"_376":234,"_377":234},"posthogKey","","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
