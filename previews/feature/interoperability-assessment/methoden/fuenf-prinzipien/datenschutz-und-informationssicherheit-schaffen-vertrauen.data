[{"_1":2,"_3":4},"root",{"_5":262},"routes/methoden.fuenf-prinzipien.$prinzip",{"_5":6},"data",{"_7":8,"_9":10},"prinzip",{"_34":35,"_16":17,"_36":37,"_20":21,"_38":27,"_18":19,"_39":40,"_41":42},"prinzipList",[11,12,13,14,15],{"_16":31,"_18":32,"_20":33},{"_16":28,"_18":29,"_20":30},{"_16":25,"_18":26,"_20":27},{"_16":22,"_18":23,"_20":24},{"_16":17,"_18":19,"_20":21},"Name","Datenschutz und Informationssicherheit schaffen Vertrauen","URLBezeichnung","datenschutz-und-informationssicherheit-schaffen-vertrauen","order",5,"Automatisierung basiert auf eindeutigen Regelungen","automatisierung-basiert-auf-eindeutigen-regelungen",4,"Etablierte Technologien ermöglichen effiziente Umsetzung","etablierte-technologien-ermoeglichen-effiziente-umsetzung",3,"Datenwiederverwendung benötigt einheitliches Recht","datenwiederverwendung-benoetigt-einheitliches-recht",2,"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",1,"documentId","bnx9lmblnceu1m3uy3rziy0i","Beschreibung",[243,244,245],"Nummer","Beispiel",{"_34":218,"_38":24,"_51":219,"_62":220,"_221":222},"Aspekte",[43,44],{"_38":133,"_46":134,"_48":135,"_36":136,"_51":137,"_53":138,"_55":-5,"_56":139,"_39":140},{"_38":45,"_46":47,"_48":49,"_36":50,"_51":52,"_53":54,"_55":-5,"_56":57,"_39":58},"5.2","Titel","Gewährleisten Sie die Informationssicherheit","Kurzbezeichnung","Informationssicherheit","Gewährleisten Sie die Informationssicherheit: Ergreifen Sie notwendige technische und organisatorische Maßnahmen, um die Vertraulichkeit, Integrität und Verfügbarkeit aller relevanten Informationen zu schützen.","Text",[122],"Leitfragen",[84],"Formulierungsbeispiel","Anwendung",[],{"_34":59,"_38":60,"_51":61,"_62":63},"wcxx3x3bzdzfsrkr0fxlr7bi",10,[72],"Paragraph",{"_38":64,"_65":66,"_46":67,"_68":69},"66a","Gesetz","LuftVG","Register über Betreiber von unbemannten Fluggeräten","Beispielvorhaben",{"_18":70,"_46":71},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","Register über Betreiber von unbemannten Fluggeräten – LuftVG",{"_73":74,"_75":76},"type","paragraph","children",[77,78],{"_79":83,"_73":79},{"_79":80,"_73":79,"_81":82},"text","Einvernehmen mit dem Bundesamt für Sicherheit in der Informationstechnik insbesondere unter Beachtung der Vorgaben der Artikel 24, 25 und 32 der Verordnung (EU) 2016/679 nähere Anforderungen an das Datenformat sowie die Anforderungen an die Sicherheit gegen unbefugte Zugriffe auf das Register und bei der Datenübertragung fest. Sie haben dem Stand der Technik zu entsprechen und sind vom Luftfahrt-Bundesamt im Einvernehmen mit dem Bundesamt für Sicherheit in der Informationstechnik fortlaufend anzupassen[3].","underline",true,"Das Luftfahrt-Bundesamt legt im ",{"_73":85,"_86":87,"_75":88},"list","format","unordered",[89,90,91,92],{"_73":93,"_75":119},{"_73":93,"_75":116},{"_73":93,"_75":113},{"_73":93,"_75":94},"list-item",[95,96,97,98,99],{"_79":112,"_73":79},{"_101":108,"_73":103,"_75":109},{"_79":107,"_73":79},{"_101":102,"_73":103,"_75":104},{"_79":100,"_73":79},"?","url","https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/IT-Grundschutz/Zertifizierte-Informationssicherheit/zertifizierte-informationssicherheit.html","link",[105],{"_79":106,"_73":79},"ISO 27001",", z. B. ","https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/standards-und-zertifizierung_node.html",[110],{"_79":111,"_73":79},"Nachweise oder Zertifizierungen","Gibt es passende, anerkannte ",[114],{"_79":115,"_73":79},"Wurden veraltete Informationssicherheitsbedürfnisse identifiziert und abgeschafft?",[117],{"_79":118,"_73":79},"Wurden Maßnahmen vorgeschrieben, um Betrugsversuche zu erschweren?",[120],{"_79":121,"_73":79},"Werden eine geeignete, sichere Datenhaltung und sichere Übertragungswege vorgeschrieben?",{"_73":74,"_75":123},[124,125,126],{"_79":132,"_73":79},{"_101":128,"_73":103,"_75":129},{"_79":127,"_73":79},".","https://www.bsi.bund.de/DE/Themen/Oeffentliche-Verwaltung/oeffentliche-verwaltung_node.html",[130],{"_79":131,"_73":79},"Empfehlungen des BSI","Informationssicherheit betrifft alle Arten von Daten, vor allem wirtschafts- oder sicherheitsrelevante. Alle Daten müssen sicher gespeichert und übertragen werden. Dies erschwert den missbräuchlichen Zugriff, etwa zum Erschleichen von Leistungen. Folgen Sie den ","5.1","Stellen Sie den Datenschutz sicher","Datenschutz","Stellen Sie den Datenschutz sicher: Gewährleisten Sie, dass die Verarbeitung personenbezogener Daten jederzeit den geltenden Anforderungen entspricht und das Erfordernis der Datensparsamkeit beachtet wird.",[201],[179],[],{"_34":141,"_38":24,"_51":142,"_62":143},"i9t6l6by44lbcecptjuzclfe",[150,151,152],{"_38":144,"_65":145,"_46":146,"_68":147},"39","GWKH","Überprüfung der gespeicherten Daten; Datenübermittlung",{"_18":148,"_46":149},"einrichtung-herkunftsnachweisregister-fuer-gas-waerme-und-kaelte-gwkhv","Einrichtung Herkunftsnachweisregister für Gas, Wärme und Kälte  - GWKHV",{"_73":74,"_75":176},{"_73":85,"_86":158,"_75":159},{"_73":74,"_75":153},[154,155],{"_79":157,"_73":79},{"_79":156,"_73":79,"_81":82},"Die protokollierten Daten sind durch geeignete Vorkehrungen gegen zweckfremde Verwendung und gegen sonstigen Missbrauch zu schützen. Die protokollierten Daten sind sechs Monate nach der Protokollierung zu löschen.[3]","Die protokollierten Daten dürfen nur für Zwecke der Datenschutzkontrolle oder Datensicherung oder zur Sicherstellung eines ordnungsgemäßen Betriebs der Datenverarbeitungsanlage verwendet werden. ","ordered",[160,161,162,163],{"_73":93,"_75":173},{"_73":93,"_75":170},{"_73":93,"_75":167},{"_73":93,"_75":164},[165],{"_79":166,"_73":79},"die abgerufenen Daten.",[168],{"_79":169,"_73":79},"die Kennung der abrufenden Dienststelle und",[171],{"_79":172,"_73":79},"den Tag und die Uhrzeit der Abrufe,",[174],{"_79":175,"_73":79},"die bei der Durchführung der Abrufe verwendeten Daten,",[177],{"_79":178,"_73":79},"Das Umweltbundesamt kann den Betreibern der Datenbanken und der Register nach Absatz 2 sowie den Behörden nach Absatz 3 über elektronische Schnittstellen den Zugang zu den in einem Herkunftsnachweisregister nach § 3 gespeicherten Daten, einschließlich personenbezogener Daten, ermöglichen. Das Umweltbundesamt als übermittelnde Stelle hat über die Abrufe nach Satz 1 Aufzeichnungen zu fertigen, die die folgenden Daten enthalten müssen:",{"_73":85,"_86":87,"_75":180},[181,182,183,184,185],{"_73":93,"_75":198},{"_73":93,"_75":195},{"_73":93,"_75":192},{"_73":93,"_75":189},{"_73":93,"_75":186},[187],{"_79":188,"_73":79},"Genügt die Regelung den Anforderungen an den Datenschutz in allen beteiligten Ländern und Institutionen, gegebenenfalls auch in anderen EU-Staaten?",[190],{"_79":191,"_73":79},"Können überholte Datenschutzbedürfnisse abgeschafft werden?",[193],{"_79":194,"_73":79},"Haben Sie die rechtliche Basis geschaffen, um Daten zu verarbeiten? Ist der Zweck der Datenverarbeitung dargelegt?",[196],{"_79":197,"_73":79},"Werden nur notwendige Daten verarbeitet?",[199],{"_79":200,"_73":79},"Werden personenbezogene Daten verarbeitet? Sind diese besonders schützenswert, etwa Daten zur ethnischen Herkunft oder Gesundheitsdaten?",{"_73":74,"_75":202},[203,204,205,206,207],{"_79":217,"_73":79},{"_101":213,"_73":103,"_75":214},{"_79":212,"_73":79},{"_101":208,"_73":103,"_75":209},{"_79":127,"_73":79},"https://www.bfdi.bund.de/DE/Home/home_node.html",[210],{"_79":211,"_73":79},"BfDI","). Tauschen Sie sich mit Ihren Datenschutzbeauftragten aus oder kontaktieren Sie die ","https://eur-lex.europa.eu/legal-content/DE/TXT/?qid=1532348683434&uri=CELEX%3A02016R0679-20160504",[215],{"_79":216,"_73":79},"s. Art. 4 Abs. 2 DSGVO","Für den Datenschutz sind nur personenbezogene Daten relevant. Um diese zu verarbeiten, muss eine geeignete Rechtsgrundlage existieren. \"Datenverarbeitung\" umfasst u. a. das Erheben, Speichern, Abfragen, Übermitteln, Verknüpfen oder Löschen von Daten (","zcso7sdqfumq9dymth3dfssp",[235],{"_38":64,"_65":66,"_46":67,"_68":234},"PrinzipErfuellungen",[223],{"_224":225,"_226":227,"_228":229},"id","1288","Erklaerung",[230],"Prinzip",{"_38":27,"_16":17},{"_73":74,"_75":231},[232],{"_79":233,"_73":79},"Verweist auf die DSGVO.",{"_18":70,"_46":71},{"_73":74,"_75":236},[237,238,239],{"_79":242,"_73":79},{"_79":241,"_73":79,"_81":82},{"_79":240,"_73":79},", zum freien Datenverkehr und zur Aufhebung der Richtlinie 95/46/EG (ABl. L 119 vom 4.5.2016, S. 1; L 314 vom 22.11.2016, S. 72; L 127 vom 23.5.2018, S. 2) übermitteln. Absatz 3 Satz 2 gilt entsprechend.","unter Beachtung der Verordnung (EU) 2016/679 des Europäischen Parlaments und des Rates vom 27. April 2016 zum Schutz natürlicher Personen bei der Verarbeitung personenbezogener Daten[3]","Abweichend von Absatz 3 Satz 1 können Luftsportverbände die für die Registrierung zu speichernden Daten ihrer Mitglieder, die unbemannte Fluggeräte nach Absatz 1 Satz 1 betreiben, dem Luftfahrt-Bundesamt ",{"_73":74,"_75":252},{"_73":74,"_75":249},{"_73":74,"_75":246},[247],{"_79":248,"_73":79},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[250],{"_79":251,"_73":79},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[253,254,255],{"_79":261,"_73":79},{"_101":257,"_73":103,"_75":258},{"_79":256,"_73":79}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[259],{"_79":260,"_73":79},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_263":264,"_265":266,"_267":266,"_268":269,"_270":271},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_272":82,"_273":82,"_274":82,"_275":82,"_276":82},"posthogKey","","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
