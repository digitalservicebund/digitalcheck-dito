[{"_1":2,"_3":4},"root",{"_5":476},"routes/methoden.fuenf-prinzipien.$prinzip",{"_5":6},"data",{"_7":8,"_9":10},"prinzip",{"_34":35,"_16":22,"_36":37,"_20":24,"_38":21,"_18":23,"_39":40,"_41":42},"prinzipList",[11,12,13,14,15],{"_16":31,"_18":32,"_20":33},{"_16":28,"_18":29,"_20":30},{"_16":25,"_18":26,"_20":27},{"_16":22,"_18":23,"_20":24},{"_16":17,"_18":19,"_20":21},"Name","Datenschutz und Informationssicherheit schaffen Vertrauen","URLBezeichnung","datenschutz-und-informationssicherheit-schaffen-vertrauen","order",5,"Automatisierung basiert auf eindeutigen Regelungen","automatisierung-basiert-auf-eindeutigen-regelungen",4,"Etablierte Technologien ermöglichen effiziente Umsetzung","etablierte-technologien-ermoeglichen-effiziente-umsetzung",3,"Datenwiederverwendung benötigt einheitliches Recht","datenwiederverwendung-benoetigt-einheitliches-recht",2,"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",1,"documentId","got436pv8femeqmv6ee8wlm1","Beschreibung",[442,443],"Nummer","Beispiel",{"_34":411,"_38":27,"_54":412,"_64":413,"_414":415},"Aspekte",[43,44,45,46,47],{"_38":338,"_49":339,"_51":340,"_36":341,"_54":342,"_56":343,"_58":-5,"_59":344,"_39":345},{"_38":309,"_49":310,"_51":311,"_36":312,"_54":313,"_56":314,"_58":-5,"_59":315,"_39":-5},{"_38":238,"_49":239,"_51":240,"_36":241,"_54":242,"_56":243,"_58":-5,"_59":244,"_39":245},{"_38":186,"_49":187,"_51":188,"_36":189,"_54":190,"_56":191,"_58":-5,"_59":192,"_39":193},{"_38":48,"_49":50,"_51":52,"_36":53,"_54":55,"_56":57,"_58":-5,"_59":60,"_39":61},"4.5","Titel","Schreiben Sie einfach, eindeutig und widerspruchsfrei","Kurzbezeichnung","Schreibstil","Schreiben Sie einfach, eindeutig und widerspruchsfrei: Formulieren Sie Normen klar und verständlich, damit sie eine unmissverständliche Grundlage für die digitale und menschliche Anwendung bilden.","Text",[182],"Leitfragen",[167],"Formulierungsbeispiel","Anwendung",[],{"_34":62,"_38":33,"_54":63,"_64":65},"ooxbst8o2pc70zu1ggl130rf",[74,75,76,77],"Paragraph",{"_38":66,"_67":68,"_49":69,"_70":71},"5","Gesetz","PostG","Zuverlässigkeit, Leistungsfähigkeit, Fachkunde","Beispielvorhaben",{"_18":72,"_49":73},"modernisierung-des-postrechts","Modernisierung des Postrechts – PostG",{"_78":79,"_80":164},{"_78":88,"_89":90,"_80":91},{"_78":79,"_80":85},{"_78":79,"_80":81},"type","paragraph","children",[82],{"_83":84,"_78":83},"text","",[86],{"_83":87,"_78":83},"Im Einzelfall kann auch eine Gesamtabwägung von Umständen, die nicht in Satz 1 genannt sind und denen in ihrer Gesamtheit ein vergleichbares Gewicht wie den in Satz 1 genannten Umständen zuzumessen ist, die Annahme rechtfertigen, dass der Antragsteller nicht über die erforderliche Zuverlässigkeit verfügt.","list","format","ordered",[92,93,94,95,96],{"_78":97,"_80":161},{"_78":88,"_89":90,"_80":144,"_102":33},{"_78":97,"_80":139},{"_78":88,"_89":90,"_80":101,"_102":33},{"_78":97,"_80":98},"list-item",[99],{"_83":100,"_78":83},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 schwerwiegend oder wiederholt gegen Vorgaben dieses Gesetzes verstoßen hat und die Verstöße durch bestandskräftige Entscheidungen der Bundesnetzagentur festgestellt sind.",[103,104,105,106,107,108,109,110,111],"indentLevel",{"_78":97,"_80":136},{"_78":97,"_80":133},{"_78":97,"_80":130},{"_78":97,"_80":127},{"_78":97,"_80":124},{"_78":97,"_80":121},{"_78":97,"_80":118},{"_78":97,"_80":115},{"_78":97,"_80":112},[113],{"_83":114,"_78":83},"§ 111 dieses Gesetzes,",[116],{"_83":117,"_78":83},"§ 209 Absatz 1 Nummer 1 bis 7, 8, 9 oder Absatz 2 des Siebten Buches Sozialgesetzbuch,",[119],{"_83":120,"_78":83},"§ 404 Absatz 1 oder Absatz 2 Nummer 4 des Dritten Buches Sozialgesetzbuch,",[122],{"_83":123,"_78":83},"§ 8 Absatz 1 Nummer 2, Absatz 2 bis 4 des Schwarzarbeitsbekämpfungsgesetzes,",[125],{"_83":126,"_78":83},"§ 21 des Mindestlohngesetzes,",[128],{"_83":129,"_78":83},"§ 22 Absatz 1 Nummer 1 bis 7, 9 oder 10 des Arbeitszeitgesetzes,",[131],{"_83":132,"_78":83},"§ 25 des Arbeitsschutzgesetzes,",[134],{"_83":135,"_78":83},"§ 16 des Arbeitnehmerüberlassungsgesetzes,",[137],{"_83":138,"_78":83},"§ 23 des Arbeitnehmerentsendegesetzes,",[140],{"_83":141,"_78":83,"_142":143},"gegen den Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 bei Antragstellern mit bis zu zehn Beschäftigten mindestens zwei, bei Antragstellern mit bis zu 250 Beschäftigten mindestens zehn, bei Antragstellern mit bis zu 500 Beschäftigten mindestens 20 und bei Antragstellern mit mehr als 500 Beschäftigten mindestens 25 unanfechtbare Bußgeldentscheidungen wegen einer der nachstehend aufgeführten Ordnungswidrigkeiten in Höhe von jeweils mindestens 1 500 Euro ergangen sind:[5]","underline",true,[145,146,147,148],{"_78":97,"_80":158},{"_78":97,"_80":155},{"_78":97,"_80":152},{"_78":97,"_80":149},[150],{"_83":151,"_78":83},"§§ 202, 206, 263, 266a oder 267 des Strafgesetzbuches,",[153],{"_83":154,"_78":83},"§§ 10, 10a oder 11 des Schwarzarbeitsbekämpfungsgesetzes,",[156],{"_83":157,"_78":83},"§ 23 des Arbeitszeitgesetzes,",[159],{"_83":160,"_78":83},"§§ 15 oder 15a des Arbeitnehmerüberlassungsgesetzes,",[162],{"_83":163,"_78":83},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 wegen Versuchs oder Vollendung eines Verbrechens im Sinne von § 12 Absatz 1 des Strafgesetzbuches oder einer der nachstehend aufgeführten Straftaten zu einer Freiheitsstrafe, Jugendstrafe, auch wenn deren Verhängung ausgesetzt worden ist, Geldstrafe von mindestens 90 Tagessätzen oder mindestens zweimal zu einer geringeren Geldstrafe rechtskräftig verurteilt worden ist, wenn seit dem Eintritt der Rechtskraft der letzten erstinstanzlichen Verurteilung fünf Jahre und seit dem Eintritt der Rechtskraft der vorletzten erstinstanzlichen Verurteilung zehn Jahre noch nicht verstrichen sind:",[165],{"_83":166,"_78":83,"_142":143},"Die nach § 4 Absatz 4 Nummer 1 erforderliche Zuverlässigkeit liegt in der Regel nicht vor, wenn[5]",{"_78":88,"_89":168,"_80":169},"unordered",[170,171,172],{"_78":97,"_80":179},{"_78":97,"_80":176},{"_78":97,"_80":173},[174],{"_83":175,"_78":83},"Sind Entscheidungslogiken widerspruchsfrei?",[177],{"_83":178,"_78":83},"Ist die Regelung möglichst einfach formuliert?",[180],{"_83":181,"_78":83},"Sind Begriffe und Abläufe eindeutig definiert?",{"_78":79,"_80":183},[184],{"_83":185,"_78":83},"Logische Konsistenz und präzise Sprache sind notwendige Bedingungen für die Automatisierung der Umsetzung. Dass eine Regelung eindeutig formuliert ist, kann auch einen längeren Regelungstext zur Folge haben.","4.4","Unterscheiden Sie zwischen genereller Regel, Ausnahmen und Ermessensspielräumen","Unterscheidungen","Unterscheiden Sie zwischen genereller Regel, Ausnahmen und Ermessensspielräumen: Definieren Sie klare Abgrenzungen zwischen Standardfällen, Sonderfällen und Ermessensentscheidungen, um die Automatisierbarkeit zu ermöglichen.",[234],[212],[],{"_34":194,"_38":27,"_54":195,"_64":196},"xu1tjdat5q94xbjqhqtqjw9g",[200],{"_38":197,"_67":68,"_49":198,"_70":199},"4","Anbieterverzeichnis",{"_18":72,"_49":73},{"_78":79,"_80":201},[202,203,204,205,206],{"_83":211,"_78":83,"_142":143},{"_83":210,"_78":83},{"_83":209,"_78":83,"_142":143},{"_83":208,"_78":83},{"_83":207,"_78":83,"_142":143},"Ist die Frist nach Satz 1 abgelaufen, ohne dass eine Eintragung oder Versagung erfolgt ist, gilt der Antragsteller als in das Anbieterverzeichnis eingetragen; die Bundesnetzagentur hat die Eintragung umgehend zu veranlassen.[5]"," Die erfolgte Eintragung ist dem Anbieter mitzuteilen. Liegen Gründe für die Versagung der Eintragung vor, versagt die Bundesnetzagentur die Eintragung. ","trägt die Bundesnetzagentur den Antragsteller in das Anbieterverzeichnis ein.[5]"," Liegen keine Gründe für die Versagung der Eintragung vor, ","Innerhalb von vier Wochen nach Eingang eines vollständigen Antrags prüft die Bundesnetzagentur, ob Gründe nach Absatz 4 für die Versagung der Eintragung vorliegen.[5]",{"_78":88,"_89":168,"_80":213},[214,215,216,217,218],{"_78":97,"_80":231},{"_78":97,"_80":228},{"_78":97,"_80":225},{"_78":97,"_80":222},{"_78":97,"_80":219},[220],{"_83":221,"_78":83},"Ist trotz verbleibendem Ermessen eine Automatisierung anderer Prozessschritte möglich?",[223],{"_83":224,"_78":83},"Sind Ermessensspielräume nötig? Können für bestimmte Fallgruppen gebundene Entscheidungen festgelegt werden?",[226],{"_83":227,"_78":83},"Wird in der Regelung klar zwischen grundlegender Regel und Ausnahmen unterschieden? Sind die Ausnahmen klar definiert?",[229],{"_83":230,"_78":83},"Können Pauschalen die Regelung und Umsetzung vereinfachen?",[232],{"_83":233,"_78":83},"Basieren Entscheidungslogiken auf objektiven Kriterien?",{"_78":79,"_80":235},[236],{"_83":237,"_78":83},"Sachverhalte sollten durch das Zusammenspiel von Gesetzen und Verordnungen möglichst abschließend geregelt werden. Finden Sie die Balance zwischen notwendigen Ausnahmen für eine gerechte Regelung, Spielraum in der Umsetzung und klar geregelten Prozessen, die sich gut digitalisieren lassen.","4.3","Nutzen Sie das Potenzial von Automatisierung","Automatisierung","Nutzen Sie das Potenzial von Automatisierung: Legen Sie Entscheidungsstrukturen so fest, dass sie durch eindeutige Logik maschinell verarbeitet werden können, um Zeit und Ressourcen zu sparen.",[305],[275],[],{"_34":246,"_38":30,"_54":247,"_64":248},"fvj31s0fav5aw2vlu65q0arw",[255,256],{"_38":249,"_67":250,"_49":251,"_70":252},"1131","ZPO","Kommunikations-, Austausch- und Übermittlungsformen",{"_18":253,"_49":254},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit",{"_78":79,"_80":270},{"_78":88,"_89":90,"_80":257},[258,259,260],{"_78":97,"_80":267},{"_78":97,"_80":264},{"_78":97,"_80":261},[262],{"_83":263,"_78":83,"_142":143},"für die elektronischen Dokumente oder strukturierten Datensätze auf der Kommunikationsplattform eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[5]",[265],{"_83":266,"_78":83,"_142":143},"bei der Datenübermittlung ein sicheres Verfahren verwendet wird, das die Authentizität und Integrität der Daten gewährleistet, und [3]",[268],{"_83":269,"_78":83},"ein Identifizierungsverfahren nach Absatz 1 genutzt wird,",[271,272],{"_83":274,"_78":83,"_142":143},{"_83":273,"_78":83},", sofern","Eine in diesem Gesetz angeordnete Schriftform kann auch durch Übermittlung elektronischer Dokumente oder strukturierter Datensätze über die Kommunikationsplattform ersetzt werden[1]",{"_78":88,"_89":168,"_80":276},[277,278,279,280,281],{"_78":97,"_80":302},{"_78":97,"_80":299},{"_78":97,"_80":296},{"_78":97,"_80":293},{"_78":97,"_80":282},[283,284,285],{"_83":292,"_78":83},{"_287":288,"_78":289,"_80":290},{"_83":286,"_78":83},"“.","url","/#datenwiederverwendung-ben-tigt-einheitliches-recht","link",[291],{"_83":28,"_78":83},"Ist ein komplett antragsloses Verfahren möglich? Beachten Sie hierfür auch das Prinzip „",[294],{"_83":295,"_78":83},"Erlaubt die Regelung eine automatisierte Fallbearbeitung?",[297],{"_83":298,"_78":83},"Handelt es sich um eine gebundene Entscheidung?",[300],{"_83":301,"_78":83},"Gibt es bereits Vorschläge für Automatisierungspotenziale aus der Umsetzung?",[303],{"_83":304,"_78":83},"Wie groß ist die erwartete Fallzahl pro Jahr? Sind in den Behörden genug Ressourcen vorhanden, um z. B. Anträge fristgerecht zu bearbeiten?",{"_78":79,"_80":306},[307],{"_83":308,"_78":83},"Automatisierung wirkt sich besonders effizienzsteigernd auf Prozesse mit großen Bearbeitungsfallzahlen aus, die als gebundene Entscheidungen geregelt werden können.","4.2","Bündeln Sie Aufgaben im Vollzug","Aufgabenbündelung","Bündeln Sie Aufgaben im Vollzug: Fassen Sie ähnliche oder zusammenhängende Tätigkeiten in der Umsetzung zusammen, um Effizienz zu steigern und die Übersichtlichkeit zu verbessern.",[334],[316],[],{"_78":88,"_89":168,"_80":317},[318,319,320,321],{"_78":97,"_80":331},{"_78":97,"_80":328},{"_78":97,"_80":325},{"_78":97,"_80":322},[323],{"_83":324,"_78":83},"Können Sie Spezialisierungsvorteile nutzen, in dem Sie fachlich anspruchsvolle Aufgaben, die selten anfallen, bündeln?",[326],{"_83":327,"_78":83},"Kann eine gemeinsame technische Lösung für alle Behörden entwickelt werden?",[329],{"_83":330,"_78":83},"Können Sie vermeiden, dass dieselben Aufgaben in jeder Kommunen erfüllt werden müssen?",[332],{"_83":333,"_78":83},"Ermöglicht die Regelung, dass andere, möglichst übergeordnete oder ressortübergreifende, Behörden Aufgaben automatisieren können? Ist es ausreichend, wenn die zuständige Behörde das Ergebnis erhält?",{"_78":79,"_80":335},[336],{"_83":337,"_78":83},"Vereinfachen Sie, wie die Aufgaben zwischen Bund und Ländern verteilt sind. Aufgaben oder Teilaufgaben können gebündelt werden: Sie müssen nicht mehr in jeder Kommune oder jeder Behörde individuell erfüllt werden. Gerade bei Aufgaben mit hohen Fallzahlen und hohem Standardisierungspotenzial können Automatisierung und Aufgabenneuorganisation die Vollzugsbehörden spürbar entlasten.","4.1","Beachten Sie bestehende Prozesse und Verantwortlichkeiten","Bestehende Prozesse","Beachten Sie bestehende Prozesse und Verantwortlichkeiten: Integrieren Sie neue Regelungen harmonisch in die vorhandenen Arbeitsabläufe und klären Sie die Zuständigkeiten, um eine reibungslose Umsetzung zu sichern.",[407],[378],[],{"_34":346,"_38":347,"_54":348,"_64":349},"aws985sev373qzjm9gagbjyl",7,[356,357,358],{"_38":350,"_67":351,"_49":352,"_70":353},"66a","LuftVG","Register über Betreiber von unbemannten Fluggeräten",{"_18":354,"_49":355},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","Register über Betreiber von unbemannten Fluggeräten – LuftVG",{"_78":79,"_80":371},{"_78":88,"_89":90,"_80":362},{"_78":79,"_80":359},[360],{"_83":361,"_78":83},"wenn diese Daten auf andere Weise nicht oder nicht rechtzeitig oder nur mit unverhältnismäßigem Aufwand zu erlangen sind. Die Verantwortung für die Zulässigkeit des einzelnen automatisierten Abrufs trägt die abrufende Stelle. Das Luftfahrt-Bundesamt überprüft die Zulässigkeit des Abrufs nur, wenn dazu Anlass besteht.",[363,364],{"_78":97,"_80":368},{"_78":97,"_80":365},[366],{"_83":367,"_78":83},"zur Abwehr von Gefahren für die öffentliche Sicherheit,",[369],{"_83":370,"_78":83},"zur Verfolgung von Straftaten oder",[372,373,374],{"_83":377,"_78":83},{"_83":376,"_78":83,"_142":143},{"_83":375,"_78":83}," an die Polizeien des Bundes und der Länder erfolgen","aus dem Register darf durch Abruf im automatisierten Verfahren[5]","Die Übermittlung nach Absatz 6 Satz 1 ",{"_78":88,"_89":168,"_80":379},[380,381,382,383,384],{"_78":97,"_80":397},{"_78":97,"_80":394},{"_78":97,"_80":391},{"_78":97,"_80":388},{"_78":97,"_80":385},[386],{"_83":387,"_78":83},"Falls ein Verwaltungsprozess betroffen ist: Lassen sich die Teilschritte in einer chronologischen Reihenfolge abbilden?",[389],{"_83":390,"_78":83},"Können bestehende Prozesse vereinfacht werden?",[392],{"_83":393,"_78":83},"Bekommt oder verliert eine Behörde Kompetenzen? Wie wirkt sich das aus?",[395],{"_83":396,"_78":83},"Haben Sie bestehende Prozesse in Deutschland und anderen EU-Mitgliedsstaaten berücksichtigt",[398,399,400],{"_83":406,"_78":83},{"_287":402,"_78":289,"_80":403},{"_83":401,"_78":83},", auf denen Sie aufsetzen können?","https://fimportal.de/search?resource=process&page=1&page_size=20",[404],{"_83":405,"_78":83},"FIM-Portal","Gibt es bereits Prozess-Visualisierungen im ",{"_78":79,"_80":408},[409],{"_83":410,"_78":83},"Um eine effektive Umsetzung zu gewährleisten, sollten existierende Prozesse und Verantwortlichkeiten beachtet und, wenn möglich, angeglichen werden. Dabei helfen Ihnen Visualisierungen.","uvun402oruwdnjke6epwd5qt",[434],{"_38":350,"_67":351,"_49":352,"_70":433},"PrinzipErfuellungen",[416],{"_417":418,"_419":420,"_421":422},"id","1286","Erklaerung",[423],"Prinzip",{"_38":21,"_16":22},{"_78":88,"_89":168,"_80":424},[425,426],{"_78":97,"_80":430},{"_78":97,"_80":427},[428],{"_83":429,"_78":83},"Neben der Automatisierung besteht das Recht auf Entscheidung durch einen Amtsträger.",[431],{"_83":432,"_78":83},"Schafft die Rechtsgrundlage zur potenziellen Automatisierung.",{"_18":354,"_49":355},{"_78":79,"_80":435},[436,437,438],{"_83":441,"_78":83},{"_83":440,"_78":83,"_142":143},{"_83":439,"_78":83}," Satz 3 gilt nicht, wenn ein Betreiber Rechte nach Satz 4 geltend macht oder wenn aus anderen Gründen Anlass besteht, den Einzelfall durch Amtsträger zu bearbeiten. Setzt das Luftfahrt-Bundesamt automatische Einrichtungen zum Erlass von Verwaltungsakten ein, muss es Angaben des Betreibers berücksichtigen, die für den Einzelfall bedeutsam sind und im automatischen Verfahren nicht ermittelt würden.","Das Luftfahrt-Bundesamt kann Verwaltungsakte hinsichtlich der Registrierung eines Betreibers sowie Gebührenbescheide für die Registrierung durch automatische Einrichtungen erlassen. Betreiber haben das Recht auf Darlegung des eigenen Standpunktes und das Recht auf Entscheidung durch einen Amtsträger.[5]","Betreiber von unbemannten Fluggeräten nach Absatz 1 Satz 1 haben dem Luftfahrt-Bundesamt vor der erstmaligen Aufnahme des Betriebs die für die Registrierung zu speichernden Daten nach Absatz 2 zu übermitteln und deren Richtigkeit auf Verlangen zu belegen, soweit dies für die Registrierung durch das Luftfahrt-Bundesamt erforderlich ist. Registrierte Betreiber haben dem Luftfahrt-Bundesamt unverzüglich jede Änderung der Voraussetzungen für eine Registrierung nach Absatz 1 und jede Änderung der Daten nach Absatz 2 zu übermitteln. ",{"_78":79,"_80":459},{"_78":79,"_80":444},[445,446,447,448,449],{"_83":458,"_78":83},{"_83":456,"_78":83,"_457":143},{"_83":455,"_78":83},{"_287":451,"_78":289,"_80":452},{"_83":450,"_78":83},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[453],{"_83":454,"_78":83},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[460,461,462,463,464],{"_83":475,"_78":83},{"_287":471,"_78":289,"_80":472},{"_83":470,"_78":83},{"_287":466,"_78":289,"_80":467},{"_83":465,"_78":83}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[468],{"_83":469,"_78":83},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[473],{"_83":474,"_78":83},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_477":478,"_479":480,"_481":480,"_482":483,"_484":84},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_485":143,"_486":143,"_487":143,"_488":143,"_489":143},"posthogKey","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
