[{"_1":2,"_3":4},"root",{"_5":1433},"routes/methoden.fuenf-prinzipien._index",{"_5":6},"data",{"_7":8},"prinzips",[9,10,11,12,13],{"_14":1186,"_16":1187,"_18":1188,"_20":1189,"_22":1190,"_24":1191,"_26":293,"_28":293,"_30":1192,"_32":1193,"_34":1194},{"_14":923,"_16":504,"_18":924,"_20":925,"_22":926,"_24":927,"_26":460,"_28":460,"_30":928,"_32":929,"_34":930},{"_14":704,"_16":705,"_18":706,"_20":707,"_22":708,"_24":709,"_26":29,"_28":710,"_30":711,"_32":712,"_34":713},{"_14":272,"_16":273,"_18":274,"_20":275,"_22":276,"_24":277,"_26":130,"_28":27,"_30":278,"_32":279,"_34":280},{"_14":15,"_16":17,"_18":19,"_20":21,"_22":23,"_24":25,"_26":27,"_28":29,"_30":31,"_32":33,"_34":35},"documentId","bnx9lmblnceu1m3uy3rziy0i","Name","Datenschutz und Informationssicherheit schaffen Vertrauen","Beschreibung",[259,260,261],"Kurzbeschreibung",[255],"Hilfetext",[236,237,238],"Erklaerungshilfe",[232],"order",5,"Nummer",3,"URLBezeichnung","datenschutz-und-informationssicherheit-schaffen-vertrauen","Beispiel",{"_14":207,"_28":130,"_43":208,"_52":209,"_210":211},"Aspekte",[36,37],{"_38":123,"_40":124,"_18":125,"_43":126,"_45":127,"_47":-5,"_32":128},{"_38":39,"_40":41,"_18":42,"_43":44,"_45":46,"_47":-5,"_32":48},"Titel","Gewährleisten Sie die Informationssicherheit","Kurzbezeichnung","Informationssicherheit","Gewährleisten Sie die Informationssicherheit: Ergreifen Sie notwendige technische und organisatorische Maßnahmen, um die Vertraulichkeit, Integrität und Verfügbarkeit aller relevanten Informationen zu schützen.","Text",[112],"Leitfragen",[74],"Formulierungsbeispiel",{"_14":49,"_28":50,"_43":51,"_52":53},"wcxx3x3bzdzfsrkr0fxlr7bi",10,[62],"Paragraph",{"_28":54,"_55":56,"_38":57,"_58":59},"66a","Gesetz","LuftVG","Register über Betreiber von unbemannten Fluggeräten","Beispielvorhaben",{"_30":60,"_38":61},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","Register über Betreiber von unbemannten Fluggeräten – LuftVG",{"_63":64,"_65":66},"type","paragraph","children",[67,68],{"_69":73,"_63":69},{"_69":70,"_63":69,"_71":72},"text","Einvernehmen mit dem Bundesamt für Sicherheit in der Informationstechnik insbesondere unter Beachtung der Vorgaben der Artikel 24, 25 und 32 der Verordnung (EU) 2016/679 nähere Anforderungen an das Datenformat sowie die Anforderungen an die Sicherheit gegen unbefugte Zugriffe auf das Register und bei der Datenübertragung fest. Sie haben dem Stand der Technik zu entsprechen und sind vom Luftfahrt-Bundesamt im Einvernehmen mit dem Bundesamt für Sicherheit in der Informationstechnik fortlaufend anzupassen[3].","underline",true,"Das Luftfahrt-Bundesamt legt im ",{"_63":75,"_76":77,"_65":78},"list","format","unordered",[79,80,81,82],{"_63":83,"_65":109},{"_63":83,"_65":106},{"_63":83,"_65":103},{"_63":83,"_65":84},"list-item",[85,86,87,88,89],{"_69":102,"_63":69},{"_91":98,"_63":93,"_65":99},{"_69":97,"_63":69},{"_91":92,"_63":93,"_65":94},{"_69":90,"_63":69},"?","url","https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/IT-Grundschutz/Zertifizierte-Informationssicherheit/zertifizierte-informationssicherheit.html","link",[95],{"_69":96,"_63":69},"ISO 27001",", z. B. ","https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/standards-und-zertifizierung_node.html",[100],{"_69":101,"_63":69},"Nachweise oder Zertifizierungen","Gibt es passende, anerkannte ",[104],{"_69":105,"_63":69},"Wurden veraltete Informationssicherheitsbedürfnisse identifiziert und abgeschafft?",[107],{"_69":108,"_63":69},"Wurden Maßnahmen vorgeschrieben, um Betrugsversuche zu erschweren?",[110],{"_69":111,"_63":69},"Werden eine geeignete, sichere Datenhaltung und sichere Übertragungswege vorgeschrieben?",{"_63":64,"_65":113},[114,115,116],{"_69":122,"_63":69},{"_91":118,"_63":93,"_65":119},{"_69":117,"_63":69},".","https://www.bsi.bund.de/DE/Themen/Oeffentliche-Verwaltung/oeffentliche-verwaltung_node.html",[120],{"_69":121,"_63":69},"Empfehlungen des BSI","Informationssicherheit betrifft alle Arten von Daten, vor allem wirtschafts- oder sicherheitsrelevante. Alle Daten müssen sicher gespeichert und übertragen werden. Dies erschwert den missbräuchlichen Zugriff, etwa zum Erschleichen von Leistungen. Folgen Sie den ","Stellen Sie den Datenschutz sicher","Datenschutz","Stellen Sie den Datenschutz sicher: Gewährleisten Sie, dass die Verarbeitung personenbezogener Daten jederzeit den geltenden Anforderungen entspricht und das Erfordernis der Datensparsamkeit beachtet wird.",[190],[168],{"_14":129,"_28":130,"_43":131,"_52":132},"i9t6l6by44lbcecptjuzclfe",4,[139,140,141],{"_28":133,"_55":134,"_38":135,"_58":136},"39","GWKH","Überprüfung der gespeicherten Daten; Datenübermittlung",{"_30":137,"_38":138},"einrichtung-herkunftsnachweisregister-fuer-gas-waerme-und-kaelte-gwkhv","Einrichtung Herkunftsnachweisregister für Gas, Wärme und Kälte  - GWKHV",{"_63":64,"_65":165},{"_63":75,"_76":147,"_65":148},{"_63":64,"_65":142},[143,144],{"_69":146,"_63":69},{"_69":145,"_63":69,"_71":72},"Die protokollierten Daten sind durch geeignete Vorkehrungen gegen zweckfremde Verwendung und gegen sonstigen Missbrauch zu schützen. Die protokollierten Daten sind sechs Monate nach der Protokollierung zu löschen.[3]","Die protokollierten Daten dürfen nur für Zwecke der Datenschutzkontrolle oder Datensicherung oder zur Sicherstellung eines ordnungsgemäßen Betriebs der Datenverarbeitungsanlage verwendet werden. ","ordered",[149,150,151,152],{"_63":83,"_65":162},{"_63":83,"_65":159},{"_63":83,"_65":156},{"_63":83,"_65":153},[154],{"_69":155,"_63":69},"die abgerufenen Daten.",[157],{"_69":158,"_63":69},"die Kennung der abrufenden Dienststelle und",[160],{"_69":161,"_63":69},"den Tag und die Uhrzeit der Abrufe,",[163],{"_69":164,"_63":69},"die bei der Durchführung der Abrufe verwendeten Daten,",[166],{"_69":167,"_63":69},"Das Umweltbundesamt kann den Betreibern der Datenbanken und der Register nach Absatz 2 sowie den Behörden nach Absatz 3 über elektronische Schnittstellen den Zugang zu den in einem Herkunftsnachweisregister nach § 3 gespeicherten Daten, einschließlich personenbezogener Daten, ermöglichen. Das Umweltbundesamt als übermittelnde Stelle hat über die Abrufe nach Satz 1 Aufzeichnungen zu fertigen, die die folgenden Daten enthalten müssen:",{"_63":75,"_76":77,"_65":169},[170,171,172,173,174],{"_63":83,"_65":187},{"_63":83,"_65":184},{"_63":83,"_65":181},{"_63":83,"_65":178},{"_63":83,"_65":175},[176],{"_69":177,"_63":69},"Genügt die Regelung den Anforderungen an den Datenschutz in allen beteiligten Ländern und Institutionen, gegebenenfalls auch in anderen EU-Staaten?",[179],{"_69":180,"_63":69},"Können überholte Datenschutzbedürfnisse abgeschafft werden?",[182],{"_69":183,"_63":69},"Haben Sie die rechtliche Basis geschaffen, um Daten zu verarbeiten? Ist der Zweck der Datenverarbeitung dargelegt?",[185],{"_69":186,"_63":69},"Werden nur notwendige Daten verarbeitet?",[188],{"_69":189,"_63":69},"Werden personenbezogene Daten verarbeitet? Sind diese besonders schützenswert, etwa Daten zur ethnischen Herkunft oder Gesundheitsdaten?",{"_63":64,"_65":191},[192,193,194,195,196],{"_69":206,"_63":69},{"_91":202,"_63":93,"_65":203},{"_69":201,"_63":69},{"_91":197,"_63":93,"_65":198},{"_69":117,"_63":69},"https://www.bfdi.bund.de/DE/Home/home_node.html",[199],{"_69":200,"_63":69},"BfDI","). Tauschen Sie sich mit Ihren Datenschutzbeauftragten aus oder kontaktieren Sie die ","https://eur-lex.europa.eu/legal-content/DE/TXT/?qid=1532348683434&uri=CELEX%3A02016R0679-20160504",[204],{"_69":205,"_63":69},"s. Art. 4 Abs. 2 DSGVO","Für den Datenschutz sind nur personenbezogene Daten relevant. Um diese zu verarbeiten, muss eine geeignete Rechtsgrundlage existieren. \"Datenverarbeitung\" umfasst u. a. das Erheben, Speichern, Abfragen, Übermitteln, Verknüpfen oder Löschen von Daten (","zcso7sdqfumq9dymth3dfssp",[224],{"_28":54,"_55":56,"_38":57,"_58":223},"PrinzipErfuellungen",[212],{"_213":214,"_215":216,"_217":218},"id","1288","Erklaerung",[219],"Prinzip",{"_28":29,"_16":17},{"_63":64,"_65":220},[221],{"_69":222,"_63":69},"Verweist auf die DSGVO.",{"_30":60,"_38":61},{"_63":64,"_65":225},[226,227,228],{"_69":231,"_63":69},{"_69":230,"_63":69,"_71":72},{"_69":229,"_63":69},", zum freien Datenverkehr und zur Aufhebung der Richtlinie 95/46/EG (ABl. L 119 vom 4.5.2016, S. 1; L 314 vom 22.11.2016, S. 72; L 127 vom 23.5.2018, S. 2) übermitteln. Absatz 3 Satz 2 gilt entsprechend.","unter Beachtung der Verordnung (EU) 2016/679 des Europäischen Parlaments und des Rates vom 27. April 2016 zum Schutz natürlicher Personen bei der Verarbeitung personenbezogener Daten[3]","Abweichend von Absatz 3 Satz 1 können Luftsportverbände die für die Registrierung zu speichernden Daten ihrer Mitglieder, die unbemannte Fluggeräte nach Absatz 1 Satz 1 betreiben, dem Luftfahrt-Bundesamt ",{"_63":64,"_65":233},[234],{"_69":235,"_63":69},"Tragen Sie in Stichpunkten Ihre Erläuterung ein z.B.: „Bedingungen für die Verwendung von Kontaktdaten, siehe § 1a (2)”.",{"_63":64,"_65":245},{"_63":64,"_65":242},{"_63":64,"_65":239},[240],{"_69":241,"_63":69},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[243],{"_69":244,"_63":69},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[246,247,248],{"_69":254,"_63":69},{"_91":250,"_63":93,"_65":251},{"_69":249,"_63":69}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[252],{"_69":253,"_63":69},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_63":64,"_65":256},[257],{"_69":258,"_63":69},"Datenschutz nach DSGVO und Informationssicherheit schützen Menschen vor unbefugtem Zugriff, stärken das Vertrauen in den Staat und werden durch konsequente Datensparsamkeit erleichtert, die zugleich den Erfüllungsaufwand reduziert.",{"_63":64,"_65":266},{"_63":64,"_65":264},{"_63":64,"_65":262},[263],{"_69":241,"_63":69},[265],{"_69":244,"_63":69},[267,268,269],{"_69":254,"_63":69},{"_91":250,"_63":93,"_65":270},{"_69":249,"_63":69},[271],{"_69":253,"_63":69},"got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[684,685],[680],[646,647],[642],"automatisierung-basiert-auf-eindeutigen-regelungen",{"_14":615,"_28":29,"_43":616,"_52":617,"_210":618},[281,282,283,284,285],{"_38":549,"_40":550,"_18":551,"_43":552,"_45":553,"_47":-5,"_32":554},{"_38":522,"_40":523,"_18":524,"_43":525,"_45":526,"_47":-5,"_32":-5},{"_38":453,"_40":454,"_18":455,"_43":456,"_45":457,"_47":-5,"_32":458},{"_38":403,"_40":404,"_18":405,"_43":406,"_45":407,"_47":-5,"_32":408},{"_38":286,"_40":287,"_18":288,"_43":289,"_45":290,"_47":-5,"_32":291},"Schreiben Sie einfach, eindeutig und widerspruchsfrei","Schreibstil","Schreiben Sie einfach, eindeutig und widerspruchsfrei: Formulieren Sie Normen klar und verständlich, damit sie eine unmissverständliche Grundlage für die digitale und menschliche Anwendung bilden.",[399],[385],{"_14":292,"_28":293,"_43":294,"_52":295},"ooxbst8o2pc70zu1ggl130rf",1,[302,303,304,305],{"_28":296,"_55":297,"_38":298,"_58":299},"5","PostG","Zuverlässigkeit, Leistungsfähigkeit, Fachkunde",{"_30":300,"_38":301},"modernisierung-des-postrechts","Modernisierung des Postrechts – PostG",{"_63":64,"_65":382},{"_63":75,"_76":147,"_65":312},{"_63":64,"_65":309},{"_63":64,"_65":306},[307],{"_69":308,"_63":69},"",[310],{"_69":311,"_63":69},"Im Einzelfall kann auch eine Gesamtabwägung von Umständen, die nicht in Satz 1 genannt sind und denen in ihrer Gesamtheit ein vergleichbares Gewicht wie den in Satz 1 genannten Umständen zuzumessen ist, die Annahme rechtfertigen, dass der Antragsteller nicht über die erforderliche Zuverlässigkeit verfügt.",[313,314,315,316,317],{"_63":83,"_65":379},{"_63":75,"_76":147,"_65":362,"_322":293},{"_63":83,"_65":359},{"_63":75,"_76":147,"_65":321,"_322":293},{"_63":83,"_65":318},[319],{"_69":320,"_63":69},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 schwerwiegend oder wiederholt gegen Vorgaben dieses Gesetzes verstoßen hat und die Verstöße durch bestandskräftige Entscheidungen der Bundesnetzagentur festgestellt sind.",[323,324,325,326,327,328,329,330,331],"indentLevel",{"_63":83,"_65":356},{"_63":83,"_65":353},{"_63":83,"_65":350},{"_63":83,"_65":347},{"_63":83,"_65":344},{"_63":83,"_65":341},{"_63":83,"_65":338},{"_63":83,"_65":335},{"_63":83,"_65":332},[333],{"_69":334,"_63":69},"§ 111 dieses Gesetzes,",[336],{"_69":337,"_63":69},"§ 209 Absatz 1 Nummer 1 bis 7, 8, 9 oder Absatz 2 des Siebten Buches Sozialgesetzbuch,",[339],{"_69":340,"_63":69},"§ 404 Absatz 1 oder Absatz 2 Nummer 4 des Dritten Buches Sozialgesetzbuch,",[342],{"_69":343,"_63":69},"§ 8 Absatz 1 Nummer 2, Absatz 2 bis 4 des Schwarzarbeitsbekämpfungsgesetzes,",[345],{"_69":346,"_63":69},"§ 21 des Mindestlohngesetzes,",[348],{"_69":349,"_63":69},"§ 22 Absatz 1 Nummer 1 bis 7, 9 oder 10 des Arbeitszeitgesetzes,",[351],{"_69":352,"_63":69},"§ 25 des Arbeitsschutzgesetzes,",[354],{"_69":355,"_63":69},"§ 16 des Arbeitnehmerüberlassungsgesetzes,",[357],{"_69":358,"_63":69},"§ 23 des Arbeitnehmerentsendegesetzes,",[360],{"_69":361,"_63":69,"_71":72},"gegen den Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 bei Antragstellern mit bis zu zehn Beschäftigten mindestens zwei, bei Antragstellern mit bis zu 250 Beschäftigten mindestens zehn, bei Antragstellern mit bis zu 500 Beschäftigten mindestens 20 und bei Antragstellern mit mehr als 500 Beschäftigten mindestens 25 unanfechtbare Bußgeldentscheidungen wegen einer der nachstehend aufgeführten Ordnungswidrigkeiten in Höhe von jeweils mindestens 1 500 Euro ergangen sind:[5]",[363,364,365,366],{"_63":83,"_65":376},{"_63":83,"_65":373},{"_63":83,"_65":370},{"_63":83,"_65":367},[368],{"_69":369,"_63":69},"§§ 202, 206, 263, 266a oder 267 des Strafgesetzbuches,",[371],{"_69":372,"_63":69},"§§ 10, 10a oder 11 des Schwarzarbeitsbekämpfungsgesetzes,",[374],{"_69":375,"_63":69},"§ 23 des Arbeitszeitgesetzes,",[377],{"_69":378,"_63":69},"§§ 15 oder 15a des Arbeitnehmerüberlassungsgesetzes,",[380],{"_69":381,"_63":69},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 wegen Versuchs oder Vollendung eines Verbrechens im Sinne von § 12 Absatz 1 des Strafgesetzbuches oder einer der nachstehend aufgeführten Straftaten zu einer Freiheitsstrafe, Jugendstrafe, auch wenn deren Verhängung ausgesetzt worden ist, Geldstrafe von mindestens 90 Tagessätzen oder mindestens zweimal zu einer geringeren Geldstrafe rechtskräftig verurteilt worden ist, wenn seit dem Eintritt der Rechtskraft der letzten erstinstanzlichen Verurteilung fünf Jahre und seit dem Eintritt der Rechtskraft der vorletzten erstinstanzlichen Verurteilung zehn Jahre noch nicht verstrichen sind:",[383],{"_69":384,"_63":69,"_71":72},"Die nach § 4 Absatz 4 Nummer 1 erforderliche Zuverlässigkeit liegt in der Regel nicht vor, wenn[5]",{"_63":75,"_76":77,"_65":386},[387,388,389],{"_63":83,"_65":396},{"_63":83,"_65":393},{"_63":83,"_65":390},[391],{"_69":392,"_63":69},"Sind Entscheidungslogiken widerspruchsfrei?",[394],{"_69":395,"_63":69},"Ist die Regelung möglichst einfach formuliert?",[397],{"_69":398,"_63":69},"Sind Begriffe und Abläufe eindeutig definiert?",{"_63":64,"_65":400},[401],{"_69":402,"_63":69},"Logische Konsistenz und präzise Sprache sind notwendige Bedingungen für die Automatisierung der Umsetzung. Dass eine Regelung eindeutig formuliert ist, kann auch einen längeren Regelungstext zur Folge haben.","Unterscheiden Sie zwischen genereller Regel, Ausnahmen und Ermessensspielräumen","Unterscheidungen","Unterscheiden Sie zwischen genereller Regel, Ausnahmen und Ermessensspielräumen: Definieren Sie klare Abgrenzungen zwischen Standardfällen, Sonderfällen und Ermessensentscheidungen, um die Automatisierbarkeit zu ermöglichen.",[449],[427],{"_14":409,"_28":29,"_43":410,"_52":411},"xu1tjdat5q94xbjqhqtqjw9g",[415],{"_28":412,"_55":297,"_38":413,"_58":414},"4","Anbieterverzeichnis",{"_30":300,"_38":301},{"_63":64,"_65":416},[417,418,419,420,421],{"_69":426,"_63":69,"_71":72},{"_69":425,"_63":69},{"_69":424,"_63":69,"_71":72},{"_69":423,"_63":69},{"_69":422,"_63":69,"_71":72},"Ist die Frist nach Satz 1 abgelaufen, ohne dass eine Eintragung oder Versagung erfolgt ist, gilt der Antragsteller als in das Anbieterverzeichnis eingetragen; die Bundesnetzagentur hat die Eintragung umgehend zu veranlassen.[5]"," Die erfolgte Eintragung ist dem Anbieter mitzuteilen. Liegen Gründe für die Versagung der Eintragung vor, versagt die Bundesnetzagentur die Eintragung. ","trägt die Bundesnetzagentur den Antragsteller in das Anbieterverzeichnis ein.[5]"," Liegen keine Gründe für die Versagung der Eintragung vor, ","Innerhalb von vier Wochen nach Eingang eines vollständigen Antrags prüft die Bundesnetzagentur, ob Gründe nach Absatz 4 für die Versagung der Eintragung vorliegen.[5]",{"_63":75,"_76":77,"_65":428},[429,430,431,432,433],{"_63":83,"_65":446},{"_63":83,"_65":443},{"_63":83,"_65":440},{"_63":83,"_65":437},{"_63":83,"_65":434},[435],{"_69":436,"_63":69},"Ist trotz verbleibendem Ermessen eine Automatisierung anderer Prozessschritte möglich?",[438],{"_69":439,"_63":69},"Sind Ermessensspielräume nötig? Können für bestimmte Fallgruppen gebundene Entscheidungen festgelegt werden?",[441],{"_69":442,"_63":69},"Wird in der Regelung klar zwischen grundlegender Regel und Ausnahmen unterschieden? Sind die Ausnahmen klar definiert?",[444],{"_69":445,"_63":69},"Können Pauschalen die Regelung und Umsetzung vereinfachen?",[447],{"_69":448,"_63":69},"Basieren Entscheidungslogiken auf objektiven Kriterien?",{"_63":64,"_65":450},[451],{"_69":452,"_63":69},"Sachverhalte sollten durch das Zusammenspiel von Gesetzen und Verordnungen möglichst abschließend geregelt werden. Finden Sie die Balance zwischen notwendigen Ausnahmen für eine gerechte Regelung, Spielraum in der Umsetzung und klar geregelten Prozessen, die sich gut digitalisieren lassen.","Nutzen Sie das Potenzial von Automatisierung","Automatisierung","Nutzen Sie das Potenzial von Automatisierung: Legen Sie Entscheidungsstrukturen so fest, dass sie durch eindeutige Logik maschinell verarbeitet werden können, um Zeit und Ressourcen zu sparen.",[518],[489],{"_14":459,"_28":460,"_43":461,"_52":462},"fvj31s0fav5aw2vlu65q0arw",2,[469,470],{"_28":463,"_55":464,"_38":465,"_58":466},"1131","ZPO","Kommunikations-, Austausch- und Übermittlungsformen",{"_30":467,"_38":468},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit",{"_63":64,"_65":484},{"_63":75,"_76":147,"_65":471},[472,473,474],{"_63":83,"_65":481},{"_63":83,"_65":478},{"_63":83,"_65":475},[476],{"_69":477,"_63":69,"_71":72},"für die elektronischen Dokumente oder strukturierten Datensätze auf der Kommunikationsplattform eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[5]",[479],{"_69":480,"_63":69,"_71":72},"bei der Datenübermittlung ein sicheres Verfahren verwendet wird, das die Authentizität und Integrität der Daten gewährleistet, und [3]",[482],{"_69":483,"_63":69},"ein Identifizierungsverfahren nach Absatz 1 genutzt wird,",[485,486],{"_69":488,"_63":69,"_71":72},{"_69":487,"_63":69},", sofern","Eine in diesem Gesetz angeordnete Schriftform kann auch durch Übermittlung elektronischer Dokumente oder strukturierter Datensätze über die Kommunikationsplattform ersetzt werden[1]",{"_63":75,"_76":77,"_65":490},[491,492,493,494,495],{"_63":83,"_65":515},{"_63":83,"_65":512},{"_63":83,"_65":509},{"_63":83,"_65":506},{"_63":83,"_65":496},[497,498,499],{"_69":505,"_63":69},{"_91":501,"_63":93,"_65":502},{"_69":500,"_63":69},"“.","/#datenwiederverwendung-ben-tigt-einheitliches-recht",[503],{"_69":504,"_63":69},"Datenwiederverwendung benötigt einheitliches Recht","Ist ein komplett antragsloses Verfahren möglich? Beachten Sie hierfür auch das Prinzip „",[507],{"_69":508,"_63":69},"Erlaubt die Regelung eine automatisierte Fallbearbeitung?",[510],{"_69":511,"_63":69},"Handelt es sich um eine gebundene Entscheidung?",[513],{"_69":514,"_63":69},"Gibt es bereits Vorschläge für Automatisierungspotenziale aus der Umsetzung?",[516],{"_69":517,"_63":69},"Wie groß ist die erwartete Fallzahl pro Jahr? Sind in den Behörden genug Ressourcen vorhanden, um z. B. Anträge fristgerecht zu bearbeiten?",{"_63":64,"_65":519},[520],{"_69":521,"_63":69},"Automatisierung wirkt sich besonders effizienzsteigernd auf Prozesse mit großen Bearbeitungsfallzahlen aus, die als gebundene Entscheidungen geregelt werden können.","Bündeln Sie Aufgaben im Vollzug","Aufgabenbündelung","Bündeln Sie Aufgaben im Vollzug: Fassen Sie ähnliche oder zusammenhängende Tätigkeiten in der Umsetzung zusammen, um Effizienz zu steigern und die Übersichtlichkeit zu verbessern.",[545],[527],{"_63":75,"_76":77,"_65":528},[529,530,531,532],{"_63":83,"_65":542},{"_63":83,"_65":539},{"_63":83,"_65":536},{"_63":83,"_65":533},[534],{"_69":535,"_63":69},"Können Sie Spezialisierungsvorteile nutzen, in dem Sie fachlich anspruchsvolle Aufgaben, die selten anfallen, bündeln?",[537],{"_69":538,"_63":69},"Kann eine gemeinsame technische Lösung für alle Behörden entwickelt werden?",[540],{"_69":541,"_63":69},"Können Sie vermeiden, dass dieselben Aufgaben in jeder Kommunen erfüllt werden müssen?",[543],{"_69":544,"_63":69},"Ermöglicht die Regelung, dass andere, möglichst übergeordnete oder ressortübergreifende, Behörden Aufgaben automatisieren können? Ist es ausreichend, wenn die zuständige Behörde das Ergebnis erhält?",{"_63":64,"_65":546},[547],{"_69":548,"_63":69},"Vereinfachen Sie, wie die Aufgaben zwischen Bund und Ländern verteilt sind. Aufgaben oder Teilaufgaben können gebündelt werden: Sie müssen nicht mehr in jeder Kommune oder jeder Behörde individuell erfüllt werden. Gerade bei Aufgaben mit hohen Fallzahlen und hohem Standardisierungspotenzial können Automatisierung und Aufgabenneuorganisation die Vollzugsbehörden spürbar entlasten.","Beachten Sie bestehende Prozesse und Verantwortlichkeiten","Bestehende Prozesse","Beachten Sie bestehende Prozesse und Verantwortlichkeiten: Integrieren Sie neue Regelungen harmonisch in die vorhandenen Arbeitsabläufe und klären Sie die Zuständigkeiten, um eine reibungslose Umsetzung zu sichern.",[611],[582],{"_14":555,"_28":556,"_43":557,"_52":558},"aws985sev373qzjm9gagbjyl",7,[560,561,562],{"_28":54,"_55":56,"_38":57,"_58":559},{"_30":60,"_38":61},{"_63":64,"_65":575},{"_63":75,"_76":147,"_65":566},{"_63":64,"_65":563},[564],{"_69":565,"_63":69},"wenn diese Daten auf andere Weise nicht oder nicht rechtzeitig oder nur mit unverhältnismäßigem Aufwand zu erlangen sind. Die Verantwortung für die Zulässigkeit des einzelnen automatisierten Abrufs trägt die abrufende Stelle. Das Luftfahrt-Bundesamt überprüft die Zulässigkeit des Abrufs nur, wenn dazu Anlass besteht.",[567,568],{"_63":83,"_65":572},{"_63":83,"_65":569},[570],{"_69":571,"_63":69},"zur Abwehr von Gefahren für die öffentliche Sicherheit,",[573],{"_69":574,"_63":69},"zur Verfolgung von Straftaten oder",[576,577,578],{"_69":581,"_63":69},{"_69":580,"_63":69,"_71":72},{"_69":579,"_63":69}," an die Polizeien des Bundes und der Länder erfolgen","aus dem Register darf durch Abruf im automatisierten Verfahren[5]","Die Übermittlung nach Absatz 6 Satz 1 ",{"_63":75,"_76":77,"_65":583},[584,585,586,587,588],{"_63":83,"_65":601},{"_63":83,"_65":598},{"_63":83,"_65":595},{"_63":83,"_65":592},{"_63":83,"_65":589},[590],{"_69":591,"_63":69},"Falls ein Verwaltungsprozess betroffen ist: Lassen sich die Teilschritte in einer chronologischen Reihenfolge abbilden?",[593],{"_69":594,"_63":69},"Können bestehende Prozesse vereinfacht werden?",[596],{"_69":597,"_63":69},"Bekommt oder verliert eine Behörde Kompetenzen? Wie wirkt sich das aus?",[599],{"_69":600,"_63":69},"Haben Sie bestehende Prozesse in Deutschland und anderen EU-Mitgliedsstaaten berücksichtigt",[602,603,604],{"_69":610,"_63":69},{"_91":606,"_63":93,"_65":607},{"_69":605,"_63":69},", auf denen Sie aufsetzen können?","https://fimportal.de/search?resource=process&page=1&page_size=20",[608],{"_69":609,"_63":69},"FIM-Portal","Gibt es bereits Prozess-Visualisierungen im ",{"_63":64,"_65":612},[613],{"_69":614,"_63":69},"Um eine effektive Umsetzung zu gewährleisten, sollten existierende Prozesse und Verantwortlichkeiten beachtet und, wenn möglich, angeglichen werden. Dabei helfen Ihnen Visualisierungen.","uvun402oruwdnjke6epwd5qt",[634],{"_28":54,"_55":56,"_38":57,"_58":633},[619],{"_213":620,"_215":621,"_217":622},"1286",[623],{"_28":27,"_16":273},{"_63":75,"_76":77,"_65":624},[625,626],{"_63":83,"_65":630},{"_63":83,"_65":627},[628],{"_69":629,"_63":69},"Neben der Automatisierung besteht das Recht auf Entscheidung durch einen Amtsträger.",[631],{"_69":632,"_63":69},"Schafft die Rechtsgrundlage zur potenziellen Automatisierung.",{"_30":60,"_38":61},{"_63":64,"_65":635},[636,637,638],{"_69":641,"_63":69},{"_69":640,"_63":69,"_71":72},{"_69":639,"_63":69}," Satz 3 gilt nicht, wenn ein Betreiber Rechte nach Satz 4 geltend macht oder wenn aus anderen Gründen Anlass besteht, den Einzelfall durch Amtsträger zu bearbeiten. Setzt das Luftfahrt-Bundesamt automatische Einrichtungen zum Erlass von Verwaltungsakten ein, muss es Angaben des Betreibers berücksichtigen, die für den Einzelfall bedeutsam sind und im automatischen Verfahren nicht ermittelt würden.","Das Luftfahrt-Bundesamt kann Verwaltungsakte hinsichtlich der Registrierung eines Betreibers sowie Gebührenbescheide für die Registrierung durch automatische Einrichtungen erlassen. Betreiber haben das Recht auf Darlegung des eigenen Standpunktes und das Recht auf Entscheidung durch einen Amtsträger.[5]","Betreiber von unbemannten Fluggeräten nach Absatz 1 Satz 1 haben dem Luftfahrt-Bundesamt vor der erstmaligen Aufnahme des Betriebs die für die Registrierung zu speichernden Daten nach Absatz 2 zu übermitteln und deren Richtigkeit auf Verlangen zu belegen, soweit dies für die Registrierung durch das Luftfahrt-Bundesamt erforderlich ist. Registrierte Betreiber haben dem Luftfahrt-Bundesamt unverzüglich jede Änderung der Voraussetzungen für eine Registrierung nach Absatz 1 und jede Änderung der Daten nach Absatz 2 zu übermitteln. ",{"_63":64,"_65":643},[644],{"_69":645,"_63":69},"Tragen Sie Ihre Erläuterung ein z.B.: „Ermessensspielräume werden reduziert, durch automatische Eintrag in das Verzeichnis nach Fristblauf  siehe § 10b“.",{"_63":64,"_65":663},{"_63":64,"_65":648},[649,650,651,652,653],{"_69":662,"_63":69},{"_69":660,"_63":69,"_661":72},{"_69":659,"_63":69},{"_91":655,"_63":93,"_65":656},{"_69":654,"_63":69},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[657],{"_69":658,"_63":69},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[664,665,666,667,668],{"_69":679,"_63":69},{"_91":675,"_63":93,"_65":676},{"_69":674,"_63":69},{"_91":670,"_63":93,"_65":671},{"_69":669,"_63":69}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[672],{"_69":673,"_63":69},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[677],{"_69":678,"_63":69},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_63":64,"_65":681},[682],{"_69":683,"_63":69},"Klare, logische und verständliche Regelungen – wie sie GGO und Handbuch der Rechtsförmlichkeit vorschreiben – stärken das Vertrauen in den Staat, ermöglichen automatisierte Verwaltungsprozesse und setzen dadurch Ressourcen für komplexere Fälle frei.",{"_63":64,"_65":694},{"_63":64,"_65":686},[687,688,689,690,691],{"_69":662,"_63":69},{"_69":660,"_63":69,"_661":72},{"_69":659,"_63":69},{"_91":655,"_63":93,"_65":692},{"_69":654,"_63":69},[693],{"_69":658,"_63":69},[695,696,697,698,699],{"_69":679,"_63":69},{"_91":675,"_63":93,"_65":702},{"_69":674,"_63":69},{"_91":670,"_63":93,"_65":700},{"_69":669,"_63":69},[701],{"_69":673,"_63":69},[703],{"_69":678,"_63":69},"habu0yjh39lc5wug5mqsqzaj","Etablierte Technologien ermöglichen effiziente Umsetzung",[916],[912],[901],[897],6,"etablierte-technologien-ermoeglichen-effiziente-umsetzung",{"_14":876,"_28":293,"_43":877,"_52":878,"_210":879},[714,715],{"_38":768,"_40":769,"_18":770,"_43":771,"_45":772,"_47":773,"_32":774},{"_38":716,"_40":717,"_18":718,"_43":719,"_45":720,"_47":-5,"_32":721},"Bevorzugen Sie Open-Source-Software und offene Spezifikationen","Open-Source-Software","Bevorzugen Sie Open-Source-Software und offene Spezifikationen: Setzen Sie auf Transparenz und Zugänglichkeit bei Code und Standards, um die Zusammenarbeit zu fördern und die Austauschbarkeit von Systemen zu gewährleisten.",[744],[734],{"_14":722,"_28":293,"_43":723,"_52":724},"u3sg1zismobz1t707uo3xav8",[728],{"_28":725,"_55":464,"_38":726,"_58":727},"1134","Umfang der Erprobung",{"_30":467,"_38":468},{"_63":64,"_65":729},[730,731],{"_69":733,"_63":69,"_71":72},{"_69":732,"_63":69}," Satz 1 gilt nicht im Anwendungsbereich des Online-Verfahrens nach Abschnitt 2 dieses Buchs.","Das Bundesministerium der Justiz kann digitale Eingabesysteme als Referenzimplementierung entwickeln und bundeseinheitlich zur Erprobung bereitstellen, soweit diese dem elektronischen Erstellen von Anträgen oder Erklärungen nach § 129a Absatz 1 dienen.[6]",{"_63":75,"_76":77,"_65":735},[736,737],{"_63":83,"_65":741},{"_63":83,"_65":738},[739],{"_69":740,"_63":69},"Werden gegebenenfalls bei Neuentwicklung Quelloffenheit und offene Spezifikationen vorgeschrieben?",[742],{"_69":743,"_63":69},"Wird der Einsatz von Open-Source-Software ermöglicht und gefördert?",{"_63":64,"_65":745},[746,747,748,749,750,751,752],{"_69":767,"_63":69},{"_91":763,"_63":93,"_65":764},{"_69":762,"_63":69},{"_91":758,"_63":93,"_65":759},{"_69":757,"_63":69},{"_91":753,"_63":93,"_65":754},{"_69":117,"_63":69},"https://www.zendis.de/",[755],{"_69":756,"_63":69},"Zentrum für digitale Souveränität","). Dies ermöglicht die Nachvollziehbarkeit der technischen Lösung und verhindert die Abhängigkeit von einzelnen Software-Anbietern. Weitere Informationen erhalten Sie beim ","https://servicestandard.gov.de/",[760],{"_69":761,"_63":69},"Servicestandard"," oder ","https://www.bundestag.de/resource/blob/194886/696f36f795961df200fb27fb6803d83e/koalitionsvertrag-data.pdf#page=152",[765],{"_69":766,"_63":69},"Koalitionsvertrag 18. Legislaturperiode","Open-Source bedeutet, dass der Quellcode eines IT-Systems veröffentlicht ist. Offene Spezifikationen beschreiben öffentlich, was ein IT-System genau leistet. Beide stärken Transparenz und Wiederverwendbarkeit (vgl. ","Ermöglichen Sie die Nutzung etablierter, öffentlicher Lösungen","Vorhandene Lösungen","Ermöglichen Sie die Nutzung etablierter, öffentlicher Lösungen: Nutzen Sie existierende und bewährte technologische Fundamente, um die Entwicklung digitaler Angebote zu beschleunigen und ihre Wirtschaftlichkeit zu steigern.",[861,862],[816],[799],{"_14":775,"_28":293,"_43":776,"_52":777},"g6pdcvhx2a4cleuywyb0fbuu",[779,780,781],{"_28":463,"_55":464,"_38":465,"_58":778},{"_30":467,"_38":468},{"_63":64,"_65":794},{"_63":75,"_76":147,"_65":785},{"_63":64,"_65":782},[783],{"_69":784,"_63":69},"Wurde der Nachweis der Identität nach Satz 1 erbracht, so kann die spätere Authentisierung des Inhabers des Identitätsnachweises auch durch andere geeignete Authentisierungsmittel erfolgen.",[786,787],{"_63":83,"_65":791},{"_63":83,"_65":788},[789],{"_69":790,"_63":69,"_71":72},"für die Identifizierung anderer Verfahrensbeteiligter: ein Verfahren über ein Nutzerkonto nach § 2 Absatz 5 in Verbindung mit § 3 Absatz 4 des Onlinezugangsgesetzes.[6]",[792],{"_69":793,"_63":69,"_71":72},"für die Identifizierung von Rechtsanwälten: das Verfahren zum Zugang zum besonderen elektronischen Anwaltspostfach nach § 31a Absatz 3 Satz 1 der Bundesrechtsanwaltsordnung;",[795,796],{"_69":798,"_63":69,"_71":72},{"_69":797,"_63":69},", sofern hierfür digitale Eingabesysteme zur Verfügung stehen und eines der folgenden Identifizierungsverfahren genutzt wird:","Eine in diesem Gesetz angeordnete Schriftform kann durch unmittelbare Eingabe von Anträgen und Erklärungen der Verfahrensbeteiligten über die Kommunikationsplattform nach § 1130 ersetzt werden[1]",{"_63":75,"_76":77,"_65":800},[801,802],{"_63":83,"_65":813},{"_63":83,"_65":803},[804,805,806],{"_69":812,"_63":69},{"_91":808,"_63":93,"_65":809},{"_69":807,"_63":69},")","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=95",[810],{"_69":811,"_63":69},"4. Auflage, Teil B, 3.4. Verweisungen auf technische Regeln","Beispiele für technologieoffene Formulierungen finden Sie z. B. im Handbuch der Rechtsförmlichkeit (",[814],{"_69":815,"_63":69},"Sie können die Technologie bereits im Gesetz festschreiben und in der Verordnung ausdefinieren. Tauschen Sie sich dafür mit den umsetzenden Akteurinnen und Akteuren aus und nutzen Sie unseren Support.",{"_63":75,"_76":77,"_65":817},[818,819,820,821],{"_63":83,"_65":858},{"_63":83,"_65":855},{"_63":83,"_65":832},{"_63":83,"_65":822},[823,824,825],{"_69":831,"_63":69},{"_91":827,"_63":93,"_65":828},{"_69":826,"_63":69}," wiederverwendet werden könnten?","https://interoperable-europe.ec.europa.eu/solutions",[829],{"_69":830,"_63":69},"existierende europäische Interoperabilitätslösungen","Wurde untersucht, ob bereits ",[833,834,835,836,837,838,839],{"_69":854,"_63":69},{"_91":850,"_63":93,"_65":851},{"_69":762,"_63":69},{"_91":846,"_63":93,"_65":847},{"_69":845,"_63":69},{"_91":841,"_63":93,"_65":842},{"_69":840,"_63":69}," relevant?","https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/Technische-Richtlinien/technische-richtlinien_node.html",[843],{"_69":844,"_63":69},"technische Richtlinien des BSI"," – oder ","https://www.bsi.bund.de/DE/Themen/Regulierte-Wirtschaft/NIS-2-regulierte-Unternehmen/NIS-2-FAQ/FAQ-zu-NIS-2_node.html",[848],{"_69":849,"_63":69},"NIS2","https://www.personalausweisportal.de/Webs/PA/DE/verwaltung/eIDAS-verordnung-der-EU/eidas-verordnung-der-eu-node.html",[852],{"_69":853,"_63":69},"eIDAS","Sind EU-Vorgaben – wie ",[856],{"_69":857,"_63":69},"Existieren für die beschriebenen digitalen Prozesse bereits etablierte, technische Lösungen? Ermöglicht die Regelung die Nutzung dieser Systeme bzw. den Anschluss an sie?",[859],{"_69":860,"_63":69},"Wie viel Spielraum bzw. Standardisierung brauchen die umsetzenden Akteurinnen und Akteuren? Das hängt auch davon ab, ob Sie an einem Gesetz oder einer Verordnung arbeiten.",{"_63":64,"_65":866},{"_63":64,"_65":863},[864],{"_69":865,"_63":69},"Gestalten Sie die Regelung so, dass Sie die Nutzung dieser Lösungen ermöglichen oder sogar vorschreiben. Sollte es keine etablierte Lösung geben, formulieren Sie die Regelung technologieoffen.",[867,868,869],{"_69":875,"_63":69},{"_91":871,"_63":93,"_65":872},{"_69":870,"_63":69},". Die Wiederverwendung existierender Lösungen spart Zeit und verringert den Erfüllungsaufwand für Entwicklung und Betrieb. Einheitliche Systeme, wie z. B. ein nationales Postfach, sind für Nutzende oft einfacher zu bedienen und erleichtern die Zusammenarbeit zwischen Behörden.","https://www.digitale-verwaltung.de/Webs/DV/DE/onlinezugangsgesetz/rahmenarchitektur/basisdienste-basiskomponenten/basisdienste-basiskomponenten-node.html",[873],{"_69":874,"_63":69},"Eine Übersicht finden Sie im Rahmen des OZG","Lösungen sind u. a. öffentliche Basisdienste, Softwarearchitekturen oder Komponentenbibliotheken. ","qa6whcwveoqofa32go7qv776",[891],{"_28":888,"_55":464,"_38":889,"_58":890},[880],{"_213":881,"_215":882,"_217":883},"1358",[884],{"_28":710,"_16":705},{"_63":64,"_65":885},[886],{"_69":887,"_63":69},"Die Entwicklung und bundeseinheitliche Bereitstellung von Referenzimplementierungen fördert die Nutzung etablierter und standardisierter Lösungen.","1125","Digitale Eingabesysteme im Online-Verfahren; Verordnungsermächtigung",{"_30":467,"_38":468},{"_63":64,"_65":892},[893,894],{"_69":896,"_63":69,"_71":72},{"_69":895,"_63":69}," Das Bundesministerium der Justiz regelt durch Rechtsverordnung mit Zustimmung des Bundesrates die technischen, organisatorischen und datenschutzrechtlichen Rahmenbedingungen für Entwicklung, Betrieb, Pflege und Weiterentwicklung der digitalen Eingabesysteme nach Satz 2.","Die digitalen Eingabesysteme nach § 1124 Absatz 1 und 2 werden vom Bundesministerium der Justiz als Referenzimplementierung entwickelt und den Ländern zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitgestellt. Die Länder können weitere digitale Eingabesysteme entwickeln und zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitstellen.[6]",{"_63":64,"_65":898},[899],{"_69":900,"_63":69},"Tragen Sie Ihre Erläuterung ein z.B.: „Datenstandard definiert, siehe § 3a, rechtliche Voraussetzung zum Datenaustausch geschaffen, siehe § 3b”.",{"_63":64,"_65":902},[903,904,905],{"_69":911,"_63":69},{"_91":907,"_63":93,"_65":908},{"_69":906,"_63":69}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[909],{"_69":910,"_63":69},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_63":64,"_65":913},[914],{"_69":915,"_63":69},"Digitale Angebote lassen sich schneller, günstiger und sicherer bereitstellen, wenn sie auf bestehenden Technologien, offenen Schnittstellen und Open-Source aufbauen – was zugleich die Interoperabilität fördert.",{"_63":64,"_65":917},[918,919,920],{"_69":911,"_63":69},{"_91":907,"_63":93,"_65":921},{"_69":906,"_63":69},[922],{"_69":910,"_63":69},"s18bibg9sdf0jt8up7h8btup",[1179],[1175],[1164],[1161],"datenwiederverwendung-benoetigt-einheitliches-recht",{"_14":1126,"_28":293,"_43":1127,"_52":1128,"_210":1129},[931,932,933,934,935],{"_38":1100,"_40":1101,"_18":1102,"_43":1103,"_45":1104,"_47":-5,"_32":-5},{"_38":1056,"_40":1057,"_18":1058,"_43":1059,"_45":1060,"_47":-5,"_32":1061},{"_38":1022,"_40":1023,"_18":1024,"_43":1025,"_45":1026,"_47":-5,"_32":1027},{"_38":959,"_40":960,"_18":961,"_43":962,"_45":963,"_47":-5,"_32":964},{"_38":936,"_40":937,"_18":938,"_43":939,"_45":940,"_47":-5,"_32":-5},"Suchen Sie frühzeitig den Austausch mit allen Beteiligten","Frühzeitigen Austausch suchen","Suchen Sie frühzeitig den Austausch mit allen Beteiligten: Beziehen Sie Normadressaten und umsetzende Behörden frühzeitig in den Prozess ein, um eine kohärente und effiziente Umsetzung der Regelung zu ermöglichen.",[955],[941],{"_63":75,"_76":77,"_65":942},[943,944,945],{"_63":83,"_65":952},{"_63":83,"_65":949},{"_63":83,"_65":946},[947],{"_69":948,"_63":69},"Besteht die Möglichkeit, im Zuge des Vorhabens auch IT-Verfahren zu modernisieren? Wie können alle Beteiligten davon profitieren?",[950],{"_69":951,"_63":69},"Wie ist die Erfahrung mit existierenden Systemen?",[953],{"_69":954,"_63":69},"Wie viel Vorlauf benötigen beteiligte Unternehmen, um IT-Systeme anzupassen oder umzustellen?",{"_63":64,"_65":956},[957],{"_69":958,"_63":69},"Neben rein technischen Voraussetzungen gilt es auch zu beachten, wie sich organisatorische Aspekte auf die Umsetzung Ihres Vorhabens auswirken. Hier hilft der Austausch mit anderen Beteiligten, wie z. B. den Behörden oder IT-Beauftragten.","Nutzen Sie bestehende technische Standards","Technische Standards nutzen","Nutzen Sie bestehende technische Standards: Greifen Sie auf etablierte technische Vorgaben zurück, um die Kompatibilität von Systemen zu gewährleisten und einen effizienten Datenaustausch zu fördern.",[987,988],[977],{"_14":965,"_28":460,"_43":966,"_52":967},"t0037mojhj4ibwqs1d5zleq9",[973],{"_28":968,"_55":969,"_38":-5,"_58":970},"23a","BVerfGG",{"_30":971,"_38":972},"elektronischer-rechtsverkehr-mit-dem-bundesverfassungsgericht-b-verf-g","Elektronischer Rechtsverkehr mit dem Bundesverfassungsgericht – BVerfGG",{"_63":64,"_65":974},[975],{"_69":976,"_63":69,"_71":72},"Das elektronische Dokument muss für die Bearbeitung durch das Bundesverfassungsgericht geeignet sein. Für die Übermittlung und die Eignung zur Bearbeitung durch das Bundesverfassungsgericht gelten die in der Elektronischer-Rechtsverkehr-Verordnung geregelten technischen Rahmenbedingungen des elektronischen Rechtsverkehrs entsprechend.[2]",{"_63":75,"_76":77,"_65":978},[979,980],{"_63":83,"_65":984},{"_63":83,"_65":981},[982],{"_69":983,"_63":69},"Wurde beachtet, wie die Daten übertragen werden sollen?",[985],{"_69":986,"_63":69},"Welche Datenformate existieren bereits? Muss gegebenenfalls ein neuer Standard entwickelt oder ein bestehender Standard erweitert werden?",{"_63":64,"_65":1019},{"_63":64,"_65":989},[990,991,992,993,994,995,996,997,998],{"_69":1018,"_63":69},{"_91":1014,"_63":93,"_65":1015},{"_69":1013,"_63":69},{"_91":1009,"_63":93,"_65":1010},{"_69":1008,"_63":69},{"_91":1004,"_63":93,"_65":1005},{"_69":1003,"_63":69},{"_91":999,"_63":93,"_65":1000},{"_69":117,"_63":69},"https://www.verwaltungsdaten-informationsplattform.de",[1001],{"_69":1002,"_63":69},"Verwaltungsdaten-Informationsplattform"," und auf der ","https://www.xrepository.de/",[1006],{"_69":1007,"_63":69},"XRepository"," mit zugehörigem ","https://www.xoev.de/",[1011],{"_69":1012,"_63":69},"XÖV",", auf den Seiten des ","https://www.fitko.de/",[1016],{"_69":1017,"_63":69},"FITKO","Informationen zu Standards der öffentlichen Verwaltung erhalten Sie bei der ",[1020],{"_69":1021,"_63":69},"Nutzen Sie geeignete technische Standards, wie z. B. Datenaustauschformate, um den Austausch zwischen IT-Systemen zu begünstigen. Möglicherweise ist es sinnvoll, diese in der Regelung vorzuschreiben.","Machen Sie erhobene Daten für andere nutzbar","Datennachnutzung ermöglichen","Machen Sie erhobene Daten für andere nutzbar: Ermöglichen Sie den datenschutzkonformen Zugriff und die Wiederverwendung von Daten, um Synergien zu schaffen und mehrfachen Erhebungsaufwand zu vermeiden.",[1052],[1038],{"_14":1028,"_28":27,"_43":1029,"_52":1030},"sdtovch52centy3wu4grz3ko",[1032],{"_28":133,"_55":134,"_38":135,"_58":1031},{"_30":137,"_38":138},{"_63":64,"_65":1033},[1034,1035],{"_69":1037,"_63":69,"_71":72},{"_69":1036,"_63":69},", soweit es für den Vollzug des Gebäudeenergiegesetzes vom 8. August 2020 (BGBl. I S. 1728), das durch Artikel 1 des Gesetzes vom 16. Oktober 2023 (BGBl. 2023 I Nr. 280) geändert worden ist, erforderlich ist. Absatz 4 Satz 2 bis 5 ist entsprechend anzuwenden.","Das Umweltbundesamt richtet eine elektronische Schnittstelle ein, die es ermöglicht, Daten an die nach Landesrecht zuständigen Behörden zu übermitteln[2]",{"_63":75,"_76":77,"_65":1039},[1040,1041,1042],{"_63":83,"_65":1049},{"_63":83,"_65":1046},{"_63":83,"_65":1043},[1044],{"_69":1045,"_63":69},"Ist ein transeuropäischer Datenaustausch möglich? Gibt es passende Lizenzmodelle?",[1047],{"_69":1048,"_63":69},"Wie werden die Daten verwaltet? Sind die Verantwortlichkeiten klar?",[1050],{"_69":1051,"_63":69},"Stehen der Nachnutzung der Daten rechtliche Beschränkungen im Weg? Können erhobene Daten sogar öffentlich geteilt werden?",{"_63":64,"_65":1053},[1054],{"_69":1055,"_63":69},"Müssen neue Daten erhoben werden, sollten Sie eine Nachnutzung dieser Daten ermöglichen.","Nutzen Sie existierende Daten","Existierende Daten nachnutzen","Nutzen Sie existierende Daten: Wenden Sie das Once-Only-Prinzip konsequent an, damit Nutzende Daten nur einmal angeben müssen und so Kosten und Zeit gespart werden.",[1096],[1074],{"_14":1062,"_28":29,"_43":1063,"_52":1064},"aeym55q2neygiz4irjpf8bll",[1068],{"_28":1065,"_55":297,"_38":1066,"_58":1067},"11","Digitaler Atlas zur Postversorgung, Verordnungsermächtigung",{"_30":300,"_38":301},{"_63":64,"_65":1069},[1070,1071],{"_69":1073,"_63":69},{"_69":1072,"_63":69,"_71":72},"Soweit möglich greift die Bundesnetzagentur auf die Daten, die ihr nach § 10 Absatz 1 übermittelt werden, zurück.[2]","Anbieter sind verpflichtet, der Bundesnetzagentur die Informationen nach Absatz 2 auf Anforderung zu übermitteln. Die Bundesnetzagentur kann durch Allgemeinverfügung geeignete Vorgaben machen, in welcher Form, in welchem technischen Format und in welchem Detailgrad die Informationen nach Absatz 2 zu übermitteln sind und in welchen Zeitintervallen die Informationen zu aktualisieren sind. ",{"_63":75,"_76":77,"_65":1075},[1076,1077],{"_63":83,"_65":1081},{"_63":83,"_65":1078},[1079],{"_69":1080,"_63":69},"Genügen die Daten den Anforderungen an Qualität und Aktualität oder sollten Kontrolldaten erhoben werden? Stehen Löschfristen einer Nachnutzung im Wege?",[1082,1083,1084,1085,1086],{"_69":1095,"_63":69},{"_91":1091,"_63":93,"_65":1092},{"_69":762,"_63":69},{"_91":1087,"_63":93,"_65":1088},{"_69":117,"_63":69},"https://data.gov.de/",[1089],{"_69":1090,"_63":69},"data.gov.de","https://www.verwaltungsdaten-informationsplattform.de/",[1093],{"_69":1094,"_63":69},"verwaltungsdaten-informationsplattform.de","Können existierende verwaltungsinterne oder öffentliche Daten wiederverwendet werden? Recherchieren Sie u. a. auf ",{"_63":64,"_65":1097},[1098],{"_69":1099,"_63":69},"Überprüfen Sie, ob Daten schon an anderer Stelle zur Verfügung stehen und genutzt werden können. Optimalerweise wird auf die Originaldaten zugegriffen, statt diese zu kopieren. Für einen Datenaustausch zwischen Behörden müssen Sie dann eine geeignete Rechtsgrundlage schaffen.","Nutzen Sie harmonisierte Rechtsbegriffe","Harmonisierung von Rechtsbegriffen","Nutzen Sie harmonisierte Rechtsbegriffe: Verwenden Sie konsistente und abgestimmte Begriffe im Recht, um die Grundlage für einen reibungslosen, datenschutzkonformen Datenaustausch zu schaffen.",[1115,1116,1117],[1105],{"_63":75,"_76":77,"_65":1106},[1107,1108],{"_63":83,"_65":1112},{"_63":83,"_65":1109},[1110],{"_69":1111,"_63":69},"Haben Sie die Konsistenz zu Regelwerken der EU und von anderen EU-Staaten betrachtet?",[1113],{"_69":1114,"_63":69},"Haben diese Begriffe innerhalb und außerhalb Ihres Rechtsbereichs die gleiche Bedeutung? Ist eine übergreifende Harmonisierung nötig?",{"_63":64,"_65":1123},{"_63":64,"_65":1120},{"_63":64,"_65":1118},[1119],{"_69":308,"_63":69},[1121],{"_69":1122,"_63":69},"Es kann nötig sein, Begriffe über Ihren Rechtsbereich hinaus zu harmonisieren, um bestehende Daten zu verwenden. Ist dies nicht möglich, können Sie die Informationen möglicherweise aus verschiedenen Datenpunkten zusammensetzen, etwa das Einkommen aus Gehalt und weiteren Einnahmen.",[1124],{"_69":1125,"_63":69},"Um wiederverwendet zu werden, müssen Daten die gleiche inhaltliche Bedeutung haben, d. h. semantisch interoperabel sein. Dafür müssen die Rechtsbegriffe einheitlich definiert und verwendet werden.","hpcdwgmccb8r01rbouf3u8ok",[1145,1146],{"_28":133,"_55":134,"_38":135,"_58":1144},[1130],{"_213":1131,"_215":1132,"_217":1133},"1402",[1134],{"_28":460,"_16":504},{"_63":75,"_76":77,"_65":1135},[1136,1137],{"_63":83,"_65":1141},{"_63":83,"_65":1138},[1139],{"_69":1140,"_63":69},"Im folgenden Absatz wird der Abgleich und Austausch der Daten näher spezifiziert und erweitert.  ",[1142],{"_69":1143,"_63":69},"Verringert die Fehleranfälligkeit durch den Datenabgleich.",{"_30":137,"_38":138},{"_63":64,"_65":1156},{"_63":75,"_76":147,"_65":1147},[1148,1149],{"_63":83,"_65":1153},{"_63":83,"_65":1150},[1151],{"_69":1152,"_63":69},"thermischer Energie aus Gas aus oder auf Basis von erneuerbarer Energie oder kohlenstoffarmem Gas.",[1154],{"_69":1155,"_63":69},"Gas aus oder auf Basis von thermischer Energie sowie",[1157,1158],{"_69":1160,"_63":69,"_71":72},{"_69":1159,"_63":69}," im Hinblick auf die Erzeugung von","Für einen effizienten Registerbetrieb gleicht das Umweltbundesamt die im Herkunftsnachweisregister für Gas und die im Herkunftsnachweisregister für Wärme oder Kälte gespeicherten Daten, einschließlich personenbezogener Daten, miteinander ab und tauscht sie zwischen diesen Registern aus[2]",{"_63":64,"_65":1162},[1163],{"_69":900,"_63":69},{"_63":64,"_65":1165},[1166,1167,1168],{"_69":1174,"_63":69},{"_91":1170,"_63":93,"_65":1171},{"_69":1169,"_63":69}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[1172],{"_69":1173,"_63":69},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_63":64,"_65":1176},[1177],{"_69":1178,"_63":69},"Das Once-Only-Prinzip spart Zeit und Kosten, indem Daten nur einmal angegeben und dann auf Basis harmonisierter Rechtsbegriffe, Datenschutz und technischer Standards wiederverwendet werden.",{"_63":64,"_65":1180},[1181,1182,1183],{"_69":1174,"_63":69},{"_91":1170,"_63":93,"_65":1184},{"_69":1169,"_63":69},[1185],{"_69":1173,"_63":69},"r57rc9d82ulv2bsc3gdbnj73","Digitale Angebote für alle nutzbar gestalten",[1412,1413,1414],[1408],[1404],[1400],"digitale-angebote-fuer-alle-nutzbar-gestalten",{"_14":459,"_28":460,"_43":1349,"_52":1350,"_210":1351},[1195,1196,1197,1198,1199],{"_38":1337,"_40":1338,"_18":1339,"_43":1340,"_45":-5,"_47":-5,"_32":-5},{"_38":1291,"_40":1292,"_18":1293,"_43":1294,"_45":-5,"_47":1295,"_32":1296},{"_38":1283,"_40":1284,"_18":1285,"_43":1286,"_45":-5,"_47":-5,"_32":-5},{"_38":1237,"_40":1238,"_18":1239,"_43":1240,"_45":1241,"_47":1242,"_32":-5},{"_38":1200,"_40":1201,"_18":1202,"_43":1203,"_45":1204,"_47":-5,"_32":1205},"Stellen Sie eine nutzerfreundliche Umsetzung sicher","Nutzerfreundlichkeit","Stellen Sie eine nutzerfreundliche Umsetzung sicher: Sorgen Sie für eine an den Nutzenden orientierte Entwicklung, die eine einfache, intuitive und zugängliche Interaktion mit dem digitalen Angebot gewährleistet.",[1233],[1218],{"_14":1206,"_28":29,"_43":1207,"_52":1208},"yaa803r10yjs4h9ay4srsb84",[1212],{"_28":1209,"_55":464,"_38":1210,"_58":1211},"1130","Entwicklung und Bereitstellung; Verordnungsermächtigungen",{"_30":467,"_38":468},{"_63":64,"_65":1213},[1214,1215],{"_69":1217,"_63":69},{"_69":1216,"_63":69,"_71":72},"Sie ist nach Maßgabe der Barrierefreie-Informationstechnik-Verordnung barrierefrei zu gestalten. Ferner ist bei der Gestaltung der Kommunikationsplattform deren Nutzerfreundlichkeit sowie eine einfache und intuitive Bedienbarkeit sicherzustellen.[1]","Die nach Absatz 2 entwickelte Kommunikationsplattform ist über ein Justizportal des Bundes und der Länder für die Nutzer bereitzustellen. ",{"_63":75,"_76":77,"_65":1219},[1220,1221],{"_63":83,"_65":1230},{"_63":83,"_65":1222},[1223,1224,1225],{"_69":1229,"_63":69},{"_91":758,"_63":93,"_65":1227},{"_69":1226,"_63":69}," an? Dieser stellt eine nutzerzentrierte Entwicklung sicher. Er unterstützt umsetzende Akteure dabei, die verbindlichen Qualitätsanforderungen zu erfüllen.",[1228],{"_69":761,"_63":69},"Ergeben sich für den Vollzug Anforderungen aus dem ",[1231],{"_69":1232,"_63":69},"Was ist die wichtigste Aufgabe aus Sicht der Nutzenden?",{"_63":64,"_65":1234},[1235],{"_69":1236,"_63":69},"Barrierearme Angebote sind oft auch nutzerfreundlicher. Darüber hinaus macht eine nutzerzentrierte Entwicklung, die z. B. in kleinen Schritten agiert und Texte in einfacher Sprache oder mehrsprachig gestaltet, ihr Angebot zugänglicher.","Denken Sie Barrierefreiheit von Anfang an mit","Barrierefreiheit","Denken Sie Barrierefreiheit von Anfang an mit: Gestalten Sie das digitale Angebot so, dass es ohne jegliche Hürden von allen Nutzenden, unabhängig von ihren individuellen Bedürfnissen, uneingeschränkt genutzt werden kann.",[1272],[1266],[1243],{"_63":75,"_76":77,"_65":1244},[1245,1246],{"_63":83,"_65":1256},{"_63":83,"_65":1247},[1248,1249,1250],{"_69":1255,"_63":69},{"_91":1251,"_63":93,"_65":1252},{"_69":807,"_63":69},"https://www.gesetze-im-internet.de/sgb_5/__354.html",[1253],{"_69":1254,"_63":69},"§ 354 SGB V","[...] nach dem Stand der Technik auch die erforderlichen technischen und organisatorischen Verfahren festzulegen oder technischen Voraussetzungen zu schaffen dafür, dass [...] Daten [...] barrierefrei zur Verfügung gestellt und [...] barrierefrei verarbeitet werden können [...] (",[1257,1258,1259],{"_69":1265,"_63":69},{"_91":1261,"_63":93,"_65":1262},{"_69":1260,"_63":69},"). So eine Formulierung muss in einer Verordnung ausgestaltet werden.","https://www.gesetze-im-internet.de/sgb_9_2018/__106.html",[1263],{"_69":1264,"_63":69},"§ 106 Abs. 1 SGB IX","\"Die Beratung erfolgt in einer für den Leistungsberechtigten wahrnehmbaren Form\" (",{"_63":75,"_76":77,"_65":1267},[1268],{"_63":83,"_65":1269},[1270],{"_69":1271,"_63":69},"Haben Sie die Bedürfnisse von Menschen mit unterschiedlichen Arten von Behinderungen berücksichtigt?",{"_63":64,"_65":1273},[1274,1275,1276],{"_69":1282,"_63":69},{"_91":1278,"_63":93,"_65":1279},{"_69":1277,"_63":69}," barrierefrei sein. Barrierefrei bedeutet, dass Menschen mit und ohne Behinderung das Angebot in gleicher Weise nutzen können. Da es viele unterschiedliche Arten von Behinderungen gibt, müssen viele Aspekte beachtet werden. Etwa die Aufbereitung für blinde und sehbehinderte Menschen oder Angebote in deutscher Gebärdensprache oder leichter Sprache.","https://www.gesetze-im-internet.de/bgg/__12a.html",[1280],{"_69":1281,"_63":69},"§ 12 a Behindertengleichstellungsgesetz","Digitale Angebote müssen nach ","Denken Sie an Antragsstellung, Bearbeitung und Bescheid","Antragsprozess beachten","Denken Sie an Antragsstellung, Bearbeitung und Bescheid: Planen Sie den vollständigen Lebenszyklus der Daten, damit diese durchgehend digital verarbeitet werden können und ihre Qualität im Prozess gesichert wird.",[1287],{"_63":64,"_65":1288},[1289],{"_69":1290,"_63":69},"Für eine erfolreiche Digitalisierung ist es wichtig, dass Sie den gesamten Prozess des Vollzugs Ihrer Regelung betrachten. Dies verhindert Logik- und Medienbrüche.","Formulieren Sie die Regelung technologieoffen","Technologieoffenheit","Formulieren Sie die Regelungen technologieoffen: Stellen Sie sicher, dass Vorschriften nicht an spezifische technische Lösungen gebunden sind, um die Nutzung etablierter oder zukünftiger Technologien zu ermöglichen.",[1318,1319,1320],[1311],{"_14":1297,"_28":27,"_43":1298,"_52":1299},"eed54a9k0yrk07n6317zk0o8",[1301],{"_28":54,"_55":56,"_38":57,"_58":1300},{"_30":60,"_38":61},{"_63":64,"_65":1302},[1303,1304,1305,1306],{"_69":1310,"_63":69,"_71":72},{"_69":1309,"_63":69},{"_69":1308,"_63":69,"_71":72},{"_69":1307,"_63":69},"; Absatz 3 Satz 4 bis 6 gilt entsprechend. Das Luftfahrt-Bundesamt stellt sicher, dass das Register insbesondere den Vorgaben der Artikel 24, 25 und 32 der Verordnung (EU) 2016/679 entspricht.","Das Luftfahrt-Bundesamt kann die Registrierung eines Betreibers eines unbemannten Fluggerätes für den Betrieb in den Betriebskategorien „offen“ und „speziell“ durch automatische Einrichtungen bestätigen, sofern kein Anlass besteht, den Einzelfall durch Amtsträger zu bearbeiten[5]",", die für alle von ihm nach Absatz 1 Satz 1 betriebenen unbemannten Fluggeräte gilt und dem Luftfahrt-Bundesamt eine individuelle Identifizierung des Betreibers nach Artikel 14 der Durchführungsverordnung (EU) 2019/947 ermöglicht. ","Das Luftfahrt-Bundesamt übermittelt jedem Betreiber nach Absatz 1 Satz 1 elektronisch eine Registrierungsnummer[1]",{"_63":64,"_65":1312},[1313,1314,1315],{"_69":1317,"_63":69,"_661":72},{"_69":762,"_63":69},{"_69":1316,"_63":69,"_661":72},"„Der Antrag ist zu stellen.“","„Der Antrag ist elektronisch oder schriftlich zu stellen.“",{"_63":64,"_65":1333},{"_63":64,"_65":1330},{"_63":64,"_65":1321},[1322,1323,1324],{"_69":1329,"_63":69},{"_91":1326,"_63":93,"_65":1327},{"_69":1325,"_63":69},"“. Ob das sinnvoll ist, hängt vom konkreten Einzelfall ab.","https://digitalcheck.bund.de/methoden/fuenf-prinzipien/etablierte-technologien-ermoeglichen-effiziente-umsetzung",[1328],{"_69":705,"_63":69},"Andererseits kann die Nutzung etablierter Basisdienste die Umsetzung erleichtern und die Anwendung für Nutzende vereinfachen – im Sinne des Prinzips „",[1331],{"_69":1332,"_63":69},"Wenn Sie Übertragungswege – wie DE-Mail oder PDF – festlegen, riskieren Sie, dass Ihre Regelung bald nicht mehr dem Stand der Technik entspricht.",[1334],{"_1335":72,"_69":1336,"_63":69},"bold","Prüfen Sie, ob die Nennung spezifischer Technologien notwendig bzw. gerechtfertigt ist.","Ermöglichen Sie digitale Kommunikation und Bearbeitung","Digitale Kommunikation","Ermöglichen Sie digitale Kommunikation: Beseitigen Sie Hürden wie Schriftform oder persönliches Erscheinen und bieten Sie alternative Kommunikationswege an.",[1341,1342],{"_63":64,"_65":1346},{"_63":64,"_65":1343},[1344],{"_69":1345,"_63":69},"Digitale Kommunikation sollte immer bedarfsorientiert und inklusiv sein – in bestimmten Fällen kann z. B. ergänzend auch die Schriftform sinnvoll sein, sofern eine digitale Weiterverarbeitung sichergestellt ist. Bürgerinnen und Bürger, die keine digitalen Angebote nutzen können oder wollen, müssen dabei auch bedacht werden.",[1347],{"_69":1348,"_63":69},"Digital zu kommunizieren bietet viele Vorteile: Anträge und Bescheide können in Echtzeit übermittelt werden, was Wartezeiten für Bürgerinnen, Bürger und Unternehmen verkürzt. Werden Anträge und sonstige Daten digital an die Verwaltung übermittelt, können sie außerdem effizient digital weiterverarbeitet, geprüft und an weitere beteiligte Behörden übermittelt werden.",[1385,1386],{"_28":463,"_55":464,"_38":465,"_58":1384},[1352,1353,1354],{"_213":1371,"_215":1372,"_217":1373},{"_213":1362,"_215":1363,"_217":1364},{"_213":1355,"_215":1356,"_217":1357},"1338",[1358],{"_28":29,"_16":17},{"_63":64,"_65":1359},[1360],{"_69":1361,"_63":69},"Stellt die Informationssicherheit sicher, indem sie die Anforderung eines sicheren Verfahrens stellt, das die Authentizität und Integrität der Daten gewährleistet.","1337",[1365],{"_28":27,"_16":273},{"_63":75,"_76":77,"_65":1366},[1367],{"_63":83,"_65":1368},[1369],{"_69":1370,"_63":69},"Geht von einer automatisierten Bearbeitung der Daten aus.","1336",[1374],{"_28":293,"_16":1187},{"_63":75,"_76":77,"_65":1375},[1376,1377],{"_63":83,"_65":1381},{"_63":83,"_65":1378},[1379],{"_69":1380,"_63":69},"Schriftformerfordernisse werden durch die digitale Übermittlung ersetzt.",[1382],{"_69":1383,"_63":69},"Die digitale Übermittlung von Dokumenten ermöglicht eine Kommunikation über die digitale Kommunikationsplattform.",{"_30":467,"_38":468},{"_63":64,"_65":1397},{"_63":75,"_76":147,"_65":1387},[1388,1389,1390],{"_63":83,"_65":1395},{"_63":83,"_65":1393},{"_63":83,"_65":1391},[1392],{"_69":477,"_63":69,"_71":72},[1394],{"_69":480,"_63":69,"_71":72},[1396],{"_69":483,"_63":69},[1398,1399],{"_69":488,"_63":69,"_71":72},{"_69":487,"_63":69},{"_63":64,"_65":1401},[1402],{"_69":1403,"_63":69},"Tragen Sie Ihre Erläuterung ein z.B.: „Online-Beratung wird ermöglicht, siehe § 1a“.",{"_63":64,"_65":1405},[1406],{"_69":1407,"_63":69},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_63":64,"_65":1409},[1410],{"_69":1411,"_63":69},"Eine Regelung gilt als erfolgreich digitalisiert, wenn Bürger und Unternehmen Anträge intuitiv online stellen können, Behörden die Daten systemübergreifend ohne manuelle Nacherfassung verarbeiten und Digitaltauglichkeit von Anfang an mitgedacht wurde.",{"_63":64,"_65":1431},{"_63":64,"_65":1428},{"_63":75,"_76":77,"_65":1415},[1416,1417,1418],{"_63":83,"_65":1425},{"_63":83,"_65":1422},{"_63":83,"_65":1419},[1420],{"_69":1421,"_63":69},"wie Barrierefreiheit zu bedenken ist.",[1423],{"_69":1424,"_63":69},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[1426],{"_69":1427,"_63":69},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[1429],{"_69":1430,"_63":69},"Erfahren Sie in diesem Abschnitt,",[1432],{"_69":1407,"_63":69},{"_1434":1435,"_1436":1437,"_1438":1437,"_1439":1440,"_1441":308},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_1442":72,"_1443":72,"_1444":72,"_1445":72,"_1446":72},"posthogKey","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
