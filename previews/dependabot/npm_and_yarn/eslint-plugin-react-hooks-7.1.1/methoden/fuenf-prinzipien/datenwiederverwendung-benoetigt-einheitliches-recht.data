[{"_1":2,"_3":4},"root",{"_5":434},"routes/methoden.fuenf-prinzipien.$prinzip",{"_5":6},"data",{"_7":8,"_9":10},"prinzip",{"_34":35,"_16":28,"_36":37,"_20":30,"_38":30,"_18":29,"_39":40,"_41":42},"prinzipList",[11,12,13,14,15],{"_16":31,"_18":32,"_20":33},{"_16":28,"_18":29,"_20":30},{"_16":25,"_18":26,"_20":27},{"_16":22,"_18":23,"_20":24},{"_16":17,"_18":19,"_20":21},"Name","Datenschutz und Informationssicherheit schaffen Vertrauen","URLBezeichnung","datenschutz-und-informationssicherheit-schaffen-vertrauen","order",5,"Automatisierung basiert auf eindeutigen Regelungen","automatisierung-basiert-auf-eindeutigen-regelungen",4,"Etablierte Technologien ermöglichen effiziente Umsetzung","etablierte-technologien-ermoeglichen-effiziente-umsetzung",3,"Datenwiederverwendung benötigt einheitliches Recht","datenwiederverwendung-benoetigt-einheitliches-recht",2,"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",1,"documentId","s18bibg9sdf0jt8up7h8btup","Beschreibung",[423],"Nummer","Beispiel",{"_34":384,"_38":33,"_54":385,"_97":386,"_387":388},"Aspekte",[43,44,45,46,47],{"_38":251,"_49":252,"_51":253,"_36":254,"_54":255,"_56":256,"_58":-5,"_59":257,"_39":-5},{"_38":201,"_49":202,"_51":203,"_36":204,"_54":205,"_56":206,"_58":-5,"_59":207,"_39":208},{"_38":160,"_49":161,"_51":162,"_36":163,"_54":164,"_56":165,"_58":-5,"_59":166,"_39":167},{"_38":87,"_49":88,"_51":89,"_36":90,"_54":91,"_56":92,"_58":-5,"_59":93,"_39":94},{"_38":48,"_49":50,"_51":52,"_36":53,"_54":55,"_56":57,"_58":-5,"_59":60,"_39":-5},"2.5","Titel","Suchen Sie frühzeitig den Austausch mit allen Beteiligten","Kurzbezeichnung","Austausch","Suchen Sie frühzeitig den Austausch mit allen Beteiligten: Beziehen Sie Normadressaten und umsetzende Behörden frühzeitig in den Prozess ein, um eine kohärente und effiziente Umsetzung der Regelung zu ermöglichen.","Text",[82],"Leitfragen",[61],"Formulierungsbeispiel","Anwendung",[],{"_62":63,"_64":65,"_66":67},"type","list","format","unordered","children",[68,69,70],{"_62":71,"_66":79},{"_62":71,"_66":76},{"_62":71,"_66":72},"list-item",[73],{"_74":75,"_62":74},"text","Besteht die Möglichkeit, im Zuge des Vorhabens auch IT-Verfahren zu modernisieren? Wie können alle Beteiligten davon profitieren?",[77],{"_74":78,"_62":74},"Wie ist die Erfahrung mit existierenden Systemen?",[80],{"_74":81,"_62":74},"Wie viel Vorlauf benötigen beteiligte Unternehmen, um IT-Systeme anzupassen oder umzustellen?",{"_62":83,"_66":84},"paragraph",[85],{"_74":86,"_62":74},"Neben rein technischen Voraussetzungen gilt es auch zu beachten, wie sich organisatorische Aspekte auf die Umsetzung Ihres Vorhabens auswirken. Hier hilft der Austausch mit anderen Beteiligten, wie z. B. den Behörden oder IT-Beauftragten.","2.4","Nutzen Sie bestehende technische Standards","Technische Standards","Nutzen Sie bestehende technische Standards: Greifen Sie auf etablierte technische Vorgaben zurück, um die Kompatibilität von Systemen zu gewährleisten und einen effizienten Datenaustausch zu fördern.",[122,123],[112],[],{"_34":95,"_38":30,"_54":96,"_97":98},"t0037mojhj4ibwqs1d5zleq9",[106],"Paragraph",{"_38":99,"_100":101,"_49":-5,"_102":103},"23a","Gesetz","BVerfGG","Beispielvorhaben",{"_18":104,"_49":105},"elektronischer-rechtsverkehr-mit-dem-bundesverfassungsgericht-b-verf-g","Elektronischer Rechtsverkehr mit dem Bundesverfassungsgericht – BVerfGG",{"_62":83,"_66":107},[108],{"_74":109,"_62":74,"_110":111},"Das elektronische Dokument muss für die Bearbeitung durch das Bundesverfassungsgericht geeignet sein. Für die Übermittlung und die Eignung zur Bearbeitung durch das Bundesverfassungsgericht gelten die in der Elektronischer-Rechtsverkehr-Verordnung geregelten technischen Rahmenbedingungen des elektronischen Rechtsverkehrs entsprechend.[2]","underline",true,{"_62":63,"_64":65,"_66":113},[114,115],{"_62":71,"_66":119},{"_62":71,"_66":116},[117],{"_74":118,"_62":74},"Wurde beachtet, wie die Daten übertragen werden sollen?",[120],{"_74":121,"_62":74},"Welche Datenformate existieren bereits? Muss gegebenenfalls ein neuer Standard entwickelt oder ein bestehender Standard erweitert werden?",{"_62":83,"_66":157},{"_62":83,"_66":124},[125,126,127,128,129,130,131,132,133],{"_74":156,"_62":74},{"_135":152,"_62":137,"_66":153},{"_74":151,"_62":74},{"_135":147,"_62":137,"_66":148},{"_74":146,"_62":74},{"_135":142,"_62":137,"_66":143},{"_74":141,"_62":74},{"_135":136,"_62":137,"_66":138},{"_74":134,"_62":74},".","url","https://www.verwaltungsdaten-informationsplattform.de","link",[139],{"_74":140,"_62":74},"Verwaltungsdaten-Informationsplattform"," und auf der ","https://www.xrepository.de/",[144],{"_74":145,"_62":74},"XRepository"," mit zugehörigem ","https://www.xoev.de/",[149],{"_74":150,"_62":74},"XÖV",", auf den Seiten des ","https://www.fitko.de/",[154],{"_74":155,"_62":74},"FITKO","Informationen zu Standards der öffentlichen Verwaltung erhalten Sie bei der ",[158],{"_74":159,"_62":74},"Nutzen Sie geeignete technische Standards, wie z. B. Datenaustauschformate, um den Austausch zwischen IT-Systemen zu begünstigen. Möglicherweise ist es sinnvoll, diese in der Regelung vorzuschreiben.","2.3","Machen Sie erhobene Daten für andere nutzbar","Datenoffenheit","Machen Sie erhobene Daten für andere nutzbar: Ermöglichen Sie den datenschutzkonformen Zugriff und die Wiederverwendung von Daten, um Synergien zu schaffen und mehrfachen Erhebungsaufwand zu vermeiden.",[197],[183],[],{"_34":168,"_38":21,"_54":169,"_97":170},"sdtovch52centy3wu4grz3ko",[177],{"_38":171,"_100":172,"_49":173,"_102":174},"39","GWKH","Überprüfung der gespeicherten Daten; Datenübermittlung",{"_18":175,"_49":176},"einrichtung-herkunftsnachweisregister-fuer-gas-waerme-und-kaelte-gwkhv","Einrichtung Herkunftsnachweisregister für Gas, Wärme und Kälte  - GWKHV",{"_62":83,"_66":178},[179,180],{"_74":182,"_62":74,"_110":111},{"_74":181,"_62":74},", soweit es für den Vollzug des Gebäudeenergiegesetzes vom 8. August 2020 (BGBl. I S. 1728), das durch Artikel 1 des Gesetzes vom 16. Oktober 2023 (BGBl. 2023 I Nr. 280) geändert worden ist, erforderlich ist. Absatz 4 Satz 2 bis 5 ist entsprechend anzuwenden.","Das Umweltbundesamt richtet eine elektronische Schnittstelle ein, die es ermöglicht, Daten an die nach Landesrecht zuständigen Behörden zu übermitteln[2]",{"_62":63,"_64":65,"_66":184},[185,186,187],{"_62":71,"_66":194},{"_62":71,"_66":191},{"_62":71,"_66":188},[189],{"_74":190,"_62":74},"Ist ein transeuropäischer Datenaustausch möglich? Gibt es passende Lizenzmodelle?",[192],{"_74":193,"_62":74},"Wie werden die Daten verwaltet? Sind die Verantwortlichkeiten klar?",[195],{"_74":196,"_62":74},"Stehen der Nachnutzung der Daten rechtliche Beschränkungen im Weg? Können erhobene Daten sogar öffentlich geteilt werden?",{"_62":83,"_66":198},[199],{"_74":200,"_62":74},"Müssen neue Daten erhoben werden, sollten Sie eine Nachnutzung dieser Daten ermöglichen.","2.2","Nutzen Sie existierende Daten","Existierende Daten","Nutzen Sie existierende Daten: Wenden Sie das Once-Only-Prinzip konsequent an, damit Nutzende Daten nur einmal angeben müssen und so Kosten und Zeit gespart werden.",[247],[224],[],{"_34":209,"_38":27,"_54":210,"_97":211},"aeym55q2neygiz4irjpf8bll",[218],{"_38":212,"_100":213,"_49":214,"_102":215},"11","PostG","Digitaler Atlas zur Postversorgung, Verordnungsermächtigung",{"_18":216,"_49":217},"modernisierung-des-postrechts","Modernisierung des Postrechts – PostG",{"_62":83,"_66":219},[220,221],{"_74":223,"_62":74},{"_74":222,"_62":74,"_110":111},"Soweit möglich greift die Bundesnetzagentur auf die Daten, die ihr nach § 10 Absatz 1 übermittelt werden, zurück.[2]","Anbieter sind verpflichtet, der Bundesnetzagentur die Informationen nach Absatz 2 auf Anforderung zu übermitteln. Die Bundesnetzagentur kann durch Allgemeinverfügung geeignete Vorgaben machen, in welcher Form, in welchem technischen Format und in welchem Detailgrad die Informationen nach Absatz 2 zu übermitteln sind und in welchen Zeitintervallen die Informationen zu aktualisieren sind. ",{"_62":63,"_64":65,"_66":225},[226,227],{"_62":71,"_66":231},{"_62":71,"_66":228},[229],{"_74":230,"_62":74},"Genügen die Daten den Anforderungen an Qualität und Aktualität oder sollten Kontrolldaten erhoben werden? Stehen Löschfristen einer Nachnutzung im Wege?",[232,233,234,235,236],{"_74":246,"_62":74},{"_135":242,"_62":137,"_66":243},{"_74":241,"_62":74},{"_135":237,"_62":137,"_66":238},{"_74":134,"_62":74},"https://data.gov.de/",[239],{"_74":240,"_62":74},"data.gov.de"," oder ","https://www.verwaltungsdaten-informationsplattform.de/",[244],{"_74":245,"_62":74},"verwaltungsdaten-informationsplattform.de","Können existierende verwaltungsinterne oder öffentliche Daten wiederverwendet werden? Recherchieren Sie u. a. auf ",{"_62":83,"_66":248},[249],{"_74":250,"_62":74},"Überprüfen Sie, ob Daten schon an anderer Stelle zur Verfügung stehen und genutzt werden können. Optimalerweise wird auf die Originaldaten zugegriffen, statt diese zu kopieren. Für einen Datenaustausch zwischen Behörden müssen Sie dann eine geeignete Rechtsgrundlage schaffen.","2.1","Nutzen Sie harmonisierte Rechtsbegriffe","Harmonisierung von Rechtsbegriffen","Nutzen Sie harmonisierte Rechtsbegriffe: Verwenden Sie konsistente und abgestimmte Begriffe im Recht, um die Grundlage für einen reibungslosen, datenschutzkonformen Datenaustausch zu schaffen.",[372,373,374],[362],[258,259],{"_49":317,"_261":318,"_58":-5,"_39":-5},{"_49":260,"_261":262,"_58":-5,"_39":-5},"Nutzen Sie modularisierte Begriffe","Erklaerung",[263,264,265,266,267],{"_62":83,"_66":311},{"_62":83,"_66":302},{"_62":83,"_66":299},{"_62":63,"_64":65,"_66":278},{"_62":83,"_66":268},[269,270,271],{"_74":277,"_62":74},{"_135":273,"_62":137,"_66":274},{"_74":272,"_62":74},", S. 93ff.","https://www.normenkontrollrat.bund.de/Webs/NKR/DE/veroeffentlichungen/gutachten/_documents/2020-06-digitale-verwaltung-braucht-digitaltaugliches-recht.html",[275],{"_74":276,"_62":74},"NKR-Gutachten \"Digitale Verwaltung braucht digitaltaugliches Recht\"","Quelle: ",[279,280,281,282,283],{"_62":71,"_66":296},{"_62":71,"_66":293},{"_62":71,"_66":290},{"_62":71,"_66":287},{"_62":71,"_66":284},[285],{"_74":286,"_62":74},"Sie fördert die digitaltaugliche Ausgestaltung des Begriffes und ermöglicht es, die (Sub-)Module in Datenmodule und Datenfelder zu übersetzen.",[288],{"_74":289,"_62":74},"Sie zwingt nicht zur weiteren Harmonisierung.",[291],{"_74":292,"_62":74},"Eindeutig bezeichnete Module können einen Anknüpfungspunkt für Verweise bilden.",[294],{"_74":295,"_62":74},"Der Begriff erhält eine klar ersichtliche Struktur, die sich in Datenstrukturen abbilden lässt.",[297],{"_74":298,"_62":74},"Sie sichert die einheitliche sprachliche (eindeutige) Verwendung von Begrifflichkeiten.",[300],{"_74":301,"_62":74},"Die Modularisierung des Einkommensbegriffes bietet folgende Vorteile:",[303,304,305],{"_74":310,"_62":74},{"_135":273,"_62":137,"_66":307},{"_74":306,"_62":74},", S. 93ff:",[308],{"_74":309,"_62":74},"Gutachten zum modularen Einkommensbegriff des Nationalen Normenkontrollrats (NKR)","Weiterführende Empfehlungen finden Sie im ",[312,313],{"_74":315,"_62":74,"_316":111},{"_74":314,"_62":74}," kann bei komplexen Begriffen wie Einkommen helfen: Rechtsbegriffe werden in standardisierte, klar definierte Module zerlegt. Die so erhobenen Bestandteile können je nach Bedarf neu zusammengesetzt und nachgenutzt werden, etwa das Einkommen aus Gehalt und weiteren Einnahmen.","Modularisierung","italic","Greifen Sie über (Teil-)Verweise auf bestehende Definitionen zurück",[319,320,321,322],{"_62":83,"_66":359},{"_62":83,"_66":347},{"_62":83,"_66":344},{"_62":63,"_64":65,"_66":323},[324,325],{"_62":71,"_66":335},{"_62":71,"_66":326},[327,328,329],{"_74":334,"_62":74},{"_135":330,"_62":137,"_66":331},{"_74":134,"_62":74},"http://interoperable-europe.ec.europa.eu",[332],{"_74":333,"_62":74},"Interoperable Europe Portal","Das auf EU-Ebene vereinheitlichte Vokabular zu Begriffen im Kontext der öffentlichen Verwaltung: ",[336,337,338],{"_74":343,"_62":74},{"_135":339,"_62":137,"_66":340},{"_74":134,"_62":74},"https://docs.fitko.de/fim/docs/leistungen_neu/technik/codelisten/",[341],{"_74":342,"_62":74},"Seite der FITKO","Codelisten: standardisierte, feste Listen von Codes und ihren zugehörigen Klartextbezeichnungen, die zur eindeutigen und maschinenlesbaren Darstellung von Informationen (wie Staaten, Verwaltungsleistungen oder Merkmale) in digitalen Verwaltungsprozessen dienen. Sie finden diese auf der ",[345],{"_74":346,"_62":74},"Weitere Ressourcen:",[348,349,350,351,352],{"_74":358,"_62":74},{"_135":273,"_62":137,"_66":356},{"_74":355,"_62":74},{"_74":354,"_62":74,"_316":111},{"_74":353,"_62":74},"”, S. 96ff.","Harmonisierung durch Verweise",", Abschnitt „",[357],{"_74":309,"_62":74},"Eine ausführliche Erklärung finden Sie im ",[360],{"_74":361,"_62":74},"Werden für Begriffe, die in mehreren Regelungen vorkommen (z. B. \"Einkommen\", \"Kind\"), Verweise genutzt, macht dies die Begriffe eindeutiger. Dies vereinfacht den Datenaustausch, da der entsprechende Datensatz direkt bei der datenhaltenden Behörde abgefragt werden kann. ",{"_62":63,"_64":65,"_66":363},[364,365],{"_62":71,"_66":369},{"_62":71,"_66":366},[367],{"_74":368,"_62":74},"Haben Sie die Konsistenz zu Regelwerken der EU und von anderen EU-Staaten betrachtet?",[370],{"_74":371,"_62":74},"Haben diese Begriffe innerhalb und außerhalb Ihres Rechtsbereichs die gleiche Bedeutung? Ist eine übergreifende Harmonisierung nötig?",{"_62":83,"_66":381},{"_62":83,"_66":378},{"_62":83,"_66":375},[376],{"_74":377,"_62":74},"",[379],{"_74":380,"_62":74},"Es kann nötig sein, Begriffe über Ihren Rechtsbereich hinaus zu harmonisieren, um bestehende Daten zu verwenden. Ist dies nicht möglich, können Sie die Informationen möglicherweise aus verschiedenen Datenpunkten zusammensetzen, etwa das Einkommen aus Gehalt und weiteren Einnahmen.",[382],{"_74":383,"_62":74},"Um wiederverwendet zu werden, müssen Daten die gleiche inhaltliche Bedeutung haben, d. h. semantisch interoperabel sein. Dafür müssen die Rechtsbegriffe einheitlich definiert und verwendet werden.","hpcdwgmccb8r01rbouf3u8ok",[406,407],{"_38":171,"_100":172,"_49":173,"_102":405},"PrinzipErfuellungen",[389],{"_390":391,"_261":392,"_393":394},"id","1402",[395],"Prinzip",{"_38":30,"_16":28},{"_62":63,"_64":65,"_66":396},[397,398],{"_62":71,"_66":402},{"_62":71,"_66":399},[400],{"_74":401,"_62":74},"Im folgenden Absatz wird der Abgleich und Austausch der Daten näher spezifiziert und erweitert.  ",[403],{"_74":404,"_62":74},"Verringert die Fehleranfälligkeit durch den Datenabgleich.",{"_18":175,"_49":176},{"_62":83,"_66":418},{"_62":63,"_64":408,"_66":409},"ordered",[410,411],{"_62":71,"_66":415},{"_62":71,"_66":412},[413],{"_74":414,"_62":74},"thermischer Energie aus Gas aus oder auf Basis von erneuerbarer Energie oder kohlenstoffarmem Gas.",[416],{"_74":417,"_62":74},"Gas aus oder auf Basis von thermischer Energie sowie",[419,420],{"_74":422,"_62":74,"_110":111},{"_74":421,"_62":74}," im Hinblick auf die Erzeugung von","Für einen effizienten Registerbetrieb gleicht das Umweltbundesamt die im Herkunftsnachweisregister für Gas und die im Herkunftsnachweisregister für Wärme oder Kälte gespeicherten Daten, einschließlich personenbezogener Daten, miteinander ab und tauscht sie zwischen diesen Registern aus[2]",{"_62":83,"_66":424},[425,426,427],{"_74":433,"_62":74},{"_135":429,"_62":137,"_66":430},{"_74":428,"_62":74}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[431],{"_74":432,"_62":74},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_435":436,"_437":438,"_439":438,"_440":441,"_442":377},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_443":111,"_444":111,"_445":111,"_446":111,"_447":111,"_448":111,"_449":111},"posthogKey","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
