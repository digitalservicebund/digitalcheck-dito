[{"_1":2,"_3":4},"root",{"_5":274},"routes/methoden.fuenf-prinzipien.$prinzip",{"_5":6},"data",{"_7":8,"_9":10},"prinzip",{"_34":35,"_16":25,"_36":37,"_20":27,"_38":39,"_18":26,"_40":41,"_42":43},"prinzipList",[11,12,13,14,15],{"_16":31,"_18":32,"_20":33},{"_16":28,"_18":29,"_20":30},{"_16":25,"_18":26,"_20":27},{"_16":22,"_18":23,"_20":24},{"_16":17,"_18":19,"_20":21},"Name","Datenschutz und Informationssicherheit schaffen Vertrauen","URLBezeichnung","datenschutz-und-informationssicherheit-schaffen-vertrauen","order",5,"Automatisierung basiert auf eindeutigen Regelungen","automatisierung-basiert-auf-eindeutigen-regelungen",4,"Etablierte Technologien ermöglichen effiziente Umsetzung","etablierte-technologien-ermoeglichen-effiziente-umsetzung",3,"Datenwiederverwendung benötigt einheitliches Recht","datenwiederverwendung-benoetigt-einheitliches-recht",2,"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",1,"documentId","habu0yjh39lc5wug5mqsqzaj","Beschreibung",[263],"Nummer",6,"Beispiel",{"_34":238,"_38":33,"_52":239,"_62":240,"_241":242},"Aspekte",[44,45],{"_38":125,"_47":126,"_49":127,"_36":128,"_52":129,"_54":130,"_56":131,"_57":132,"_40":133},{"_38":46,"_47":48,"_49":50,"_36":51,"_52":53,"_54":55,"_56":-5,"_57":58,"_40":59},"3.2","Titel","Bevorzugen Sie Open-Source-Software und offene Spezifikationen","Kurzbezeichnung","Open-Source-Software","Bevorzugen Sie Open-Source-Software und offene Spezifikationen: Setzen Sie auf Transparenz und Zugänglichkeit bei Code und Standards, um die Zusammenarbeit zu fördern und die Austauschbarkeit von Systemen zu gewährleisten.","Text",[98],"Leitfragen",[84],"Formulierungsbeispiel","Anwendung",[],{"_34":60,"_38":33,"_52":61,"_62":63},"u3sg1zismobz1t707uo3xav8",[72],"Paragraph",{"_38":64,"_65":66,"_47":67,"_68":69},"1134","Gesetz","ZPO","Umfang der Erprobung","Beispielvorhaben",{"_18":70,"_47":71},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit",{"_73":74,"_75":76},"type","paragraph","children",[77,78],{"_79":81,"_73":79,"_82":83},{"_79":80,"_73":79},"text"," Satz 1 gilt nicht im Anwendungsbereich des Online-Verfahrens nach Abschnitt 2 dieses Buchs.","Das Bundesministerium der Justiz kann digitale Eingabesysteme als Referenzimplementierung entwickeln und bundeseinheitlich zur Erprobung bereitstellen, soweit diese dem elektronischen Erstellen von Anträgen oder Erklärungen nach § 129a Absatz 1 dienen.[6]","underline",true,{"_73":85,"_86":87,"_75":88},"list","format","unordered",[89,90],{"_73":91,"_75":95},{"_73":91,"_75":92},"list-item",[93],{"_79":94,"_73":79},"Werden gegebenenfalls bei Neuentwicklung Quelloffenheit und offene Spezifikationen vorgeschrieben?",[96],{"_79":97,"_73":79},"Wird der Einsatz von Open-Source-Software ermöglicht und gefördert?",{"_73":74,"_75":99},[100,101,102,103,104,105,106],{"_79":124,"_73":79},{"_108":120,"_73":110,"_75":121},{"_79":119,"_73":79},{"_108":115,"_73":110,"_75":116},{"_79":114,"_73":79},{"_108":109,"_73":110,"_75":111},{"_79":107,"_73":79},".","url","https://www.zendis.de/","link",[112],{"_79":113,"_73":79},"Zentrum für digitale Souveränität","). Dies ermöglicht die Nachvollziehbarkeit der technischen Lösung und verhindert die Abhängigkeit von einzelnen Software-Anbietern. Weitere Informationen erhalten Sie beim ","https://servicestandard.gov.de/",[117],{"_79":118,"_73":79},"Servicestandard"," oder ","https://www.bundestag.de/resource/blob/194886/696f36f795961df200fb27fb6803d83e/koalitionsvertrag-data.pdf#page=152",[122],{"_79":123,"_73":79},"Koalitionsvertrag 18. Legislaturperiode","Open-Source bedeutet, dass der Quellcode eines IT-Systems veröffentlicht ist. Offene Spezifikationen beschreiben öffentlich, was ein IT-System genau leistet. Beide stärken Transparenz und Wiederverwendbarkeit (vgl. ","3.1","Ermöglichen Sie die Nutzung etablierter, öffentlicher Lösungen","Vorhandene Lösungen","Ermöglichen Sie die Nutzung etablierter, öffentlicher Lösungen: Nutzen Sie existierende und bewährte technologische Fundamente, um die Entwicklung digitaler Angebote zu beschleunigen und ihre Wirtschaftlichkeit zu steigern.",[223,224],[178],[161],[],{"_34":134,"_38":33,"_52":135,"_62":136},"g6pdcvhx2a4cleuywyb0fbuu",[140,141,142],{"_38":137,"_65":66,"_47":138,"_68":139},"1131","Kommunikations-, Austausch- und Übermittlungsformen",{"_18":70,"_47":71},{"_73":74,"_75":156},{"_73":85,"_86":146,"_75":147},{"_73":74,"_75":143},[144],{"_79":145,"_73":79},"Wurde der Nachweis der Identität nach Satz 1 erbracht, so kann die spätere Authentisierung des Inhabers des Identitätsnachweises auch durch andere geeignete Authentisierungsmittel erfolgen.","ordered",[148,149],{"_73":91,"_75":153},{"_73":91,"_75":150},[151],{"_79":152,"_73":79,"_82":83},"für die Identifizierung anderer Verfahrensbeteiligter: ein Verfahren über ein Nutzerkonto nach § 2 Absatz 5 in Verbindung mit § 3 Absatz 4 des Onlinezugangsgesetzes.[6]",[154],{"_79":155,"_73":79,"_82":83},"für die Identifizierung von Rechtsanwälten: das Verfahren zum Zugang zum besonderen elektronischen Anwaltspostfach nach § 31a Absatz 3 Satz 1 der Bundesrechtsanwaltsordnung;",[157,158],{"_79":160,"_73":79,"_82":83},{"_79":159,"_73":79},", sofern hierfür digitale Eingabesysteme zur Verfügung stehen und eines der folgenden Identifizierungsverfahren genutzt wird:","Eine in diesem Gesetz angeordnete Schriftform kann durch unmittelbare Eingabe von Anträgen und Erklärungen der Verfahrensbeteiligten über die Kommunikationsplattform nach § 1130 ersetzt werden[1]",{"_73":85,"_86":87,"_75":162},[163,164],{"_73":91,"_75":175},{"_73":91,"_75":165},[166,167,168],{"_79":174,"_73":79},{"_108":170,"_73":110,"_75":171},{"_79":169,"_73":79},")","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=95",[172],{"_79":173,"_73":79},"4. Auflage, Teil B, 3.4. Verweisungen auf technische Regeln","Beispiele für technologieoffene Formulierungen finden Sie z. B. im Handbuch der Rechtsförmlichkeit (",[176],{"_79":177,"_73":79},"Sie können die Technologie bereits im Gesetz festschreiben und in der Verordnung ausdefinieren. Tauschen Sie sich dafür mit den umsetzenden Akteurinnen und Akteuren aus und nutzen Sie unseren Support.",{"_73":85,"_86":87,"_75":179},[180,181,182,183],{"_73":91,"_75":220},{"_73":91,"_75":217},{"_73":91,"_75":194},{"_73":91,"_75":184},[185,186,187],{"_79":193,"_73":79},{"_108":189,"_73":110,"_75":190},{"_79":188,"_73":79}," wiederverwendet werden könnten?","https://interoperable-europe.ec.europa.eu/solutions",[191],{"_79":192,"_73":79},"existierende europäische Interoperabilitätslösungen","Wurde untersucht, ob bereits ",[195,196,197,198,199,200,201],{"_79":216,"_73":79},{"_108":212,"_73":110,"_75":213},{"_79":119,"_73":79},{"_108":208,"_73":110,"_75":209},{"_79":207,"_73":79},{"_108":203,"_73":110,"_75":204},{"_79":202,"_73":79}," relevant?","https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/Technische-Richtlinien/technische-richtlinien_node.html",[205],{"_79":206,"_73":79},"technische Richtlinien des BSI"," – oder ","https://www.bsi.bund.de/DE/Themen/Regulierte-Wirtschaft/NIS-2-regulierte-Unternehmen/NIS-2-FAQ/FAQ-zu-NIS-2_node.html",[210],{"_79":211,"_73":79},"NIS2","https://www.personalausweisportal.de/Webs/PA/DE/verwaltung/eIDAS-verordnung-der-EU/eidas-verordnung-der-eu-node.html",[214],{"_79":215,"_73":79},"eIDAS","Sind EU-Vorgaben – wie ",[218],{"_79":219,"_73":79},"Existieren für die beschriebenen digitalen Prozesse bereits etablierte, technische Lösungen? Ermöglicht die Regelung die Nutzung dieser Systeme bzw. den Anschluss an sie?",[221],{"_79":222,"_73":79},"Wie viel Spielraum bzw. Standardisierung brauchen die umsetzenden Akteurinnen und Akteuren? Das hängt auch davon ab, ob Sie an einem Gesetz oder einer Verordnung arbeiten.",{"_73":74,"_75":228},{"_73":74,"_75":225},[226],{"_79":227,"_73":79},"Gestalten Sie die Regelung so, dass Sie die Nutzung dieser Lösungen ermöglichen oder sogar vorschreiben. Sollte es keine etablierte Lösung geben, formulieren Sie die Regelung technologieoffen.",[229,230,231],{"_79":237,"_73":79},{"_108":233,"_73":110,"_75":234},{"_79":232,"_73":79},". Die Wiederverwendung existierender Lösungen spart Zeit und verringert den Erfüllungsaufwand für Entwicklung und Betrieb. Einheitliche Systeme, wie z. B. ein nationales Postfach, sind für Nutzende oft einfacher zu bedienen und erleichtern die Zusammenarbeit zwischen Behörden.","https://www.digitale-verwaltung.de/Webs/DV/DE/onlinezugangsgesetz/rahmenarchitektur/basisdienste-basiskomponenten/basisdienste-basiskomponenten-node.html",[235],{"_79":236,"_73":79},"Eine Übersicht finden Sie im Rahmen des OZG","Lösungen sind u. a. öffentliche Basisdienste, Softwarearchitekturen oder Komponentenbibliotheken. ","qa6whcwveoqofa32go7qv776",[257],{"_38":254,"_65":66,"_47":255,"_68":256},"PrinzipErfuellungen",[243],{"_244":245,"_246":247,"_248":249},"id","1358","Erklaerung",[250],"Prinzip",{"_38":39,"_16":25},{"_73":74,"_75":251},[252],{"_79":253,"_73":79},"Die Entwicklung und bundeseinheitliche Bereitstellung von Referenzimplementierungen fördert die Nutzung etablierter und standardisierter Lösungen.","1125","Digitale Eingabesysteme im Online-Verfahren; Verordnungsermächtigung",{"_18":70,"_47":71},{"_73":74,"_75":258},[259,260],{"_79":262,"_73":79,"_82":83},{"_79":261,"_73":79}," Das Bundesministerium der Justiz regelt durch Rechtsverordnung mit Zustimmung des Bundesrates die technischen, organisatorischen und datenschutzrechtlichen Rahmenbedingungen für Entwicklung, Betrieb, Pflege und Weiterentwicklung der digitalen Eingabesysteme nach Satz 2.","Die digitalen Eingabesysteme nach § 1124 Absatz 1 und 2 werden vom Bundesministerium der Justiz als Referenzimplementierung entwickelt und den Ländern zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitgestellt. Die Länder können weitere digitale Eingabesysteme entwickeln und zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitstellen.[6]",{"_73":74,"_75":264},[265,266,267],{"_79":273,"_73":79},{"_108":269,"_73":110,"_75":270},{"_79":268,"_73":79}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[271],{"_79":272,"_73":79},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_275":276,"_277":278,"_279":278,"_280":281,"_282":283},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_284":83,"_285":83,"_286":83,"_287":83,"_288":83,"_289":83,"_290":83},"posthogKey","","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
