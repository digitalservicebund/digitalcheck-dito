[{"_1":2,"_3":4},"root",{"_5":510},"routes/methoden.fuenf-prinzipien.$prinzip",{"_5":6},"data",{"_7":8,"_9":10},"prinzip",{"_34":35,"_16":31,"_36":37,"_20":33,"_38":33,"_18":32,"_39":40,"_41":42},"prinzipList",[11,12,13,14,15],{"_16":31,"_18":32,"_20":33},{"_16":28,"_18":29,"_20":30},{"_16":25,"_18":26,"_20":27},{"_16":22,"_18":23,"_20":24},{"_16":17,"_18":19,"_20":21},"Name","Datenschutz und Informationssicherheit schaffen Vertrauen","URLBezeichnung","datenschutz-und-informationssicherheit-schaffen-vertrauen","order",5,"Automatisierung basiert auf eindeutigen Regelungen","automatisierung-basiert-auf-eindeutigen-regelungen",4,"Etablierte Technologien ermöglichen effiziente Umsetzung","etablierte-technologien-ermoeglichen-effiziente-umsetzung",3,"Datenwiederverwendung benötigt einheitliches Recht","datenwiederverwendung-benoetigt-einheitliches-recht",2,"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",1,"documentId","r57rc9d82ulv2bsc3gdbnj73","Beschreibung",[488,489,490],"Nummer","Beispiel",{"_34":425,"_38":30,"_54":426,"_64":427,"_428":429},"Aspekte",[43,44,45,46,47],{"_38":280,"_49":281,"_51":282,"_36":283,"_54":284,"_56":-5,"_58":-5,"_59":285,"_39":-5},{"_38":226,"_49":227,"_51":228,"_36":229,"_54":230,"_56":-5,"_58":231,"_59":232,"_39":233},{"_38":177,"_49":178,"_51":179,"_36":180,"_54":181,"_56":-5,"_58":-5,"_59":182,"_39":-5},{"_38":113,"_49":114,"_51":115,"_36":116,"_54":117,"_56":118,"_58":119,"_59":120,"_39":-5},{"_38":48,"_49":50,"_51":52,"_36":53,"_54":55,"_56":57,"_58":-5,"_59":60,"_39":61},"1.5","Titel","Stellen Sie eine nutzerfreundliche Umsetzung sicher","Kurzbezeichnung","Nutzerfreundlichkeit","Stellen Sie eine nutzerfreundliche Umsetzung sicher: Sorgen Sie für eine an den Nutzenden orientierte Entwicklung, die eine einfache, intuitive und zugängliche Interaktion mit dem digitalen Angebot gewährleistet.","Text",[109],"Leitfragen",[86],"Formulierungsbeispiel","Anwendung",[],{"_34":62,"_38":27,"_54":63,"_64":65},"yaa803r10yjs4h9ay4srsb84",[74],"Paragraph",{"_38":66,"_67":68,"_49":69,"_70":71},"1130","Gesetz","ZPO","Entwicklung und Bereitstellung; Verordnungsermächtigungen","Beispielvorhaben",{"_18":72,"_49":73},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit",{"_75":76,"_77":78},"type","paragraph","children",[79,80],{"_81":85,"_75":81},{"_81":82,"_75":81,"_83":84},"text","Sie ist nach Maßgabe der Barrierefreie-Informationstechnik-Verordnung barrierefrei zu gestalten. Ferner ist bei der Gestaltung der Kommunikationsplattform deren Nutzerfreundlichkeit sowie eine einfache und intuitive Bedienbarkeit sicherzustellen.[1]","underline",true,"Die nach Absatz 2 entwickelte Kommunikationsplattform ist über ein Justizportal des Bundes und der Länder für die Nutzer bereitzustellen. ",{"_75":87,"_88":89,"_77":90},"list","format","unordered",[91,92],{"_75":93,"_77":106},{"_75":93,"_77":94},"list-item",[95,96,97],{"_81":105,"_75":81},{"_99":100,"_75":101,"_77":102},{"_81":98,"_75":81}," an? Dieser stellt eine nutzerzentrierte Entwicklung sicher. Er unterstützt umsetzende Akteure dabei, die verbindlichen Qualitätsanforderungen zu erfüllen.","url","https://servicestandard.gov.de/","link",[103],{"_81":104,"_75":81},"Servicestandard","Ergeben sich für den Vollzug Anforderungen aus dem ",[107],{"_81":108,"_75":81},"Was ist die wichtigste Aufgabe aus Sicht der Nutzenden?",{"_75":76,"_77":110},[111],{"_81":112,"_75":81},"Barrierearme Angebote sind oft auch nutzerfreundlicher. Darüber hinaus macht eine nutzerzentrierte Entwicklung, die z. B. in kleinen Schritten agiert und Texte in einfacher Sprache oder mehrsprachig gestaltet, ihr Angebot zugänglicher.","1.4","Denken Sie Barrierefreiheit von Anfang an mit","Barrierefreiheit","Denken Sie Barrierefreiheit von Anfang an mit: Gestalten Sie das digitale Angebot so, dass es ohne jegliche Hürden von allen Nutzenden, unabhängig von ihren individuellen Bedürfnissen, uneingeschränkt genutzt werden kann.",[166],[160],[136],[121],{"_49":122,"_123":124,"_58":-5,"_39":-5},"Falls anwendbar: Prüfen Sie, welche Regelwerke für die Umsetzung digitaler Barrierefreiheit für Ihr Vorhaben relevant sind.","Erklaerung",[125],{"_75":76,"_77":126},[127,128,129],{"_81":135,"_75":81},{"_99":131,"_75":101,"_77":132},{"_81":130,"_75":81},".","https://www.barrierefreiheit-dienstekonsolidierung.bund.de/Webs/PB/DE/standardanforderungskatalog/standardanforderungskatalog-node.html",[133],{"_81":134,"_75":81},"Standardanforderungskatalog","Nutzen Sie dafür beispielsweise den ",{"_75":87,"_88":89,"_77":137},[138,139],{"_75":93,"_77":150},{"_75":93,"_77":140},[141,142,143],{"_81":149,"_75":81},{"_99":145,"_75":101,"_77":146},{"_81":144,"_75":81},")","https://www.gesetze-im-internet.de/sgb_5/__354.html",[147],{"_81":148,"_75":81},"§ 354 SGB V","[...] nach dem Stand der Technik auch die erforderlichen technischen und organisatorischen Verfahren festzulegen oder technischen Voraussetzungen zu schaffen dafür, dass [...] Daten [...] barrierefrei zur Verfügung gestellt und [...] barrierefrei verarbeitet werden können [...] (",[151,152,153],{"_81":159,"_75":81},{"_99":155,"_75":101,"_77":156},{"_81":154,"_75":81},"). So eine Formulierung muss in einer Verordnung ausgestaltet werden.","https://www.gesetze-im-internet.de/sgb_9_2018/__106.html",[157],{"_81":158,"_75":81},"§ 106 Abs. 1 SGB IX","\"Die Beratung erfolgt in einer für den Leistungsberechtigten wahrnehmbaren Form\" (",{"_75":87,"_88":89,"_77":161},[162],{"_75":93,"_77":163},[164],{"_81":165,"_75":81},"Haben Sie die Bedürfnisse von Menschen mit unterschiedlichen Arten von Behinderungen berücksichtigt?",{"_75":76,"_77":167},[168,169,170],{"_81":176,"_75":81},{"_99":172,"_75":101,"_77":173},{"_81":171,"_75":81}," barrierefrei sein. Barrierefrei bedeutet, dass Menschen mit und ohne Behinderung das Angebot in gleicher Weise nutzen können. Da es viele unterschiedliche Arten von Behinderungen gibt, müssen viele Aspekte beachtet werden. Etwa die Aufbereitung für blinde und sehbehinderte Menschen oder Angebote in deutscher Gebärdensprache oder leichter Sprache.","https://www.gesetze-im-internet.de/bgg/__12a.html",[174],{"_81":175,"_75":81},"§ 12 a Behindertengleichstellungsgesetz","Digitale Angebote müssen nach ","1.3","Denken Sie an Antragsstellung, Bearbeitung und Bescheid","Antragsprozess beachten","Denken Sie an Antragsstellung, Bearbeitung und Bescheid: Planen Sie den vollständigen Lebenszyklus der Daten, damit diese durchgehend digital verarbeitet werden können und ihre Qualität im Prozess gesichert wird.",[222],[183,184],{"_49":205,"_123":206,"_58":-5,"_39":-5},{"_49":185,"_123":186,"_58":-5,"_39":-5},"Ermöglichen Sie automatische Kontrollen (z. B. Plausibilitätsprüfungen)",[187,188,189],{"_75":76,"_77":202},{"_75":76,"_77":199},{"_75":87,"_88":89,"_77":190},[191,192],{"_75":93,"_77":196},{"_75":93,"_77":193},[194],{"_81":195,"_75":81},"Codelisten.",[197],{"_81":198,"_75":81},"die Nutzung bestehender Standards entsprechend dem Prinzip Datenwiederverwendung benötigt einheitliches Recht sowie",[200],{"_81":201,"_75":81},"Hierbei helfen",[203],{"_81":204,"_75":81},"Sogenannte Plausibilitätsprüfungen kontrollieren, ob Ort und Postleitzahl zusammenpassen oder ob ein angegebener Zeitraum antragsberechtigt ist. Dies reduziert vermeidbare Fehler in Anträgen, die ansonsten oft zeitaufwändige Rückfragen nach sich ziehen.","Räumen Sie verwaltungsinterne Medienbrüche aus und vereinfachen Sie Prozesse",[207,208,209],{"_75":76,"_77":219},{"_75":76,"_77":216},{"_75":76,"_77":210},[211,212],{"_214":84,"_81":215,"_75":81},{"_81":213,"_75":81}," Digital erfasste Daten direkt digital weiterzuverarbeiten, spart Zeit, weil Informationen nicht eingescannt oder abgetippt werden müssen. Digitale Oberflächen, die für Nutzende zusätzliche Hilfestellungen und Kontrollen enthalten, erhöhen die Qualität der Daten. ","bold","Vorteile:",[217],{"_81":218,"_75":81},"Beziehen Sie den gesamten Prozess in die Gestaltung der Regelung mit ein: Welche Informationen werden von wem an wen übermittelt? Wirkt sich die Regelung auch auf verwaltungsinterne Kommunikation oder den Austausch zwischen Behörden und Unternehmen aus?",[220],{"_81":221,"_75":81},"Hierzu kann es hilfreich sein, die Technologien und Verfahren der umsetzenden Behörden zu erheben. Nutzen Sie hierfür z. B. eine Visualisierung. Prüfen Sie, inwiefern bisher analog gespeicherte Daten stattdessen digital gespeichert werden können.",{"_75":76,"_77":223},[224],{"_81":225,"_75":81},"Für eine erfolreiche Digitalisierung ist es wichtig, dass Sie den gesamten Prozess des Vollzugs Ihrer Regelung betrachten. Dies verhindert Logik- und Medienbrüche.","1.2","Formulieren Sie die Regelung technologieoffen","Technologieoffenheit","Formulieren Sie die Regelungen technologieoffen: Stellen Sie sicher, dass Vorschriften nicht an spezifische technische Lösungen gebunden sind, um die Nutzung etablierter oder zukünftiger Technologien zu ermöglichen.",[262,263,264],[253],[],{"_34":234,"_38":21,"_54":235,"_64":236},"eed54a9k0yrk07n6317zk0o8",[243],{"_38":237,"_67":238,"_49":239,"_70":240},"66a","LuftVG","Register über Betreiber von unbemannten Fluggeräten",{"_18":241,"_49":242},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","Register über Betreiber von unbemannten Fluggeräten – LuftVG",{"_75":76,"_77":244},[245,246,247,248],{"_81":252,"_75":81,"_83":84},{"_81":251,"_75":81},{"_81":250,"_75":81,"_83":84},{"_81":249,"_75":81},"; Absatz 3 Satz 4 bis 6 gilt entsprechend. Das Luftfahrt-Bundesamt stellt sicher, dass das Register insbesondere den Vorgaben der Artikel 24, 25 und 32 der Verordnung (EU) 2016/679 entspricht.","Das Luftfahrt-Bundesamt kann die Registrierung eines Betreibers eines unbemannten Fluggerätes für den Betrieb in den Betriebskategorien „offen“ und „speziell“ durch automatische Einrichtungen bestätigen, sofern kein Anlass besteht, den Einzelfall durch Amtsträger zu bearbeiten[5]",", die für alle von ihm nach Absatz 1 Satz 1 betriebenen unbemannten Fluggeräte gilt und dem Luftfahrt-Bundesamt eine individuelle Identifizierung des Betreibers nach Artikel 14 der Durchführungsverordnung (EU) 2019/947 ermöglicht. ","Das Luftfahrt-Bundesamt übermittelt jedem Betreiber nach Absatz 1 Satz 1 elektronisch eine Registrierungsnummer[1]",{"_75":76,"_77":254},[255,256,257],{"_81":261,"_75":81,"_259":84},{"_81":260,"_75":81},{"_81":258,"_75":81,"_259":84},"„Der Antrag ist zu stellen.“","italic"," oder ","„Der Antrag ist elektronisch oder schriftlich zu stellen.“",{"_75":76,"_77":277},{"_75":76,"_77":274},{"_75":76,"_77":265},[266,267,268],{"_81":273,"_75":81},{"_99":270,"_75":101,"_77":271},{"_81":269,"_75":81},"“. Ob das sinnvoll ist, hängt vom konkreten Einzelfall ab.","https://digitalcheck.bund.de/methoden/fuenf-prinzipien/etablierte-technologien-ermoeglichen-effiziente-umsetzung",[272],{"_81":25,"_75":81},"Andererseits kann die Nutzung etablierter Basisdienste die Umsetzung erleichtern und die Anwendung für Nutzende vereinfachen – im Sinne des Prinzips „",[275],{"_81":276,"_75":81},"Wenn Sie Übertragungswege – wie DE-Mail oder PDF – festlegen, riskieren Sie, dass Ihre Regelung bald nicht mehr dem Stand der Technik entspricht.",[278],{"_214":84,"_81":279,"_75":81},"Prüfen Sie, ob die Nennung spezifischer Technologien notwendig bzw. gerechtfertigt ist.","1.1","Ermöglichen Sie digitale Kommunikation und Bearbeitung","Digitale Kommunikation","Ermöglichen Sie digitale Kommunikation: Beseitigen Sie Hürden wie Schriftform oder persönliches Erscheinen und bieten Sie alternative Kommunikationswege an.",[417,418],[286,287,288,289],{"_49":394,"_123":395,"_58":-5,"_39":396},{"_49":326,"_123":327,"_58":-5,"_39":-5},{"_49":300,"_123":301,"_58":302,"_39":-5},{"_49":290,"_123":291,"_58":-5,"_39":-5},"Ermöglichen Sie weiterhin alternative Kommunikationswege",[292,293],{"_75":76,"_77":297},{"_75":76,"_77":294},[295],{"_81":296,"_75":81},"Denken Sie bei Privatpersonen an Bürgerinnen und Bürger, die keine digitalen Angebote nutzen können oder wollen.",[298],{"_81":299,"_75":81},"Für Unternehmen kann eine rein digitale Kommunikation vorgeschrieben werden.","Dokumente nur nach Bedarf anfordern",[322],[303,304],{"_75":76,"_77":315},{"_75":76,"_77":305},[306,307,308],{"_81":314,"_75":81},{"_99":310,"_75":101,"_77":311},{"_81":309,"_75":81},"","https://www.gesetze-im-internet.de/estdv_1955/__50.html",[312],{"_81":313,"_75":81},"§ 50 Abs. 8 EStDV","Analog zu: ",[316,317,318],{"_81":321,"_75":81,"_259":84},{"_214":84,"_81":320,"_75":81,"_259":84},{"_81":319,"_75":81,"_259":84}," und der Behörde auf Verlangen für eine Prüfung zugänglich zu machen.","aufzubewahren","Der Antragsteller hat die Belege für die Dauer von [X] Jahren ",{"_75":76,"_77":323},[324],{"_81":325,"_75":81},"Prüfen Sie, ob eine Vorlagepflicht durch eine Vorhaltepflicht ersetzt werden kann oder sogar komplett entfallen kann.","Vermeiden Sie persönliches Erscheinen ",[328,329,330,331,332,333,334,335],{"_75":76,"_77":391},{"_75":76,"_77":388},{"_75":87,"_88":89,"_77":383},{"_75":87,"_88":89,"_77":357},{"_75":87,"_88":89,"_77":346},{"_75":76,"_77":341},{"_75":76,"_77":338},{"_75":76,"_77":336},[337],{"_81":309,"_75":81},[339],{"_81":340,"_75":81},"[1] Verordnung (EU) Nr. 910/2014 über elektronische Identifizierung und Vertrauensdienste für elektronische Transaktionen im Binnenmarkt und zur Aufhebung der Richtlinie 1999/93/EG, zuletzt geändert durch Verordnung (EU) Nr. 2024/1183.",[342,343],{"_214":84,"_81":345,"_75":81},{"_81":344,"_75":81}," Prüfen Sie, ob die eingesetzten Verfahren der eIDAS-2.0-Verordnung [1] entsprechen. Identifizierungssysteme müssen interoperabel sein und EU-weit gegenseitig anerkannt sein. Die Verordnung betrifft elektronische Signaturen, Siegel, Zeitstempel, Dokumente, Zustellung digitaler Einschreiben sowie Website-Authentifizierung.","Interoperabilität:",[347],{"_75":93,"_77":348},[349,350,351],{"_81":356,"_75":81},{"_99":352,"_75":101,"_77":353},{"_81":130,"_75":81},"https://digitalcheck.bund.de/beispiele/prinzipien/digitale-angebote-fuer-alle-nutzbar-gestalten#absatz-g6pdcvhx2a4cleuywyb0fbuu",[354],{"_81":355,"_75":81},"§ 1131 ZPO","Sichere Zustellung kann durch elektronische Postfächer erfolgen. Ein Beispiel findet sich in ",[358],{"_75":93,"_77":359},[360,361,362,363,364,365,366],{"_81":382,"_75":81},{"_99":378,"_75":101,"_77":379},{"_81":377,"_75":81},{"_99":373,"_75":101,"_77":374},{"_81":372,"_75":81},{"_99":368,"_75":101,"_77":369},{"_81":367,"_75":81}," die Schriftform.","https://www.gesetze-im-internet.de/vwvfg/__3a.html",[370],{"_81":371,"_75":81},"§ 3a VwVfG"," eIDAS-Verordnung. Sie ersetzt etwa in den Bereichen des Verwaltungsverfahrensgesetz nach Anwendung von ","https://eur-lex.europa.eu/legal-content/DE/TXT/PDF/?uri=CELEX:32014R0910",[375],{"_81":376,"_75":81},"Artikel 25 Abs. 2"," entspricht der handschriftlichen Unterschrift, vgl. ","https://www.elektronische-vertrauensdienste.de/EVD/DE/Uebersicht_eVD/Dienste/1_Signatur.html?nn=691386",[380],{"_81":381,"_75":81},"Qualifizierte Elektronische Signatur","Die ",[384],{"_75":93,"_77":385},[386],{"_81":387,"_75":81},"Die Online-Ausweisfunktion bzw. ein Nutzerkonto ermöglicht eine Identitätsprüfung. Ein Verweis auf das OZG-Nutzerkonto findet sich in § 1131 Abs. 1 ZPO.",[389],{"_81":390,"_75":81},"Empfehlung: Ermöglichen Sie, dass gleichwertige digitale Verfahren zugelassen sind:",[392],{"_81":393,"_75":81},"Das persönliche Erscheinen kann erforderlich werden, wenn die Identität einer Person festgestellt werden muss, eine Erklärung nicht delegierbar ist oder eine Belehrung/Beratung im direkten Gespräch notwendig ist.","Prüfen Sie Schriftformerfordernisse",[407,408],{"_34":397,"_38":33,"_54":398,"_399":-5,"_64":400},"rdfocmyt6wqirzqsmwjgz9vo",[403],"Auszug",{"_38":401,"_67":402,"_49":-5},"23a","BVerfGG",{"_75":76,"_77":404},[405],{"_81":406,"_75":81,"_83":84},"Schriftlich einzureichende Anträge und Erklärungen sowie sonstige Schriftsätze und deren Anlagen können nach Maßgabe der folgenden Absätze als elektronische Dokumente beim Bundesverfassungsgericht eingereicht werden.[1]",{"_75":76,"_77":412},{"_75":76,"_77":409},[410],{"_81":411,"_75":81},"Hintergrund: Ausdrucken, Unterschreiben, Versenden und Archivieren führen in digitalen Prozessen zu unnötigen Verzögerungen und Kosten.",[413,414],{"_214":84,"_81":416,"_75":81},{"_81":415,"_75":81},", prüfen Sie kritisch, ob elektronische Verfahren nicht bereits ausreichend Übereilungsschutz bieten und die Beweisfunktion sicherstellen.","Bevor Sie die Schriftform als erforderlich festlegen",{"_75":76,"_77":422},{"_75":76,"_77":419},[420],{"_81":421,"_75":81},"Digitale Kommunikation sollte immer bedarfsorientiert und inklusiv sein – in bestimmten Fällen kann z. B. ergänzend auch die Schriftform sinnvoll sein, sofern eine digitale Weiterverarbeitung sichergestellt ist. Bürgerinnen und Bürger, die keine digitalen Angebote nutzen können oder wollen, müssen dabei auch bedacht werden.",[423],{"_81":424,"_75":81},"Digital zu kommunizieren bietet viele Vorteile: Anträge und Bescheide können in Echtzeit übermittelt werden, was Wartezeiten für Bürgerinnen, Bürger und Unternehmen verkürzt. Werden Anträge und sonstige Daten digital an die Verwaltung übermittelt, können sie außerdem effizient digital weiterverarbeitet, geprüft und an weitere beteiligte Behörden übermittelt werden.","fvj31s0fav5aw2vlu65q0arw",[467,468],{"_38":464,"_67":68,"_49":465,"_70":466},"PrinzipErfuellungen",[430,431,432],{"_433":451,"_123":452,"_436":453},{"_433":442,"_123":443,"_436":444},{"_433":434,"_123":435,"_436":437},"id","1338",[438],"Prinzip",{"_38":27,"_16":17},{"_75":76,"_77":439},[440],{"_81":441,"_75":81},"Stellt die Informationssicherheit sicher, indem sie die Anforderung eines sicheren Verfahrens stellt, das die Authentizität und Integrität der Daten gewährleistet.","1337",[445],{"_38":21,"_16":22},{"_75":87,"_88":89,"_77":446},[447],{"_75":93,"_77":448},[449],{"_81":450,"_75":81},"Geht von einer automatisierten Bearbeitung der Daten aus.","1336",[454],{"_38":33,"_16":31},{"_75":87,"_88":89,"_77":455},[456,457],{"_75":93,"_77":461},{"_75":93,"_77":458},[459],{"_81":460,"_75":81},"Schriftformerfordernisse werden durch die digitale Übermittlung ersetzt.",[462],{"_81":463,"_75":81},"Die digitale Übermittlung von Dokumenten ermöglicht eine Kommunikation über die digitale Kommunikationsplattform.","1131","Kommunikations-, Austausch- und Übermittlungsformen",{"_18":72,"_49":73},{"_75":76,"_77":483},{"_75":87,"_88":469,"_77":470},"ordered",[471,472,473],{"_75":93,"_77":480},{"_75":93,"_77":477},{"_75":93,"_77":474},[475],{"_81":476,"_75":81,"_83":84},"für die elektronischen Dokumente oder strukturierten Datensätze auf der Kommunikationsplattform eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[5]",[478],{"_81":479,"_75":81,"_83":84},"bei der Datenübermittlung ein sicheres Verfahren verwendet wird, das die Authentizität und Integrität der Daten gewährleistet, und [3]",[481],{"_81":482,"_75":81},"ein Identifizierungsverfahren nach Absatz 1 genutzt wird,",[484,485],{"_81":487,"_75":81,"_83":84},{"_81":486,"_75":81},", sofern","Eine in diesem Gesetz angeordnete Schriftform kann auch durch Übermittlung elektronischer Dokumente oder strukturierter Datensätze über die Kommunikationsplattform ersetzt werden[1]",{"_75":76,"_77":507},{"_75":76,"_77":504},{"_75":87,"_88":89,"_77":491},[492,493,494],{"_75":93,"_77":501},{"_75":93,"_77":498},{"_75":93,"_77":495},[496],{"_81":497,"_75":81},"wie Barrierefreiheit zu bedenken ist.",[499],{"_81":500,"_75":81},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[502],{"_81":503,"_75":81},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[505],{"_81":506,"_75":81},"Erfahren Sie in diesem Abschnitt,",[508],{"_81":509,"_75":81},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_511":512,"_513":514,"_515":514,"_516":517,"_518":309},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_519":84,"_520":84,"_521":84,"_522":84,"_523":84,"_524":84,"_525":84},"posthogKey","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
