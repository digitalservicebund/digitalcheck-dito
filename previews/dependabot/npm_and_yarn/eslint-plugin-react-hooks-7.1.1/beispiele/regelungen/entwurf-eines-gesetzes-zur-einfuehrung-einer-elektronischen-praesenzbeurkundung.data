[{"_1":2,"_3":4,"_5":6},"root",{"_7":226},"routes/beispiele",{"_7":85},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":14,"_15":-5,"_16":17,"_18":19,"_20":-5,"_21":22,"_23":-5,"_24":25,"_26":27,"_28":29,"_30":31},"documentId","hd9l569cf26ovo1pfav5fke4","Titel","Entwurf eines Gesetzes zur Einführung einer elektronischen Präsenzbeurkundung","NKRNummer",7621,"Rechtsgebiet","Ressort","BMJV","URLBezeichnung","entwurf-eines-gesetzes-zur-einfuehrung-einer-elektronischen-praesenzbeurkundung","VeroeffentlichungsDatum","LinkRegelungstext","https://dip.bundestag.de/vorgang/gesetz-zur-einf%C3%BChrung-einer-elektronischen-pr%C3%A4senzbeurkundung/324805","NKRStellungnahmeLink","GesetzStatus","Regelungsentwurf","Paragraphen",[],"Visualisierungen",[40],"Digitalchecks",[32],{"_9":33,"_11":12,"_34":-5,"_35":-5,"_36":-5,"_37":-5,"_38":-5,"_39":-5},"qm5lbua8ez0gyx93g3l87mv4","EinschaetzungAutomatisierung","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",{"_9":41,"_11":42,"_43":44,"_45":46,"_47":48,"_49":-5,"_16":-5,"_50":51,"_52":53},"xvtg21ye68vdd2fmh07enhgj","Visualisierung unterschiedlicher Handlungsoptionen","Beschreibung",[60],"Visualisierungsart","Flussdiagramm","Visualisierungstool","Bizagi","Aufwand","Bild",{"_9":54,"_55":56,"_57":-5,"_58":59},"Beispielvorhaben",{"_18":19,"_20":-5,"_15":-5,"_11":12,"_16":17},"avdz9w5qo9tufkncvu1y0pr8","url","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/250624_NKR_7621_Vorschlag_fbed061e1f.PNG","previewUrl","alternativeText","Das vorliegende Diagramm veranschaulicht zwei alternative Optionen für die Signatur durch Beteiligte, nämlich eine qualifizierte elektronische Signatur oder eine eigenhändige Signatur auf einem Gerät. Zudem wird der abschließende Schritt der qualifizierten elektronischen Signatur durch den Notar dargestellt. ",{"_61":62,"_63":64,"_65":66},"type","list","format","unordered","children",[67,68,69,70],{"_61":71,"_65":82},{"_61":71,"_65":79},{"_61":71,"_65":76},{"_61":71,"_65":72},"list-item",[73],{"_74":75,"_61":74},"text","Zeigt den vollständigen \"End-to-End\"-Prozess von der Initiierung bis zur final signierten Niederschrift.",[77],{"_74":78,"_61":74},"Verknüpft jeden Handlungsschritt direkt mit dem konkreten Absatz-Verweis zur einfachen Überprüfbarkeit.",[80],{"_74":81,"_61":74},"Grenzt die Rollen der Beteiligten und des Notars durch \"Schwimmbahnen\" voneinander ab.",[83],{"_74":84,"_61":74},"Visualisiert unterschiedliche rechtliche Handlungsoptionen als klare Verzweigungen im Ablauf.",[86,87,88,89,90],{"_9":198,"_92":199,"_94":200,"_43":201,"_18":202,"_98":203,"_100":199},{"_9":181,"_92":182,"_94":183,"_43":184,"_18":185,"_98":186,"_100":182},{"_9":164,"_92":165,"_94":166,"_43":167,"_18":168,"_98":169,"_100":93},{"_9":123,"_92":101,"_94":124,"_43":125,"_18":126,"_98":127,"_100":128},{"_9":91,"_92":93,"_94":95,"_43":96,"_18":97,"_98":99,"_100":101},"bnx9lmblnceu1m3uy3rziy0i","Nummer",3,"Name","Datenschutz und Informationssicherheit schaffen Vertrauen",[102,103,104],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Kurzbezeichnung","Informationssicherheit und Datenschutz","order",5,{"_61":105,"_65":112},{"_61":105,"_65":109},{"_61":105,"_65":106},"paragraph",[107],{"_74":108,"_61":74},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[110],{"_74":111,"_61":74},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[113,114,115],{"_74":122,"_61":74},{"_55":117,"_61":118,"_65":119},{"_74":116,"_61":74}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de","link",[120],{"_74":121,"_61":74},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ","got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[129,130],"automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_61":105,"_65":147},{"_61":105,"_65":131},[132,133,134,135,136],{"_74":146,"_61":74},{"_74":143,"_61":74,"_144":145},{"_74":142,"_61":74},{"_55":138,"_61":118,"_65":139},{"_74":137,"_61":74},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[140],{"_74":141,"_61":74},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic",true,"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[148,149,150,151,152],{"_74":163,"_61":74},{"_55":159,"_61":118,"_65":160},{"_74":158,"_61":74},{"_55":154,"_61":118,"_65":155},{"_74":153,"_61":74}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[156],{"_74":157,"_61":74},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[161],{"_74":162,"_61":74},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ","habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[170],"etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",{"_61":105,"_65":171},[172,173,174],{"_74":180,"_61":74},{"_55":176,"_61":118,"_65":177},{"_74":175,"_61":74}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[178],{"_74":179,"_61":74},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ","s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[187],"datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_61":105,"_65":188},[189,190,191],{"_74":197,"_61":74},{"_55":193,"_61":118,"_65":194},{"_74":192,"_61":74}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[195],{"_74":196,"_61":74},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ","r57rc9d82ulv2bsc3gdbnj73",1,"Digitale Angebote für alle nutzbar gestalten",[204,205,206],"digitale-angebote-fuer-alle-nutzbar-gestalten","Digitale Angebote",{"_61":105,"_65":223},{"_61":105,"_65":220},{"_61":62,"_63":64,"_65":207},[208,209,210],{"_61":71,"_65":217},{"_61":71,"_65":214},{"_61":71,"_65":211},[212],{"_74":213,"_61":74},"wie Barrierefreiheit zu bedenken ist.",[215],{"_74":216,"_61":74},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[218],{"_74":219,"_61":74},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[221],{"_74":222,"_61":74},"Erfahren Sie in diesem Abschnitt,",[224],{"_74":225,"_61":74},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_227":228,"_229":230,"_231":230,"_232":233,"_234":235},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_236":145,"_237":145,"_238":145,"_239":145,"_240":145,"_241":145,"_242":145},"posthogKey","","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
