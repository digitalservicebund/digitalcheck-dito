[{"_1":2,"_3":4,"_5":6},"root",{"_7":262},"routes/beispiele",{"_7":123},"routes/beispiele.regelungen.$regelung",{"_7":8},"data",{"_9":10,"_11":12,"_13":14,"_15":-5,"_16":17,"_18":19,"_20":21,"_22":23,"_24":25,"_26":27,"_28":29,"_30":31,"_32":33},"documentId","t0e2ipr952di6k1k7r3xqupo","Titel","Digitale-Dienste-Gesetz","NKRNummer",6801,"Rechtsgebiet","Ressort","BMV","URLBezeichnung","digitale-dienste-gesetz","VeroeffentlichungsDatum","2024-05-13","LinkRegelungstext","https://www.recht.bund.de/bgbl/1/2024/149/VO.html","NKRStellungnahmeLink","https://www.normenkontrollrat.bund.de/Webs/NKR/SharedDocs/Stellungnahmen/DE/2023/nkr-nr-6801.html","GesetzStatus","Verkuendetes_Gesetz_aktuelle_Fassung","Paragraphen",[],"Visualisierungen",[82],"Digitalchecks",[34],{"_9":35,"_11":36,"_37":38,"_39":38,"_40":41,"_42":38,"_43":38,"_44":45},"ntq4wl5b290bmx2sliywnnsq","DC - Digitale-Dienste-Gesetz","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","Nein","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",[46,47,48,49,50,51,52,53],{"_54":55,"_56":79},{"_54":55,"_56":76},{"_54":55,"_56":73},{"_54":55,"_56":70},{"_54":55,"_56":67},{"_54":55,"_56":64},{"_54":55,"_56":61},{"_54":55,"_56":57},"type","paragraph","children",[58],{"_59":60,"_54":59},"text","Der NKR begrüßt die Visualisierung der Zusammenarbeit zwischen Behörden, welche im Zusammenhang mit der Neuregelung vorgelegt wurde. ",[62],{"_59":63,"_54":59},"• Die Regelung ermöglicht die Automatisierung des Vollzugs, indem weitestgehend harmonisierte Rechtsbegriffe verwendet werden. ",[65],{"_59":66,"_54":59},"• Das Vorhaben enthält klare Regelungen für eine digitale Ausführung, indem es technologieneutral und hinsichtlich digitaler Abläufe offen formuliert ist. So wird die Zusammenarbeit zwischen zuständigen Behörden nicht beeinträchtigt. ",[68],{"_59":69,"_54":59},"• Die Regelung schafft die Voraussetzungen für eine Gewährleistung von Datenschutz und Informationssicherheit, da sie in engem Austausch mit dem oder der BfDI erarbeitet wurde. ",[71],{"_59":72,"_54":59},"• Es werden die Voraussetzungen für eine digitale Kommunikation geschaffen, indem die Regelung technologieoffen gestaltet ist. Außerdem wird die digitale Kommunikation zwischen den beteiligten Behörden ermöglicht; auf Formerfordernisse wird verzichtet. ",[74],{"_59":75,"_54":59},"• Die Bedürfnisse der Betroffenen und des Vollzugs werden in der Regelung berücksichtigt, indem bei der Erstellung der Regelung frühzeitig Stellungnahmen von Verbänden und NGOs eingeholt wurden. Außerdem wurden die am Vollzug beteiligten Bundesbehörden eng in die Entwicklung der Regelung eingebunden. ",[77],{"_59":78,"_54":59},"• Die Vollzugsprozesse wurden visuell dargestellt. ",[80],{"_59":81,"_54":59},"Das Ressort hat die Möglichkeiten zum digitalen Vollzug der Neuregelung (Digitaltauglichkeit) geprüft und hierzu einen Digitalcheck mit nachvollziehbarem Ergebnis durchgeführt.  ",{"_9":83,"_11":84,"_85":86,"_87":88,"_89":-5,"_90":-5,"_16":-5,"_91":92,"_93":94},"b7us17xq6zc3c66yxm6av6gm","Übersicht verantwortlicher Akteure","Beschreibung",[101],"Visualisierungsart","Schaubild","Visualisierungstool","Aufwand","Bild",{"_9":95,"_96":97,"_98":-5,"_99":100},"Beispielvorhaben",{"_18":19,"_20":21,"_15":-5,"_11":12,"_16":17},"drewf3y70uxnm8ycy9s5q4k2","url","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/Visualisierung_DDG_dd77dac88c.jpg","previewUrl","alternativeText","Flussdiagramm zur Koordinierungsstelle für digitale Dienste, das Zuständigkeiten und Zusammenarbeit mit Bundesnetzagentur, BfDI, Bundeskriminalamt und weiteren Akteuren zeigt.",{"_54":102,"_103":104,"_56":105},"list","format","unordered",[106,107],{"_54":108,"_56":116},{"_54":108,"_56":109},"list-item",[110,111],{"_59":115,"_54":59},{"_112":113,"_59":114,"_54":59},"bold",true,"explizite Nennung der Paragraphen.","Erleichtert das Auffinden der relevanten Textpassagen, aus welchen sich die jeweiligen Verantwortlichkeiten ergeben, durch ",[117,118,119],{"_59":122,"_54":59},{"_112":113,"_59":121,"_54":59},{"_59":120,"_54":59},"und wie diese mit der neu eingerichteten Koordinierungsstelle interagieren.","die verantwortlichen Akteure für die Umsetzung und Überwachung darstellt ","Macht die Regelung leichter verständlich, indem sie ",[124,125,126,127,128],{"_9":234,"_130":235,"_132":236,"_85":237,"_18":238,"_136":239,"_138":235},{"_9":217,"_130":218,"_132":219,"_85":220,"_18":221,"_136":222,"_138":218},{"_9":200,"_130":201,"_132":202,"_85":203,"_18":204,"_136":205,"_138":131},{"_9":160,"_130":139,"_132":161,"_85":162,"_18":163,"_136":164,"_138":165},{"_9":129,"_130":131,"_132":133,"_85":134,"_18":135,"_136":137,"_138":139},"bnx9lmblnceu1m3uy3rziy0i","Nummer",3,"Name","Datenschutz und Informationssicherheit schaffen Vertrauen",[140,141,142],"datenschutz-und-informationssicherheit-schaffen-vertrauen","Kurzbezeichnung","Informationssicherheit und Datenschutz","order",5,{"_54":55,"_56":149},{"_54":55,"_56":146},{"_54":55,"_56":143},[144],{"_59":145,"_54":59},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[147],{"_59":148,"_54":59},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",[150,151,152],{"_59":159,"_54":59},{"_96":154,"_54":155,"_56":156},{"_59":153,"_54":59}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de","link",[157],{"_59":158,"_54":59},"DSGVO","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ","got436pv8femeqmv6ee8wlm1","Automatisierung basiert auf eindeutigen Regelungen",[166,167],"automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_54":55,"_56":183},{"_54":55,"_56":168},[169,170,171,172,173],{"_59":182,"_54":59},{"_59":180,"_54":59,"_181":113},{"_59":179,"_54":59},{"_96":175,"_54":155,"_56":176},{"_59":174,"_54":59},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","https://www.gesetze-im-internet.de/vwvfg/__35a.html",[177],{"_59":178,"_54":59},"§ 35a VwVfG"," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (","Verwaltungsakt","italic","Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",[184,185,186,187,188],{"_59":199,"_54":59},{"_96":195,"_54":155,"_56":196},{"_59":194,"_54":59},{"_96":190,"_54":155,"_56":191},{"_59":189,"_54":59}," vorgeschrieben.","https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[192],{"_59":193,"_54":59},"Handbuch der Rechtsförmlichkeit"," und das ","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[197],{"_59":198,"_54":59},"GGO","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ","habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[206],"etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",{"_54":55,"_56":207},[208,209,210],{"_59":216,"_54":59},{"_96":212,"_54":155,"_56":213},{"_59":211,"_54":59}," und fördern die Interoperabilität.","/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[214],{"_59":215,"_54":59},"Sicherheit der Angebote","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ","s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[223],"datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_54":55,"_56":224},[225,226,227],{"_59":233,"_54":59},{"_96":229,"_54":155,"_56":230},{"_59":228,"_54":59}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[231],{"_59":232,"_54":59},"Once-Only-Prinzip","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ","r57rc9d82ulv2bsc3gdbnj73",1,"Digitale Angebote für alle nutzbar gestalten",[240,241,242],"digitale-angebote-fuer-alle-nutzbar-gestalten","Digitale Angebote",{"_54":55,"_56":259},{"_54":55,"_56":256},{"_54":102,"_103":104,"_56":243},[244,245,246],{"_54":108,"_56":253},{"_54":108,"_56":250},{"_54":108,"_56":247},[248],{"_59":249,"_54":59},"wie Barrierefreiheit zu bedenken ist.",[251],{"_59":252,"_54":59},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",[254],{"_59":255,"_54":59},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",[257],{"_59":258,"_54":59},"Erfahren Sie in diesem Abschnitt,",[260],{"_59":261,"_54":59},"Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_263":264,"_265":266,"_267":266,"_268":269,"_270":271},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_272":113,"_273":113,"_274":113,"_275":113,"_276":113,"_277":113,"_278":113},"posthogKey","","showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts"]
