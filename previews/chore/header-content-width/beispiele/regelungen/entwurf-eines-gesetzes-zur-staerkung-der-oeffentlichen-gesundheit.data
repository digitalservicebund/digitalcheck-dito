[{"_1":2,"_22":23,"_175":176},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_20":21},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13,"_19":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":24},[25,69,89,108,150],{"_26":27,"_28":29,"_30":31,"_32":33,"_64":65,"_66":67,"_68":29},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[34,42,46],{"_35":36,"_37":38},"type","paragraph","children",[39],{"_40":41,"_35":40},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_35":36,"_37":43},[44],{"_40":45,"_35":40},"Erfahren Sie in diesem Abschnitt,",{"_35":47,"_48":49,"_37":50},"list","format","unordered",[51,56,60],{"_35":52,"_37":53},"list-item",[54],{"_40":55,"_35":40},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_35":52,"_37":57},[58],{"_40":59,"_35":40},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_35":52,"_37":61},[62],{"_40":63,"_35":40},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_26":70,"_28":71,"_30":72,"_32":73,"_64":87,"_66":88,"_68":71},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[74],{"_35":36,"_37":75},[76,78,85],{"_40":77,"_35":40},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_79":80,"_35":81,"_37":82},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[83],{"_40":84,"_35":40},"Once-Only-Prinzip",{"_40":86,"_35":40}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_26":90,"_28":91,"_30":92,"_32":93,"_64":105,"_66":106,"_68":107},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[94],{"_35":36,"_37":95},[96,98,103],{"_40":97,"_35":40},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_79":99,"_35":81,"_37":100},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[101],{"_40":102,"_35":40},"Sicherheit der Angebote",{"_40":104,"_35":40}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_26":109,"_28":110,"_30":111,"_32":112,"_64":147,"_66":148,"_68":149},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[113,131],{"_35":36,"_37":114},[115,117,122,124,129],{"_40":116,"_35":40},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_79":118,"_35":81,"_37":119},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[120],{"_40":121,"_35":40},"GGO",{"_40":123,"_35":40}," und das ",{"_79":125,"_35":81,"_37":126},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[127],{"_40":128,"_35":40},"Handbuch der Rechtsförmlichkeit",{"_40":130,"_35":40}," vorgeschrieben.",{"_35":36,"_37":132},[133,135,138,140,145],{"_40":134,"_35":40},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_40":136,"_35":40,"_137":13},"Verwaltungsakt","italic",{"_40":139,"_35":40}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_79":141,"_35":81,"_37":142},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[143],{"_40":144,"_35":40},"§ 35a VwVfG",{"_40":146,"_35":40},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_26":151,"_28":107,"_30":152,"_32":153,"_64":173,"_66":174,"_68":110},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[154,165,169],{"_35":36,"_37":155},[156,158,163],{"_40":157,"_35":40},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_79":159,"_35":81,"_37":160},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[161],{"_40":162,"_35":40},"DSGVO",{"_40":164,"_35":40}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_35":36,"_37":166},[167],{"_40":168,"_35":40},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_35":36,"_37":170},[171],{"_40":172,"_35":40},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":177},{"_26":178,"_179":180,"_181":182,"_183":-5,"_184":185,"_64":186,"_187":188,"_189":190,"_191":192,"_193":194,"_195":196,"_351":352,"_353":354},"zxsi0nin10qonxffc5ht0wy9","Titel","Entwurf eines Gesetzes zur Stärkung der Öffentlichen Gesundheit – BIPAM-ErrichtungsG","NKRNummer",7202,"Rechtsgebiet","Ressort","BMG","entwurf-eines-gesetzes-zur-staerkung-der-oeffentlichen-gesundheit","VeroeffentlichungsDatum","2024-07-17","LinkRegelungstext","https://www.bundesgesundheitsministerium.de/service/gesetze-und-verordnungen/detail/gesetz-zur-staerkung-der-oeffentlichen-gesundheit","NKRStellungnahmeLink","https://www.normenkontrollrat.bund.de/Webs/NKR/SharedDocs/Stellungnahmen/DE/2024/nkr-nr-7202.html","GesetzStatus","Regelungsentwurf","Paragraphen",[197],{"_26":198,"_28":199,"_179":200,"_201":202,"_203":204,"_205":206},"g4h3dgsp9r8u4kiyjgpmqxxl","2","Aufgaben des Bundesinstituts","Gesetz","BIPAM–ErrichtungsG","Artikel","1","Absaetze",[207,217,343],{"_26":208,"_209":210,"_28":29,"_215":216},"im4exdj7qs5gmdi07im8n9uy","Text",[211],{"_35":36,"_37":212},[213],{"_40":214,"_35":40},"Das Bundesinstitut nimmt Aufgaben des Bundes auf den Gebieten der Öffentlichen Gesundheit wahr, die ihm durch dieses Gesetz oder durch andere Bundesgesetze oder auf Grund dieser Gesetze zugewiesen werden. Die Aufgaben bestehender Einrichtungen des Bundes außerhalb des Geschäftsbereichs des Bundesministeriums für Gesundheit bleiben davon unberührt. Das Bundesinstitut übernimmt die Aufgaben der Bundeszentrale für gesundheitliche Aufklärung, einschließlich derer aus dem Geschäftsbereich des Bundesministeriums für Familie, Senioren, Frauen und Jugend.","PrinzipErfuellungen",[],{"_26":218,"_209":219,"_28":71,"_215":263},"cf3uooinyhchvdcj0sy6e55e",[220,229,259],{"_35":36,"_37":221},[222,224,227],{"_40":223,"_35":40},"Das Bundesinstitut nimmt Aufgaben nach Absatz 1, ",{"_40":225,"_35":40,"_226":13},"einschließlich der damit verbundenen Verarbeitung personenbezogener Gesundheitsdaten im Umfang der jeweils einschlägigen fachrechtlichen Bestimmungen[3]","underline",{"_40":228,"_35":40},", insbesondere auf folgenden Gebieten wahr:",{"_35":47,"_48":230,"_37":231},"ordered",[232,236,240,246,251,255],{"_35":52,"_37":233},[234],{"_40":235,"_35":40,"_226":13},"Beobachtung von gesundheitsrelevanten Faktoren und von gesundheitlichen Rahmenbedingungen[2],",{"_35":52,"_37":237},[238],{"_40":239,"_35":40,"_226":13},"Gesundheitsberichterstattung des Bundes, einschließlich Gesundheitsmonitoring[2],",{"_35":52,"_37":241},[242,244],{"_40":243,"_35":40,"_226":13},"Stärkung der Öffentlichen Gesundheit durch freiwillige Kooperation und Vernetzung mit Akteuren der Öffentlichen Gesundheit[2]",{"_40":245,"_35":40},",",{"_35":52,"_37":247},[248,250],{"_40":249,"_35":40,"_226":13},"evidenzbasierte, zielgruppenspezifische, insbesondere auf vulnerable Bevölkerungsgruppen ausgerichtete Kommunikation im Zuständigkeitsbereich des Bundesministeriums für Gesundheit[1]",{"_40":245,"_35":40},{"_35":52,"_37":252},[253],{"_40":254,"_35":40},"Stärkung der Vorbeugung und Verhütung von Krankheiten sowie Stärkung der Gesundheitsförderung und der Gesundheitskompetenz in der Bevölkerung, jeweils im Rahmen der Zuständigkeit des Bundes,",{"_35":52,"_37":256},[257],{"_40":258,"_35":40},"wissenschaftliche Forschung und Zusammenarbeit mit Institutionen auf nationaler, europäischer und internationaler Ebene, einschließlich der Unterstützung dieser Institutionen bei der Entwicklung von Leitlinien und Standards.",{"_35":36,"_37":260},[261],{"_40":262,"_35":40},"Besondere Vorschriften zur Bestimmung von Aufgaben bleiben hiervon unberührt, insbesondere die Aufgaben des Robert Koch-Instituts nach § 4 des Infektionsschutzgesetzes und nach § 2 Absatz 3 in Verbindung mit § 4 des BGA-Nachfolgegesetzes.",[264,295,317],{"_265":266,"_267":268,"_279":280},"id","1305","Erklaerung",[269],{"_35":47,"_48":49,"_37":270},[271,275],{"_35":52,"_37":272},[273],{"_40":274,"_35":40},"Nennt explizit die Verarbeitung personenbezogener Daten als Spezifizierung der Aufgaben von Absatz 1.",{"_35":52,"_37":276},[277],{"_40":278,"_35":40},"Konkretisiert die Art der personenbezogenen Daten (Gesundheitsdaten) und verweist darüber hinaus auf die dafür geltenden fachrechtlichen Bestimmungen.","Prinzip",{"_26":151,"_28":107,"_30":152,"_32":281,"_64":173,"_66":174,"_68":110},[282,289,292],{"_35":36,"_37":283},[284,285,288],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":286},[287],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":290},[291],{"_40":168,"_35":40},{"_35":36,"_37":293},[294],{"_40":172,"_35":40},{"_265":296,"_267":297,"_279":308},"1306",[298],{"_35":47,"_48":49,"_37":299},[300,304],{"_35":52,"_37":301},[302],{"_40":303,"_35":40},"Fördert die Wiederverwendung von Daten durch standardisierte Gesundheitsberichterstattung und einheitliches Monitoring. ",{"_35":52,"_37":305},[306],{"_40":307,"_35":40},"Ermöglicht den effizienten Austausch vorhandener Daten durch die Vernetzung und Kooperation mit Akteuren der Öffentlichen Gesundheit. Vermeidet Doppelarbeit und schont Ressourcen.",{"_26":70,"_28":71,"_30":72,"_32":309,"_64":87,"_66":88,"_68":71},[310],{"_35":36,"_37":311},[312,313,316],{"_40":77,"_35":40},{"_79":80,"_35":81,"_37":314},[315],{"_40":84,"_35":40},{"_40":86,"_35":40},{"_265":318,"_267":319,"_279":324},"1307",[320],{"_35":36,"_37":321},[322],{"_40":323,"_35":40},"Stellt sicher, dass Informationen effizient und barrierefrei zugänglich sind, indem es eine bedarfsorientierte und inklusive digitale Kommunikation vorschreibt.",{"_26":27,"_28":29,"_30":31,"_32":325,"_64":65,"_66":67,"_68":29},[326,329,332],{"_35":36,"_37":327},[328],{"_40":41,"_35":40},{"_35":36,"_37":330},[331],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":333},[334,337,340],{"_35":52,"_37":335},[336],{"_40":55,"_35":40},{"_35":52,"_37":338},[339],{"_40":59,"_35":40},{"_35":52,"_37":341},[342],{"_40":63,"_35":40},{"_26":344,"_209":345,"_28":107,"_215":350},"iz0dn69esvlecmyh7x0zogob",[346],{"_35":36,"_37":347},[348],{"_40":349,"_35":40},"Das Bundesinstitut erledigt, soweit keine andere Zuständigkeit gesetzlich festgelegt ist, in seinem Zuständigkeitsbereich weitere Aufgaben des Bundes, die mit den in den Absätzen 1 und 2 genannten Gebieten zusammenhängen und mit deren Durchführung es vom Bundesministerium für Gesundheit oder mit dessen Zustimmung von der sachlich zuständigen obersten Bundesbehörde beauftragt wird.",[],"Visualisierungen",[],"Digitalchecks",[355],{"_26":356,"_179":357,"_358":359,"_360":361,"_362":359,"_363":361,"_364":361,"_365":366},"dzuhoz9isss8kzvk7nq5qcgo","Entwurf eines Gesetzes zur Stärkung der Öffentlichen Gesundheit","EinschaetzungAutomatisierung","Nicht_Relevant","EinschaetzungDatenschutz","Ja","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText",[367,371,375],{"_35":36,"_37":368},[369],{"_40":370,"_35":40},"Das Ressort hat Möglichkeiten zum digitalen Vollzug der Neuregelung (Digitaltauglichkeit) geprüft und hierzu einen Digitalcheck mit nachvollziehbarem Ergebnis durchgeführt. Das Ressort stellt dar, dass die Bedürfnisse der Betroffenen berücksichtigt worden sind, indem u. a. Verbände bereits vor der gesetzlichen Verbändebeteiligung sowie Expertengremien einbezogen wurden. Zudem wurde eine „Task Force“ mit dem betroffenen RKI und der BZgA eingerichtet.",{"_35":36,"_37":372},[373],{"_40":374,"_35":40},"Die Erkenntnisse daraus spiegeln sich nach Darstellung des Ressorts vor allem in der Organisationsstruktur, der Darstellung der Aufgabengebiete und den Regelungen zu Datenverarbeitungsfragen wider.",{"_35":36,"_37":376},[377],{"_40":378,"_35":40},"Hinsichtlich der Schaffung von Voraussetzungen für digitale Kommunikation wird weiterhin erklärt, dass dies durch Regelungen zum Zugang für Bürgerinnen und Bürger zu gut verständlichen und adressatengerecht gestalteten Gesundheitsinformationen erfüllt wurde. Hinsichtlich der Wiederverwendung von Daten und Standards stellt das Ressort dar, dass die Anforderungen nach §12a E-Government-Gesetz und dem Datennutzungsgesetz adressiert werden."]
