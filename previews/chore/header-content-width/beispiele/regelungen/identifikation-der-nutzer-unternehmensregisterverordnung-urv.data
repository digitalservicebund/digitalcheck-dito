[{"_1":2,"_22":23,"_175":176},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_20":21},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13,"_19":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":24},[25,69,89,108,150],{"_26":27,"_28":29,"_30":31,"_32":33,"_64":65,"_66":67,"_68":29},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[34,42,46],{"_35":36,"_37":38},"type","paragraph","children",[39],{"_40":41,"_35":40},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_35":36,"_37":43},[44],{"_40":45,"_35":40},"Erfahren Sie in diesem Abschnitt,",{"_35":47,"_48":49,"_37":50},"list","format","unordered",[51,56,60],{"_35":52,"_37":53},"list-item",[54],{"_40":55,"_35":40},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_35":52,"_37":57},[58],{"_40":59,"_35":40},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_35":52,"_37":61},[62],{"_40":63,"_35":40},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_26":70,"_28":71,"_30":72,"_32":73,"_64":87,"_66":88,"_68":71},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[74],{"_35":36,"_37":75},[76,78,85],{"_40":77,"_35":40},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_79":80,"_35":81,"_37":82},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[83],{"_40":84,"_35":40},"Once-Only-Prinzip",{"_40":86,"_35":40}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_26":90,"_28":91,"_30":92,"_32":93,"_64":105,"_66":106,"_68":107},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[94],{"_35":36,"_37":95},[96,98,103],{"_40":97,"_35":40},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_79":99,"_35":81,"_37":100},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[101],{"_40":102,"_35":40},"Sicherheit der Angebote",{"_40":104,"_35":40}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_26":109,"_28":110,"_30":111,"_32":112,"_64":147,"_66":148,"_68":149},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[113,131],{"_35":36,"_37":114},[115,117,122,124,129],{"_40":116,"_35":40},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_79":118,"_35":81,"_37":119},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[120],{"_40":121,"_35":40},"GGO",{"_40":123,"_35":40}," und das ",{"_79":125,"_35":81,"_37":126},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[127],{"_40":128,"_35":40},"Handbuch der Rechtsförmlichkeit",{"_40":130,"_35":40}," vorgeschrieben.",{"_35":36,"_37":132},[133,135,138,140,145],{"_40":134,"_35":40},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_40":136,"_35":40,"_137":13},"Verwaltungsakt","italic",{"_40":139,"_35":40}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_79":141,"_35":81,"_37":142},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[143],{"_40":144,"_35":40},"§ 35a VwVfG",{"_40":146,"_35":40},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_26":151,"_28":107,"_30":152,"_32":153,"_64":173,"_66":174,"_68":110},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[154,165,169],{"_35":36,"_37":155},[156,158,163],{"_40":157,"_35":40},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_79":159,"_35":81,"_37":160},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[161],{"_40":162,"_35":40},"DSGVO",{"_40":164,"_35":40}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_35":36,"_37":166},[167],{"_40":168,"_35":40},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_35":36,"_37":170},[171],{"_40":172,"_35":40},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":177},{"_26":178,"_179":180,"_181":182,"_183":-5,"_184":185,"_64":186,"_187":188,"_189":190,"_191":-5,"_192":193,"_194":195,"_371":372,"_422":423},"kgszoepavdh3zkfxehxx0zng","Titel","Identifikation der Nutzer Unternehmensregisterverordnung – URV","NKRNummer",6898,"Rechtsgebiet","Ressort","BMJV","identifikation-der-nutzer-unternehmensregisterverordnung-urv","VeroeffentlichungsDatum","2024-10-08","LinkRegelungstext","https://www.gesetze-im-internet.de/urv/BJNR021700007.html","NKRStellungnahmeLink","GesetzStatus","Verkuendetes_Gesetz_aktuelle_Fassung","Paragraphen",[196],{"_26":197,"_28":198,"_179":199,"_200":201,"_202":-5,"_203":204},"icj7tfownt5q9dk34m2hgrv5","3a","Identifikation der Nutzer","Gesetz","URV","Artikel","Absaetze",[205,273,331,339],{"_26":206,"_207":208,"_28":29,"_242":243},"yjvchqu3zrcpbd539g0qnjnr","Text",[209,216],{"_35":36,"_37":210},[211,214],{"_40":212,"_35":40,"_213":13},"Für eine Registrierung nach § 3 Absatz 2 hat eine elektronische Identifikation des Nutzers zu erfolgen.[1]","underline",{"_40":215,"_35":40}," Nutzer ist diejenige natürliche Person, die eine Datenübermittlung nach § 11 Absatz 2 für Veröffentlichungs- und Offenlegungspflichtige tatsächlich vornehmen soll. Die elektronische Identifikation erfolgt anhand",{"_35":47,"_48":217,"_37":218},"ordered",[219,223,227,238],{"_35":52,"_37":220},[221],{"_40":222,"_35":40},"eines elektronischen Identitätsnachweises nach § 18 des Personalausweisgesetzes, nach § 12 des eID-Karte- Gesetzes oder nach § 78 Absatz 5 des Aufenthaltsgesetzes,",{"_35":52,"_37":224},[225],{"_40":226,"_35":40},"eines elektronischen Identifizierungsmittels, das von einem anderen Mitgliedstaat der Europäischen Union ausgestellt wurde und das",{"_35":47,"_48":217,"_37":228,"_237":29},[229,233],{"_35":52,"_37":230},[231],{"_40":232,"_35":40},"für die Zwecke der grenzüberschreitenden Authentifizierung nach Artikel 6 der Verordnung (EU) Nr. 910/2014 des Europäischen Parlaments und des Rates vom 23. Juli 2014 über elektronische Identifizierung und Vertrauensdienste für elektronische Transaktionen im Binnenmarkt und zur Aufhebung der Richtlinie 1999/93/EG (ABl. L 257 vom 28.8.2014, S. 73; L 23 vom 29.1.2015, S. 19; L 155 vom 14.6.2016, S. 44), die durch die Richtlinie (EU) 2022/2555 (ABl. L 333 vom 27.12.2022, S. 80) geändert worden ist, anerkannt wird und",{"_35":52,"_37":234},[235],{"_40":236,"_35":40},"dem Sicherheitsniveau „hoch“ im Sinne des Artikels 8 Absatz 2 Buchstabe c der Verordnung (EU) Nr. 910/2014 entspricht, oder","indentLevel",{"_35":52,"_37":239},[240],{"_40":241,"_35":40},"einer von der registerführenden Stelle zur Verfügung gestellten Identifizierungsmethode im Sinne des Artikels 24 Absatz 1 Unterabsatz 2 Buchstabe d Satz 1 der Verordnung (EU) Nr. 910/2014.","PrinzipErfuellungen",[244],{"_245":246,"_247":248,"_253":254},"id","1377","Erklaerung",[249],{"_35":36,"_37":250},[251],{"_40":252,"_35":40},"Führt zu ausschließlich digitaler Kommunikation, eine für die Nutzergruppe geeignete Form.","Prinzip",{"_26":27,"_28":29,"_30":31,"_32":255,"_64":65,"_66":67,"_68":29},[256,259,262],{"_35":36,"_37":257},[258],{"_40":41,"_35":40},{"_35":36,"_37":260},[261],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":263},[264,267,270],{"_35":52,"_37":265},[266],{"_40":55,"_35":40},{"_35":52,"_37":268},[269],{"_40":59,"_35":40},{"_35":52,"_37":271},[272],{"_40":63,"_35":40},{"_26":274,"_207":275,"_28":71,"_242":308},"x08f0pfhfwc2hxhnhaqh51it",[276,282,304],{"_35":36,"_37":277},[278,280],{"_40":279,"_35":40},"Bei erfolgreicher Identifikation werden der Prozessnachweis, der Familienname und die Vornamen des Nutzers im Nutzerkonto gespeichert. ",{"_40":281,"_35":40,"_213":13},"Die folgenden Identifizierungsdaten werden im Unternehmensregister gespeichert und sind acht Jahre nach der letzten Datenübermittlung zu löschen:[3]",{"_35":47,"_48":217,"_37":283},[284,288,292,296,300],{"_35":52,"_37":285},[286],{"_40":287,"_35":40},"Titel,",{"_35":52,"_37":289},[290],{"_40":291,"_35":40},"Tag der Geburt,",{"_35":52,"_37":293},[294],{"_40":295,"_35":40},"Anschrift,",{"_35":52,"_37":297},[298],{"_40":299,"_35":40},"Dokumentenart des Ausweisdokuments,",{"_35":52,"_37":301},[302],{"_40":303,"_35":40},"Zeitstempel.",{"_35":36,"_37":305},[306],{"_40":307,"_35":40},"Sofern keine Datenübermittlung erfolgt ist, sind die in Satz 2 genannten Daten acht Jahre nach Abschluss des Identifikationsvorganges zu löschen. Weitere im Rahmen der Identifizierung erhobene Daten sind drei Monate nach Abschluss des Identifikationsvorganges zu löschen. Bei erfolgloser Identifikation werden der Prozessnachweis, der Familienname und die Vornamen des Nutzers zusammen mit den Daten nach Satz 3 gelöscht.",[309],{"_245":310,"_247":311,"_253":316},"1385",[312],{"_35":36,"_37":313},[314],{"_40":315,"_35":40},"Spezifiziert einen vergleichsweise geringen Umfang an Daten und verknüpft diese bereits mit einer Löschfrist.",{"_26":151,"_28":107,"_30":152,"_32":317,"_64":173,"_66":174,"_68":110},[318,325,328],{"_35":36,"_37":319},[320,321,324],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":322},[323],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":326},[327],{"_40":168,"_35":40},{"_35":36,"_37":329},[330],{"_40":172,"_35":40},{"_26":332,"_207":333,"_28":107,"_242":338},"v18moh4ayoao8wrjkboiyp28",[334],{"_35":36,"_37":335},[336],{"_40":337,"_35":40},"Hat die registerführende Stelle im Rahmen der Registrierung oder der Datenübermittlung nach § 11 Absatz 2 Satz 1 ernstliche Zweifel an der Rechtsfähigkeit oder Geschäftsfähigkeit eines Nutzers oder an seiner Berechtigung zur Datenübermittlung, so kann die registerführende Stelle von ihm oder dem für ihn handelnden Berechtigten die Übermittlung geeigneter Nachweise oder eine erneute Identifikation verlangen.",[],{"_26":340,"_207":341,"_28":149,"_242":354},"lzd173a3z6lkm3jdxdna9b1v",[342],{"_35":36,"_37":343},[344,346,348,350,352],{"_40":345,"_35":40},"Die registerführende Stelle ist befugt, ",{"_40":347,"_35":40,"_213":13},"nach ihren technischen Vorgaben eine Schnittstelle zur Steuerberaterplattform nach § 86c des Steuerberatungsgesetzes einzurichten. Ist eine solche Schnittstelle eingerichtet, so müssen sich Nutzer, die bereits über die Steuerberaterplattform identifiziert sind, für die Registrierung nach § 3 nicht nach Absatz 1 identifizieren.[2]",{"_40":349,"_35":40}," In diesen Fällen kann die registerführende Stelle ",{"_40":351,"_35":40,"_213":13},"vom Betreiber der Steuerberaterplattform verlangen, ihr die dort erhobenen Identifizierungsdaten über die Schnittstelle zu übermitteln.[2]",{"_40":353,"_35":40}," Die registerführende Stelle ist befugt, die übermittelten Identifizierungsdaten und die Daten der SAFE-Visitenkarte zu verarbeiten. Absatz 2 Satz 1 bis 3 gilt entsprechend. Die registerführende Stelle ist berechtigt, sich auf die Richtigkeit und Vollständigkeit der ihr übermittelten Daten zu verlassen, es sei denn, an deren Richtigkeit oder Vollständigkeit bestehen ernstliche Zweifel; in diesem Fall ist sie verpflichtet, vom Betreiber der Steuerberaterplattform die erforderlichen Nachweise über eine erfolgte Identifizierung zu verlangen.",[355],{"_245":356,"_247":357,"_253":362},"1381",[358],{"_35":36,"_37":359},[360],{"_40":361,"_35":40},"Reduziert den Aufwand für die Nutzergruppe, indem bereits erhobene Daten der Steuerberaterplattform wiederverwendet werden.",{"_26":70,"_28":71,"_30":72,"_32":363,"_64":87,"_66":88,"_68":71},[364],{"_35":36,"_37":365},[366,367,370],{"_40":77,"_35":40},{"_79":80,"_35":81,"_37":368},[369],{"_40":84,"_35":40},{"_40":86,"_35":40},"Visualisierungen",[373],{"_26":374,"_179":375,"_32":376,"_408":409,"_410":411,"_412":-5,"_184":-5,"_413":414,"_420":421},"tkqvdwq669c7nkqrflqvzb5s","Vorher-Nachher-Vergleich",[377,381],{"_35":36,"_37":378},[379],{"_40":380,"_35":40},"Nach §3a URV",{"_35":47,"_48":49,"_37":382},[383,395,401],{"_35":52,"_37":384},[385,387,389,391,393],{"_40":386,"_35":40},"Macht Auswirkungen der Änderungen – den Wegfall von Extraschritt bei Nutzergruppe – durch einen ",{"_388":13,"_40":375,"_35":40},"bold",{"_40":390,"_35":40}," ",{"_388":13,"_40":392,"_35":40},"nachvollziehbar",{"_40":394,"_35":40},".",{"_35":52,"_37":396},[397,399],{"_388":13,"_40":398,"_35":40},"Abstrahiert die inhaltliche Komplexität zu einer schematischen Darstellung",{"_40":400,"_35":40}," und ist damit verständlich für Fachleute und Laien.",{"_35":52,"_37":402},[403,405,407],{"_40":404,"_35":40},"Fördert eine schnelle Orientierung durch",{"_388":13,"_40":406,"_35":40}," Verknüpfung des Paragraphen mit der Visualisierung",{"_40":394,"_35":40},"Visualisierungsart","Flussdiagramm","Visualisierungstool","PowerPoint","Aufwand","Bild",{"_26":415,"_79":416,"_417":-5,"_418":419},"rnvl92pn9drorwlvgar3nhd0","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/visualisierung_Unternehmensregisterverordnung_791d12038d.jpg","previewUrl","alternativeText","Das Bild zeigt zwei Flussdiagramme, die den Prozess der Identifizierung und Speicherung von Steuerberatern vor und nach einer Gesetzesänderung darstellen.","Beispielvorhaben",{"_64":186,"_187":188,"_183":-5,"_179":180,"_184":185},"Digitalchecks",[424],{"_26":425,"_179":426,"_427":428,"_429":428,"_430":431,"_432":428,"_433":428,"_434":-5},"r4usyeyo7xtb4a1665p3i9wx","Verordnung zur Änderung der Unternehmensregisterverordnung","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","Teilweise","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText"]
