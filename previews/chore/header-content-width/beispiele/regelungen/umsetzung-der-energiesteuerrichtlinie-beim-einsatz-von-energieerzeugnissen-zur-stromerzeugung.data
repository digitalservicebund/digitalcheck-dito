[{"_1":2,"_22":23,"_175":176},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_20":21},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13,"_19":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":24},[25,69,89,108,150],{"_26":27,"_28":29,"_30":31,"_32":33,"_64":65,"_66":67,"_68":29},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[34,42,46],{"_35":36,"_37":38},"type","paragraph","children",[39],{"_40":41,"_35":40},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_35":36,"_37":43},[44],{"_40":45,"_35":40},"Erfahren Sie in diesem Abschnitt,",{"_35":47,"_48":49,"_37":50},"list","format","unordered",[51,56,60],{"_35":52,"_37":53},"list-item",[54],{"_40":55,"_35":40},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_35":52,"_37":57},[58],{"_40":59,"_35":40},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_35":52,"_37":61},[62],{"_40":63,"_35":40},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_26":70,"_28":71,"_30":72,"_32":73,"_64":87,"_66":88,"_68":71},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[74],{"_35":36,"_37":75},[76,78,85],{"_40":77,"_35":40},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_79":80,"_35":81,"_37":82},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[83],{"_40":84,"_35":40},"Once-Only-Prinzip",{"_40":86,"_35":40}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_26":90,"_28":91,"_30":92,"_32":93,"_64":105,"_66":106,"_68":107},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[94],{"_35":36,"_37":95},[96,98,103],{"_40":97,"_35":40},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_79":99,"_35":81,"_37":100},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[101],{"_40":102,"_35":40},"Sicherheit der Angebote",{"_40":104,"_35":40}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_26":109,"_28":110,"_30":111,"_32":112,"_64":147,"_66":148,"_68":149},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[113,131],{"_35":36,"_37":114},[115,117,122,124,129],{"_40":116,"_35":40},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_79":118,"_35":81,"_37":119},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[120],{"_40":121,"_35":40},"GGO",{"_40":123,"_35":40}," und das ",{"_79":125,"_35":81,"_37":126},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[127],{"_40":128,"_35":40},"Handbuch der Rechtsförmlichkeit",{"_40":130,"_35":40}," vorgeschrieben.",{"_35":36,"_37":132},[133,135,138,140,145],{"_40":134,"_35":40},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_40":136,"_35":40,"_137":13},"Verwaltungsakt","italic",{"_40":139,"_35":40}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_79":141,"_35":81,"_37":142},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[143],{"_40":144,"_35":40},"§ 35a VwVfG",{"_40":146,"_35":40},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_26":151,"_28":107,"_30":152,"_32":153,"_64":173,"_66":174,"_68":110},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[154,165,169],{"_35":36,"_37":155},[156,158,163],{"_40":157,"_35":40},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_79":159,"_35":81,"_37":160},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[161],{"_40":162,"_35":40},"DSGVO",{"_40":164,"_35":40}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_35":36,"_37":166},[167],{"_40":168,"_35":40},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_35":36,"_37":170},[171],{"_40":172,"_35":40},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":177},{"_26":178,"_179":180,"_181":182,"_183":-5,"_184":185,"_64":186,"_187":-5,"_188":189,"_190":-5,"_191":192,"_193":194,"_195":196,"_232":233},"qzv801pz13xe7a25exak46b5","Titel","Umsetzung der Energiesteuerrichtlinie beim Einsatz von Energieerzeugnissen zur Stromerzeugung","NKRNummer",7747,"Rechtsgebiet","Ressort","BMF","umsetzung-der-energiesteuerrichtlinie-beim-einsatz-von-energieerzeugnissen-zur-stromerzeugung","VeroeffentlichungsDatum","LinkRegelungstext","https://dserver.bundestag.de/brd/2025/0427-25.pdf","NKRStellungnahmeLink","GesetzStatus","Regelungsentwurf","Paragraphen",[],"Visualisierungen",[197],{"_26":198,"_179":199,"_32":200,"_219":220,"_221":-5,"_222":-5,"_184":-5,"_223":224,"_230":231},"p2pp79qa780sk2l0thggnoxd","Vorher-Nachher-Vergleich komplexer Regelungen",[201],{"_35":47,"_48":49,"_37":202},[203,207,211,215],{"_35":52,"_37":204},[205],{"_40":206,"_35":40},"Bereitet die komplexen steuerrechtlichen Regelungen zum Einsatz von Energieerzeugnissen zur Stromerzeugung strukturiert und übersichtlich auf. ",{"_35":52,"_37":208},[209],{"_40":210,"_35":40},"Unterstützt die Prüfung einzelner Fallkonstellationen durch klar nachvollziehbare Entscheidungsschritte.",{"_35":52,"_37":212},[213],{"_40":214,"_35":40},"Stellt die Unterschiede zwischen der bisherigen Rechtslage und der Rechtslage ab dem 1. Januar 2026 übersichtlich dar.",{"_35":52,"_37":216},[217],{"_40":218,"_35":40},"Verknüpft gesetzliche Grundlagen mit den jeweiligen Prozessschritten und erleichtert eine einheitliche Anwendung der Regelungen.","Visualisierungsart","Schaubild","Visualisierungstool","Aufwand","Bild",{"_26":225,"_79":226,"_227":-5,"_228":229},"j8hoeynu4ftspby7p5hs3d3i","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/7747_Anlage_Digi_Check_Anhang5_6b48c77525.jpg","previewUrl","alternativeText","Das übersichtliche Schaubild zeigt Schritt für Schritt, wann Energieerzeugnisse zur Stromerzeugung steuerfrei oder steuerlich entlastet sind. Dazu erfolgt ein Vergleich zwischen der bisherigen Rechtslage und den ab dem 1. Januar 2026 geltenden Regeln.","Beispielvorhaben",{"_64":186,"_187":-5,"_183":-5,"_179":180,"_184":185},"Digitalchecks",[234],{"_26":235,"_179":180,"_236":-5,"_237":-5,"_238":-5,"_239":-5,"_240":-5,"_241":-5},"ytodfe6dxnps28lzxj4z02hz","EinschaetzungAutomatisierung","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText"]
