[{"_1":2,"_22":23,"_175":176},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_20":21},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13,"_19":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":24},[25,69,89,108,150],{"_26":27,"_28":29,"_30":31,"_32":33,"_64":65,"_66":67,"_68":29},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[34,42,46],{"_35":36,"_37":38},"type","paragraph","children",[39],{"_40":41,"_35":40},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_35":36,"_37":43},[44],{"_40":45,"_35":40},"Erfahren Sie in diesem Abschnitt,",{"_35":47,"_48":49,"_37":50},"list","format","unordered",[51,56,60],{"_35":52,"_37":53},"list-item",[54],{"_40":55,"_35":40},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_35":52,"_37":57},[58],{"_40":59,"_35":40},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_35":52,"_37":61},[62],{"_40":63,"_35":40},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_26":70,"_28":71,"_30":72,"_32":73,"_64":87,"_66":88,"_68":71},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[74],{"_35":36,"_37":75},[76,78,85],{"_40":77,"_35":40},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_79":80,"_35":81,"_37":82},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[83],{"_40":84,"_35":40},"Once-Only-Prinzip",{"_40":86,"_35":40}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_26":90,"_28":91,"_30":92,"_32":93,"_64":105,"_66":106,"_68":107},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[94],{"_35":36,"_37":95},[96,98,103],{"_40":97,"_35":40},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_79":99,"_35":81,"_37":100},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[101],{"_40":102,"_35":40},"Sicherheit der Angebote",{"_40":104,"_35":40}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_26":109,"_28":110,"_30":111,"_32":112,"_64":147,"_66":148,"_68":149},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[113,131],{"_35":36,"_37":114},[115,117,122,124,129],{"_40":116,"_35":40},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_79":118,"_35":81,"_37":119},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[120],{"_40":121,"_35":40},"GGO",{"_40":123,"_35":40}," und das ",{"_79":125,"_35":81,"_37":126},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[127],{"_40":128,"_35":40},"Handbuch der Rechtsförmlichkeit",{"_40":130,"_35":40}," vorgeschrieben.",{"_35":36,"_37":132},[133,135,138,140,145],{"_40":134,"_35":40},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_40":136,"_35":40,"_137":13},"Verwaltungsakt","italic",{"_40":139,"_35":40}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_79":141,"_35":81,"_37":142},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[143],{"_40":144,"_35":40},"§ 35a VwVfG",{"_40":146,"_35":40},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_26":151,"_28":107,"_30":152,"_32":153,"_64":173,"_66":174,"_68":110},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[154,165,169],{"_35":36,"_37":155},[156,158,163],{"_40":157,"_35":40},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_79":159,"_35":81,"_37":160},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[161],{"_40":162,"_35":40},"DSGVO",{"_40":164,"_35":40}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_35":36,"_37":166},[167],{"_40":168,"_35":40},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_35":36,"_37":170},[171],{"_40":172,"_35":40},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":177},{"_26":178,"_179":180,"_181":182,"_183":-5,"_184":185,"_64":186,"_187":188,"_189":190,"_191":-5,"_192":193,"_194":195,"_653":654,"_655":656},"i56trtj4v0xt7x1qzmgenwvq","Titel","Einrichtung Herkunftsnachweisregister für Gas, Wärme und Kälte  - GWKHV","NKRNummer",6894,"Rechtsgebiet","Ressort","BMWE","einrichtung-herkunftsnachweisregister-fuer-gas-waerme-und-kaelte-gwkhv","VeroeffentlichungsDatum","2024-01-24","LinkRegelungstext","https://www.gesetze-im-internet.de/gwkhv/BJNR08B0A0024.html","NKRStellungnahmeLink","GesetzStatus","Verkuendetes_Gesetz_aktuelle_Fassung","Paragraphen",[196,450,500,549],{"_26":197,"_28":198,"_179":199,"_200":201,"_202":-5,"_203":204},"fwvm8hxrd7ip42ufoaeg96vx","39","Überprüfung der gespeicherten Daten; Datenübermittlung","Gesetz","GWKH","Artikel","Absaetze",[205,254,300,358,418],{"_26":206,"_207":208,"_28":29,"_227":228},"hpcdwgmccb8r01rbouf3u8ok","Text",[209,216],{"_35":36,"_37":210},[211,214],{"_40":212,"_35":40,"_213":13},"Für einen effizienten Registerbetrieb gleicht das Umweltbundesamt die im Herkunftsnachweisregister für Gas und die im Herkunftsnachweisregister für Wärme oder Kälte gespeicherten Daten, einschließlich personenbezogener Daten, miteinander ab und tauscht sie zwischen diesen Registern aus[2]","underline",{"_40":215,"_35":40}," im Hinblick auf die Erzeugung von",{"_35":47,"_48":217,"_37":218},"ordered",[219,223],{"_35":52,"_37":220},[221],{"_40":222,"_35":40},"Gas aus oder auf Basis von thermischer Energie sowie",{"_35":52,"_37":224},[225],{"_40":226,"_35":40},"thermischer Energie aus Gas aus oder auf Basis von erneuerbarer Energie oder kohlenstoffarmem Gas.","PrinzipErfuellungen",[229],{"_230":231,"_232":233,"_244":245},"id","1401","Erklaerung",[234],{"_35":47,"_48":49,"_37":235},[236,240],{"_35":52,"_37":237},[238],{"_40":239,"_35":40},"Verringert die Fehleranfälligkeit durch den Datenabgleich.",{"_35":52,"_37":241},[242],{"_40":243,"_35":40},"Im folgenden Absatz wird der Abgleich und Austausch der Daten näher spezifiziert und erweitert.  ","Prinzip",{"_26":70,"_28":71,"_30":72,"_32":246,"_64":87,"_66":88,"_68":71},[247],{"_35":36,"_37":248},[249,250,253],{"_40":77,"_35":40},{"_79":80,"_35":81,"_37":251},[252],{"_40":84,"_35":40},{"_40":86,"_35":40},{"_26":255,"_207":256,"_28":71,"_227":299},"sffli6kz1ucnfl3t2zkxhekm",[257,261,295],{"_35":36,"_37":258},[259],{"_40":260,"_35":40},"Das Umweltbundesamt kann die in den Herkunftsnachweisregistern nach § 3 eingetragenen Daten, einschließlich personenbezogener Daten, mit den Daten abgleichen, die",{"_35":47,"_48":217,"_37":262},[263,267,271,275,279,283,287,291],{"_35":52,"_37":264},[265],{"_40":266,"_35":40},"im Herkunftsnachweisregister nach § 79 des Erneuerbare-Energien-Gesetzes gespeichert sind,",{"_35":52,"_37":268},[269],{"_40":270,"_35":40},"im Marktstammdatenregister nach § 111e Absatz 1 des Energiewirtschaftsgesetzes, das zuletzt durch Artikel 1 des Gesetzes vom 5. Februar 2024 (BGBl. 2024 I Nr. 32) geändert worden ist, gespeichert sind,",{"_35":52,"_37":272},[273],{"_40":274,"_35":40},"im Register Biostrom nach § 44 der Biomassestrom-Nachhaltigkeitsverordnung gespeichert sind,",{"_35":52,"_37":276},[277],{"_40":278,"_35":40},"im Register Biokraftstoffe nach § 42 der Biokraftstoff-Nachhaltigkeitsverordnung gespeichert sind,",{"_35":52,"_37":280},[281],{"_40":282,"_35":40},"der zuständigen Stelle nach § 37d Absatz 1 des Bundes-Immissionsschutzgesetzes in der Fassung der Bekanntmachung vom 17. Mai 2013 (BGBl. I S. 1274; 2021 I S. 123), das zuletzt durch Artikel 11 Absatz 3 des Gesetzes vom 26. Juli 2023 (BGBl. 2023 I Nr. 202) geändert worden ist, vorliegen,",{"_35":52,"_37":284},[285],{"_40":286,"_35":40},"in der Datenbank Nachhaltige-Biomasse-Systeme gespeichert sind,",{"_35":52,"_37":288},[289],{"_40":290,"_35":40},"im Biogasregister der Deutschen Energie-Agentur gespeichert sind oder",{"_35":52,"_37":292},[293],{"_40":294,"_35":40},"das Bundesamt für Wirtschaft und Ausfuhrkontrolle im Rahmen der Durchführung seiner Aufgaben nach dem Kraft-Wärme-Kopplungsgesetz oder nach der Richtlinie für die Bundesförderung für effiziente Wärmenetze „BEW“ vom 1. August 2022 (Banz AT 18.08.2022 B1) erhoben und gespeichert hat.\n",{"_35":36,"_37":296},[297],{"_40":298,"_35":40},"Das Umweltbundesamt kann Daten nach den Sätzen 3 und 4 mit dem Betreiber eines Registers oder einer Datenbank austauschen, soweit dies zur Gewährleistung der Sicherheit, der Richtigkeit oder der Zuverlässigkeit der Herkunftsnachweisregister nach § 3 erforderlich ist. Zu diesem Zwecke darf das Umweltbundesamt Daten aus einem Register oder einer Datenbank nach Satz 1 erheben, speichern und verwenden, soweit diesbezüglich eine Mitteilungspflicht eines Registerteilnehmers nach dieser Verordnung besteht. Das Umweltbundesamt darf Daten an den Betreiber eines Registers oder einer Datenbank nach Satz 1 übermitteln, soweit die Daten dem Umweltbundesamt und in dem Register oder der Datenbank nach Satz 1 vorliegen und diesbezüglich eine Mitteilungspflicht des Registerteilnehmers im Zusammenhang mit dem Betrieb des jeweiligen Registers oder der jeweiligen Datenbank nach Satz 1 besteht.",[],{"_26":301,"_207":302,"_28":107,"_227":335},"v49aduz75b8spi2mwx3zodm4",[303,309],{"_35":36,"_37":304},[305,307],{"_40":306,"_35":40,"_213":13},"Soweit es zur Durchführung dieser Verordnung erforderlich ist, darf das Umweltbundesamt Daten aus dem Herkunftsnachweisregister für Gas oder dem Herkunftsnachweisregister für Wärme oder Kälte übermitteln[3]",{"_40":308,"_35":40}," an",{"_35":47,"_48":217,"_37":310},[311,315,319,323,327,331],{"_35":52,"_37":312},[313],{"_40":314,"_35":40},"das Bundesministerium für Wirtschaft und Klimaschutz,",{"_35":52,"_37":316},[317],{"_40":318,"_35":40},"das Bundesministerium für Umwelt, Naturschutz, nukleare Sicherheit und Verbraucherschutz,",{"_35":52,"_37":320},[321],{"_40":322,"_35":40},"das Bundesministerium für Ernährung und Landwirtschaft,",{"_35":52,"_37":324},[325],{"_40":326,"_35":40},"die nachgeordneten Behörden der in den Nummern 1 bis 3 genannten Bundesministerien,",{"_35":52,"_37":328},[329],{"_40":330,"_35":40},"Behörden anderer Mitgliedstaaten der Europäischen Union und von Drittstaaten sowie",{"_35":52,"_37":332},[333],{"_40":334,"_35":40},"Organe der Europäischen Union.",[336],{"_230":337,"_232":338,"_244":343},"1407",[339],{"_35":36,"_37":340},[341],{"_40":342,"_35":40},"Schränkt die Datenübermittlung durch die Zweckbindung ein.",{"_26":151,"_28":107,"_30":152,"_32":344,"_64":173,"_66":174,"_68":110},[345,352,355],{"_35":36,"_37":346},[347,348,351],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":349},[350],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":353},[354],{"_40":168,"_35":40},{"_35":36,"_37":356},[357],{"_40":172,"_35":40},{"_26":359,"_207":360,"_28":149,"_227":389},"i9t6l6by44lbcecptjuzclfe",[361,365,383],{"_35":36,"_37":362},[363],{"_40":364,"_35":40},"Das Umweltbundesamt kann den Betreibern der Datenbanken und der Register nach Absatz 2 sowie den Behörden nach Absatz 3 über elektronische Schnittstellen den Zugang zu den in einem Herkunftsnachweisregister nach § 3 gespeicherten Daten, einschließlich personenbezogener Daten, ermöglichen. Das Umweltbundesamt als übermittelnde Stelle hat über die Abrufe nach Satz 1 Aufzeichnungen zu fertigen, die die folgenden Daten enthalten müssen:",{"_35":47,"_48":217,"_37":366},[367,371,375,379],{"_35":52,"_37":368},[369],{"_40":370,"_35":40},"die bei der Durchführung der Abrufe verwendeten Daten,",{"_35":52,"_37":372},[373],{"_40":374,"_35":40},"den Tag und die Uhrzeit der Abrufe,",{"_35":52,"_37":376},[377],{"_40":378,"_35":40},"die Kennung der abrufenden Dienststelle und",{"_35":52,"_37":380},[381],{"_40":382,"_35":40},"die abgerufenen Daten.",{"_35":36,"_37":384},[385,387],{"_40":386,"_35":40},"Die protokollierten Daten dürfen nur für Zwecke der Datenschutzkontrolle oder Datensicherung oder zur Sicherstellung eines ordnungsgemäßen Betriebs der Datenverarbeitungsanlage verwendet werden. ",{"_40":388,"_35":40,"_213":13},"Die protokollierten Daten sind durch geeignete Vorkehrungen gegen zweckfremde Verwendung und gegen sonstigen Missbrauch zu schützen. Die protokollierten Daten sind sechs Monate nach der Protokollierung zu löschen.[3]",[390],{"_230":391,"_232":392,"_244":403},"1403",[393],{"_35":47,"_48":49,"_37":394},[395,399],{"_35":52,"_37":396},[397],{"_40":398,"_35":40},"Erfordert Sicherheitsvorkehrungen, die allerdings noch näher spezifiziert werden müssten.",{"_35":52,"_37":400},[401],{"_40":402,"_35":40},"Legt klare Löschfristen fest.",{"_26":151,"_28":107,"_30":152,"_32":404,"_64":173,"_66":174,"_68":110},[405,412,415],{"_35":36,"_37":406},[407,408,411],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":409},[410],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":413},[414],{"_40":168,"_35":40},{"_35":36,"_37":416},[417],{"_40":172,"_35":40},{"_26":419,"_207":420,"_28":110,"_227":427},"sdtovch52centy3wu4grz3ko",[421],{"_35":36,"_37":422},[423,425],{"_40":424,"_35":40,"_213":13},"Das Umweltbundesamt richtet eine elektronische Schnittstelle ein, die es ermöglicht, Daten an die nach Landesrecht zuständigen Behörden zu übermitteln[2]",{"_40":426,"_35":40},", soweit es für den Vollzug des Gebäudeenergiegesetzes vom 8. August 2020 (BGBl. I S. 1728), das durch Artikel 1 des Gesetzes vom 16. Oktober 2023 (BGBl. 2023 I Nr. 280) geändert worden ist, erforderlich ist. Absatz 4 Satz 2 bis 5 ist entsprechend anzuwenden.",[428],{"_230":429,"_232":430,"_244":441},"1409",[431],{"_35":47,"_48":49,"_37":432},[433,437],{"_35":52,"_37":434},[435],{"_40":436,"_35":40},"Vermeidet durch die Bereitstellung einer Schnittstelle doppelte Datenerhebung und ermöglicht die Wiederverwendung des Registers.",{"_35":52,"_37":438},[439],{"_40":440,"_35":40},"Die elektronische Schnittstelle stellt sicher, dass die Daten immer aktuell sind und der Zugriff protokolliert ist. Dieses Vorgehen ist dem Kopieren/Duplizieren von Daten vorzuziehen.",{"_26":70,"_28":71,"_30":72,"_32":442,"_64":87,"_66":88,"_68":71},[443],{"_35":36,"_37":444},[445,446,449],{"_40":77,"_35":40},{"_79":80,"_35":81,"_37":447},[448],{"_40":84,"_35":40},{"_40":86,"_35":40},{"_26":451,"_28":452,"_179":453,"_200":454,"_202":-5,"_203":455},"kywe489y1tdhef04nzlh78ih","5","Gemeinsame Datenbank","GWKHV",[456,492],{"_26":457,"_207":458,"_28":29,"_227":465},"u0972rnbgw3m6pmiqi8ld0cf",[459],{"_35":36,"_37":460},[461,463],{"_40":462,"_35":40,"_213":13},"Das Umweltbundesamt darf das Herkunftsnachweisregister für Gas, das Herkunftsnachweisregister für Wärme oder Kälte sowie das Herkunftsnachweisregister nach § 79 des Erneuerbare-Energien-Gesetzes in derselben elektronischen Datenbank betreiben.[6]",{"_40":464,"_35":40}," Innerhalb dieser Datenbank müssen die in Satz 1 genannten Herkunftsnachweisregister jedoch getrennt voneinander betrieben werden.",[466],{"_230":467,"_232":468,"_244":483},"1397",[469],{"_35":47,"_48":49,"_37":470},[471,475,479],{"_35":52,"_37":472},[473],{"_40":474,"_35":40},"Ermöglicht eine zeitsparende Umsetzung durch Nutzung einer bereits existierenden Lösung.",{"_35":52,"_37":476},[477],{"_40":478,"_35":40},"Ermöglicht das effiziente Betreiben der Register in derselben Datenbankinstanz, ohne die technologische Umsetzung einzuschränken.",{"_35":52,"_37":480},[481],{"_40":482,"_35":40},"Benennt die verschiedenen Register, die in der derselben Datenbank betrieben werden dürfen.",{"_26":90,"_28":91,"_30":92,"_32":484,"_64":105,"_66":106,"_68":107},[485],{"_35":36,"_37":486},[487,488,491],{"_40":97,"_35":40},{"_79":99,"_35":81,"_37":489},[490],{"_40":102,"_35":40},{"_40":104,"_35":40},{"_26":493,"_207":494,"_28":71,"_227":499},"zzolm34nhtr69qk35cc11p12",[495],{"_35":36,"_37":496},[497],{"_40":498,"_35":40},"Das Umweltbundesamt darf das Herkunftsnachweisregister für Gas mit dem zentralen Register für erneuerbare Kraftstoffe nicht biogenen Ursprungs nach § 44 Absatz 1 der Verordnung zur Anrechnung von strombasierten Kraftstoffen und mitverarbeiteten biogenen Ölen auf die Treibhausgasquote vom 17. April 2024 (BGBl. 2024 I Nr. 131) in derselben elektronischen Datenbank betreiben, sofern gewährleistet ist, dass der Herkunftsnachweis für Gas sowie der Nachweis nach § 16 der Verordnung zur Anrechnung von strombasierten Kraftstoffen und mitverarbeiteten biogenen Ölen auf die Treibhausgasquote jeweils als eigenständige Nachweisinstrumente genutzt werden können. Innerhalb der Datenbank müssen die beiden Register getrennt voneinander betrieben werden.",[],{"_26":501,"_28":502,"_179":503,"_200":454,"_202":-5,"_203":504},"surqyqhc2g41rtpk5dr76qa8","8","Kommunikationssystem",[505,513],{"_26":506,"_207":507,"_28":29,"_227":512},"sk37qf19d2qbf6q7vhu2gbjf",[508],{"_35":36,"_37":509},[510],{"_40":511,"_35":40},"Das Umweltbundesamt stellt ein Kommunikationssystem sowie ein Postfach innerhalb des Kommunikationssystems zur Führung eines Kontos zur Verfügung.",[],{"_26":514,"_207":515,"_28":71,"_227":522},"r6yhzlk7038f4j6ay171lp7y",[516],{"_35":36,"_37":517},[518,520],{"_40":519,"_35":40,"_213":13},"Registerteilnehmer sind verpflichtet, für die Kommunikation mit dem Umweltbundesamt einen Zugang zu diesem Kommunikationssystem zu eröffnen und den Zugang zu nutzen[1]",{"_40":521,"_35":40},", insbesondere für die Stellung von Anträgen, die Abgabe von Erklärungen sowie die Übermittlung von Daten und Dokumenten.",[523],{"_230":524,"_232":525,"_244":530},"1351",[526],{"_35":36,"_37":527},[528],{"_40":529,"_35":40},"Reduziert Aufwand in der Verwaltung, indem es Unternehmen zu digitaler Kommunikation zwingt.",{"_26":27,"_28":29,"_30":31,"_32":531,"_64":65,"_66":67,"_68":29},[532,535,538],{"_35":36,"_37":533},[534],{"_40":41,"_35":40},{"_35":36,"_37":536},[537],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":539},[540,543,546],{"_35":52,"_37":541},[542],{"_40":55,"_35":40},{"_35":52,"_37":544},[545],{"_40":59,"_35":40},{"_35":52,"_37":547},[548],{"_40":63,"_35":40},{"_26":550,"_28":551,"_179":552,"_200":454,"_202":-5,"_203":553},"ojid2yvevb6mbkvmu6sr2s4g","9","Kontoeröffnung und -führung ",[554,637,645],{"_26":555,"_207":556,"_28":29,"_227":620},"i4krwhcjn6mgbhshq8z53u3e",[557,561],{"_35":36,"_37":558},[559],{"_40":560,"_35":40},"Im Antrag auf Kontoeröffnung sind folgende Daten an das Umweltbundesamt zu übermitteln:",{"_35":47,"_48":217,"_37":562},[563,567,590,594],{"_35":52,"_37":564},[565],{"_40":566,"_35":40},"wenn der Antragsteller eine natürliche Person ist,",{"_35":47,"_48":217,"_37":568,"_589":29},[569,573,577,581,585],{"_35":52,"_37":570},[571],{"_40":572,"_35":40},"sein Vorname und sein Nachname, ",{"_35":52,"_37":574},[575],{"_40":576,"_35":40},"seine Wohnanschrift bestehend aus Straße, Hausnummer, Postleitzahl, Ort und Staat unter Angabe von Landkreis und Bundesland,",{"_35":52,"_37":578},[579],{"_40":580,"_35":40},"seine Telefonnummer, ",{"_35":52,"_37":582},[583],{"_40":584,"_35":40},"seine E-Mail-Adresse und ",{"_35":52,"_37":586},[587],{"_40":588,"_35":40,"_213":13},"die Umsatzsteuer-Identifikationsnummer oder die Wirtschafts-Identifikationsnummer, soweit eine solche vergeben ist,[2]","indentLevel",{"_35":52,"_37":591},[592],{"_40":593,"_35":40},"wenn der Antragsteller eine juristische Person oder rechtsfähige Personengesellschaft ist,",{"_35":47,"_48":217,"_37":595,"_589":29},[596,600,604,608,612,616],{"_35":52,"_37":597},[598],{"_40":599,"_35":40},"sein Name oder die Firma,",{"_35":52,"_37":601},[602],{"_40":603,"_35":40},"sein Sitz,",{"_35":52,"_37":605},[606],{"_40":607,"_35":40},"seine Telefonnummer,",{"_35":52,"_37":609},[610],{"_40":611,"_35":40},"seine E-Mail-Adresse,",{"_35":52,"_37":613},[614],{"_40":615,"_35":40},"die Angabe der gesetzlichen Vertreter und, sofern der Antragsteller im Handels-, Genossenschafts-, Partnerschafts- oder Vereinsregister oder in einem ähnlichen Register eingetragen ist, die Registernummer sowie die Angabe, bei welcher Stelle das Register geführt wird, und",{"_35":52,"_37":617},[618],{"_40":619,"_35":40,"_213":13},"die Umsatzsteuer-Identifikationsnummer oder die Wirtschafts-Identifikationsnummer, soweit eine solche vergeben ist.[2]",[621],{"_230":622,"_232":623,"_244":628},"1393",[624],{"_35":36,"_37":625},[626],{"_40":627,"_35":40},"Erfordert ein Identifikationsmerkmal (Umsatzsteuer-ID oder Wirtschafts-ID), was einen Abruf der restlichen geforderten Daten aus der Finanzverwaltung ermöglicht. Das legt den Grundstein für eine potentielle Datenabfrage (Erfüllung Once-Only Prinzip).",{"_26":70,"_28":71,"_30":72,"_32":629,"_64":87,"_66":88,"_68":71},[630],{"_35":36,"_37":631},[632,633,636],{"_40":77,"_35":40},{"_79":80,"_35":81,"_37":634},[635],{"_40":84,"_35":40},{"_40":86,"_35":40},{"_26":638,"_207":639,"_28":71,"_227":644},"w75r8engrmjhqtgmr63p7b9j",[640],{"_35":36,"_37":641},[642],{"_40":643,"_35":40},"Ein Kontoinhaber kann einen Dienstleister beauftragen, ein bestehendes Konto zu führen.",[],{"_26":646,"_207":647,"_28":107,"_227":652},"qyu6w399vk11bbw9225hb69b",[648],{"_35":36,"_37":649},[650],{"_40":651,"_35":40},"Ein Umweltgutachter oder eine Umweltgutachterorganisation muss sich vor Beginn seiner oder ihrer Tätigkeit im Zusammenhang mit dieser Verordnung im jeweiligen Herkunftsnachweisregister registrieren lassen, damit die für die Ausführung der Tätigkeit erforderlichen Daten und Nachweise übermittelt werden können.",[],"Visualisierungen",[],"Digitalchecks",[657],{"_26":658,"_179":659,"_660":661,"_662":661,"_663":661,"_664":661,"_665":661,"_666":-5},"a1d148tzium772ixiliqdyqn","Gas- und Wärme Herkunftsnachweisregisterverordnung – Gas/Wärme-HkNRV ","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText"]
