[{"_1":2,"_22":23,"_175":176},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_20":21},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13,"_19":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":24},[25,69,89,108,150],{"_26":27,"_28":29,"_30":31,"_32":33,"_64":65,"_66":67,"_68":29},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[34,42,46],{"_35":36,"_37":38},"type","paragraph","children",[39],{"_40":41,"_35":40},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_35":36,"_37":43},[44],{"_40":45,"_35":40},"Erfahren Sie in diesem Abschnitt,",{"_35":47,"_48":49,"_37":50},"list","format","unordered",[51,56,60],{"_35":52,"_37":53},"list-item",[54],{"_40":55,"_35":40},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_35":52,"_37":57},[58],{"_40":59,"_35":40},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_35":52,"_37":61},[62],{"_40":63,"_35":40},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_26":70,"_28":71,"_30":72,"_32":73,"_64":87,"_66":88,"_68":71},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[74],{"_35":36,"_37":75},[76,78,85],{"_40":77,"_35":40},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_79":80,"_35":81,"_37":82},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[83],{"_40":84,"_35":40},"Once-Only-Prinzip",{"_40":86,"_35":40}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_26":90,"_28":91,"_30":92,"_32":93,"_64":105,"_66":106,"_68":107},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[94],{"_35":36,"_37":95},[96,98,103],{"_40":97,"_35":40},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_79":99,"_35":81,"_37":100},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[101],{"_40":102,"_35":40},"Sicherheit der Angebote",{"_40":104,"_35":40}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_26":109,"_28":110,"_30":111,"_32":112,"_64":147,"_66":148,"_68":149},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[113,131],{"_35":36,"_37":114},[115,117,122,124,129],{"_40":116,"_35":40},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_79":118,"_35":81,"_37":119},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[120],{"_40":121,"_35":40},"GGO",{"_40":123,"_35":40}," und das ",{"_79":125,"_35":81,"_37":126},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[127],{"_40":128,"_35":40},"Handbuch der Rechtsförmlichkeit",{"_40":130,"_35":40}," vorgeschrieben.",{"_35":36,"_37":132},[133,135,138,140,145],{"_40":134,"_35":40},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_40":136,"_35":40,"_137":13},"Verwaltungsakt","italic",{"_40":139,"_35":40}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_79":141,"_35":81,"_37":142},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[143],{"_40":144,"_35":40},"§ 35a VwVfG",{"_40":146,"_35":40},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_26":151,"_28":107,"_30":152,"_32":153,"_64":173,"_66":174,"_68":110},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[154,165,169],{"_35":36,"_37":155},[156,158,163],{"_40":157,"_35":40},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_79":159,"_35":81,"_37":160},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[161],{"_40":162,"_35":40},"DSGVO",{"_40":164,"_35":40}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_35":36,"_37":166},[167],{"_40":168,"_35":40},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_35":36,"_37":170},[171],{"_40":172,"_35":40},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":177},{"_26":178,"_179":180,"_181":182,"_183":-5,"_184":185,"_64":186,"_187":-5,"_188":189,"_190":-5,"_191":192,"_193":194,"_1240":1241,"_1242":1243},"hzc3pdjaq0pw6o4ek6nbsw57","Titel","Modernisierung des Postrechts – PostG","NKRNummer",6980,"Rechtsgebiet","Ressort","BMWE","modernisierung-des-postrechts","VeroeffentlichungsDatum","LinkRegelungstext","https://www.gesetze-im-internet.de/postg_2024/BJNR0EC0B0024.html","NKRStellungnahmeLink","GesetzStatus","Verkuendetes_Gesetz_aktuelle_Fassung","Paragraphen",[195,318,441,490,607,757,901,947,1030,1141],{"_26":196,"_28":197,"_179":198,"_199":200,"_201":-5,"_202":203},"y0ix7t5auga2x6p3rsw83y3d","10","Filialen und automatisierte Stationen","Gesetz","PostG","Artikel","Absaetze",[204,268,310],{"_26":205,"_206":207,"_28":29,"_235":236},"rkxbr6378l5dwez6fm71o5t8","Text",[208,213,228,232],{"_35":36,"_37":209},[210],{"_40":211,"_35":40,"_212":13},"Betreiben Anbieter Filialen oder automatisierte Stationen, so haben sie der Bundesnetzagentur jeweils zum 1. Januar und zum 1. Juli eines Jahres die folgenden Informationen zu diesen Einrichtungen elektronisch zu übermitteln:[1]","underline",{"_35":47,"_48":214,"_37":215},"ordered",[216,220,224],{"_35":52,"_37":217},[218],{"_40":219,"_35":40},"die Anschrift der Einrichtung bestehend aus Straße, Hausnummer, Postleitzahl, Ort,",{"_35":52,"_37":221},[222],{"_40":223,"_35":40},"den Betreiber der Einrichtung in Form der in § 6 Absatz 1 Nummer 1 Buchstabe a, d und e genannten Informationen; bei juristischen Personen in Form der in § 6 Absatz 1 Nummer 2 Buchstabe a, b, d und e genannten Informationen, wobei § 6 Absatz 1 Nummer 2 Buchstabe b mit der Maßgabe zur Anwendung kommt, dass nur die Informationen nach § 6 Absatz 1 Nummer 1 Buchstabe a, d und e in Bezug genommen werden,",{"_35":52,"_37":225},[226],{"_40":227,"_35":40},"die Art der Einrichtung.",{"_35":36,"_37":229},[230],{"_40":231,"_35":40},"Betreiben Anbieter Filialen oder automatisierte Stationen im Auftrag eines anderen Anbieters, so sind die Informationen nach Satz 1 ausschließlich durch den Anbieter zu übermitteln, in dessen Auftrag die Filiale oder die automatisierte Station betrieben wird.",{"_35":36,"_37":233},[234],{"_40":21,"_35":40},"PrinzipErfuellungen",[237],{"_238":239,"_240":241,"_248":249},"id","1425","Erklaerung",[242],{"_35":47,"_48":49,"_37":243},[244],{"_35":52,"_37":245},[246],{"_40":247,"_35":40},"Schnellere Prüfung, Verarbeitung und Dokumentation durch die Bundesnetzagentur möglich.","Prinzip",{"_26":27,"_28":29,"_30":31,"_32":250,"_64":65,"_66":67,"_68":29},[251,254,257],{"_35":36,"_37":252},[253],{"_40":41,"_35":40},{"_35":36,"_37":255},[256],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":258},[259,262,265],{"_35":52,"_37":260},[261],{"_40":55,"_35":40},{"_35":52,"_37":263},[264],{"_40":59,"_35":40},{"_35":52,"_37":266},[267],{"_40":63,"_35":40},{"_26":269,"_206":270,"_28":71,"_235":275},"lla12fe20ru59nlyzt2weysj",[271],{"_35":36,"_37":272},[273],{"_40":274,"_35":40,"_212":13},"Die Bundesnetzagentur legt durch Allgemeinverfügung fest, in welcher Form und in welchem technischen Format die Informationen zu übermitteln sind.[1]",[276],{"_238":277,"_240":278,"_248":291},"1419",[279,285],{"_35":47,"_48":49,"_37":280},[281],{"_35":52,"_37":282},[283],{"_40":284,"_35":40},"Die Übermittlung ist technologieoffen geregelt, sodass digitale Verfahren möglich sind. ",{"_35":47,"_48":49,"_37":286},[287],{"_35":52,"_37":288},[289],{"_40":290,"_35":40},"Die Bundesnetzagentur kann in ihrer Allgemeinverfügung einheitliche Formate festlegen, um Datenaustausch und Wiederverwendung zu erleichtern. Das sorgt für strukturierte, maschinenlesbare und qualitativ hochwertige Daten.",{"_26":27,"_28":29,"_30":31,"_32":292,"_64":65,"_66":67,"_68":29},[293,296,299],{"_35":36,"_37":294},[295],{"_40":41,"_35":40},{"_35":36,"_37":297},[298],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":300},[301,304,307],{"_35":52,"_37":302},[303],{"_40":55,"_35":40},{"_35":52,"_37":305},[306],{"_40":59,"_35":40},{"_35":52,"_37":308},[309],{"_40":63,"_35":40},{"_26":311,"_206":312,"_28":107,"_235":317},"c7lpfb527lfgq3gegjmqv048",[313],{"_35":36,"_37":314},[315],{"_40":316,"_35":40},"Für Anbieter, die ausschließlich Filialen oder automatisierte Stationen betreiben, gelten die Vorgaben der §§ 4 bis 9 nicht. Unbeschadet des Satzes 1 kann die Bundesnetzagentur die nach Absatz 1 gemeldeten Informationen im Anbieterverzeichnis veröffentlichen.",[],{"_26":319,"_28":320,"_179":321,"_199":200,"_201":-5,"_202":322},"q6kg2pueimp70onf98w7wdhk","11","Digitaler Atlas zur Postversorgung, Verordnungsermächtigung",[323,359,377,403,411],{"_26":324,"_206":325,"_28":29,"_235":334},"rtc7m7e65khzn2wgv05gxjh9",[326],{"_35":36,"_37":327},[328,330,332],{"_40":329,"_35":40},"Die Bundesnetzagentur führt einen digitalen Atlas zur Postversorgung. ",{"_40":331,"_35":40,"_212":13},"Der digitale Atlas dient der Transparenz für die Nutzer hinsichtlich der zur Verfügung stehenden Annahme- und Zustellstrukturen einschließlich des jeweiligen Produktangebots und der Erfassung, Aufbereitung und Veröffentlichung von Postinfrastrukturdaten durch die Bundesnetzagentur.[2]",{"_40":333,"_35":40}," Die Bundesnetzagentur stellt den digitalen Atlas im Internet unentgeltlich bereit.",[335],{"_238":336,"_240":337,"_248":350},"1405",[338,344],{"_35":47,"_48":49,"_37":339},[340],{"_35":52,"_37":341},[342],{"_40":343,"_35":40},"Digitale Erfassung und Veröffentlichung von Postinfrastrukturdaten im digitalen Atlas ermöglichen einfacheren Datenaustausch und Weiterverarbeitung zwischen Behörden.",{"_35":47,"_48":49,"_37":345},[346],{"_35":52,"_37":347},[348],{"_40":349,"_35":40},"Daten stehen als Open Data bereit und können von Forschung, Behörden und Nutzern nachgenutzt werden.",{"_26":70,"_28":71,"_30":72,"_32":351,"_64":87,"_66":88,"_68":71},[352],{"_35":36,"_37":353},[354,355,358],{"_40":77,"_35":40},{"_79":80,"_35":81,"_37":356},[357],{"_40":84,"_35":40},{"_40":86,"_35":40},{"_26":360,"_206":361,"_28":71,"_235":376},"gd6sm76skzukzexsqizr43rf",[362,366],{"_35":36,"_37":363},[364],{"_40":365,"_35":40},"Der digitale Atlas enthält Informationen über",{"_35":47,"_48":214,"_37":367},[368,372],{"_35":52,"_37":369},[370],{"_40":371,"_35":40},"die für Nutzer zur Verfügung stehenden Netzzugangspunkte, einschließlich Angaben über das jeweilige Produktangebot, die Betriebs- und Leerungszeiten sowie die Barrierefreiheit, und",{"_35":52,"_37":373},[374],{"_40":375,"_35":40},"die durch die jeweiligen Anbieter versorgten Zustellgebiete.",[],{"_26":378,"_206":379,"_28":107,"_235":386},"aeym55q2neygiz4irjpf8bll",[380],{"_35":36,"_37":381},[382,384],{"_40":383,"_35":40},"Anbieter sind verpflichtet, der Bundesnetzagentur die Informationen nach Absatz 2 auf Anforderung zu übermitteln. Die Bundesnetzagentur kann durch Allgemeinverfügung geeignete Vorgaben machen, in welcher Form, in welchem technischen Format und in welchem Detailgrad die Informationen nach Absatz 2 zu übermitteln sind und in welchen Zeitintervallen die Informationen zu aktualisieren sind. ",{"_40":385,"_35":40,"_212":13},"Soweit möglich greift die Bundesnetzagentur auf die Daten, die ihr nach § 10 Absatz 1 übermittelt werden, zurück.[2]",[387],{"_238":388,"_240":389,"_248":394},"1411",[390],{"_35":36,"_37":391},[392],{"_40":393,"_35":40},"Die Bundesnetzagentur nutzt bereits gemeldete Daten (z.B. zu Filialen und Stationen) für den Digitalen Atlas erneut. Das reduziert den Erfassungsaufwand für Anbieter und Verwaltung und entspricht dem Once-Only-Prinzip (Nachnutzung).\n",{"_26":70,"_28":71,"_30":72,"_32":395,"_64":87,"_66":88,"_68":71},[396],{"_35":36,"_37":397},[398,399,402],{"_40":77,"_35":40},{"_79":80,"_35":81,"_37":400},[401],{"_40":84,"_35":40},{"_40":86,"_35":40},{"_26":404,"_206":405,"_28":149,"_235":410},"c07nyax1enexka700o2htq8y",[406],{"_35":36,"_37":407},[408],{"_40":409,"_35":40},"Die Bundesnetzagentur wird nach Maßgabe der Rechtsverordnung nach Absatz 5 ermächtigt, die für die Zwecke des Absatzes 2 erhobenen Daten elektronisch an Anbieter von Informationsdiensten für Verbraucher und andere Nutzer weiterzugeben. Bei der Veröffentlichung oder Weitergabe dieser Daten müssen die Anbieter von Informationsdiensten die in der Rechtsverordnung nach Absatz 5 geregelten Vorgaben einhalten. Die Bundesnetzagentur ist befugt, bei Nichteinhaltung dieser Vorgaben von einer Weitergabe der Daten abzusehen.",[],{"_26":412,"_206":413,"_28":110,"_235":440},"dgrvp0r2nv4gwq9nz61q83z7",[414,418,436],{"_35":36,"_37":415},[416],{"_40":417,"_35":40},"Das Bundesministerium für Wirtschaft und Klimaschutz wird ermächtigt, im Wege einer Rechtsverordnung, die nicht der Zustimmung des Bundesrates bedarf, Vorgaben zur Übermittlungspflicht nach Absatz 3 und zur Weitergabe der Daten nach Absatz 4 zu erlassen, insbesondere zu",{"_35":47,"_48":214,"_37":419},[420,424,428,432],{"_35":52,"_37":421},[422],{"_40":423,"_35":40},"weiteren Informationen, die über die Vorgabe des § 10 Absatz 1 hinaus im Rahmen des digitalen Atlas verarbeitet und nach Absatz 4 weitergegeben werden können,",{"_35":52,"_37":425},[426],{"_40":427,"_35":40},"den Anforderungen an die Anbieter von Informationsdiensten für Verbraucher und andere Nutzer nach Absatz 4,",{"_35":52,"_37":429},[430],{"_40":431,"_35":40},"Inhalt, Art, Form und Umfang der Weitergabe von Daten durch die Bundesnetzagentur an die Anbieter nach Absatz 4 sowie",{"_35":52,"_37":433},[434],{"_40":435,"_35":40},"Inhalt, Art, Form und Umfang der Veröffentlichung oder Weitergabe der Daten an Verbraucher und andere Nutzer durch die Anbieter von Informationsdiensten nach Absatz 4.",{"_35":36,"_37":437},[438],{"_40":439,"_35":40},"Das Bundesministerium für Wirtschaft und Klimaschutz kann die Ermächtigung nach Satz 1 durch Rechtsverordnung auf die Bundesnetzagentur übertragen.",[],{"_26":442,"_28":443,"_179":444,"_199":200,"_201":-5,"_202":445},"yyzqwvk23cwdiwi1sbo5c14o","14","Meldung von Mängeln",[446,482],{"_26":447,"_206":448,"_28":29,"_235":455},"as4hnynyfnuqtp3s3j4iy93b",[449],{"_35":36,"_37":450},[451,453],{"_40":452,"_35":40},"Jeder ist berechtigt, der Bundesnetzagentur Mängel zu melden, die die Qualität von Postdienstleistungen und die Gewährleistung der flächendeckenden Versorgung mit Postdienstleistungen betreffen. ",{"_40":454,"_35":40,"_212":13},"Die Bundesnetzagentur stellt zu diesem Zweck eine digitale Plattform zur Verfügung.[1]",[456],{"_238":457,"_240":458,"_248":463},"1303",[459],{"_35":36,"_37":460},[461],{"_40":462,"_35":40},"Ein digitaler Weg wird bereitgestellt, um Mängel zu melden. Dieser schließt andere, nicht digitale Kommunikationswege nicht aus, sondern komplettiert diese.",{"_26":27,"_28":29,"_30":31,"_32":464,"_64":65,"_66":67,"_68":29},[465,468,471],{"_35":36,"_37":466},[467],{"_40":41,"_35":40},{"_35":36,"_37":469},[470],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":472},[473,476,479],{"_35":52,"_37":474},[475],{"_40":55,"_35":40},{"_35":52,"_37":477},[478],{"_40":59,"_35":40},{"_35":52,"_37":480},[481],{"_40":63,"_35":40},{"_26":483,"_206":484,"_28":71,"_235":489},"qb106u49flh1mvyyzebdr5ps",[485],{"_35":36,"_37":486},[487],{"_40":488,"_35":40},"Die Bundesnetzagentur veröffentlicht regelmäßig Informationen über das Beschwerdeaufkommen und die wesentlichen Beschwerdegründe.",[],{"_26":491,"_28":492,"_179":493,"_199":200,"_201":-5,"_202":494},"efl6ojdgkzofuheheguykgl1","17","Infrastrukturvorgaben",[495,503,557,565,591,599],{"_26":496,"_206":497,"_28":29,"_235":502},"cw9yqpwro4qcliajltb1vpef",[498],{"_35":36,"_37":499},[500],{"_40":501,"_35":40},"Bundesweit müssen mindestens 12 000 Universaldienstfilialen vorhanden sein. Sie müssen werktäglich nachfragegerecht geöffnet sein. In allen Gemeinden und in allen zusammenhängend bebauten Wohngebieten mit mehr als 2 000 Einwohnern muss ein Universaldienstanbieter mindestens eine Universaldienstfiliale betreiben. Satz 3 gilt in der Regel auch für Gemeinden, die nach landesplanerischen Regelungen eine zentralörtliche Funktion haben. In zusammenhängend bebauten Wohngebieten mit mehr als 4 000 Einwohnern ist grundsätzlich zu gewährleisten, dass eine Universaldienstfiliale in höchstens 2 000 Metern erreichbar ist. In allen Landkreisen muss ein Universaldienstanbieter mindestens je Fläche von 80 Quadratkilometern eine Universaldienstfiliale betreiben. Alle übrigen Orte müssen durch einen mobilen Postdienst versorgt werden. Bei Veränderungen im Bestand von Universaldienstfilialen hat der Universaldienstanbieter mindestens zehn Wochen vor der Maßnahme das Benehmen mit der zuständigen kommunalen Gebietskörperschaft herzustellen.",[],{"_26":504,"_206":505,"_28":71,"_235":530},"p0ykh0pi0p5x0c3auzkqvrwq",[506,512,526],{"_35":36,"_37":507},[508,510],{"_40":509,"_35":40,"_212":13},"Abweichend von Absatz 1 kann die Bundesnetzagentur im Benehmen mit der jeweils betroffenen Gebietskörperschaft automatisierte Stationen anstelle von Universaldienstfilialen zulassen, wenn diese barrierefrei sind und eine Nutzung ohne eigene technische Geräte ermöglichen.[1]",{"_40":511,"_35":40}," Sie berücksichtigt dabei insbesondere",{"_35":47,"_48":214,"_37":513},[514,518,522],{"_35":52,"_37":515},[516],{"_40":517,"_35":40},"die örtliche Nachfrage nach Postdienstleistungen,",{"_35":52,"_37":519},[520],{"_40":521,"_35":40},"die Möglichkeit, eine Universaldienstfiliale im Sinne des Absatzes 1 einzurichten, und",{"_35":52,"_37":523},[524],{"_40":525,"_35":40},"die flächendeckend angemessene und ausreichende Verfügbarkeit von Universaldienstfilialen, insbesondere im ländlichen Raum.",{"_35":36,"_37":527},[528],{"_40":529,"_35":40},"Nach Ablauf von zwei Jahren ab Zulassung einer automatisierten Station im Einzelfall überprüft die Bundesnetzagentur die getroffene Zulassungsentscheidung, wenn die betroffene Gebietskörperschaft dies beantragt und im Antrag glaubhaft macht, dass die Voraussetzungen der Sätze 1 und 2 nicht mehr vorliegen. Durch Allgemeinverfügung kann die Bundesnetzagentur nach Anhörung der betroffenen Kreise, insbesondere der kommunalen Spitzenverbände, die näheren Voraussetzungen festlegen, unter denen sie automatisierte Stationen nach Satz 1 zulässt. Sie kann insbesondere die Vorgaben der Sätze 1 und 2 konkretisieren.",[531],{"_238":532,"_240":533,"_248":538},"1417",[534],{"_35":36,"_37":535},[536],{"_40":537,"_35":40},"Digitale Alternativen zu Filialen (automatisierte Stationen) sind nur zulässig, wenn sie barrierefrei und ohne eigene technische Geräte nutzbar sind. So werden die Bedürfnisse von Menschen mit Behinderungen berücksichtigt und eine gleichberechtigte Nutzung sichergestellt.",{"_26":27,"_28":29,"_30":31,"_32":539,"_64":65,"_66":67,"_68":29},[540,543,546],{"_35":36,"_37":541},[542],{"_40":41,"_35":40},{"_35":36,"_37":544},[545],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":547},[548,551,554],{"_35":52,"_37":549},[550],{"_40":55,"_35":40},{"_35":52,"_37":552},[553],{"_40":59,"_35":40},{"_35":52,"_37":555},[556],{"_40":63,"_35":40},{"_26":558,"_206":559,"_28":107,"_235":564},"eblmd7mcqxscypi1urdoetgx",[560],{"_35":36,"_37":561},[562],{"_40":563,"_35":40},"Postbriefkästen müssen so ausreichend vorhanden sein, dass die Kunden in zusammenhängend bebauten Wohngebieten in der Regel nicht mehr als 1 000 Meter zurückzulegen haben, um einen Postbriefkasten zu erreichen. Sie sind jeden Werktag sowie bedarfsgerecht jeden Sonn- und Feiertag zu leeren. Dabei sind die Leerungszeiten an den Bedürfnissen des Wirtschaftslebens, insbesondere der Verbraucher, zu orientieren. Die Leerungszeiten sind auf den Postbriefkästen anzugeben.",[],{"_26":566,"_206":567,"_28":149,"_235":590},"xxur13rfx41mf2y7af2m0rra",[568,572,586],{"_35":36,"_37":569},[570],{"_40":571,"_35":40},"Die Bundesnetzagentur kann die unbestimmten Begriffe",{"_35":47,"_48":214,"_37":573},[574,578,582],{"_35":52,"_37":575},[576],{"_40":577,"_35":40},"nachfragegerecht im Sinne von Absatz 1 Satz 2,",{"_35":52,"_37":579},[580],{"_40":581,"_35":40},"bedarfsgerecht im Sinne von Absatz 3 Satz 2 sowie",{"_35":52,"_37":583},[584],{"_40":585,"_35":40},"Bedürfnisse des Wirtschaftslebens, insbesondere der Verbraucher, im Sinne von Absatz 3 Satz 3",{"_35":36,"_37":587},[588],{"_40":589,"_35":40},"nach Anhörung der betroffenen Kreise und im Benehmen mit dem Bundesministerium für Wirtschaft und Klimaschutz und mit dem Bundesministerium für Umwelt, Naturschutz, nukleare Sicherheit und Verbraucherschutz durch Allgemeinverfügung konkretisieren. Sie berücksichtigt dabei die Interessen verschiedener Nutzergruppen.",[],{"_26":592,"_206":593,"_28":110,"_235":598},"wgtrfmujpc2k898x4segdrq2",[594],{"_35":36,"_37":595},[596],{"_40":597,"_35":40},"Im Einvernehmen mit der betroffenen kommunalen Gebietskörperschaft kann im Einzelfall von den Vorgaben des Absatzes 1 Satz 3 bis 5 und des Absatzes 3 Satz 1 abgewichen werden, wenn dies den Bedürfnissen der Nutzerinnen und Nutzer vor Ort entspricht.",[],{"_26":600,"_206":601,"_28":91,"_235":606},"r8o47isyc3wvfhvuakkhmgi8",[602],{"_35":36,"_37":603},[604],{"_40":605,"_35":40},"Nach Ablauf von fünf Jahren ab dem 19. Juli 2024 evaluiert die Bundesnetzagentur die Vorgaben des Absatzes 2. Dabei berücksichtigt sie den Stand der technischen Entwicklung von automatisierten Stationen sowie die Entwicklung der Kundenbedürfnisse innerhalb der vergangenen fünf Jahre. Auf Grundlage der Evaluierung legt die Bundesnetzagentur dem Bundesministerium für Wirtschaft und Klimaschutz einen Bericht vor, der auch zu der Frage einer Anpassung der Vorgaben des Absatzes 2 Stellung nimmt. § 24 bleibt unberührt.",[],{"_26":608,"_28":609,"_179":610,"_199":200,"_201":-5,"_202":611},"wh4t82ac4wr4ap2mvmwujiii","4","Anbieterverzeichnis",[612,660,668,719,741,749],{"_26":613,"_206":614,"_28":29,"_235":625},"qumw0qegdpv8ft65d7q6kgyw",[615],{"_35":36,"_37":616},[617,619,621,623],{"_40":618,"_35":40},"Die Bundesnetzagentur für Elektrizität, Gas, Telekommunikation, Post und Eisenbahnen (Bundesnetzagentur) ",{"_40":620,"_35":40,"_212":13},"führt ein digitales Verzeichnis der Anbieter von Postdienstleistungen (Anbieterverzeichnis).[1]",{"_40":622,"_35":40}," Postdienstleistungen dürfen nur von Anbietern erbracht werden, die in das Anbieterverzeichnis eingetragen sind. Ein Anbieter darf einen anderen Anbieter nur dann mit der Erbringung von Postdienstleistungen beauftragen, wenn der beauftragte Anbieter in das Anbieterverzeichnis eingetragen ist. ",{"_40":624,"_35":40,"_212":13},"Die Bundesnetzagentur veröffentlicht das Anbieterverzeichnis und aktualisiert es fortlaufend.[1]",[626],{"_238":627,"_240":628,"_248":641},"1321",[629,635],{"_35":47,"_48":49,"_37":630},[631],{"_35":52,"_37":632},[633],{"_40":634,"_35":40},"Ein digitales Verzeichnis ermöglicht eine direkte Übermittlung und Bearbeitung von Daten.",{"_35":47,"_48":49,"_37":636},[637],{"_35":52,"_37":638},[639],{"_40":640,"_35":40},"Die Veröffentlichung des digitalen Anbieterverzeichnisses macht die von den Anbietern erhobenen Daten für andere Akteure (Bürger, Unternehmen, andere Behörden) nutzbar.",{"_26":27,"_28":29,"_30":31,"_32":642,"_64":65,"_66":67,"_68":29},[643,646,649],{"_35":36,"_37":644},[645],{"_40":41,"_35":40},{"_35":36,"_37":647},[648],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":650},[651,654,657],{"_35":52,"_37":652},[653],{"_40":55,"_35":40},{"_35":52,"_37":655},[656],{"_40":59,"_35":40},{"_35":52,"_37":658},[659],{"_40":63,"_35":40},{"_26":661,"_206":662,"_28":71,"_235":667},"b77apwkg5a9691l8fmg6bwjt",[663],{"_35":36,"_37":664},[665],{"_40":666,"_35":40},"Wer beabsichtigt, Postdienstleistungen zu erbringen, hat vor Aufnahme der Tätigkeit die Eintragung in das Anbieterverzeichnis bei der Bundesnetzagentur zu beantragen. Die Antragstellung erfolgt mittels eines von der Bundesnetzagentur zur Verfügung gestellten digitalen Verfahrens. Der Antrag ist vollständig, wenn sämtliche Informationen und Belege nach § 6 Absatz 1 bis 3 bei der Bundesnetzagentur eingegangen sind. Die Bundesnetzagentur bestätigt den Eingang eines vollständigen Antrags.",[],{"_26":669,"_206":670,"_28":107,"_235":683},"xu1tjdat5q94xbjqhqtqjw9g",[671],{"_35":36,"_37":672},[673,675,677,679,681],{"_40":674,"_35":40,"_212":13},"Innerhalb von vier Wochen nach Eingang eines vollständigen Antrags prüft die Bundesnetzagentur, ob Gründe nach Absatz 4 für die Versagung der Eintragung vorliegen.[5]",{"_40":676,"_35":40}," Liegen keine Gründe für die Versagung der Eintragung vor, ",{"_40":678,"_35":40,"_212":13},"trägt die Bundesnetzagentur den Antragsteller in das Anbieterverzeichnis ein.[5]",{"_40":680,"_35":40}," Die erfolgte Eintragung ist dem Anbieter mitzuteilen. Liegen Gründe für die Versagung der Eintragung vor, versagt die Bundesnetzagentur die Eintragung. ",{"_40":682,"_35":40,"_212":13},"Ist die Frist nach Satz 1 abgelaufen, ohne dass eine Eintragung oder Versagung erfolgt ist, gilt der Antragsteller als in das Anbieterverzeichnis eingetragen; die Bundesnetzagentur hat die Eintragung umgehend zu veranlassen.[5]",[684],{"_238":685,"_240":686,"_248":697},"1329",[687],{"_35":47,"_48":49,"_37":688},[689,693],{"_35":52,"_37":690},[691],{"_40":692,"_35":40},"Klare Verhältnisse: Bei Nicht-Entscheidung der Behörde innerhalb von 4 Wochen gilt der Antrag automatisch als genehmigt („Fiktionswirkung“)",{"_35":52,"_37":694},[695],{"_40":696,"_35":40},"Rechtssicherheit für die Antragstellenden wird geschaffen, da eindeutig feststeht, wann ein Antrag als erfolgreich abgeschlossen gilt",{"_26":109,"_28":110,"_30":111,"_32":698,"_64":147,"_66":148,"_68":149},[699,710],{"_35":36,"_37":700},[701,702,705,706,709],{"_40":116,"_35":40},{"_79":118,"_35":81,"_37":703},[704],{"_40":121,"_35":40},{"_40":123,"_35":40},{"_79":125,"_35":81,"_37":707},[708],{"_40":128,"_35":40},{"_40":130,"_35":40},{"_35":36,"_37":711},[712,713,714,715,718],{"_40":134,"_35":40},{"_40":136,"_35":40,"_137":13},{"_40":139,"_35":40},{"_79":141,"_35":81,"_37":716},[717],{"_40":144,"_35":40},{"_40":146,"_35":40},{"_26":720,"_206":721,"_28":149,"_235":740},"q4qgmeakz3d8xdv2u615w768",[722,726],{"_35":36,"_37":723},[724],{"_40":725,"_35":40},"Die Eintragung in das Anbieterverzeichnis ist zu versagen, wenn Tatsachen die Annahme rechtfertigen, dass",{"_35":47,"_48":214,"_37":727},[728,732,736],{"_35":52,"_37":729},[730],{"_40":731,"_35":40},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person nicht die für die Tätigkeit als Anbieter von Postdienstleistungen erforderliche Zuverlässigkeit, insbesondere im Hinblick auf die Einhaltung der in Rechts- oder Verwaltungsvorschriften enthaltenen Regelungen über Arbeitsbedingungen, besitzt,",{"_35":52,"_37":733},[734],{"_40":735,"_35":40},"der Antragsteller nicht die für die Tätigkeit als Anbieter von Postdienstleistungen erforderliche Leistungsfähigkeit oder Fachkunde besitzt oder",{"_35":52,"_37":737},[738],{"_40":739,"_35":40},"durch die Aufnahme der Tätigkeit die öffentliche Sicherheit oder Ordnung gefährdet würde.",[],{"_26":742,"_206":743,"_28":110,"_235":748},"bhprxjm9erxia0xa8x6utl1t",[744],{"_35":36,"_37":745},[746],{"_40":747,"_35":40},"Die Eintragung ist zurückzunehmen, wenn nachträglich bekannt wird, dass die Eintragung hätte versagt werden müssen. Die Eintragung ist zu widerrufen, wenn nachträglich Gründe nach Absatz 4 eintreten, die zur Versagung der Eintragung geführt hätten. Absatz 6 Satz 2 gilt in den Fällen der Sätze 1 und 2 entsprechend.",[],{"_26":750,"_206":751,"_28":91,"_235":756},"fsf51qms8bibbmbvsn9u2cqs",[752],{"_35":36,"_37":753},[754],{"_40":755,"_35":40},"Beendet ein Anbieter seine Tätigkeit als Anbieter von Postdienstleistungen, so teilt er dies der Bundesnetzagentur unverzüglich mit. Die Bundesnetzagentur löscht den Anbieter aus dem Anbieterverzeichnis. Satz 2 gilt auch, wenn die Eintragung nach Absatz 5 zurückgenommen oder widerrufen wurde oder die Beendigung der Tätigkeit eines Anbieters feststeht, ohne dass der Anbieter eine Mitteilung nach Satz 1 gemacht hat.",[],{"_26":758,"_28":759,"_179":760,"_199":200,"_201":-5,"_202":761},"pb2w08wxpnnnkycn9og23fbc","5","Zuverlässigkeit, Leistungsfähigkeit, Fachkunde",[762,885,893],{"_26":763,"_206":764,"_28":29,"_235":847},"ooxbst8o2pc70zu1ggl130rf",[765,769,840,844],{"_35":36,"_37":766},[767],{"_40":768,"_35":40,"_212":13},"Die nach § 4 Absatz 4 Nummer 1 erforderliche Zuverlässigkeit liegt in der Regel nicht vor, wenn[5]",{"_35":47,"_48":214,"_37":770},[771,775,794,798,836],{"_35":52,"_37":772},[773],{"_40":774,"_35":40},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 wegen Versuchs oder Vollendung eines Verbrechens im Sinne von § 12 Absatz 1 des Strafgesetzbuches oder einer der nachstehend aufgeführten Straftaten zu einer Freiheitsstrafe, Jugendstrafe, auch wenn deren Verhängung ausgesetzt worden ist, Geldstrafe von mindestens 90 Tagessätzen oder mindestens zweimal zu einer geringeren Geldstrafe rechtskräftig verurteilt worden ist, wenn seit dem Eintritt der Rechtskraft der letzten erstinstanzlichen Verurteilung fünf Jahre und seit dem Eintritt der Rechtskraft der vorletzten erstinstanzlichen Verurteilung zehn Jahre noch nicht verstrichen sind:",{"_35":47,"_48":214,"_37":776,"_793":29},[777,781,785,789],{"_35":52,"_37":778},[779],{"_40":780,"_35":40},"§§ 15 oder 15a des Arbeitnehmerüberlassungsgesetzes,",{"_35":52,"_37":782},[783],{"_40":784,"_35":40},"§ 23 des Arbeitszeitgesetzes,",{"_35":52,"_37":786},[787],{"_40":788,"_35":40},"§§ 10, 10a oder 11 des Schwarzarbeitsbekämpfungsgesetzes,",{"_35":52,"_37":790},[791],{"_40":792,"_35":40},"§§ 202, 206, 263, 266a oder 267 des Strafgesetzbuches,","indentLevel",{"_35":52,"_37":795},[796],{"_40":797,"_35":40,"_212":13},"gegen den Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 bei Antragstellern mit bis zu zehn Beschäftigten mindestens zwei, bei Antragstellern mit bis zu 250 Beschäftigten mindestens zehn, bei Antragstellern mit bis zu 500 Beschäftigten mindestens 20 und bei Antragstellern mit mehr als 500 Beschäftigten mindestens 25 unanfechtbare Bußgeldentscheidungen wegen einer der nachstehend aufgeführten Ordnungswidrigkeiten in Höhe von jeweils mindestens 1 500 Euro ergangen sind:[5]",{"_35":47,"_48":214,"_37":799,"_793":29},[800,804,808,812,816,820,824,828,832],{"_35":52,"_37":801},[802],{"_40":803,"_35":40},"§ 23 des Arbeitnehmerentsendegesetzes,",{"_35":52,"_37":805},[806],{"_40":807,"_35":40},"§ 16 des Arbeitnehmerüberlassungsgesetzes,",{"_35":52,"_37":809},[810],{"_40":811,"_35":40},"§ 25 des Arbeitsschutzgesetzes,",{"_35":52,"_37":813},[814],{"_40":815,"_35":40},"§ 22 Absatz 1 Nummer 1 bis 7, 9 oder 10 des Arbeitszeitgesetzes,",{"_35":52,"_37":817},[818],{"_40":819,"_35":40},"§ 21 des Mindestlohngesetzes,",{"_35":52,"_37":821},[822],{"_40":823,"_35":40},"§ 8 Absatz 1 Nummer 2, Absatz 2 bis 4 des Schwarzarbeitsbekämpfungsgesetzes,",{"_35":52,"_37":825},[826],{"_40":827,"_35":40},"§ 404 Absatz 1 oder Absatz 2 Nummer 4 des Dritten Buches Sozialgesetzbuch,",{"_35":52,"_37":829},[830],{"_40":831,"_35":40},"§ 209 Absatz 1 Nummer 1 bis 7, 8, 9 oder Absatz 2 des Siebten Buches Sozialgesetzbuch,",{"_35":52,"_37":833},[834],{"_40":835,"_35":40},"§ 111 dieses Gesetzes,",{"_35":52,"_37":837},[838],{"_40":839,"_35":40},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 schwerwiegend oder wiederholt gegen Vorgaben dieses Gesetzes verstoßen hat und die Verstöße durch bestandskräftige Entscheidungen der Bundesnetzagentur festgestellt sind.",{"_35":36,"_37":841},[842],{"_40":843,"_35":40},"Im Einzelfall kann auch eine Gesamtabwägung von Umständen, die nicht in Satz 1 genannt sind und denen in ihrer Gesamtheit ein vergleichbares Gewicht wie den in Satz 1 genannten Umständen zuzumessen ist, die Annahme rechtfertigen, dass der Antragsteller nicht über die erforderliche Zuverlässigkeit verfügt.",{"_35":36,"_37":845},[846],{"_40":21,"_35":40},[848],{"_238":849,"_240":850,"_248":863},"1343",[851,857],{"_35":47,"_48":49,"_37":852},[853],{"_35":52,"_37":854},[855],{"_40":856,"_35":40},"Es werden objektive und quantifizierbare Kriterien zur Beurteilung der Zuverlässigkeit eines Antragstellers definiert, die eine automatisierte Vorprüfung oder sogar eine teilautomatisierte Entscheidung ermöglichen.",{"_35":47,"_48":49,"_37":858},[859],{"_35":52,"_37":860},[861],{"_40":862,"_35":40},"Reduziert den manuellen Prüfaufwand ",{"_26":109,"_28":110,"_30":111,"_32":864,"_64":147,"_66":148,"_68":149},[865,876],{"_35":36,"_37":866},[867,868,871,872,875],{"_40":116,"_35":40},{"_79":118,"_35":81,"_37":869},[870],{"_40":121,"_35":40},{"_40":123,"_35":40},{"_79":125,"_35":81,"_37":873},[874],{"_40":128,"_35":40},{"_40":130,"_35":40},{"_35":36,"_37":877},[878,879,880,881,884],{"_40":134,"_35":40},{"_40":136,"_35":40,"_137":13},{"_40":139,"_35":40},{"_79":141,"_35":81,"_37":882},[883],{"_40":144,"_35":40},{"_40":146,"_35":40},{"_26":886,"_206":887,"_28":71,"_235":892},"vvglzrv4g5xdi6cu2k9m8tzr",[888],{"_35":36,"_37":889},[890],{"_40":891,"_35":40},"Die nach § 4 Absatz 4 Nummer 2 erforderliche Leistungsfähigkeit besitzt, wer über die für die Erbringung der jeweiligen Postdienstleistungen erforderlichen Finanz- und Produktionsmittel sowie das dafür erforderliche Personal dauerhaft verfügt und die Gewähr für eine postrechtskonforme Erbringung der jeweiligen Postdienstleistungen bietet. Neben den für das jeweilige Geschäftsmodell ausreichenden Finanzmitteln haben die für die Postbeförderung erforderlichen Betriebsstätten und Fahrzeuge sowie eine für die beabsichtigte Tätigkeit ausreichende Anzahl von Beschäftigten zur Verfügung zu stehen, insbesondere um im Falle des § 73 Absatz 2 eine rechtskonforme Beförderung von Paketen über 20 Kilogramm Gewicht sicherzustellen.",[],{"_26":894,"_206":895,"_28":107,"_235":900},"xhbc8hkejz7rnpoos8z3fm3x",[896],{"_35":36,"_37":897},[898],{"_40":899,"_35":40},"Die nach § 4 Absatz 4 Nummer 2 erforderliche Fachkunde besitzt, wer über die erforderlichen Kenntnisse, Erfahrungen und Fertigkeiten für die Erbringung von Postdienstleistungen verfügt, insbesondere mit den praktischen Abläufen und den rechtlichen Grundlagen, auch im Hinblick auf Postgeheimnis und Postdatenschutz, vertraut ist.",[],{"_26":902,"_28":903,"_179":904,"_199":200,"_201":-5,"_202":905},"v1g7jodj5gzkkmveixb8xnw1","67","Datenschutz",[906],{"_26":907,"_206":908,"_28":29,"_235":916},"vic45xxx218j9mrqjap2ye2y",[909,913],{"_35":36,"_37":910},[911],{"_40":912,"_35":40,"_212":13},"Für Diensteanbieter werden die Vorgaben der Verordnung (EU) 2016/679 des Europäischen Parlaments und des Rates vom 27. April 2016 zum Schutz natürlicher Personen bei der Verarbeitung personenbezogener Daten, zum freien Datenverkehr und zur Aufhebung der Richtlinie 95/46/EG (Datenschutz-Grundverordnung) (ABl. L 119 vom 4.5.2016, S. 1; L 314 vom 22.11.2016, S. 72; L 127 vom 23.5.2018, S. 2) in der jeweils geltenden Fassung durch die Regelungen des § 65 sowie der §§ 68 bis 71 ergänzt.[3]",{"_35":36,"_37":914},[915],{"_40":21,"_35":40},[917],{"_238":918,"_240":919,"_248":932},"1399",[920,926],{"_35":47,"_48":49,"_37":921},[922],{"_35":52,"_37":923},[924],{"_40":925,"_35":40},"DSGVO ist zentrale Grundlage für Datenschutz.",{"_35":47,"_48":49,"_37":927},[928],{"_35":52,"_37":929},[930],{"_40":931,"_35":40},"§§ 65, 68-71 Postmodernisierungsgesetz ergänzen die Vorgaben für den Postbereich. Damit wird rechtssichere und datenschutzkonforme Verarbeitung personenbezogener Daten im Postsektor gewährleistet.",{"_26":151,"_28":107,"_30":152,"_32":933,"_64":173,"_66":174,"_68":110},[934,941,944],{"_35":36,"_37":935},[936,937,940],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":938},[939],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":942},[943],{"_40":168,"_35":40},{"_35":36,"_37":945},[946],{"_40":172,"_35":40},{"_26":948,"_28":949,"_179":950,"_199":200,"_201":-5,"_202":951},"x9lejjge04sst0vlxk3d0stz","69","Ausweisdaten",[952,963,992,1000],{"_26":953,"_206":954,"_28":29,"_235":962},"zuk0t8r1l2tee3xswsg4afp3",[955,959],{"_35":36,"_37":956},[957],{"_40":958,"_35":40},"Diensteanbieter können von am Postverkehr Beteiligten verlangen, sich über ihre Person durch Vorlage eines gültigen Personalausweises oder Passes oder durch Vorlage sonstiger amtlicher Ausweispapiere auszuweisen, um die ordnungsgemäße Ausführung des Postdienstes sicherzustellen.",{"_35":36,"_37":960},[961],{"_40":21,"_35":40},[],{"_26":964,"_206":965,"_28":71,"_235":991},"dtrjzs1xcpg3dhshpx3nkect",[966,970,988],{"_35":36,"_37":967},[968],{"_40":969,"_35":40},"Besteht ein besonderes Beweissicherungsinteresse, so können zum späteren Beweis der ordnungsgemäßen Ausführung des Postdienstes folgende Daten des Ausweispapiers gespeichert werden:",{"_35":47,"_48":214,"_37":971},[972,976,980,984],{"_35":52,"_37":973},[974],{"_40":975,"_35":40},"die Art des Ausweises, ",{"_35":52,"_37":977},[978],{"_40":979,"_35":40},"die ausstellende Behörde, ",{"_35":52,"_37":981},[982],{"_40":983,"_35":40},"die Nummer des Ausweises sowie ",{"_35":52,"_37":985},[986],{"_40":987,"_35":40},"das Ausstellungsdatum.",{"_35":36,"_37":989},[990],{"_40":21,"_35":40},[],{"_26":993,"_206":994,"_28":107,"_235":999},"w6mqg8gqxg0xkxfhmty5037f",[995],{"_35":36,"_37":996},[997],{"_40":998,"_35":40},"Eine Verarbeitung der Daten ist zulässig, um einen Beweis über die ordnungsgemäße Ausführung des Postdienstes zu erbringen.",[],{"_26":1001,"_206":1002,"_28":149,"_235":1007},"tow4qb7kq4jpc3do0iie1931",[1003],{"_35":36,"_37":1004},[1005],{"_40":1006,"_35":40,"_212":13},"Die Daten sind spätestens sechs Monate nach Ablauf gesetzlicher oder vertraglicher Verjährungsfristen zu löschen.[3]",[1008],{"_238":1009,"_240":1010,"_248":1015},"1327",[1011],{"_35":36,"_37":1012},[1013],{"_40":1014,"_35":40},"Sensible, nicht mehr benötigte Daten werden gelöscht, sodass sie nicht mehr verfügbar sind – das schützt sie vor Missbrauch.",{"_26":151,"_28":107,"_30":152,"_32":1016,"_64":173,"_66":174,"_68":110},[1017,1024,1027],{"_35":36,"_37":1018},[1019,1020,1023],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":1021},[1022],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":1025},[1026],{"_40":168,"_35":40},{"_35":36,"_37":1028},[1029],{"_40":172,"_35":40},{"_26":1031,"_28":1032,"_179":1033,"_199":200,"_201":-5,"_202":1034},"h5qbve0ky2p48scu29g3xaha","92","Verfahren zur Übermittlung von Informationen",[1035,1097,1105],{"_26":1036,"_206":1037,"_28":29,"_235":1048},"k5p1thys57i5t4fwu7njwb64",[1038],{"_35":36,"_37":1039},[1040,1042,1044,1046],{"_40":1041,"_35":40},"Soweit dieses Gesetz natürliche oder juristische Personen dazu verpflichtet, Informationen an die Bundesnetzagentur zu übermitteln, ",{"_40":1043,"_35":40,"_212":13},"soll die Übermittlung ausschließlich elektronisch erfolgen, es sei denn, das Gesetz sieht ausdrücklich eine andere Form der Übermittlung vor. Zu diesem Zweck stellt die Bundesnetzagentur entsprechende elektronische Verfahren zur Verfügung, die eine sichere Übermittlung und Nutzung der Informationen sicherstellt.[1]",{"_40":1045,"_35":40}," ",{"_40":1047,"_35":40,"_212":13},"Die Bundesnetzagentur gewährleistet insbesondere den Schutz personenbezogener Daten und den Schutz von Betriebs- und Geschäftsgeheimnissen.[3]",[1049,1075],{"_238":1050,"_240":1051,"_248":1056},"1345",[1052],{"_35":36,"_37":1053},[1054],{"_40":1055,"_35":40},"Die Formulierung legt elektronische Kommunikation als Standardfall fest. Es lässt das Verfahren offen, anstatt es zu definieren.",{"_26":27,"_28":29,"_30":31,"_32":1057,"_64":65,"_66":67,"_68":29},[1058,1061,1064],{"_35":36,"_37":1059},[1060],{"_40":41,"_35":40},{"_35":36,"_37":1062},[1063],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":1065},[1066,1069,1072],{"_35":52,"_37":1067},[1068],{"_40":55,"_35":40},{"_35":52,"_37":1070},[1071],{"_40":59,"_35":40},{"_35":52,"_37":1073},[1074],{"_40":63,"_35":40},{"_238":1076,"_240":1077,"_248":1082},"1346",[1078],{"_35":36,"_37":1079},[1080],{"_40":1081,"_35":40},"Die Bundesnetzagentur wird ausdrücklich als besonders verantwortlich für Datenschutz und Informationssicherheit benannt.",{"_26":151,"_28":107,"_30":152,"_32":1083,"_64":173,"_66":174,"_68":110},[1084,1091,1094],{"_35":36,"_37":1085},[1086,1087,1090],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":1088},[1089],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":1092},[1093],{"_40":168,"_35":40},{"_35":36,"_37":1095},[1096],{"_40":172,"_35":40},{"_26":1098,"_206":1099,"_28":71,"_235":1104},"z9m4m15kq3qnq3mo635wurj5",[1100],{"_35":36,"_37":1101},[1102],{"_40":1103,"_35":40},"Soweit Informationen regelmäßig zu übermitteln sind, soll die Bundesnetzagentur verschiedene Informationen nach Möglichkeit gebündelt abfragen, um den Aufwand der Betroffenen gering zu halten.",[],{"_26":1106,"_206":1107,"_28":107,"_235":1114},"em1d54qds7px5v24rt1u9585",[1108],{"_35":36,"_37":1109},[1110,1112],{"_40":1111,"_35":40,"_212":13},"Soweit die Bundesnetzagentur auf Grundlage dieses Gesetzes mit natürlichen oder juristischen Personen in Kontakt tritt, soll dies ausschließlich elektronisch[1]",{"_40":1113,"_35":40},", soweit möglich unter Nutzung der nach § 6 Absatz 1 Nummer 1 Buchstabe e und Nummer 2 Buchstabe e, jeweils auch in Verbindung mit § 10 Absatz 1 Nummer 2 gemeldeten Adresse für die elektronische Kommunikation, erfolgen, es sei denn, das Gesetz sieht ausdrücklich eine andere Form vor.",[1115],{"_238":1116,"_240":1117,"_248":1122},"1349",[1118],{"_35":36,"_37":1119},[1120],{"_40":1121,"_35":40},"Die Bundesnetzagentur wird zur elektronischen Kommunikation verpflichtet.",{"_26":27,"_28":29,"_30":31,"_32":1123,"_64":65,"_66":67,"_68":29},[1124,1127,1130],{"_35":36,"_37":1125},[1126],{"_40":41,"_35":40},{"_35":36,"_37":1128},[1129],{"_40":45,"_35":40},{"_35":47,"_48":49,"_37":1131},[1132,1135,1138],{"_35":52,"_37":1133},[1134],{"_40":55,"_35":40},{"_35":52,"_37":1136},[1137],{"_40":59,"_35":40},{"_35":52,"_37":1139},[1140],{"_40":63,"_35":40},{"_26":1142,"_28":1143,"_179":1144,"_199":200,"_201":-5,"_202":1145},"kyr6115p6u0r69e88w16iadu","93","Datennutzung",[1146,1174,1206],{"_26":1147,"_206":1148,"_28":29,"_235":1157},"yt31e1xsc5cjiu3ahhwzdvld",[1149],{"_35":36,"_37":1150},[1151,1153,1155],{"_40":1152,"_35":40},"Unbeschadet spezialgesetzlicher Regelungen ist die Bundesnetzagentur berechtigt, ihr vorliegende, aufgrund einer speziellen Ermächtigungsgrundlage erhobene Daten ",{"_40":1154,"_35":40,"_212":13},"auch zur Erfüllung weiterer gesetzlicher Aufgaben auszuwerten und zu nutzen[2]",{"_40":1156,"_35":40},". Dem steht die in § 90 Absatz 2 Satz 2 und 3 genannte Zweckbestimmung nicht entgegen.",[1158],{"_238":1159,"_240":1160,"_248":1165},"1363",[1161],{"_35":36,"_37":1162},[1163],{"_40":1164,"_35":40},"Die Möglichkeit wird eröffnet, Daten für weitere Zwecke zu verwenden, solange eine Rechtsgrundlage existiert.",{"_26":70,"_28":71,"_30":72,"_32":1166,"_64":87,"_66":88,"_68":71},[1167],{"_35":36,"_37":1168},[1169,1170,1173],{"_40":77,"_35":40},{"_79":80,"_35":81,"_37":1171},[1172],{"_40":84,"_35":40},{"_40":86,"_35":40},{"_26":1175,"_206":1176,"_28":71,"_235":1183},"hq9kmot38je6rlp2ynm4fu2r",[1177],{"_35":36,"_37":1178},[1179,1181],{"_40":1180,"_35":40},"Die Bundesnetzagentur kann die ihr vorliegenden, den Postsektor betreffenden Daten, insbesondere die aufgrund eines Auskunftsverlangens nach § 90 erhaltenen Daten, für Dritte oder die Öffentlichkeit bereitstellen, soweit die Daten für die Öffentlichkeit Bedeutung haben können. ",{"_40":1182,"_35":40,"_212":13},"Satz 1 gilt nicht für Daten, für die kein oder nur ein eingeschränktes Zugangsrecht insbesondere gemäß § 3 des Informationsfreiheitsgesetzes besteht, sowie für personenbezogene Daten und als solche gekennzeichnete Betriebs- oder Geschäftsgeheimnisse.[3]",[1184],{"_238":1185,"_240":1186,"_248":1191},"1353",[1187],{"_35":36,"_37":1188},[1189],{"_40":1190,"_35":40},"Hinweis auf die Beschränkung von Zugangsrechten von personenbezogenen Daten, als auch Daten die § 3 Informationsfreiheitsgesetz unterliegen oder gekennzeichnete Betriebs- oder Geschäftsgeheimnisse sind.",{"_26":151,"_28":107,"_30":152,"_32":1192,"_64":173,"_66":174,"_68":110},[1193,1200,1203],{"_35":36,"_37":1194},[1195,1196,1199],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":1197},[1198],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":1201},[1202],{"_40":168,"_35":40},{"_35":36,"_37":1204},[1205],{"_40":172,"_35":40},{"_26":1207,"_206":1208,"_28":107,"_235":1217},"pzpg5oeumqtk7nq4n0bia6lq",[1209],{"_35":36,"_37":1210},[1211,1213,1215],{"_40":1212,"_35":40},"Soweit erforderlich, werden diese Daten aggregiert oder ",{"_40":1214,"_35":40,"_212":13},"unternehmensbezogene Angaben auf sonstige Weise unkenntlich gemacht[3]",{"_40":1216,"_35":40},". Die öffentliche Bereitstellung kann insbesondere auf der Internetseite der Bundesnetzagentur erfolgen.",[1218],{"_238":1219,"_240":1220,"_248":1225},"1355",[1221],{"_35":36,"_37":1222},[1223],{"_40":1224,"_35":40},"Daten können unkenntlich gemacht werden oder werden aggregiert, um geschützt zu werden.",{"_26":151,"_28":107,"_30":152,"_32":1226,"_64":173,"_66":174,"_68":110},[1227,1234,1237],{"_35":36,"_37":1228},[1229,1230,1233],{"_40":157,"_35":40},{"_79":159,"_35":81,"_37":1231},[1232],{"_40":162,"_35":40},{"_40":164,"_35":40},{"_35":36,"_37":1235},[1236],{"_40":168,"_35":40},{"_35":36,"_37":1238},[1239],{"_40":172,"_35":40},"Visualisierungen",[],"Digitalchecks",[1244],{"_26":1245,"_179":1246,"_1247":1248,"_1249":1248,"_1250":1248,"_1251":1248,"_1252":1248,"_1253":-5},"edu7vf0p1z3kx5xd1gsm13xv","Modernisierung des Postrechts","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText"]
