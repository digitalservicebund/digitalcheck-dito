[{"_1":2,"_22":23},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_20":21},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13,"_19":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/dokumentation",{"_3":24},{"_25":26,"_74":75},"routes",[27,40,43,46,68,71],{"_28":29,"_30":31,"_32":33,"_39":-7},"url","/dokumentation/hinweise","title","Hinweise","parent",{"_28":34,"_30":35,"_32":36,"_39":-7},"/dokumentation","Dokumentation",{"_28":37,"_30":38},"/","Startseite","hideInSitemap",{"_28":41,"_30":42,"_32":33,"_39":-7},"/dokumentation/regelungsvorhaben-titel","Regelungsvorhaben Titel",{"_28":44,"_30":45,"_32":33,"_39":-7},"/dokumentation/beteiligungsformate","Beteiligungsformate",[47,52,56,60,64],{"_30":48,"_28":49,"_50":51},"Digitale Angebote für alle nutzbar gestalten","/dokumentation/digitale-angebote-fuer-alle-nutzbar-gestalten","principleId","r57rc9d82ulv2bsc3gdbnj73",{"_30":53,"_28":54,"_50":55},"Datenwiederverwendung benötigt einheitliches Recht","/dokumentation/datenwiederverwendung-benoetigt-einheitliches-recht","s18bibg9sdf0jt8up7h8btup",{"_30":57,"_28":58,"_50":59},"Etablierte Technologien ermöglichen effiziente Umsetzung","/dokumentation/etablierte-technologien-ermoeglichen-effiziente-umsetzung","habu0yjh39lc5wug5mqsqzaj",{"_30":61,"_28":62,"_50":63},"Automatisierung basiert auf eindeutigen Regelungen","/dokumentation/automatisierung-basiert-auf-eindeutigen-regelungen","got436pv8femeqmv6ee8wlm1",{"_30":65,"_28":66,"_50":67},"Datenschutz und Informationssicherheit schaffen Vertrauen","/dokumentation/datenschutz-und-informationssicherheit-schaffen-vertrauen","bnx9lmblnceu1m3uy3rziy0i",{"_28":69,"_30":70,"_32":33,"_39":-7},"/dokumentation/zusammenfassung","Zusammenfassung",{"_28":72,"_30":73,"_32":33,"_39":-7},"/dokumentation/absenden","Absenden","prinzips",[76,375,643,852,1260],{"_77":51,"_78":48,"_79":80,"_111":112,"_117":118,"_122":123,"_124":123,"_125":126,"_127":128,"_205":206},"documentId","Name","Beschreibung",[81,89,93],{"_82":83,"_84":85},"type","paragraph","children",[86],{"_87":88,"_82":87},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_82":83,"_84":90},[91],{"_87":92,"_82":87},"Erfahren Sie in diesem Abschnitt,",{"_82":94,"_95":96,"_84":97},"list","format","unordered",[98,103,107],{"_82":99,"_84":100},"list-item",[101],{"_87":102,"_82":87},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_82":99,"_84":104},[105],{"_87":106,"_82":87},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_82":99,"_84":108},[109],{"_87":110,"_82":87},"wie Barrierefreiheit zu bedenken ist.","Kurzbeschreibung",[113],{"_82":83,"_84":114},[115],{"_87":116,"_82":87},"Eine Regelung gilt als erfolgreich digitalisiert, wenn Bürger und Unternehmen Anträge intuitiv online stellen können, Behörden die Daten systemübergreifend ohne manuelle Nacherfassung verarbeiten und Digitaltauglichkeit von Anfang an mitgedacht wurde.","Hilfetext",[119],{"_82":83,"_84":120},[121],{"_87":88,"_82":87},"order",1,"Nummer","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Beispiel",{"_77":129,"_124":130,"_131":132,"_155":156,"_166":167},"fvj31s0fav5aw2vlu65q0arw",2,"Text",[133,140],{"_82":83,"_84":134},[135,138],{"_87":136,"_82":87,"_137":13},"Eine in diesem Gesetz angeordnete Schriftform kann auch durch Übermittlung elektronischer Dokumente oder strukturierter Datensätze über die Kommunikationsplattform ersetzt werden[1]","underline",{"_87":139,"_82":87},", sofern",{"_82":94,"_95":141,"_84":142},"ordered",[143,147,151],{"_82":99,"_84":144},[145],{"_87":146,"_82":87},"ein Identifizierungsverfahren nach Absatz 1 genutzt wird,",{"_82":99,"_84":148},[149],{"_87":150,"_82":87,"_137":13},"bei der Datenübermittlung ein sicheres Verfahren verwendet wird, das die Authentizität und Integrität der Daten gewährleistet, und [3]",{"_82":99,"_84":152},[153],{"_87":154,"_82":87,"_137":13},"für die elektronischen Dokumente oder strukturierten Datensätze auf der Kommunikationsplattform eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[5]","Paragraph",{"_124":157,"_158":159,"_160":161,"_162":163},"1131","Gesetz","ZPO","Titel","Kommunikations-, Austausch- und Übermittlungsformen","Beispielvorhaben",{"_125":164,"_160":165},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit","PrinzipErfuellungen",[168,185,196],{"_169":170,"_171":172,"_183":184},"id","1336","Erklaerung",[173],{"_82":94,"_95":96,"_84":174},[175,179],{"_82":99,"_84":176},[177],{"_87":178,"_82":87},"Die digitale Übermittlung von Dokumenten ermöglicht eine Kommunikation über die digitale Kommunikationsplattform.",{"_82":99,"_84":180},[181],{"_87":182,"_82":87},"Schriftformerfordernisse werden durch die digitale Übermittlung ersetzt.","Prinzip",{"_124":123,"_78":48},{"_169":186,"_171":187,"_183":194},"1337",[188],{"_82":94,"_95":96,"_84":189},[190],{"_82":99,"_84":191},[192],{"_87":193,"_82":87},"Geht von einer automatisierten Bearbeitung der Daten aus.",{"_124":195,"_78":61},5,{"_169":197,"_171":198,"_183":203},"1338",[199],{"_82":83,"_84":200},[201],{"_87":202,"_82":87},"Stellt die Informationssicherheit sicher, indem sie die Anforderung eines sicheren Verfahrens stellt, das die Authentizität und Integrität der Daten gewährleistet.",{"_124":204,"_78":65},3,"Aspekte",[207,223,278,287,335],{"_160":208,"_209":210,"_79":211,"_131":212,"_221":-5,"_222":-5,"_127":-5},"Ermöglichen Sie digitale Kommunikation und Bearbeitung","Kurzbezeichnung","Digitale Kommunikation","Ermöglichen Sie digitale Kommunikation: Beseitigen Sie Hürden wie Schriftform oder persönliches Erscheinen und bieten Sie alternative Kommunikationswege an.",[213,217],{"_82":83,"_84":214},[215],{"_87":216,"_82":87},"Digital zu kommunizieren bietet viele Vorteile: Anträge und Bescheide können in Echtzeit übermittelt werden, was Wartezeiten für Bürgerinnen, Bürger und Unternehmen verkürzt. Werden Anträge und sonstige Daten digital an die Verwaltung übermittelt, können sie außerdem effizient digital weiterverarbeitet, geprüft und an weitere beteiligte Behörden übermittelt werden.",{"_82":83,"_84":218},[219],{"_87":220,"_82":87},"Digitale Kommunikation sollte immer bedarfsorientiert und inklusiv sein – in bestimmten Fällen kann z. B. ergänzend auch die Schriftform sinnvoll sein, sofern eine digitale Weiterverarbeitung sichergestellt ist. Bürgerinnen und Bürger, die keine digitalen Angebote nutzen können oder wollen, müssen dabei auch bedacht werden.","Leitfragen","Formulierungsbeispiel",{"_160":224,"_209":225,"_79":226,"_131":227,"_221":-5,"_222":248,"_127":258},"Formulieren Sie die Regelung technologieoffen","Technologieoffenheit","Formulieren Sie die Regelungen technologieoffen: Stellen Sie sicher, dass Vorschriften nicht an spezifische technische Lösungen gebunden sind, um die Nutzung etablierter oder zukünftiger Technologien zu ermöglichen.",[228,233,237],{"_82":83,"_84":229},[230],{"_231":13,"_87":232,"_82":87},"bold","Prüfen Sie, ob die Nennung spezifischer Technologien notwendig bzw. gerechtfertigt ist.",{"_82":83,"_84":234},[235],{"_87":236,"_82":87},"Wenn Sie Übertragungswege – wie DE-Mail oder PDF – festlegen, riskieren Sie, dass Ihre Regelung bald nicht mehr dem Stand der Technik entspricht.",{"_82":83,"_84":238},[239,241,246],{"_87":240,"_82":87},"Andererseits kann die Nutzung etablierter Basisdienste die Umsetzung erleichtern und die Anwendung für Nutzende vereinfachen – im Sinne des Prinzips „",{"_28":242,"_82":243,"_84":244},"https://digitalcheck.bund.de/methoden/fuenf-prinzipien/etablierte-technologien-ermoeglichen-effiziente-umsetzung","link",[245],{"_87":57,"_82":87},{"_87":247,"_82":87},"“. Ob das sinnvoll ist, hängt vom konkreten Einzelfall ab.",[249],{"_82":83,"_84":250},[251,254,256],{"_87":252,"_82":87,"_253":13},"„Der Antrag ist elektronisch oder schriftlich zu stellen.“","italic",{"_87":255,"_82":87}," oder ",{"_87":257,"_82":87,"_253":13},"„Der Antrag ist zu stellen.“",{"_77":259,"_124":195,"_131":260,"_155":271},"eed54a9k0yrk07n6317zk0o8",[261],{"_82":83,"_84":262},[263,265,267,269],{"_87":264,"_82":87,"_137":13},"Das Luftfahrt-Bundesamt übermittelt jedem Betreiber nach Absatz 1 Satz 1 elektronisch eine Registrierungsnummer[1]",{"_87":266,"_82":87},", die für alle von ihm nach Absatz 1 Satz 1 betriebenen unbemannten Fluggeräte gilt und dem Luftfahrt-Bundesamt eine individuelle Identifizierung des Betreibers nach Artikel 14 der Durchführungsverordnung (EU) 2019/947 ermöglicht. ",{"_87":268,"_82":87,"_137":13},"Das Luftfahrt-Bundesamt kann die Registrierung eines Betreibers eines unbemannten Fluggerätes für den Betrieb in den Betriebskategorien „offen“ und „speziell“ durch automatische Einrichtungen bestätigen, sofern kein Anlass besteht, den Einzelfall durch Amtsträger zu bearbeiten[5]",{"_87":270,"_82":87},"; Absatz 3 Satz 4 bis 6 gilt entsprechend. Das Luftfahrt-Bundesamt stellt sicher, dass das Register insbesondere den Vorgaben der Artikel 24, 25 und 32 der Verordnung (EU) 2016/679 entspricht.",{"_124":272,"_158":273,"_160":274,"_162":275},"66a","LuftVG","Register über Betreiber von unbemannten Fluggeräten",{"_125":276,"_160":277},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","Register über Betreiber von unbemannten Fluggeräten – LuftVG",{"_160":279,"_209":280,"_79":281,"_131":282,"_221":-5,"_222":-5,"_127":-5},"Denken Sie an Antragsstellung, Bearbeitung und Bescheid","Antragsprozess beachten","Denken Sie an Antragsstellung, Bearbeitung und Bescheid: Planen Sie den vollständigen Lebenszyklus der Daten, damit diese durchgehend digital verarbeitet werden können und ihre Qualität im Prozess gesichert wird.",[283],{"_82":83,"_84":284},[285],{"_87":286,"_82":87},"Für eine erfolreiche Digitalisierung ist es wichtig, dass Sie den gesamten Prozess des Vollzugs Ihrer Regelung betrachten. Dies verhindert Logik- und Medienbrüche.",{"_160":288,"_209":289,"_79":290,"_131":291,"_221":303,"_222":310,"_127":-5},"Denken Sie Barrierefreiheit von Anfang an mit","Barrierefreiheit","Denken Sie Barrierefreiheit von Anfang an mit: Gestalten Sie das digitale Angebot so, dass es ohne jegliche Hürden von allen Nutzenden, unabhängig von ihren individuellen Bedürfnissen, uneingeschränkt genutzt werden kann.",[292],{"_82":83,"_84":293},[294,296,301],{"_87":295,"_82":87},"Digitale Angebote müssen nach ",{"_28":297,"_82":243,"_84":298},"https://www.gesetze-im-internet.de/bgg/__12a.html",[299],{"_87":300,"_82":87},"§ 12 a Behindertengleichstellungsgesetz",{"_87":302,"_82":87}," barrierefrei sein. Barrierefrei bedeutet, dass Menschen mit und ohne Behinderung das Angebot in gleicher Weise nutzen können. Da es viele unterschiedliche Arten von Behinderungen gibt, müssen viele Aspekte beachtet werden. Etwa die Aufbereitung für blinde und sehbehinderte Menschen oder Angebote in deutscher Gebärdensprache oder leichter Sprache.",[304],{"_82":94,"_95":96,"_84":305},[306],{"_82":99,"_84":307},[308],{"_87":309,"_82":87},"Haben Sie die Bedürfnisse von Menschen mit unterschiedlichen Arten von Behinderungen berücksichtigt?",[311],{"_82":94,"_95":96,"_84":312},[313,324],{"_82":99,"_84":314},[315,317,322],{"_87":316,"_82":87},"\"Die Beratung erfolgt in einer für den Leistungsberechtigten wahrnehmbaren Form\" (",{"_28":318,"_82":243,"_84":319},"https://www.gesetze-im-internet.de/sgb_9_2018/__106.html",[320],{"_87":321,"_82":87},"§ 106 Abs. 1 SGB IX",{"_87":323,"_82":87},"). So eine Formulierung muss in einer Verordnung ausgestaltet werden.",{"_82":99,"_84":325},[326,328,333],{"_87":327,"_82":87},"[...] nach dem Stand der Technik auch die erforderlichen technischen und organisatorischen Verfahren festzulegen oder technischen Voraussetzungen zu schaffen dafür, dass [...] Daten [...] barrierefrei zur Verfügung gestellt und [...] barrierefrei verarbeitet werden können [...] (",{"_28":329,"_82":243,"_84":330},"https://www.gesetze-im-internet.de/sgb_5/__354.html",[331],{"_87":332,"_82":87},"§ 354 SGB V",{"_87":334,"_82":87},")",{"_160":336,"_209":337,"_79":338,"_131":339,"_221":344,"_222":-5,"_127":362},"Stellen Sie eine nutzerfreundliche Umsetzung sicher","Nutzerfreundlichkeit","Stellen Sie eine nutzerfreundliche Umsetzung sicher: Sorgen Sie für eine an den Nutzenden orientierte Entwicklung, die eine einfache, intuitive und zugängliche Interaktion mit dem digitalen Angebot gewährleistet.",[340],{"_82":83,"_84":341},[342],{"_87":343,"_82":87},"Barrierearme Angebote sind oft auch nutzerfreundlicher. Darüber hinaus macht eine nutzerzentrierte Entwicklung, die z. B. in kleinen Schritten agiert und Texte in einfacher Sprache oder mehrsprachig gestaltet, ihr Angebot zugänglicher.",[345],{"_82":94,"_95":96,"_84":346},[347,351],{"_82":99,"_84":348},[349],{"_87":350,"_82":87},"Was ist die wichtigste Aufgabe aus Sicht der Nutzenden?",{"_82":99,"_84":352},[353,355,360],{"_87":354,"_82":87},"Ergeben sich für den Vollzug Anforderungen aus dem ",{"_28":356,"_82":243,"_84":357},"https://servicestandard.gov.de/",[358],{"_87":359,"_82":87},"Servicestandard",{"_87":361,"_82":87}," an? Dieser stellt eine nutzerzentrierte Entwicklung sicher. Er unterstützt umsetzende Akteure dabei, die verbindlichen Qualitätsanforderungen zu erfüllen.",{"_77":363,"_124":204,"_131":364,"_155":371},"yaa803r10yjs4h9ay4srsb84",[365],{"_82":83,"_84":366},[367,369],{"_87":368,"_82":87},"Die nach Absatz 2 entwickelte Kommunikationsplattform ist über ein Justizportal des Bundes und der Länder für die Nutzer bereitzustellen. ",{"_87":370,"_82":87,"_137":13},"Sie ist nach Maßgabe der Barrierefreie-Informationstechnik-Verordnung barrierefrei zu gestalten. Ferner ist bei der Gestaltung der Kommunikationsplattform deren Nutzerfreundlichkeit sowie eine einfache und intuitive Bedienbarkeit sicherzustellen.[1]",{"_124":372,"_158":159,"_160":373,"_162":374},"1130","Entwicklung und Bereitstellung; Verordnungsermächtigungen",{"_125":164,"_160":165},{"_77":55,"_78":53,"_79":376,"_111":388,"_117":393,"_122":130,"_124":130,"_125":401,"_127":402,"_205":443},[377],{"_82":83,"_84":378},[379,381,386],{"_87":380,"_82":87},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_28":382,"_82":243,"_84":383},"https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html",[384],{"_87":385,"_82":87},"Once-Only-Prinzip",{"_87":387,"_82":87}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.",[389],{"_82":83,"_84":390},[391],{"_87":392,"_82":87},"Das Once-Only-Prinzip spart Zeit und Kosten, indem Daten nur einmal angegeben und dann auf Basis harmonisierter Rechtsbegriffe, Datenschutz und technischer Standards wiederverwendet werden.",[394],{"_82":83,"_84":395},[396,397,400],{"_87":380,"_82":87},{"_28":382,"_82":243,"_84":398},[399],{"_87":385,"_82":87},{"_87":387,"_82":87},"datenwiederverwendung-benoetigt-einheitliches-recht",{"_77":403,"_124":123,"_131":404,"_155":421,"_166":428},"hpcdwgmccb8r01rbouf3u8ok",[405,411],{"_82":83,"_84":406},[407,409],{"_87":408,"_82":87,"_137":13},"Für einen effizienten Registerbetrieb gleicht das Umweltbundesamt die im Herkunftsnachweisregister für Gas und die im Herkunftsnachweisregister für Wärme oder Kälte gespeicherten Daten, einschließlich personenbezogener Daten, miteinander ab und tauscht sie zwischen diesen Registern aus[2]",{"_87":410,"_82":87}," im Hinblick auf die Erzeugung von",{"_82":94,"_95":141,"_84":412},[413,417],{"_82":99,"_84":414},[415],{"_87":416,"_82":87},"Gas aus oder auf Basis von thermischer Energie sowie",{"_82":99,"_84":418},[419],{"_87":420,"_82":87},"thermischer Energie aus Gas aus oder auf Basis von erneuerbarer Energie oder kohlenstoffarmem Gas.",{"_124":422,"_158":423,"_160":424,"_162":425},"39","GWKH","Überprüfung der gespeicherten Daten; Datenübermittlung",{"_125":426,"_160":427},"einrichtung-herkunftsnachweisregister-fuer-gas-waerme-und-kaelte-gwkhv","Einrichtung Herkunftsnachweisregister für Gas, Wärme und Kälte  - GWKHV",[429],{"_169":430,"_171":431,"_183":442},"1402",[432],{"_82":94,"_95":96,"_84":433},[434,438],{"_82":99,"_84":435},[436],{"_87":437,"_82":87},"Verringert die Fehleranfälligkeit durch den Datenabgleich.",{"_82":99,"_84":439},[440],{"_87":441,"_82":87},"Im folgenden Absatz wird der Abgleich und Austausch der Daten näher spezifiziert und erweitert.  ",{"_124":130,"_78":53},[444,471,520,555,619],{"_160":445,"_209":446,"_79":447,"_131":448,"_221":460,"_222":-5,"_127":-5},"Nutzen Sie harmonisierte Rechtsbegriffe","Harmonisierung von Rechtsbegriffen","Nutzen Sie harmonisierte Rechtsbegriffe: Verwenden Sie konsistente und abgestimmte Begriffe im Recht, um die Grundlage für einen reibungslosen, datenschutzkonformen Datenaustausch zu schaffen.",[449,453,457],{"_82":83,"_84":450},[451],{"_87":452,"_82":87},"Um wiederverwendet zu werden, müssen Daten die gleiche inhaltliche Bedeutung haben, d. h. semantisch interoperabel sein. Dafür müssen die Rechtsbegriffe einheitlich definiert und verwendet werden.",{"_82":83,"_84":454},[455],{"_87":456,"_82":87},"Es kann nötig sein, Begriffe über Ihren Rechtsbereich hinaus zu harmonisieren, um bestehende Daten zu verwenden. Ist dies nicht möglich, können Sie die Informationen möglicherweise aus verschiedenen Datenpunkten zusammensetzen, etwa das Einkommen aus Gehalt und weiteren Einnahmen.",{"_82":83,"_84":458},[459],{"_87":21,"_82":87},[461],{"_82":94,"_95":96,"_84":462},[463,467],{"_82":99,"_84":464},[465],{"_87":466,"_82":87},"Haben diese Begriffe innerhalb und außerhalb Ihres Rechtsbereichs die gleiche Bedeutung? Ist eine übergreifende Harmonisierung nötig?",{"_82":99,"_84":468},[469],{"_87":470,"_82":87},"Haben Sie die Konsistenz zu Regelwerken der EU und von anderen EU-Staaten betrachtet?",{"_160":472,"_209":473,"_79":474,"_131":475,"_221":480,"_222":-5,"_127":504},"Nutzen Sie existierende Daten","Existierende Daten","Nutzen Sie existierende Daten: Wenden Sie das Once-Only-Prinzip konsequent an, damit Nutzende Daten nur einmal angeben müssen und so Kosten und Zeit gespart werden.",[476],{"_82":83,"_84":477},[478],{"_87":479,"_82":87},"Überprüfen Sie, ob Daten schon an anderer Stelle zur Verfügung stehen und genutzt werden können. Optimalerweise wird auf die Originaldaten zugegriffen, statt diese zu kopieren. Für einen Datenaustausch zwischen Behörden müssen Sie dann eine geeignete Rechtsgrundlage schaffen.",[481],{"_82":94,"_95":96,"_84":482},[483,500],{"_82":99,"_84":484},[485,487,492,493,498],{"_87":486,"_82":87},"Können existierende verwaltungsinterne oder öffentliche Daten wiederverwendet werden? Recherchieren Sie u. a. auf ",{"_28":488,"_82":243,"_84":489},"https://www.verwaltungsdaten-informationsplattform.de/",[490],{"_87":491,"_82":87},"verwaltungsdaten-informationsplattform.de",{"_87":255,"_82":87},{"_28":494,"_82":243,"_84":495},"https://data.gov.de/",[496],{"_87":497,"_82":87},"data.gov.de",{"_87":499,"_82":87},".",{"_82":99,"_84":501},[502],{"_87":503,"_82":87},"Genügen die Daten den Anforderungen an Qualität und Aktualität oder sollten Kontrolldaten erhoben werden? Stehen Löschfristen einer Nachnutzung im Wege?",{"_77":505,"_124":204,"_131":506,"_155":513},"aeym55q2neygiz4irjpf8bll",[507],{"_82":83,"_84":508},[509,511],{"_87":510,"_82":87},"Anbieter sind verpflichtet, der Bundesnetzagentur die Informationen nach Absatz 2 auf Anforderung zu übermitteln. Die Bundesnetzagentur kann durch Allgemeinverfügung geeignete Vorgaben machen, in welcher Form, in welchem technischen Format und in welchem Detailgrad die Informationen nach Absatz 2 zu übermitteln sind und in welchen Zeitintervallen die Informationen zu aktualisieren sind. ",{"_87":512,"_82":87,"_137":13},"Soweit möglich greift die Bundesnetzagentur auf die Daten, die ihr nach § 10 Absatz 1 übermittelt werden, zurück.[2]",{"_124":514,"_158":515,"_160":516,"_162":517},"11","PostG","Digitaler Atlas zur Postversorgung, Verordnungsermächtigung",{"_125":518,"_160":519},"modernisierung-des-postrechts","Modernisierung des Postrechts – PostG",{"_160":521,"_209":522,"_79":523,"_131":524,"_221":529,"_222":-5,"_127":544},"Machen Sie erhobene Daten für andere nutzbar","Datenoffenheit","Machen Sie erhobene Daten für andere nutzbar: Ermöglichen Sie den datenschutzkonformen Zugriff und die Wiederverwendung von Daten, um Synergien zu schaffen und mehrfachen Erhebungsaufwand zu vermeiden.",[525],{"_82":83,"_84":526},[527],{"_87":528,"_82":87},"Müssen neue Daten erhoben werden, sollten Sie eine Nachnutzung dieser Daten ermöglichen.",[530],{"_82":94,"_95":96,"_84":531},[532,536,540],{"_82":99,"_84":533},[534],{"_87":535,"_82":87},"Stehen der Nachnutzung der Daten rechtliche Beschränkungen im Weg? Können erhobene Daten sogar öffentlich geteilt werden?",{"_82":99,"_84":537},[538],{"_87":539,"_82":87},"Wie werden die Daten verwaltet? Sind die Verantwortlichkeiten klar?",{"_82":99,"_84":541},[542],{"_87":543,"_82":87},"Ist ein transeuropäischer Datenaustausch möglich? Gibt es passende Lizenzmodelle?",{"_77":545,"_124":195,"_131":546,"_155":553},"sdtovch52centy3wu4grz3ko",[547],{"_82":83,"_84":548},[549,551],{"_87":550,"_82":87,"_137":13},"Das Umweltbundesamt richtet eine elektronische Schnittstelle ein, die es ermöglicht, Daten an die nach Landesrecht zuständigen Behörden zu übermitteln[2]",{"_87":552,"_82":87},", soweit es für den Vollzug des Gebäudeenergiegesetzes vom 8. August 2020 (BGBl. I S. 1728), das durch Artikel 1 des Gesetzes vom 16. Oktober 2023 (BGBl. 2023 I Nr. 280) geändert worden ist, erforderlich ist. Absatz 4 Satz 2 bis 5 ist entsprechend anzuwenden.",{"_124":422,"_158":423,"_160":424,"_162":554},{"_125":426,"_160":427},{"_160":556,"_209":557,"_79":558,"_131":559,"_221":595,"_222":-5,"_127":606},"Nutzen Sie bestehende technische Standards","Technische Standards","Nutzen Sie bestehende technische Standards: Greifen Sie auf etablierte technische Vorgaben zurück, um die Kompatibilität von Systemen zu gewährleisten und einen effizienten Datenaustausch zu fördern.",[560,564],{"_82":83,"_84":561},[562],{"_87":563,"_82":87},"Nutzen Sie geeignete technische Standards, wie z. B. Datenaustauschformate, um den Austausch zwischen IT-Systemen zu begünstigen. Möglicherweise ist es sinnvoll, diese in der Regelung vorzuschreiben.",{"_82":83,"_84":565},[566,568,573,575,580,582,587,589,594],{"_87":567,"_82":87},"Informationen zu Standards der öffentlichen Verwaltung erhalten Sie bei der ",{"_28":569,"_82":243,"_84":570},"https://www.fitko.de/",[571],{"_87":572,"_82":87},"FITKO",{"_87":574,"_82":87},", auf den Seiten des ",{"_28":576,"_82":243,"_84":577},"https://www.xoev.de/",[578],{"_87":579,"_82":87},"XÖV",{"_87":581,"_82":87}," mit zugehörigem ",{"_28":583,"_82":243,"_84":584},"https://www.xrepository.de/",[585],{"_87":586,"_82":87},"XRepository",{"_87":588,"_82":87}," und auf der ",{"_28":590,"_82":243,"_84":591},"https://www.verwaltungsdaten-informationsplattform.de",[592],{"_87":593,"_82":87},"Verwaltungsdaten-Informationsplattform",{"_87":499,"_82":87},[596],{"_82":94,"_95":96,"_84":597},[598,602],{"_82":99,"_84":599},[600],{"_87":601,"_82":87},"Welche Datenformate existieren bereits? Muss gegebenenfalls ein neuer Standard entwickelt oder ein bestehender Standard erweitert werden?",{"_82":99,"_84":603},[604],{"_87":605,"_82":87},"Wurde beachtet, wie die Daten übertragen werden sollen?",{"_77":607,"_124":130,"_131":608,"_155":613},"t0037mojhj4ibwqs1d5zleq9",[609],{"_82":83,"_84":610},[611],{"_87":612,"_82":87,"_137":13},"Das elektronische Dokument muss für die Bearbeitung durch das Bundesverfassungsgericht geeignet sein. Für die Übermittlung und die Eignung zur Bearbeitung durch das Bundesverfassungsgericht gelten die in der Elektronischer-Rechtsverkehr-Verordnung geregelten technischen Rahmenbedingungen des elektronischen Rechtsverkehrs entsprechend.[2]",{"_124":614,"_158":615,"_160":-5,"_162":616},"23a","BVerfGG",{"_125":617,"_160":618},"elektronischer-rechtsverkehr-mit-dem-bundesverfassungsgericht-b-verf-g","Elektronischer Rechtsverkehr mit dem Bundesverfassungsgericht – BVerfGG",{"_160":620,"_209":621,"_79":622,"_131":623,"_221":628,"_222":-5,"_127":-5},"Suchen Sie frühzeitig den Austausch mit allen Beteiligten","Austausch","Suchen Sie frühzeitig den Austausch mit allen Beteiligten: Beziehen Sie Normadressaten und umsetzende Behörden frühzeitig in den Prozess ein, um eine kohärente und effiziente Umsetzung der Regelung zu ermöglichen.",[624],{"_82":83,"_84":625},[626],{"_87":627,"_82":87},"Neben rein technischen Voraussetzungen gilt es auch zu beachten, wie sich organisatorische Aspekte auf die Umsetzung Ihres Vorhabens auswirken. Hier hilft der Austausch mit anderen Beteiligten, wie z. B. den Behörden oder IT-Beauftragten.",[629],{"_82":94,"_95":96,"_84":630},[631,635,639],{"_82":99,"_84":632},[633],{"_87":634,"_82":87},"Wie viel Vorlauf benötigen beteiligte Unternehmen, um IT-Systeme anzupassen oder umzustellen?",{"_82":99,"_84":636},[637],{"_87":638,"_82":87},"Wie ist die Erfahrung mit existierenden Systemen?",{"_82":99,"_84":640},[641],{"_87":642,"_82":87},"Besteht die Möglichkeit, im Zuge des Vorhabens auch IT-Verfahren zu modernisieren? Wie können alle Beteiligten davon profitieren?",{"_77":59,"_78":57,"_79":644,"_111":656,"_117":661,"_122":204,"_124":669,"_125":670,"_127":671,"_205":693},[645],{"_82":83,"_84":646},[647,649,654],{"_87":648,"_82":87},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_28":650,"_82":243,"_84":651},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[652],{"_87":653,"_82":87},"Sicherheit der Angebote",{"_87":655,"_82":87}," und fördern die Interoperabilität.",[657],{"_82":83,"_84":658},[659],{"_87":660,"_82":87},"Digitale Angebote lassen sich schneller, günstiger und sicherer bereitstellen, wenn sie auf bestehenden Technologien, offenen Schnittstellen und Open-Source aufbauen – was zugleich die Interoperabilität fördert.",[662],{"_82":83,"_84":663},[664,665,668],{"_87":648,"_82":87},{"_28":650,"_82":243,"_84":666},[667],{"_87":653,"_82":87},{"_87":655,"_82":87},6,"etablierte-technologien-ermoeglichen-effiziente-umsetzung",{"_77":672,"_124":123,"_131":673,"_155":680,"_166":684},"qa6whcwveoqofa32go7qv776",[674],{"_82":83,"_84":675},[676,678],{"_87":677,"_82":87,"_137":13},"Die digitalen Eingabesysteme nach § 1124 Absatz 1 und 2 werden vom Bundesministerium der Justiz als Referenzimplementierung entwickelt und den Ländern zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitgestellt. Die Länder können weitere digitale Eingabesysteme entwickeln und zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitstellen.[6]",{"_87":679,"_82":87}," Das Bundesministerium der Justiz regelt durch Rechtsverordnung mit Zustimmung des Bundesrates die technischen, organisatorischen und datenschutzrechtlichen Rahmenbedingungen für Entwicklung, Betrieb, Pflege und Weiterentwicklung der digitalen Eingabesysteme nach Satz 2.",{"_124":681,"_158":159,"_160":682,"_162":683},"1125","Digitale Eingabesysteme im Online-Verfahren; Verordnungsermächtigung",{"_125":164,"_160":165},[685],{"_169":686,"_171":687,"_183":692},"1358",[688],{"_82":83,"_84":689},[690],{"_87":691,"_82":87},"Die Entwicklung und bundeseinheitliche Bereitstellung von Referenzimplementierungen fördert die Nutzung etablierter und standardisierter Lösungen.",{"_124":669,"_78":57},[694,802],{"_160":695,"_209":696,"_79":697,"_131":698,"_221":714,"_222":760,"_127":777},"Ermöglichen Sie die Nutzung etablierter, öffentlicher Lösungen","Vorhandene Lösungen","Ermöglichen Sie die Nutzung etablierter, öffentlicher Lösungen: Nutzen Sie existierende und bewährte technologische Fundamente, um die Entwicklung digitaler Angebote zu beschleunigen und ihre Wirtschaftlichkeit zu steigern.",[699,710],{"_82":83,"_84":700},[701,703,708],{"_87":702,"_82":87},"Lösungen sind u. a. öffentliche Basisdienste, Softwarearchitekturen oder Komponentenbibliotheken. ",{"_28":704,"_82":243,"_84":705},"https://www.digitale-verwaltung.de/Webs/DV/DE/onlinezugangsgesetz/rahmenarchitektur/basisdienste-basiskomponenten/basisdienste-basiskomponenten-node.html",[706],{"_87":707,"_82":87},"Eine Übersicht finden Sie im Rahmen des OZG",{"_87":709,"_82":87},". Die Wiederverwendung existierender Lösungen spart Zeit und verringert den Erfüllungsaufwand für Entwicklung und Betrieb. Einheitliche Systeme, wie z. B. ein nationales Postfach, sind für Nutzende oft einfacher zu bedienen und erleichtern die Zusammenarbeit zwischen Behörden.",{"_82":83,"_84":711},[712],{"_87":713,"_82":87},"Gestalten Sie die Regelung so, dass Sie die Nutzung dieser Lösungen ermöglichen oder sogar vorschreiben. Sollte es keine etablierte Lösung geben, formulieren Sie die Regelung technologieoffen.",[715],{"_82":94,"_95":96,"_84":716},[717,721,725,749],{"_82":99,"_84":718},[719],{"_87":720,"_82":87},"Wie viel Spielraum bzw. Standardisierung brauchen die umsetzenden Akteurinnen und Akteuren? Das hängt auch davon ab, ob Sie an einem Gesetz oder einer Verordnung arbeiten.",{"_82":99,"_84":722},[723],{"_87":724,"_82":87},"Existieren für die beschriebenen digitalen Prozesse bereits etablierte, technische Lösungen? Ermöglicht die Regelung die Nutzung dieser Systeme bzw. den Anschluss an sie?",{"_82":99,"_84":726},[727,729,734,735,740,742,747],{"_87":728,"_82":87},"Sind EU-Vorgaben – wie ",{"_28":730,"_82":243,"_84":731},"https://www.personalausweisportal.de/Webs/PA/DE/verwaltung/eIDAS-verordnung-der-EU/eidas-verordnung-der-eu-node.html",[732],{"_87":733,"_82":87},"eIDAS",{"_87":255,"_82":87},{"_28":736,"_82":243,"_84":737},"https://www.bsi.bund.de/DE/Themen/Regulierte-Wirtschaft/NIS-2-regulierte-Unternehmen/NIS-2-FAQ/FAQ-zu-NIS-2_node.html",[738],{"_87":739,"_82":87},"NIS2",{"_87":741,"_82":87}," – oder ",{"_28":743,"_82":243,"_84":744},"https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/Technische-Richtlinien/technische-richtlinien_node.html",[745],{"_87":746,"_82":87},"technische Richtlinien des BSI",{"_87":748,"_82":87}," relevant?",{"_82":99,"_84":750},[751,753,758],{"_87":752,"_82":87},"Wurde untersucht, ob bereits ",{"_28":754,"_82":243,"_84":755},"https://interoperable-europe.ec.europa.eu/solutions",[756],{"_87":757,"_82":87},"existierende europäische Interoperabilitätslösungen",{"_87":759,"_82":87}," wiederverwendet werden könnten?",[761],{"_82":94,"_95":96,"_84":762},[763,767],{"_82":99,"_84":764},[765],{"_87":766,"_82":87},"Sie können die Technologie bereits im Gesetz festschreiben und in der Verordnung ausdefinieren. Tauschen Sie sich dafür mit den umsetzenden Akteurinnen und Akteuren aus und nutzen Sie unseren Support.",{"_82":99,"_84":768},[769,771,776],{"_87":770,"_82":87},"Beispiele für technologieoffene Formulierungen finden Sie z. B. im Handbuch der Rechtsförmlichkeit (",{"_28":772,"_82":243,"_84":773},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=95",[774],{"_87":775,"_82":87},"4. Auflage, Teil B, 3.4. Verweisungen auf technische Regeln",{"_87":334,"_82":87},{"_77":778,"_124":123,"_131":779,"_155":800},"g6pdcvhx2a4cleuywyb0fbuu",[780,786,796],{"_82":83,"_84":781},[782,784],{"_87":783,"_82":87,"_137":13},"Eine in diesem Gesetz angeordnete Schriftform kann durch unmittelbare Eingabe von Anträgen und Erklärungen der Verfahrensbeteiligten über die Kommunikationsplattform nach § 1130 ersetzt werden[1]",{"_87":785,"_82":87},", sofern hierfür digitale Eingabesysteme zur Verfügung stehen und eines der folgenden Identifizierungsverfahren genutzt wird:",{"_82":94,"_95":141,"_84":787},[788,792],{"_82":99,"_84":789},[790],{"_87":791,"_82":87,"_137":13},"für die Identifizierung von Rechtsanwälten: das Verfahren zum Zugang zum besonderen elektronischen Anwaltspostfach nach § 31a Absatz 3 Satz 1 der Bundesrechtsanwaltsordnung;",{"_82":99,"_84":793},[794],{"_87":795,"_82":87,"_137":13},"für die Identifizierung anderer Verfahrensbeteiligter: ein Verfahren über ein Nutzerkonto nach § 2 Absatz 5 in Verbindung mit § 3 Absatz 4 des Onlinezugangsgesetzes.[6]",{"_82":83,"_84":797},[798],{"_87":799,"_82":87},"Wurde der Nachweis der Identität nach Satz 1 erbracht, so kann die spätere Authentisierung des Inhabers des Identitätsnachweises auch durch andere geeignete Authentisierungsmittel erfolgen.",{"_124":157,"_158":159,"_160":161,"_162":801},{"_125":164,"_160":165},{"_160":803,"_209":804,"_79":805,"_131":806,"_221":828,"_222":-5,"_127":839},"Bevorzugen Sie Open-Source-Software und offene Spezifikationen","Open-Source-Software","Bevorzugen Sie Open-Source-Software und offene Spezifikationen: Setzen Sie auf Transparenz und Zugänglichkeit bei Code und Standards, um die Zusammenarbeit zu fördern und die Austauschbarkeit von Systemen zu gewährleisten.",[807],{"_82":83,"_84":808},[809,811,816,817,820,822,827],{"_87":810,"_82":87},"Open-Source bedeutet, dass der Quellcode eines IT-Systems veröffentlicht ist. Offene Spezifikationen beschreiben öffentlich, was ein IT-System genau leistet. Beide stärken Transparenz und Wiederverwendbarkeit (vgl. ",{"_28":812,"_82":243,"_84":813},"https://www.bundestag.de/resource/blob/194886/696f36f795961df200fb27fb6803d83e/koalitionsvertrag-data.pdf#page=152",[814],{"_87":815,"_82":87},"Koalitionsvertrag 18. Legislaturperiode",{"_87":255,"_82":87},{"_28":356,"_82":243,"_84":818},[819],{"_87":359,"_82":87},{"_87":821,"_82":87},"). Dies ermöglicht die Nachvollziehbarkeit der technischen Lösung und verhindert die Abhängigkeit von einzelnen Software-Anbietern. Weitere Informationen erhalten Sie beim ",{"_28":823,"_82":243,"_84":824},"https://www.zendis.de/",[825],{"_87":826,"_82":87},"Zentrum für digitale Souveränität",{"_87":499,"_82":87},[829],{"_82":94,"_95":96,"_84":830},[831,835],{"_82":99,"_84":832},[833],{"_87":834,"_82":87},"Wird der Einsatz von Open-Source-Software ermöglicht und gefördert?",{"_82":99,"_84":836},[837],{"_87":838,"_82":87},"Werden gegebenenfalls bei Neuentwicklung Quelloffenheit und offene Spezifikationen vorgeschrieben?",{"_77":840,"_124":123,"_131":841,"_155":848},"u3sg1zismobz1t707uo3xav8",[842],{"_82":83,"_84":843},[844,846],{"_87":845,"_82":87,"_137":13},"Das Bundesministerium der Justiz kann digitale Eingabesysteme als Referenzimplementierung entwickeln und bundeseinheitlich zur Erprobung bereitstellen, soweit diese dem elektronischen Erstellen von Anträgen oder Erklärungen nach § 129a Absatz 1 dienen.[6]",{"_87":847,"_82":87}," Satz 1 gilt nicht im Anwendungsbereich des Online-Verfahrens nach Abschnitt 2 dieses Buchs.",{"_124":849,"_158":159,"_160":850,"_162":851},"1134","Umfang der Erprobung",{"_125":164,"_160":165},{"_77":63,"_78":61,"_79":853,"_111":887,"_117":892,"_122":913,"_124":195,"_125":914,"_127":915,"_205":943},[854,872],{"_82":83,"_84":855},[856,858,863,865,870],{"_87":857,"_82":87},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_28":859,"_82":243,"_84":860},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[861],{"_87":862,"_82":87},"GGO",{"_87":864,"_82":87}," und das ",{"_28":866,"_82":243,"_84":867},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[868],{"_87":869,"_82":87},"Handbuch der Rechtsförmlichkeit",{"_87":871,"_82":87}," vorgeschrieben.",{"_82":83,"_84":873},[874,876,878,880,885],{"_87":875,"_82":87},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_87":877,"_82":87,"_253":13},"Verwaltungsakt",{"_87":879,"_82":87}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_28":881,"_82":243,"_84":882},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[883],{"_87":884,"_82":87},"§ 35a VwVfG",{"_87":886,"_82":87},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.",[888],{"_82":83,"_84":889},[890],{"_87":891,"_82":87},"Klare, logische und verständliche Regelungen – wie sie GGO und Handbuch der Rechtsförmlichkeit vorschreiben – stärken das Vertrauen in den Staat, ermöglichen automatisierte Verwaltungsprozesse und setzen dadurch Ressourcen für komplexere Fälle frei.",[893,904],{"_82":83,"_84":894},[895,896,899,900,903],{"_87":857,"_82":87},{"_28":859,"_82":243,"_84":897},[898],{"_87":862,"_82":87},{"_87":864,"_82":87},{"_28":866,"_82":243,"_84":901},[902],{"_87":869,"_82":87},{"_87":871,"_82":87},{"_82":83,"_84":905},[906,907,908,909,912],{"_87":875,"_82":87},{"_87":877,"_82":87,"_253":13},{"_87":879,"_82":87},{"_28":881,"_82":243,"_84":910},[911],{"_87":884,"_82":87},{"_87":886,"_82":87},4,"automatisierung-basiert-auf-eindeutigen-regelungen",{"_77":916,"_124":204,"_131":917,"_155":926,"_166":928},"uvun402oruwdnjke6epwd5qt",[918],{"_82":83,"_84":919},[920,922,924],{"_87":921,"_82":87},"Betreiber von unbemannten Fluggeräten nach Absatz 1 Satz 1 haben dem Luftfahrt-Bundesamt vor der erstmaligen Aufnahme des Betriebs die für die Registrierung zu speichernden Daten nach Absatz 2 zu übermitteln und deren Richtigkeit auf Verlangen zu belegen, soweit dies für die Registrierung durch das Luftfahrt-Bundesamt erforderlich ist. Registrierte Betreiber haben dem Luftfahrt-Bundesamt unverzüglich jede Änderung der Voraussetzungen für eine Registrierung nach Absatz 1 und jede Änderung der Daten nach Absatz 2 zu übermitteln. ",{"_87":923,"_82":87,"_137":13},"Das Luftfahrt-Bundesamt kann Verwaltungsakte hinsichtlich der Registrierung eines Betreibers sowie Gebührenbescheide für die Registrierung durch automatische Einrichtungen erlassen. Betreiber haben das Recht auf Darlegung des eigenen Standpunktes und das Recht auf Entscheidung durch einen Amtsträger.[5]",{"_87":925,"_82":87}," Satz 3 gilt nicht, wenn ein Betreiber Rechte nach Satz 4 geltend macht oder wenn aus anderen Gründen Anlass besteht, den Einzelfall durch Amtsträger zu bearbeiten. Setzt das Luftfahrt-Bundesamt automatische Einrichtungen zum Erlass von Verwaltungsakten ein, muss es Angaben des Betreibers berücksichtigen, die für den Einzelfall bedeutsam sind und im automatischen Verfahren nicht ermittelt würden.",{"_124":272,"_158":273,"_160":274,"_162":927},{"_125":276,"_160":277},[929],{"_169":930,"_171":931,"_183":942},"1286",[932],{"_82":94,"_95":96,"_84":933},[934,938],{"_82":99,"_84":935},[936],{"_87":937,"_82":87},"Schafft die Rechtsgrundlage zur potenziellen Automatisierung.",{"_82":99,"_84":939},[940],{"_87":941,"_82":87},"Neben der Automatisierung besteht das Recht auf Entscheidung durch einen Amtsträger.",{"_124":195,"_78":61},[944,1011,1039,1096,1147],{"_160":945,"_209":946,"_79":947,"_131":948,"_221":953,"_222":-5,"_127":983},"Beachten Sie bestehende Prozesse und Verantwortlichkeiten","Bestehende Prozesse","Beachten Sie bestehende Prozesse und Verantwortlichkeiten: Integrieren Sie neue Regelungen harmonisch in die vorhandenen Arbeitsabläufe und klären Sie die Zuständigkeiten, um eine reibungslose Umsetzung zu sichern.",[949],{"_82":83,"_84":950},[951],{"_87":952,"_82":87},"Um eine effektive Umsetzung zu gewährleisten, sollten existierende Prozesse und Verantwortlichkeiten beachtet und, wenn möglich, angeglichen werden. Dabei helfen Ihnen Visualisierungen.",[954],{"_82":94,"_95":96,"_84":955},[956,967,971,975,979],{"_82":99,"_84":957},[958,960,965],{"_87":959,"_82":87},"Gibt es bereits Prozess-Visualisierungen im ",{"_28":961,"_82":243,"_84":962},"https://fimportal.de/search?resource=process&page=1&page_size=20",[963],{"_87":964,"_82":87},"FIM-Portal",{"_87":966,"_82":87},", auf denen Sie aufsetzen können?",{"_82":99,"_84":968},[969],{"_87":970,"_82":87},"Haben Sie bestehende Prozesse in Deutschland und anderen EU-Mitgliedsstaaten berücksichtigt",{"_82":99,"_84":972},[973],{"_87":974,"_82":87},"Bekommt oder verliert eine Behörde Kompetenzen? Wie wirkt sich das aus?",{"_82":99,"_84":976},[977],{"_87":978,"_82":87},"Können bestehende Prozesse vereinfacht werden?",{"_82":99,"_84":980},[981],{"_87":982,"_82":87},"Falls ein Verwaltungsprozess betroffen ist: Lassen sich die Teilschritte in einer chronologischen Reihenfolge abbilden?",{"_77":984,"_124":985,"_131":986,"_155":1009},"aws985sev373qzjm9gagbjyl",7,[987,995,1005],{"_82":83,"_84":988},[989,991,993],{"_87":990,"_82":87},"Die Übermittlung nach Absatz 6 Satz 1 ",{"_87":992,"_82":87,"_137":13},"aus dem Register darf durch Abruf im automatisierten Verfahren[5]",{"_87":994,"_82":87}," an die Polizeien des Bundes und der Länder erfolgen",{"_82":94,"_95":141,"_84":996},[997,1001],{"_82":99,"_84":998},[999],{"_87":1000,"_82":87},"zur Verfolgung von Straftaten oder",{"_82":99,"_84":1002},[1003],{"_87":1004,"_82":87},"zur Abwehr von Gefahren für die öffentliche Sicherheit,",{"_82":83,"_84":1006},[1007],{"_87":1008,"_82":87},"wenn diese Daten auf andere Weise nicht oder nicht rechtzeitig oder nur mit unverhältnismäßigem Aufwand zu erlangen sind. Die Verantwortung für die Zulässigkeit des einzelnen automatisierten Abrufs trägt die abrufende Stelle. Das Luftfahrt-Bundesamt überprüft die Zulässigkeit des Abrufs nur, wenn dazu Anlass besteht.",{"_124":272,"_158":273,"_160":274,"_162":1010},{"_125":276,"_160":277},{"_160":1012,"_209":1013,"_79":1014,"_131":1015,"_221":1020,"_222":-5,"_127":-5},"Bündeln Sie Aufgaben im Vollzug","Aufgabenbündelung","Bündeln Sie Aufgaben im Vollzug: Fassen Sie ähnliche oder zusammenhängende Tätigkeiten in der Umsetzung zusammen, um Effizienz zu steigern und die Übersichtlichkeit zu verbessern.",[1016],{"_82":83,"_84":1017},[1018],{"_87":1019,"_82":87},"Vereinfachen Sie, wie die Aufgaben zwischen Bund und Ländern verteilt sind. Aufgaben oder Teilaufgaben können gebündelt werden: Sie müssen nicht mehr in jeder Kommune oder jeder Behörde individuell erfüllt werden. Gerade bei Aufgaben mit hohen Fallzahlen und hohem Standardisierungspotenzial können Automatisierung und Aufgabenneuorganisation die Vollzugsbehörden spürbar entlasten.",[1021],{"_82":94,"_95":96,"_84":1022},[1023,1027,1031,1035],{"_82":99,"_84":1024},[1025],{"_87":1026,"_82":87},"Ermöglicht die Regelung, dass andere, möglichst übergeordnete oder ressortübergreifende, Behörden Aufgaben automatisieren können? Ist es ausreichend, wenn die zuständige Behörde das Ergebnis erhält?",{"_82":99,"_84":1028},[1029],{"_87":1030,"_82":87},"Können Sie vermeiden, dass dieselben Aufgaben in jeder Kommunen erfüllt werden müssen?",{"_82":99,"_84":1032},[1033],{"_87":1034,"_82":87},"Kann eine gemeinsame technische Lösung für alle Behörden entwickelt werden?",{"_82":99,"_84":1036},[1037],{"_87":1038,"_82":87},"Können Sie Spezialisierungsvorteile nutzen, in dem Sie fachlich anspruchsvolle Aufgaben, die selten anfallen, bündeln?",{"_160":1040,"_209":1041,"_79":1042,"_131":1043,"_221":1048,"_222":-5,"_127":1077},"Nutzen Sie das Potenzial von Automatisierung","Automatisierung","Nutzen Sie das Potenzial von Automatisierung: Legen Sie Entscheidungsstrukturen so fest, dass sie durch eindeutige Logik maschinell verarbeitet werden können, um Zeit und Ressourcen zu sparen.",[1044],{"_82":83,"_84":1045},[1046],{"_87":1047,"_82":87},"Automatisierung wirkt sich besonders effizienzsteigernd auf Prozesse mit großen Bearbeitungsfallzahlen aus, die als gebundene Entscheidungen geregelt werden können.",[1049],{"_82":94,"_95":96,"_84":1050},[1051,1055,1059,1063,1067],{"_82":99,"_84":1052},[1053],{"_87":1054,"_82":87},"Wie groß ist die erwartete Fallzahl pro Jahr? Sind in den Behörden genug Ressourcen vorhanden, um z. B. Anträge fristgerecht zu bearbeiten?",{"_82":99,"_84":1056},[1057],{"_87":1058,"_82":87},"Gibt es bereits Vorschläge für Automatisierungspotenziale aus der Umsetzung?",{"_82":99,"_84":1060},[1061],{"_87":1062,"_82":87},"Handelt es sich um eine gebundene Entscheidung?",{"_82":99,"_84":1064},[1065],{"_87":1066,"_82":87},"Erlaubt die Regelung eine automatisierte Fallbearbeitung?",{"_82":99,"_84":1068},[1069,1071,1075],{"_87":1070,"_82":87},"Ist ein komplett antragsloses Verfahren möglich? Beachten Sie hierfür auch das Prinzip „",{"_28":1072,"_82":243,"_84":1073},"/#datenwiederverwendung-ben-tigt-einheitliches-recht",[1074],{"_87":53,"_82":87},{"_87":1076,"_82":87},"“.",{"_77":129,"_124":130,"_131":1078,"_155":1094},[1079,1083],{"_82":83,"_84":1080},[1081,1082],{"_87":136,"_82":87,"_137":13},{"_87":139,"_82":87},{"_82":94,"_95":141,"_84":1084},[1085,1088,1091],{"_82":99,"_84":1086},[1087],{"_87":146,"_82":87},{"_82":99,"_84":1089},[1090],{"_87":150,"_82":87,"_137":13},{"_82":99,"_84":1092},[1093],{"_87":154,"_82":87,"_137":13},{"_124":157,"_158":159,"_160":161,"_162":1095},{"_125":164,"_160":165},{"_160":1097,"_209":1098,"_79":1099,"_131":1100,"_221":1105,"_222":-5,"_127":1128},"Unterscheiden Sie zwischen genereller Regel, Ausnahmen und Ermessensspielräumen","Unterscheidungen","Unterscheiden Sie zwischen genereller Regel, Ausnahmen und Ermessensspielräumen: Definieren Sie klare Abgrenzungen zwischen Standardfällen, Sonderfällen und Ermessensentscheidungen, um die Automatisierbarkeit zu ermöglichen.",[1101],{"_82":83,"_84":1102},[1103],{"_87":1104,"_82":87},"Sachverhalte sollten durch das Zusammenspiel von Gesetzen und Verordnungen möglichst abschließend geregelt werden. Finden Sie die Balance zwischen notwendigen Ausnahmen für eine gerechte Regelung, Spielraum in der Umsetzung und klar geregelten Prozessen, die sich gut digitalisieren lassen.",[1106],{"_82":94,"_95":96,"_84":1107},[1108,1112,1116,1120,1124],{"_82":99,"_84":1109},[1110],{"_87":1111,"_82":87},"Basieren Entscheidungslogiken auf objektiven Kriterien?",{"_82":99,"_84":1113},[1114],{"_87":1115,"_82":87},"Können Pauschalen die Regelung und Umsetzung vereinfachen?",{"_82":99,"_84":1117},[1118],{"_87":1119,"_82":87},"Wird in der Regelung klar zwischen grundlegender Regel und Ausnahmen unterschieden? Sind die Ausnahmen klar definiert?",{"_82":99,"_84":1121},[1122],{"_87":1123,"_82":87},"Sind Ermessensspielräume nötig? Können für bestimmte Fallgruppen gebundene Entscheidungen festgelegt werden?",{"_82":99,"_84":1125},[1126],{"_87":1127,"_82":87},"Ist trotz verbleibendem Ermessen eine Automatisierung anderer Prozessschritte möglich?",{"_77":1129,"_124":204,"_131":1130,"_155":1143},"xu1tjdat5q94xbjqhqtqjw9g",[1131],{"_82":83,"_84":1132},[1133,1135,1137,1139,1141],{"_87":1134,"_82":87,"_137":13},"Innerhalb von vier Wochen nach Eingang eines vollständigen Antrags prüft die Bundesnetzagentur, ob Gründe nach Absatz 4 für die Versagung der Eintragung vorliegen.[5]",{"_87":1136,"_82":87}," Liegen keine Gründe für die Versagung der Eintragung vor, ",{"_87":1138,"_82":87,"_137":13},"trägt die Bundesnetzagentur den Antragsteller in das Anbieterverzeichnis ein.[5]",{"_87":1140,"_82":87}," Die erfolgte Eintragung ist dem Anbieter mitzuteilen. Liegen Gründe für die Versagung der Eintragung vor, versagt die Bundesnetzagentur die Eintragung. ",{"_87":1142,"_82":87,"_137":13},"Ist die Frist nach Satz 1 abgelaufen, ohne dass eine Eintragung oder Versagung erfolgt ist, gilt der Antragsteller als in das Anbieterverzeichnis eingetragen; die Bundesnetzagentur hat die Eintragung umgehend zu veranlassen.[5]",{"_124":1144,"_158":515,"_160":1145,"_162":1146},"4","Anbieterverzeichnis",{"_125":518,"_160":519},{"_160":1148,"_209":1149,"_79":1150,"_131":1151,"_221":1156,"_222":-5,"_127":1171},"Schreiben Sie einfach, eindeutig und widerspruchsfrei","Schreibstil","Schreiben Sie einfach, eindeutig und widerspruchsfrei: Formulieren Sie Normen klar und verständlich, damit sie eine unmissverständliche Grundlage für die digitale und menschliche Anwendung bilden.",[1152],{"_82":83,"_84":1153},[1154],{"_87":1155,"_82":87},"Logische Konsistenz und präzise Sprache sind notwendige Bedingungen für die Automatisierung der Umsetzung. Dass eine Regelung eindeutig formuliert ist, kann auch einen längeren Regelungstext zur Folge haben.",[1157],{"_82":94,"_95":96,"_84":1158},[1159,1163,1167],{"_82":99,"_84":1160},[1161],{"_87":1162,"_82":87},"Sind Begriffe und Abläufe eindeutig definiert?",{"_82":99,"_84":1164},[1165],{"_87":1166,"_82":87},"Ist die Regelung möglichst einfach formuliert?",{"_82":99,"_84":1168},[1169],{"_87":1170,"_82":87},"Sind Entscheidungslogiken widerspruchsfrei?",{"_77":1172,"_124":123,"_131":1173,"_155":1256},"ooxbst8o2pc70zu1ggl130rf",[1174,1178,1249,1253],{"_82":83,"_84":1175},[1176],{"_87":1177,"_82":87,"_137":13},"Die nach § 4 Absatz 4 Nummer 1 erforderliche Zuverlässigkeit liegt in der Regel nicht vor, wenn[5]",{"_82":94,"_95":141,"_84":1179},[1180,1184,1203,1207,1245],{"_82":99,"_84":1181},[1182],{"_87":1183,"_82":87},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 wegen Versuchs oder Vollendung eines Verbrechens im Sinne von § 12 Absatz 1 des Strafgesetzbuches oder einer der nachstehend aufgeführten Straftaten zu einer Freiheitsstrafe, Jugendstrafe, auch wenn deren Verhängung ausgesetzt worden ist, Geldstrafe von mindestens 90 Tagessätzen oder mindestens zweimal zu einer geringeren Geldstrafe rechtskräftig verurteilt worden ist, wenn seit dem Eintritt der Rechtskraft der letzten erstinstanzlichen Verurteilung fünf Jahre und seit dem Eintritt der Rechtskraft der vorletzten erstinstanzlichen Verurteilung zehn Jahre noch nicht verstrichen sind:",{"_82":94,"_95":141,"_84":1185,"_1202":123},[1186,1190,1194,1198],{"_82":99,"_84":1187},[1188],{"_87":1189,"_82":87},"§§ 15 oder 15a des Arbeitnehmerüberlassungsgesetzes,",{"_82":99,"_84":1191},[1192],{"_87":1193,"_82":87},"§ 23 des Arbeitszeitgesetzes,",{"_82":99,"_84":1195},[1196],{"_87":1197,"_82":87},"§§ 10, 10a oder 11 des Schwarzarbeitsbekämpfungsgesetzes,",{"_82":99,"_84":1199},[1200],{"_87":1201,"_82":87},"§§ 202, 206, 263, 266a oder 267 des Strafgesetzbuches,","indentLevel",{"_82":99,"_84":1204},[1205],{"_87":1206,"_82":87,"_137":13},"gegen den Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 bei Antragstellern mit bis zu zehn Beschäftigten mindestens zwei, bei Antragstellern mit bis zu 250 Beschäftigten mindestens zehn, bei Antragstellern mit bis zu 500 Beschäftigten mindestens 20 und bei Antragstellern mit mehr als 500 Beschäftigten mindestens 25 unanfechtbare Bußgeldentscheidungen wegen einer der nachstehend aufgeführten Ordnungswidrigkeiten in Höhe von jeweils mindestens 1 500 Euro ergangen sind:[5]",{"_82":94,"_95":141,"_84":1208,"_1202":123},[1209,1213,1217,1221,1225,1229,1233,1237,1241],{"_82":99,"_84":1210},[1211],{"_87":1212,"_82":87},"§ 23 des Arbeitnehmerentsendegesetzes,",{"_82":99,"_84":1214},[1215],{"_87":1216,"_82":87},"§ 16 des Arbeitnehmerüberlassungsgesetzes,",{"_82":99,"_84":1218},[1219],{"_87":1220,"_82":87},"§ 25 des Arbeitsschutzgesetzes,",{"_82":99,"_84":1222},[1223],{"_87":1224,"_82":87},"§ 22 Absatz 1 Nummer 1 bis 7, 9 oder 10 des Arbeitszeitgesetzes,",{"_82":99,"_84":1226},[1227],{"_87":1228,"_82":87},"§ 21 des Mindestlohngesetzes,",{"_82":99,"_84":1230},[1231],{"_87":1232,"_82":87},"§ 8 Absatz 1 Nummer 2, Absatz 2 bis 4 des Schwarzarbeitsbekämpfungsgesetzes,",{"_82":99,"_84":1234},[1235],{"_87":1236,"_82":87},"§ 404 Absatz 1 oder Absatz 2 Nummer 4 des Dritten Buches Sozialgesetzbuch,",{"_82":99,"_84":1238},[1239],{"_87":1240,"_82":87},"§ 209 Absatz 1 Nummer 1 bis 7, 8, 9 oder Absatz 2 des Siebten Buches Sozialgesetzbuch,",{"_82":99,"_84":1242},[1243],{"_87":1244,"_82":87},"§ 111 dieses Gesetzes,",{"_82":99,"_84":1246},[1247],{"_87":1248,"_82":87},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 schwerwiegend oder wiederholt gegen Vorgaben dieses Gesetzes verstoßen hat und die Verstöße durch bestandskräftige Entscheidungen der Bundesnetzagentur festgestellt sind.",{"_82":83,"_84":1250},[1251],{"_87":1252,"_82":87},"Im Einzelfall kann auch eine Gesamtabwägung von Umständen, die nicht in Satz 1 genannt sind und denen in ihrer Gesamtheit ein vergleichbares Gewicht wie den in Satz 1 genannten Umständen zuzumessen ist, die Annahme rechtfertigen, dass der Antragsteller nicht über die erforderliche Zuverlässigkeit verfügt.",{"_82":83,"_84":1254},[1255],{"_87":21,"_82":87},{"_124":1257,"_158":515,"_160":1258,"_162":1259},"5","Zuverlässigkeit, Leistungsfähigkeit, Fachkunde",{"_125":518,"_160":519},{"_77":67,"_78":65,"_79":1261,"_111":1281,"_117":1286,"_122":195,"_124":204,"_125":1300,"_127":1301,"_205":1323},[1262,1273,1277],{"_82":83,"_84":1263},[1264,1266,1271],{"_87":1265,"_82":87},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_28":1267,"_82":243,"_84":1268},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[1269],{"_87":1270,"_82":87},"DSGVO",{"_87":1272,"_82":87}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_82":83,"_84":1274},[1275],{"_87":1276,"_82":87},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_82":83,"_84":1278},[1279],{"_87":1280,"_82":87},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.",[1282],{"_82":83,"_84":1283},[1284],{"_87":1285,"_82":87},"Datenschutz nach DSGVO und Informationssicherheit schützen Menschen vor unbefugtem Zugriff, stärken das Vertrauen in den Staat und werden durch konsequente Datensparsamkeit erleichtert, die zugleich den Erfüllungsaufwand reduziert.",[1287,1294,1297],{"_82":83,"_84":1288},[1289,1290,1293],{"_87":1265,"_82":87},{"_28":1267,"_82":243,"_84":1291},[1292],{"_87":1270,"_82":87},{"_87":1272,"_82":87},{"_82":83,"_84":1295},[1296],{"_87":1276,"_82":87},{"_82":83,"_84":1298},[1299],{"_87":1280,"_82":87},"datenschutz-und-informationssicherheit-schaffen-vertrauen",{"_77":1302,"_124":913,"_131":1303,"_155":1312,"_166":1314},"zcso7sdqfumq9dymth3dfssp",[1304],{"_82":83,"_84":1305},[1306,1308,1310],{"_87":1307,"_82":87},"Abweichend von Absatz 3 Satz 1 können Luftsportverbände die für die Registrierung zu speichernden Daten ihrer Mitglieder, die unbemannte Fluggeräte nach Absatz 1 Satz 1 betreiben, dem Luftfahrt-Bundesamt ",{"_87":1309,"_82":87,"_137":13},"unter Beachtung der Verordnung (EU) 2016/679 des Europäischen Parlaments und des Rates vom 27. April 2016 zum Schutz natürlicher Personen bei der Verarbeitung personenbezogener Daten[3]",{"_87":1311,"_82":87},", zum freien Datenverkehr und zur Aufhebung der Richtlinie 95/46/EG (ABl. L 119 vom 4.5.2016, S. 1; L 314 vom 22.11.2016, S. 72; L 127 vom 23.5.2018, S. 2) übermitteln. Absatz 3 Satz 2 gilt entsprechend.",{"_124":272,"_158":273,"_160":274,"_162":1313},{"_125":276,"_160":277},[1315],{"_169":1316,"_171":1317,"_183":1322},"1288",[1318],{"_82":83,"_84":1319},[1320],{"_87":1321,"_82":87},"Verweist auf die DSGVO.",{"_124":204,"_78":65},[1324,1402],{"_160":1325,"_209":1326,"_79":1327,"_131":1328,"_221":1346,"_222":-5,"_127":1369},"Stellen Sie den Datenschutz sicher","Datenschutz","Stellen Sie den Datenschutz sicher: Gewährleisten Sie, dass die Verarbeitung personenbezogener Daten jederzeit den geltenden Anforderungen entspricht und das Erfordernis der Datensparsamkeit beachtet wird.",[1329],{"_82":83,"_84":1330},[1331,1333,1338,1340,1345],{"_87":1332,"_82":87},"Für den Datenschutz sind nur personenbezogene Daten relevant. Um diese zu verarbeiten, muss eine geeignete Rechtsgrundlage existieren. \"Datenverarbeitung\" umfasst u. a. das Erheben, Speichern, Abfragen, Übermitteln, Verknüpfen oder Löschen von Daten (",{"_28":1334,"_82":243,"_84":1335},"https://eur-lex.europa.eu/legal-content/DE/TXT/?qid=1532348683434&uri=CELEX%3A02016R0679-20160504",[1336],{"_87":1337,"_82":87},"s. Art. 4 Abs. 2 DSGVO",{"_87":1339,"_82":87},"). Tauschen Sie sich mit Ihren Datenschutzbeauftragten aus oder kontaktieren Sie die ",{"_28":1341,"_82":243,"_84":1342},"https://www.bfdi.bund.de/DE/Home/home_node.html",[1343],{"_87":1344,"_82":87},"BfDI",{"_87":499,"_82":87},[1347],{"_82":94,"_95":96,"_84":1348},[1349,1353,1357,1361,1365],{"_82":99,"_84":1350},[1351],{"_87":1352,"_82":87},"Werden personenbezogene Daten verarbeitet? Sind diese besonders schützenswert, etwa Daten zur ethnischen Herkunft oder Gesundheitsdaten?",{"_82":99,"_84":1354},[1355],{"_87":1356,"_82":87},"Werden nur notwendige Daten verarbeitet?",{"_82":99,"_84":1358},[1359],{"_87":1360,"_82":87},"Haben Sie die rechtliche Basis geschaffen, um Daten zu verarbeiten? Ist der Zweck der Datenverarbeitung dargelegt?",{"_82":99,"_84":1362},[1363],{"_87":1364,"_82":87},"Können überholte Datenschutzbedürfnisse abgeschafft werden?",{"_82":99,"_84":1366},[1367],{"_87":1368,"_82":87},"Genügt die Regelung den Anforderungen an den Datenschutz in allen beteiligten Ländern und Institutionen, gegebenenfalls auch in anderen EU-Staaten?",{"_77":1370,"_124":913,"_131":1371,"_155":1400},"i9t6l6by44lbcecptjuzclfe",[1372,1376,1394],{"_82":83,"_84":1373},[1374],{"_87":1375,"_82":87},"Das Umweltbundesamt kann den Betreibern der Datenbanken und der Register nach Absatz 2 sowie den Behörden nach Absatz 3 über elektronische Schnittstellen den Zugang zu den in einem Herkunftsnachweisregister nach § 3 gespeicherten Daten, einschließlich personenbezogener Daten, ermöglichen. Das Umweltbundesamt als übermittelnde Stelle hat über die Abrufe nach Satz 1 Aufzeichnungen zu fertigen, die die folgenden Daten enthalten müssen:",{"_82":94,"_95":141,"_84":1377},[1378,1382,1386,1390],{"_82":99,"_84":1379},[1380],{"_87":1381,"_82":87},"die bei der Durchführung der Abrufe verwendeten Daten,",{"_82":99,"_84":1383},[1384],{"_87":1385,"_82":87},"den Tag und die Uhrzeit der Abrufe,",{"_82":99,"_84":1387},[1388],{"_87":1389,"_82":87},"die Kennung der abrufenden Dienststelle und",{"_82":99,"_84":1391},[1392],{"_87":1393,"_82":87},"die abgerufenen Daten.",{"_82":83,"_84":1395},[1396,1398],{"_87":1397,"_82":87},"Die protokollierten Daten dürfen nur für Zwecke der Datenschutzkontrolle oder Datensicherung oder zur Sicherstellung eines ordnungsgemäßen Betriebs der Datenverarbeitungsanlage verwendet werden. ",{"_87":1399,"_82":87,"_137":13},"Die protokollierten Daten sind durch geeignete Vorkehrungen gegen zweckfremde Verwendung und gegen sonstigen Missbrauch zu schützen. Die protokollierten Daten sind sechs Monate nach der Protokollierung zu löschen.[3]",{"_124":422,"_158":423,"_160":424,"_162":1401},{"_125":426,"_160":427},{"_160":1403,"_209":1404,"_79":1405,"_131":1406,"_221":1417,"_222":-5,"_127":1450},"Gewährleisten Sie die Informationssicherheit","Informationssicherheit","Gewährleisten Sie die Informationssicherheit: Ergreifen Sie notwendige technische und organisatorische Maßnahmen, um die Vertraulichkeit, Integrität und Verfügbarkeit aller relevanten Informationen zu schützen.",[1407],{"_82":83,"_84":1408},[1409,1411,1416],{"_87":1410,"_82":87},"Informationssicherheit betrifft alle Arten von Daten, vor allem wirtschafts- oder sicherheitsrelevante. Alle Daten müssen sicher gespeichert und übertragen werden. Dies erschwert den missbräuchlichen Zugriff, etwa zum Erschleichen von Leistungen. Folgen Sie den ",{"_28":1412,"_82":243,"_84":1413},"https://www.bsi.bund.de/DE/Themen/Oeffentliche-Verwaltung/oeffentliche-verwaltung_node.html",[1414],{"_87":1415,"_82":87},"Empfehlungen des BSI",{"_87":499,"_82":87},[1418],{"_82":94,"_95":96,"_84":1419},[1420,1424,1428,1432],{"_82":99,"_84":1421},[1422],{"_87":1423,"_82":87},"Werden eine geeignete, sichere Datenhaltung und sichere Übertragungswege vorgeschrieben?",{"_82":99,"_84":1425},[1426],{"_87":1427,"_82":87},"Wurden Maßnahmen vorgeschrieben, um Betrugsversuche zu erschweren?",{"_82":99,"_84":1429},[1430],{"_87":1431,"_82":87},"Wurden veraltete Informationssicherheitsbedürfnisse identifiziert und abgeschafft?",{"_82":99,"_84":1433},[1434,1436,1441,1443,1448],{"_87":1435,"_82":87},"Gibt es passende, anerkannte ",{"_28":1437,"_82":243,"_84":1438},"https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/standards-und-zertifizierung_node.html",[1439],{"_87":1440,"_82":87},"Nachweise oder Zertifizierungen",{"_87":1442,"_82":87},", z. B. ",{"_28":1444,"_82":243,"_84":1445},"https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/IT-Grundschutz/Zertifizierte-Informationssicherheit/zertifizierte-informationssicherheit.html",[1446],{"_87":1447,"_82":87},"ISO 27001",{"_87":1449,"_82":87},"?",{"_77":1451,"_124":1452,"_131":1453,"_155":1460},"wcxx3x3bzdzfsrkr0fxlr7bi",10,[1454],{"_82":83,"_84":1455},[1456,1458],{"_87":1457,"_82":87},"Das Luftfahrt-Bundesamt legt im ",{"_87":1459,"_82":87,"_137":13},"Einvernehmen mit dem Bundesamt für Sicherheit in der Informationstechnik insbesondere unter Beachtung der Vorgaben der Artikel 24, 25 und 32 der Verordnung (EU) 2016/679 nähere Anforderungen an das Datenformat sowie die Anforderungen an die Sicherheit gegen unbefugte Zugriffe auf das Register und bei der Datenübertragung fest. Sie haben dem Stand der Technik zu entsprechen und sind vom Luftfahrt-Bundesamt im Einvernehmen mit dem Bundesamt für Sicherheit in der Informationstechnik fortlaufend anzupassen[3].",{"_124":272,"_158":273,"_160":274,"_162":1461},{"_125":276,"_160":277}]
