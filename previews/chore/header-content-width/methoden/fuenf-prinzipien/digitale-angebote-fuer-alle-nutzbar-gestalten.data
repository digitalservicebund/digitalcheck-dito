[{"_1":2,"_22":23},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_20":21},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13,"_19":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showCoreVocabularies","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/methoden.fuenf-prinzipien.$prinzip",{"_3":24},{"_25":26,"_513":514},"prinzip",{"_27":28,"_29":30,"_31":32,"_63":64,"_65":64,"_66":67,"_68":69,"_148":149},"documentId","r57rc9d82ulv2bsc3gdbnj73","Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[33,41,45],{"_34":35,"_36":37},"type","paragraph","children",[38],{"_39":40,"_34":39},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_34":35,"_36":42},[43],{"_39":44,"_34":39},"Erfahren Sie in diesem Abschnitt,",{"_34":46,"_47":48,"_36":49},"list","format","unordered",[50,55,59],{"_34":51,"_36":52},"list-item",[53],{"_39":54,"_34":39},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_34":51,"_36":56},[57],{"_39":58,"_34":39},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_34":51,"_36":60},[61],{"_39":62,"_34":39},"wie Barrierefreiheit zu bedenken ist.","order",1,"Nummer","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Beispiel",{"_27":70,"_65":71,"_72":73,"_96":97,"_107":108},"fvj31s0fav5aw2vlu65q0arw",2,"Text",[74,81],{"_34":35,"_36":75},[76,79],{"_39":77,"_34":39,"_78":13},"Eine in diesem Gesetz angeordnete Schriftform kann auch durch Übermittlung elektronischer Dokumente oder strukturierter Datensätze über die Kommunikationsplattform ersetzt werden[1]","underline",{"_39":80,"_34":39},", sofern",{"_34":46,"_47":82,"_36":83},"ordered",[84,88,92],{"_34":51,"_36":85},[86],{"_39":87,"_34":39},"ein Identifizierungsverfahren nach Absatz 1 genutzt wird,",{"_34":51,"_36":89},[90],{"_39":91,"_34":39,"_78":13},"bei der Datenübermittlung ein sicheres Verfahren verwendet wird, das die Authentizität und Integrität der Daten gewährleistet, und [3]",{"_34":51,"_36":93},[94],{"_39":95,"_34":39,"_78":13},"für die elektronischen Dokumente oder strukturierten Datensätze auf der Kommunikationsplattform eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[5]","Paragraph",{"_65":98,"_99":100,"_101":102,"_103":104},"1131","Gesetz","ZPO","Titel","Kommunikations-, Austausch- und Übermittlungsformen","Beispielvorhaben",{"_66":105,"_101":106},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit","PrinzipErfuellungen",[109,126,138],{"_110":111,"_112":113,"_124":125},"id","1336","Erklaerung",[114],{"_34":46,"_47":48,"_36":115},[116,120],{"_34":51,"_36":117},[118],{"_39":119,"_34":39},"Die digitale Übermittlung von Dokumenten ermöglicht eine Kommunikation über die digitale Kommunikationsplattform.",{"_34":51,"_36":121},[122],{"_39":123,"_34":39},"Schriftformerfordernisse werden durch die digitale Übermittlung ersetzt.","Prinzip",{"_65":64,"_29":30},{"_110":127,"_112":128,"_124":135},"1337",[129],{"_34":46,"_47":48,"_36":130},[131],{"_34":51,"_36":132},[133],{"_39":134,"_34":39},"Geht von einer automatisierten Bearbeitung der Daten aus.",{"_65":136,"_29":137},5,"Automatisierung basiert auf eindeutigen Regelungen",{"_110":139,"_112":140,"_124":145},"1338",[141],{"_34":35,"_36":142},[143],{"_39":144,"_34":39},"Stellt die Informationssicherheit sicher, indem sie die Anforderung eines sicheren Verfahrens stellt, das die Authentizität und Integrität der Daten gewährleistet.",{"_65":146,"_29":147},3,"Datenschutz und Informationssicherheit schaffen Vertrauen","Aspekte",[150,304,359,408,471],{"_65":151,"_101":152,"_153":154,"_31":155,"_72":156,"_165":-5,"_166":-5,"_167":168,"_68":-5},"1.1","Ermöglichen Sie digitale Kommunikation und Bearbeitung","Kurzbezeichnung","Digitale Kommunikation","Ermöglichen Sie digitale Kommunikation: Beseitigen Sie Hürden wie Schriftform oder persönliches Erscheinen und bieten Sie alternative Kommunikationswege an.",[157,161],{"_34":35,"_36":158},[159],{"_39":160,"_34":39},"Digital zu kommunizieren bietet viele Vorteile: Anträge und Bescheide können in Echtzeit übermittelt werden, was Wartezeiten für Bürgerinnen, Bürger und Unternehmen verkürzt. Werden Anträge und sonstige Daten digital an die Verwaltung übermittelt, können sie außerdem effizient digital weiterverarbeitet, geprüft und an weitere beteiligte Behörden übermittelt werden.",{"_34":35,"_36":162},[163],{"_39":164,"_34":39},"Digitale Kommunikation sollte immer bedarfsorientiert und inklusiv sein – in bestimmten Fällen kann z. B. ergänzend auch die Schriftform sinnvoll sein, sofern eine digitale Weiterverarbeitung sichergestellt ist. Bürgerinnen und Bürger, die keine digitalen Angebote nutzen können oder wollen, müssen dabei auch bedacht werden.","Leitfragen","Formulierungsbeispiel","Anwendung",[169,194,266,293],{"_101":170,"_112":171,"_166":-5,"_68":183},"Prüfen Sie Schriftformerfordernisse",[172,179],{"_34":35,"_36":173},[174,177],{"_175":13,"_39":176,"_34":39},"bold","Bevor Sie die Schriftform als erforderlich festlegen",{"_39":178,"_34":39},", prüfen Sie kritisch, ob elektronische Verfahren nicht bereits ausreichend Übereilungsschutz bieten und die Beweisfunktion sicherstellen.",{"_34":35,"_36":180},[181],{"_39":182,"_34":39},"Hintergrund: Ausdrucken, Unterschreiben, Versenden und Archivieren führen in digitalen Prozessen zu unnötigen Verzögerungen und Kosten.",{"_27":184,"_65":64,"_72":185,"_190":-5,"_96":191},"rdfocmyt6wqirzqsmwjgz9vo",[186],{"_34":35,"_36":187},[188],{"_39":189,"_34":39,"_78":13},"Schriftlich einzureichende Anträge und Erklärungen sowie sonstige Schriftsätze und deren Anlagen können nach Maßgabe der folgenden Absätze als elektronische Dokumente beim Bundesverfassungsgericht eingereicht werden.[1]","Auszug",{"_65":192,"_99":193,"_101":-5},"23a","BVerfGG",{"_101":195,"_112":196,"_166":-5,"_68":-5},"Vermeiden Sie persönliches Erscheinen ",[197,201,205,211,240,253,259,263],{"_34":35,"_36":198},[199],{"_39":200,"_34":39},"Das persönliche Erscheinen kann erforderlich werden, wenn die Identität einer Person festgestellt werden muss, eine Erklärung nicht delegierbar ist oder eine Belehrung/Beratung im direkten Gespräch notwendig ist.",{"_34":35,"_36":202},[203],{"_39":204,"_34":39},"Empfehlung: Ermöglichen Sie, dass gleichwertige digitale Verfahren zugelassen sind:",{"_34":46,"_47":48,"_36":206},[207],{"_34":51,"_36":208},[209],{"_39":210,"_34":39},"Die Online-Ausweisfunktion bzw. ein Nutzerkonto ermöglicht eine Identitätsprüfung. Ein Verweis auf das OZG-Nutzerkonto findet sich in § 1131 Abs. 1 ZPO.",{"_34":46,"_47":48,"_36":212},[213],{"_34":51,"_36":214},[215,217,224,226,231,233,238],{"_39":216,"_34":39},"Die ",{"_218":219,"_34":220,"_36":221},"url","https://www.elektronische-vertrauensdienste.de/EVD/DE/Uebersicht_eVD/Dienste/1_Signatur.html?nn=691386","link",[222],{"_39":223,"_34":39},"Qualifizierte Elektronische Signatur",{"_39":225,"_34":39}," entspricht der handschriftlichen Unterschrift, vgl. ",{"_218":227,"_34":220,"_36":228},"https://eur-lex.europa.eu/legal-content/DE/TXT/PDF/?uri=CELEX:32014R0910",[229],{"_39":230,"_34":39},"Artikel 25 Abs. 2",{"_39":232,"_34":39}," eIDAS-Verordnung. Sie ersetzt etwa in den Bereichen des Verwaltungsverfahrensgesetz nach Anwendung von ",{"_218":234,"_34":220,"_36":235},"https://www.gesetze-im-internet.de/vwvfg/__3a.html",[236],{"_39":237,"_34":39},"§ 3a VwVfG",{"_39":239,"_34":39}," die Schriftform.",{"_34":46,"_47":48,"_36":241},[242],{"_34":51,"_36":243},[244,246,251],{"_39":245,"_34":39},"Sichere Zustellung kann durch elektronische Postfächer erfolgen. Ein Beispiel findet sich in ",{"_218":247,"_34":220,"_36":248},"https://digitalcheck.bund.de/beispiele/prinzipien/digitale-angebote-fuer-alle-nutzbar-gestalten#absatz-g6pdcvhx2a4cleuywyb0fbuu",[249],{"_39":250,"_34":39},"§ 1131 ZPO",{"_39":252,"_34":39},".",{"_34":35,"_36":254},[255,257],{"_175":13,"_39":256,"_34":39},"Interoperabilität:",{"_39":258,"_34":39}," Prüfen Sie, ob die eingesetzten Verfahren der eIDAS-2.0-Verordnung [1] entsprechen. Identifizierungssysteme müssen interoperabel sein und EU-weit gegenseitig anerkannt sein. Die Verordnung betrifft elektronische Signaturen, Siegel, Zeitstempel, Dokumente, Zustellung digitaler Einschreiben sowie Website-Authentifizierung.",{"_34":35,"_36":260},[261],{"_39":262,"_34":39},"[1] Verordnung (EU) Nr. 910/2014 über elektronische Identifizierung und Vertrauensdienste für elektronische Transaktionen im Binnenmarkt und zur Aufhebung der Richtlinie 1999/93/EG, zuletzt geändert durch Verordnung (EU) Nr. 2024/1183.",{"_34":35,"_36":264},[265],{"_39":21,"_34":39},{"_101":267,"_112":268,"_166":273,"_68":-5},"Dokumente nur nach Bedarf anfordern",[269],{"_34":35,"_36":270},[271],{"_39":272,"_34":39},"Prüfen Sie, ob eine Vorlagepflicht durch eine Vorhaltepflicht ersetzt werden kann oder sogar komplett entfallen kann.",[274,283],{"_34":35,"_36":275},[276,279,281],{"_39":277,"_34":39,"_278":13},"Der Antragsteller hat die Belege für die Dauer von [X] Jahren ","italic",{"_175":13,"_39":280,"_34":39,"_278":13},"aufzubewahren",{"_39":282,"_34":39,"_278":13}," und der Behörde auf Verlangen für eine Prüfung zugänglich zu machen.",{"_34":35,"_36":284},[285,287,292],{"_39":286,"_34":39},"Analog zu: ",{"_218":288,"_34":220,"_36":289},"https://www.gesetze-im-internet.de/estdv_1955/__50.html",[290],{"_39":291,"_34":39},"§ 50 Abs. 8 EStDV",{"_39":21,"_34":39},{"_101":294,"_112":295,"_166":-5,"_68":-5},"Ermöglichen Sie weiterhin alternative Kommunikationswege",[296,300],{"_34":35,"_36":297},[298],{"_39":299,"_34":39},"Für Unternehmen kann eine rein digitale Kommunikation vorgeschrieben werden.",{"_34":35,"_36":301},[302],{"_39":303,"_34":39},"Denken Sie bei Privatpersonen an Bürgerinnen und Bürger, die keine digitalen Angebote nutzen können oder wollen.",{"_65":305,"_101":306,"_153":307,"_31":308,"_72":309,"_165":-5,"_166":329,"_167":338,"_68":339},"1.2","Formulieren Sie die Regelung technologieoffen","Technologieoffenheit","Formulieren Sie die Regelungen technologieoffen: Stellen Sie sicher, dass Vorschriften nicht an spezifische technische Lösungen gebunden sind, um die Nutzung etablierter oder zukünftiger Technologien zu ermöglichen.",[310,314,318],{"_34":35,"_36":311},[312],{"_175":13,"_39":313,"_34":39},"Prüfen Sie, ob die Nennung spezifischer Technologien notwendig bzw. gerechtfertigt ist.",{"_34":35,"_36":315},[316],{"_39":317,"_34":39},"Wenn Sie Übertragungswege – wie DE-Mail oder PDF – festlegen, riskieren Sie, dass Ihre Regelung bald nicht mehr dem Stand der Technik entspricht.",{"_34":35,"_36":319},[320,322,327],{"_39":321,"_34":39},"Andererseits kann die Nutzung etablierter Basisdienste die Umsetzung erleichtern und die Anwendung für Nutzende vereinfachen – im Sinne des Prinzips „",{"_218":323,"_34":220,"_36":324},"https://digitalcheck.bund.de/methoden/fuenf-prinzipien/etablierte-technologien-ermoeglichen-effiziente-umsetzung",[325],{"_39":326,"_34":39},"Etablierte Technologien ermöglichen effiziente Umsetzung",{"_39":328,"_34":39},"“. Ob das sinnvoll ist, hängt vom konkreten Einzelfall ab.",[330],{"_34":35,"_36":331},[332,334,336],{"_39":333,"_34":39,"_278":13},"„Der Antrag ist elektronisch oder schriftlich zu stellen.“",{"_39":335,"_34":39}," oder ",{"_39":337,"_34":39,"_278":13},"„Der Antrag ist zu stellen.“",[],{"_27":340,"_65":136,"_72":341,"_96":352},"eed54a9k0yrk07n6317zk0o8",[342],{"_34":35,"_36":343},[344,346,348,350],{"_39":345,"_34":39,"_78":13},"Das Luftfahrt-Bundesamt übermittelt jedem Betreiber nach Absatz 1 Satz 1 elektronisch eine Registrierungsnummer[1]",{"_39":347,"_34":39},", die für alle von ihm nach Absatz 1 Satz 1 betriebenen unbemannten Fluggeräte gilt und dem Luftfahrt-Bundesamt eine individuelle Identifizierung des Betreibers nach Artikel 14 der Durchführungsverordnung (EU) 2019/947 ermöglicht. ",{"_39":349,"_34":39,"_78":13},"Das Luftfahrt-Bundesamt kann die Registrierung eines Betreibers eines unbemannten Fluggerätes für den Betrieb in den Betriebskategorien „offen“ und „speziell“ durch automatische Einrichtungen bestätigen, sofern kein Anlass besteht, den Einzelfall durch Amtsträger zu bearbeiten[5]",{"_39":351,"_34":39},"; Absatz 3 Satz 4 bis 6 gilt entsprechend. Das Luftfahrt-Bundesamt stellt sicher, dass das Register insbesondere den Vorgaben der Artikel 24, 25 und 32 der Verordnung (EU) 2016/679 entspricht.",{"_65":353,"_99":354,"_101":355,"_103":356},"66a","LuftVG","Register über Betreiber von unbemannten Fluggeräten",{"_66":357,"_101":358},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","Register über Betreiber von unbemannten Fluggeräten – LuftVG",{"_65":360,"_101":361,"_153":362,"_31":363,"_72":364,"_165":-5,"_166":-5,"_167":369,"_68":-5},"1.3","Denken Sie an Antragsstellung, Bearbeitung und Bescheid","Antragsprozess beachten","Denken Sie an Antragsstellung, Bearbeitung und Bescheid: Planen Sie den vollständigen Lebenszyklus der Daten, damit diese durchgehend digital verarbeitet werden können und ihre Qualität im Prozess gesichert wird.",[365],{"_34":35,"_36":366},[367],{"_39":368,"_34":39},"Für eine erfolreiche Digitalisierung ist es wichtig, dass Sie den gesamten Prozess des Vollzugs Ihrer Regelung betrachten. Dies verhindert Logik- und Medienbrüche.",[370,387],{"_101":371,"_112":372,"_166":-5,"_68":-5},"Räumen Sie verwaltungsinterne Medienbrüche aus und vereinfachen Sie Prozesse",[373,377,381],{"_34":35,"_36":374},[375],{"_39":376,"_34":39},"Hierzu kann es hilfreich sein, die Technologien und Verfahren der umsetzenden Behörden zu erheben. Nutzen Sie hierfür z. B. eine Visualisierung. Prüfen Sie, inwiefern bisher analog gespeicherte Daten stattdessen digital gespeichert werden können.",{"_34":35,"_36":378},[379],{"_39":380,"_34":39},"Beziehen Sie den gesamten Prozess in die Gestaltung der Regelung mit ein: Welche Informationen werden von wem an wen übermittelt? Wirkt sich die Regelung auch auf verwaltungsinterne Kommunikation oder den Austausch zwischen Behörden und Unternehmen aus?",{"_34":35,"_36":382},[383,385],{"_175":13,"_39":384,"_34":39},"Vorteile:",{"_39":386,"_34":39}," Digital erfasste Daten direkt digital weiterzuverarbeiten, spart Zeit, weil Informationen nicht eingescannt oder abgetippt werden müssen. Digitale Oberflächen, die für Nutzende zusätzliche Hilfestellungen und Kontrollen enthalten, erhöhen die Qualität der Daten. ",{"_101":388,"_112":389,"_166":-5,"_68":-5},"Ermöglichen Sie automatische Kontrollen (z. B. Plausibilitätsprüfungen)",[390,394,398],{"_34":35,"_36":391},[392],{"_39":393,"_34":39},"Sogenannte Plausibilitätsprüfungen kontrollieren, ob Ort und Postleitzahl zusammenpassen oder ob ein angegebener Zeitraum antragsberechtigt ist. Dies reduziert vermeidbare Fehler in Anträgen, die ansonsten oft zeitaufwändige Rückfragen nach sich ziehen.",{"_34":35,"_36":395},[396],{"_39":397,"_34":39},"Hierbei helfen",{"_34":46,"_47":48,"_36":399},[400,404],{"_34":51,"_36":401},[402],{"_39":403,"_34":39},"die Nutzung bestehender Standards entsprechend dem Prinzip Datenwiederverwendung benötigt einheitliches Recht sowie",{"_34":51,"_36":405},[406],{"_39":407,"_34":39},"Codelisten.",{"_65":409,"_101":410,"_153":411,"_31":412,"_72":413,"_165":425,"_166":432,"_167":457,"_68":-5},"1.4","Denken Sie Barrierefreiheit von Anfang an mit","Barrierefreiheit","Denken Sie Barrierefreiheit von Anfang an mit: Gestalten Sie das digitale Angebot so, dass es ohne jegliche Hürden von allen Nutzenden, unabhängig von ihren individuellen Bedürfnissen, uneingeschränkt genutzt werden kann.",[414],{"_34":35,"_36":415},[416,418,423],{"_39":417,"_34":39},"Digitale Angebote müssen nach ",{"_218":419,"_34":220,"_36":420},"https://www.gesetze-im-internet.de/bgg/__12a.html",[421],{"_39":422,"_34":39},"§ 12 a Behindertengleichstellungsgesetz",{"_39":424,"_34":39}," barrierefrei sein. Barrierefrei bedeutet, dass Menschen mit und ohne Behinderung das Angebot in gleicher Weise nutzen können. Da es viele unterschiedliche Arten von Behinderungen gibt, müssen viele Aspekte beachtet werden. Etwa die Aufbereitung für blinde und sehbehinderte Menschen oder Angebote in deutscher Gebärdensprache oder leichter Sprache.",[426],{"_34":46,"_47":48,"_36":427},[428],{"_34":51,"_36":429},[430],{"_39":431,"_34":39},"Haben Sie die Bedürfnisse von Menschen mit unterschiedlichen Arten von Behinderungen berücksichtigt?",[433],{"_34":46,"_47":48,"_36":434},[435,446],{"_34":51,"_36":436},[437,439,444],{"_39":438,"_34":39},"\"Die Beratung erfolgt in einer für den Leistungsberechtigten wahrnehmbaren Form\" (",{"_218":440,"_34":220,"_36":441},"https://www.gesetze-im-internet.de/sgb_9_2018/__106.html",[442],{"_39":443,"_34":39},"§ 106 Abs. 1 SGB IX",{"_39":445,"_34":39},"). So eine Formulierung muss in einer Verordnung ausgestaltet werden.",{"_34":51,"_36":447},[448,450,455],{"_39":449,"_34":39},"[...] nach dem Stand der Technik auch die erforderlichen technischen und organisatorischen Verfahren festzulegen oder technischen Voraussetzungen zu schaffen dafür, dass [...] Daten [...] barrierefrei zur Verfügung gestellt und [...] barrierefrei verarbeitet werden können [...] (",{"_218":451,"_34":220,"_36":452},"https://www.gesetze-im-internet.de/sgb_5/__354.html",[453],{"_39":454,"_34":39},"§ 354 SGB V",{"_39":456,"_34":39},")",[458],{"_101":459,"_112":460,"_166":-5,"_68":-5},"Falls anwendbar: Prüfen Sie, welche Regelwerke für die Umsetzung digitaler Barrierefreiheit für Ihr Vorhaben relevant sind.",[461],{"_34":35,"_36":462},[463,465,470],{"_39":464,"_34":39},"Nutzen Sie dafür beispielsweise den ",{"_218":466,"_34":220,"_36":467},"https://www.barrierefreiheit-dienstekonsolidierung.bund.de/Webs/PB/DE/standardanforderungskatalog/standardanforderungskatalog-node.html",[468],{"_39":469,"_34":39},"Standardanforderungskatalog",{"_39":252,"_34":39},{"_65":472,"_101":473,"_153":474,"_31":475,"_72":476,"_165":481,"_166":-5,"_167":499,"_68":500},"1.5","Stellen Sie eine nutzerfreundliche Umsetzung sicher","Nutzerfreundlichkeit","Stellen Sie eine nutzerfreundliche Umsetzung sicher: Sorgen Sie für eine an den Nutzenden orientierte Entwicklung, die eine einfache, intuitive und zugängliche Interaktion mit dem digitalen Angebot gewährleistet.",[477],{"_34":35,"_36":478},[479],{"_39":480,"_34":39},"Barrierearme Angebote sind oft auch nutzerfreundlicher. Darüber hinaus macht eine nutzerzentrierte Entwicklung, die z. B. in kleinen Schritten agiert und Texte in einfacher Sprache oder mehrsprachig gestaltet, ihr Angebot zugänglicher.",[482],{"_34":46,"_47":48,"_36":483},[484,488],{"_34":51,"_36":485},[486],{"_39":487,"_34":39},"Was ist die wichtigste Aufgabe aus Sicht der Nutzenden?",{"_34":51,"_36":489},[490,492,497],{"_39":491,"_34":39},"Ergeben sich für den Vollzug Anforderungen aus dem ",{"_218":493,"_34":220,"_36":494},"https://servicestandard.gov.de/",[495],{"_39":496,"_34":39},"Servicestandard",{"_39":498,"_34":39}," an? Dieser stellt eine nutzerzentrierte Entwicklung sicher. Er unterstützt umsetzende Akteure dabei, die verbindlichen Qualitätsanforderungen zu erfüllen.",[],{"_27":501,"_65":146,"_72":502,"_96":509},"yaa803r10yjs4h9ay4srsb84",[503],{"_34":35,"_36":504},[505,507],{"_39":506,"_34":39},"Die nach Absatz 2 entwickelte Kommunikationsplattform ist über ein Justizportal des Bundes und der Länder für die Nutzer bereitzustellen. ",{"_39":508,"_34":39,"_78":13},"Sie ist nach Maßgabe der Barrierefreie-Informationstechnik-Verordnung barrierefrei zu gestalten. Ferner ist bei der Gestaltung der Kommunikationsplattform deren Nutzerfreundlichkeit sowie eine einfache und intuitive Bedienbarkeit sicherzustellen.[1]",{"_65":510,"_99":100,"_101":511,"_103":512},"1130","Entwicklung und Bereitstellung; Verordnungsermächtigungen",{"_66":105,"_101":106},"prinzipList",[515,516,519,521,524],{"_29":30,"_66":67,"_63":64},{"_29":517,"_66":518,"_63":71},"Datenwiederverwendung benötigt einheitliches Recht","datenwiederverwendung-benoetigt-einheitliches-recht",{"_29":326,"_66":520,"_63":146},"etablierte-technologien-ermoeglichen-effiziente-umsetzung",{"_29":137,"_66":522,"_63":523},"automatisierung-basiert-auf-eindeutigen-regelungen",4,{"_29":147,"_66":525,"_63":136},"datenschutz-und-informationssicherheit-schaffen-vertrauen"]
