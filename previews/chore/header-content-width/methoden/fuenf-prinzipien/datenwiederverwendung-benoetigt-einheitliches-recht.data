[{"_1":2,"_21":22},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_19":20},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/methoden.fuenf-prinzipien.$prinzip",{"_3":23},{"_24":25,"_433":434},"prinzip",{"_26":27,"_28":29,"_30":31,"_49":50,"_51":50,"_52":53,"_54":55,"_112":113},"documentId","s18bibg9sdf0jt8up7h8btup","Name","Datenwiederverwendung benötigt einheitliches Recht","Beschreibung",[32],{"_33":34,"_35":36},"type","paragraph","children",[37,40,47],{"_38":39,"_33":38},"text","Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_41":42,"_33":43,"_35":44},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[45],{"_38":46,"_33":38},"Once-Only-Prinzip",{"_38":48,"_33":38}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","order",2,"Nummer","URLBezeichnung","datenwiederverwendung-benoetigt-einheitliches-recht","Beispiel",{"_26":56,"_51":57,"_58":59,"_81":82,"_92":93},"hpcdwgmccb8r01rbouf3u8ok",1,"Text",[60,67],{"_33":34,"_35":61},[62,65],{"_38":63,"_33":38,"_64":13},"Für einen effizienten Registerbetrieb gleicht das Umweltbundesamt die im Herkunftsnachweisregister für Gas und die im Herkunftsnachweisregister für Wärme oder Kälte gespeicherten Daten, einschließlich personenbezogener Daten, miteinander ab und tauscht sie zwischen diesen Registern aus[2]","underline",{"_38":66,"_33":38}," im Hinblick auf die Erzeugung von",{"_33":68,"_69":70,"_35":71},"list","format","ordered",[72,77],{"_33":73,"_35":74},"list-item",[75],{"_38":76,"_33":38},"Gas aus oder auf Basis von thermischer Energie sowie",{"_33":73,"_35":78},[79],{"_38":80,"_33":38},"thermischer Energie aus Gas aus oder auf Basis von erneuerbarer Energie oder kohlenstoffarmem Gas.","Paragraph",{"_51":83,"_84":85,"_86":87,"_88":89},"39","Gesetz","GWKH","Titel","Überprüfung der gespeicherten Daten; Datenübermittlung","Beispielvorhaben",{"_52":90,"_86":91},"einrichtung-herkunftsnachweisregister-fuer-gas-waerme-und-kaelte-gwkhv","Einrichtung Herkunftsnachweisregister für Gas, Wärme und Kälte  - GWKHV","PrinzipErfuellungen",[94],{"_95":96,"_97":98,"_110":111},"id","1402","Erklaerung",[99],{"_33":68,"_69":100,"_35":101},"unordered",[102,106],{"_33":73,"_35":103},[104],{"_38":105,"_33":38},"Verringert die Fehleranfälligkeit durch den Datenabgleich.",{"_33":73,"_35":107},[108],{"_38":109,"_33":38},"Im folgenden Absatz wird der Abgleich und Austausch der Daten näher spezifiziert und erweitert.  ","Prinzip",{"_51":50,"_28":29},"Aspekte",[114,251,303,341,407],{"_51":115,"_86":116,"_117":118,"_30":119,"_58":120,"_132":133,"_144":-5,"_145":146,"_54":-5},"2.1","Nutzen Sie harmonisierte Rechtsbegriffe","Kurzbezeichnung","Harmonisierung von Rechtsbegriffen","Nutzen Sie harmonisierte Rechtsbegriffe: Verwenden Sie konsistente und abgestimmte Begriffe im Recht, um die Grundlage für einen reibungslosen, datenschutzkonformen Datenaustausch zu schaffen.",[121,125,129],{"_33":34,"_35":122},[123],{"_38":124,"_33":38},"Um wiederverwendet zu werden, müssen Daten die gleiche inhaltliche Bedeutung haben, d. h. semantisch interoperabel sein. Dafür müssen die Rechtsbegriffe einheitlich definiert und verwendet werden.",{"_33":34,"_35":126},[127],{"_38":128,"_33":38},"Es kann nötig sein, Begriffe über Ihren Rechtsbereich hinaus zu harmonisieren, um bestehende Daten zu verwenden. Ist dies nicht möglich, können Sie die Informationen möglicherweise aus verschiedenen Datenpunkten zusammensetzen, etwa das Einkommen aus Gehalt und weiteren Einnahmen.",{"_33":34,"_35":130},[131],{"_38":20,"_33":38},"Leitfragen",[134],{"_33":68,"_69":100,"_35":135},[136,140],{"_33":73,"_35":137},[138],{"_38":139,"_33":38},"Haben diese Begriffe innerhalb und außerhalb Ihres Rechtsbereichs die gleiche Bedeutung? Ist eine übergreifende Harmonisierung nötig?",{"_33":73,"_35":141},[142],{"_38":143,"_33":38},"Haben Sie die Konsistenz zu Regelwerken der EU und von anderen EU-Staaten betrachtet?","Formulierungsbeispiel","Anwendung",[147,197],{"_86":148,"_97":149,"_144":-5,"_54":-5},"Greifen Sie über (Teil-)Verweise auf bestehende Definitionen zurück",[150,154,170,174],{"_33":34,"_35":151},[152],{"_38":153,"_33":38},"Werden für Begriffe, die in mehreren Regelungen vorkommen (z. B. \"Einkommen\", \"Kind\"), Verweise genutzt, macht dies die Begriffe eindeutiger. Dies vereinfacht den Datenaustausch, da der entsprechende Datensatz direkt bei der datenhaltenden Behörde abgefragt werden kann. ",{"_33":34,"_35":155},[156,158,163,165,168],{"_38":157,"_33":38},"Eine ausführliche Erklärung finden Sie im ",{"_41":159,"_33":43,"_35":160},"https://www.normenkontrollrat.bund.de/Webs/NKR/DE/veroeffentlichungen/gutachten/_documents/2020-06-digitale-verwaltung-braucht-digitaltaugliches-recht.html",[161],{"_38":162,"_33":38},"Gutachten zum modularen Einkommensbegriff des Nationalen Normenkontrollrats (NKR)",{"_38":164,"_33":38},", Abschnitt „",{"_38":166,"_33":38,"_167":13},"Harmonisierung durch Verweise","italic",{"_38":169,"_33":38},"”, S. 96ff.",{"_33":34,"_35":171},[172],{"_38":173,"_33":38},"Weitere Ressourcen:",{"_33":68,"_69":100,"_35":175},[176,187],{"_33":73,"_35":177},[178,180,185],{"_38":179,"_33":38},"Codelisten: standardisierte, feste Listen von Codes und ihren zugehörigen Klartextbezeichnungen, die zur eindeutigen und maschinenlesbaren Darstellung von Informationen (wie Staaten, Verwaltungsleistungen oder Merkmale) in digitalen Verwaltungsprozessen dienen. Sie finden diese auf der ",{"_41":181,"_33":43,"_35":182},"https://docs.fitko.de/fim/docs/leistungen_neu/technik/codelisten/",[183],{"_38":184,"_33":38},"Seite der FITKO",{"_38":186,"_33":38},".",{"_33":73,"_35":188},[189,191,196],{"_38":190,"_33":38},"Das auf EU-Ebene vereinheitlichte Vokabular zu Begriffen im Kontext der öffentlichen Verwaltung: ",{"_41":192,"_33":43,"_35":193},"http://interoperable-europe.ec.europa.eu",[194],{"_38":195,"_33":38},"Interoperable Europe Portal",{"_38":186,"_33":38},{"_86":198,"_97":199,"_144":-5,"_54":-5},"Nutzen Sie modularisierte Begriffe",[200,206,215,219,241],{"_33":34,"_35":201},[202,204],{"_38":203,"_33":38,"_167":13},"Modularisierung",{"_38":205,"_33":38}," kann bei komplexen Begriffen wie Einkommen helfen: Rechtsbegriffe werden in standardisierte, klar definierte Module zerlegt. Die so erhobenen Bestandteile können je nach Bedarf neu zusammengesetzt und nachgenutzt werden, etwa das Einkommen aus Gehalt und weiteren Einnahmen.",{"_33":34,"_35":207},[208,210,213],{"_38":209,"_33":38},"Weiterführende Empfehlungen finden Sie im ",{"_41":159,"_33":43,"_35":211},[212],{"_38":162,"_33":38},{"_38":214,"_33":38},", S. 93ff:",{"_33":34,"_35":216},[217],{"_38":218,"_33":38},"Die Modularisierung des Einkommensbegriffes bietet folgende Vorteile:",{"_33":68,"_69":100,"_35":220},[221,225,229,233,237],{"_33":73,"_35":222},[223],{"_38":224,"_33":38},"Sie sichert die einheitliche sprachliche (eindeutige) Verwendung von Begrifflichkeiten.",{"_33":73,"_35":226},[227],{"_38":228,"_33":38},"Der Begriff erhält eine klar ersichtliche Struktur, die sich in Datenstrukturen abbilden lässt.",{"_33":73,"_35":230},[231],{"_38":232,"_33":38},"Eindeutig bezeichnete Module können einen Anknüpfungspunkt für Verweise bilden.",{"_33":73,"_35":234},[235],{"_38":236,"_33":38},"Sie zwingt nicht zur weiteren Harmonisierung.",{"_33":73,"_35":238},[239],{"_38":240,"_33":38},"Sie fördert die digitaltaugliche Ausgestaltung des Begriffes und ermöglicht es, die (Sub-)Module in Datenmodule und Datenfelder zu übersetzen.",{"_33":34,"_35":242},[243,245,249],{"_38":244,"_33":38},"Quelle: ",{"_41":159,"_33":43,"_35":246},[247],{"_38":248,"_33":38},"NKR-Gutachten \"Digitale Verwaltung braucht digitaltaugliches Recht\"",{"_38":250,"_33":38},", S. 93ff.",{"_51":252,"_86":253,"_117":254,"_30":255,"_58":256,"_132":261,"_144":-5,"_145":285,"_54":286},"2.2","Nutzen Sie existierende Daten","Existierende Daten","Nutzen Sie existierende Daten: Wenden Sie das Once-Only-Prinzip konsequent an, damit Nutzende Daten nur einmal angeben müssen und so Kosten und Zeit gespart werden.",[257],{"_33":34,"_35":258},[259],{"_38":260,"_33":38},"Überprüfen Sie, ob Daten schon an anderer Stelle zur Verfügung stehen und genutzt werden können. Optimalerweise wird auf die Originaldaten zugegriffen, statt diese zu kopieren. Für einen Datenaustausch zwischen Behörden müssen Sie dann eine geeignete Rechtsgrundlage schaffen.",[262],{"_33":68,"_69":100,"_35":263},[264,281],{"_33":73,"_35":265},[266,268,273,275,280],{"_38":267,"_33":38},"Können existierende verwaltungsinterne oder öffentliche Daten wiederverwendet werden? Recherchieren Sie u. a. auf ",{"_41":269,"_33":43,"_35":270},"https://www.verwaltungsdaten-informationsplattform.de/",[271],{"_38":272,"_33":38},"verwaltungsdaten-informationsplattform.de",{"_38":274,"_33":38}," oder ",{"_41":276,"_33":43,"_35":277},"https://data.gov.de/",[278],{"_38":279,"_33":38},"data.gov.de",{"_38":186,"_33":38},{"_33":73,"_35":282},[283],{"_38":284,"_33":38},"Genügen die Daten den Anforderungen an Qualität und Aktualität oder sollten Kontrolldaten erhoben werden? Stehen Löschfristen einer Nachnutzung im Wege?",[],{"_26":287,"_51":288,"_58":289,"_81":296},"aeym55q2neygiz4irjpf8bll",3,[290],{"_33":34,"_35":291},[292,294],{"_38":293,"_33":38},"Anbieter sind verpflichtet, der Bundesnetzagentur die Informationen nach Absatz 2 auf Anforderung zu übermitteln. Die Bundesnetzagentur kann durch Allgemeinverfügung geeignete Vorgaben machen, in welcher Form, in welchem technischen Format und in welchem Detailgrad die Informationen nach Absatz 2 zu übermitteln sind und in welchen Zeitintervallen die Informationen zu aktualisieren sind. ",{"_38":295,"_33":38,"_64":13},"Soweit möglich greift die Bundesnetzagentur auf die Daten, die ihr nach § 10 Absatz 1 übermittelt werden, zurück.[2]",{"_51":297,"_84":298,"_86":299,"_88":300},"11","PostG","Digitaler Atlas zur Postversorgung, Verordnungsermächtigung",{"_52":301,"_86":302},"modernisierung-des-postrechts","Modernisierung des Postrechts – PostG",{"_51":304,"_86":305,"_117":306,"_30":307,"_58":308,"_132":313,"_144":-5,"_145":328,"_54":329},"2.3","Machen Sie erhobene Daten für andere nutzbar","Datenoffenheit","Machen Sie erhobene Daten für andere nutzbar: Ermöglichen Sie den datenschutzkonformen Zugriff und die Wiederverwendung von Daten, um Synergien zu schaffen und mehrfachen Erhebungsaufwand zu vermeiden.",[309],{"_33":34,"_35":310},[311],{"_38":312,"_33":38},"Müssen neue Daten erhoben werden, sollten Sie eine Nachnutzung dieser Daten ermöglichen.",[314],{"_33":68,"_69":100,"_35":315},[316,320,324],{"_33":73,"_35":317},[318],{"_38":319,"_33":38},"Stehen der Nachnutzung der Daten rechtliche Beschränkungen im Weg? Können erhobene Daten sogar öffentlich geteilt werden?",{"_33":73,"_35":321},[322],{"_38":323,"_33":38},"Wie werden die Daten verwaltet? Sind die Verantwortlichkeiten klar?",{"_33":73,"_35":325},[326],{"_38":327,"_33":38},"Ist ein transeuropäischer Datenaustausch möglich? Gibt es passende Lizenzmodelle?",[],{"_26":330,"_51":331,"_58":332,"_81":339},"sdtovch52centy3wu4grz3ko",5,[333],{"_33":34,"_35":334},[335,337],{"_38":336,"_33":38,"_64":13},"Das Umweltbundesamt richtet eine elektronische Schnittstelle ein, die es ermöglicht, Daten an die nach Landesrecht zuständigen Behörden zu übermitteln[2]",{"_38":338,"_33":38},", soweit es für den Vollzug des Gebäudeenergiegesetzes vom 8. August 2020 (BGBl. I S. 1728), das durch Artikel 1 des Gesetzes vom 16. Oktober 2023 (BGBl. 2023 I Nr. 280) geändert worden ist, erforderlich ist. Absatz 4 Satz 2 bis 5 ist entsprechend anzuwenden.",{"_51":83,"_84":85,"_86":87,"_88":340},{"_52":90,"_86":91},{"_51":342,"_86":343,"_117":344,"_30":345,"_58":346,"_132":382,"_144":-5,"_145":393,"_54":394},"2.4","Nutzen Sie bestehende technische Standards","Technische Standards","Nutzen Sie bestehende technische Standards: Greifen Sie auf etablierte technische Vorgaben zurück, um die Kompatibilität von Systemen zu gewährleisten und einen effizienten Datenaustausch zu fördern.",[347,351],{"_33":34,"_35":348},[349],{"_38":350,"_33":38},"Nutzen Sie geeignete technische Standards, wie z. B. Datenaustauschformate, um den Austausch zwischen IT-Systemen zu begünstigen. Möglicherweise ist es sinnvoll, diese in der Regelung vorzuschreiben.",{"_33":34,"_35":352},[353,355,360,362,367,369,374,376,381],{"_38":354,"_33":38},"Informationen zu Standards der öffentlichen Verwaltung erhalten Sie bei der ",{"_41":356,"_33":43,"_35":357},"https://www.fitko.de/",[358],{"_38":359,"_33":38},"FITKO",{"_38":361,"_33":38},", auf den Seiten des ",{"_41":363,"_33":43,"_35":364},"https://www.xoev.de/",[365],{"_38":366,"_33":38},"XÖV",{"_38":368,"_33":38}," mit zugehörigem ",{"_41":370,"_33":43,"_35":371},"https://www.xrepository.de/",[372],{"_38":373,"_33":38},"XRepository",{"_38":375,"_33":38}," und auf der ",{"_41":377,"_33":43,"_35":378},"https://www.verwaltungsdaten-informationsplattform.de",[379],{"_38":380,"_33":38},"Verwaltungsdaten-Informationsplattform",{"_38":186,"_33":38},[383],{"_33":68,"_69":100,"_35":384},[385,389],{"_33":73,"_35":386},[387],{"_38":388,"_33":38},"Welche Datenformate existieren bereits? Muss gegebenenfalls ein neuer Standard entwickelt oder ein bestehender Standard erweitert werden?",{"_33":73,"_35":390},[391],{"_38":392,"_33":38},"Wurde beachtet, wie die Daten übertragen werden sollen?",[],{"_26":395,"_51":50,"_58":396,"_81":401},"t0037mojhj4ibwqs1d5zleq9",[397],{"_33":34,"_35":398},[399],{"_38":400,"_33":38,"_64":13},"Das elektronische Dokument muss für die Bearbeitung durch das Bundesverfassungsgericht geeignet sein. Für die Übermittlung und die Eignung zur Bearbeitung durch das Bundesverfassungsgericht gelten die in der Elektronischer-Rechtsverkehr-Verordnung geregelten technischen Rahmenbedingungen des elektronischen Rechtsverkehrs entsprechend.[2]",{"_51":402,"_84":403,"_86":-5,"_88":404},"23a","BVerfGG",{"_52":405,"_86":406},"elektronischer-rechtsverkehr-mit-dem-bundesverfassungsgericht-b-verf-g","Elektronischer Rechtsverkehr mit dem Bundesverfassungsgericht – BVerfGG",{"_51":408,"_86":409,"_117":410,"_30":411,"_58":412,"_132":417,"_144":-5,"_145":432,"_54":-5},"2.5","Suchen Sie frühzeitig den Austausch mit allen Beteiligten","Austausch","Suchen Sie frühzeitig den Austausch mit allen Beteiligten: Beziehen Sie Normadressaten und umsetzende Behörden frühzeitig in den Prozess ein, um eine kohärente und effiziente Umsetzung der Regelung zu ermöglichen.",[413],{"_33":34,"_35":414},[415],{"_38":416,"_33":38},"Neben rein technischen Voraussetzungen gilt es auch zu beachten, wie sich organisatorische Aspekte auf die Umsetzung Ihres Vorhabens auswirken. Hier hilft der Austausch mit anderen Beteiligten, wie z. B. den Behörden oder IT-Beauftragten.",[418],{"_33":68,"_69":100,"_35":419},[420,424,428],{"_33":73,"_35":421},[422],{"_38":423,"_33":38},"Wie viel Vorlauf benötigen beteiligte Unternehmen, um IT-Systeme anzupassen oder umzustellen?",{"_33":73,"_35":425},[426],{"_38":427,"_33":38},"Wie ist die Erfahrung mit existierenden Systemen?",{"_33":73,"_35":429},[430],{"_38":431,"_33":38},"Besteht die Möglichkeit, im Zuge des Vorhabens auch IT-Verfahren zu modernisieren? Wie können alle Beteiligten davon profitieren?",[],"prinzipList",[435,438,439,442,446],{"_28":436,"_52":437,"_49":57},"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",{"_28":29,"_52":53,"_49":50},{"_28":440,"_52":441,"_49":288},"Etablierte Technologien ermöglichen effiziente Umsetzung","etablierte-technologien-ermoeglichen-effiziente-umsetzung",{"_28":443,"_52":444,"_49":445},"Automatisierung basiert auf eindeutigen Regelungen","automatisierung-basiert-auf-eindeutigen-regelungen",4,{"_28":447,"_52":448,"_49":331},"Datenschutz und Informationssicherheit schaffen Vertrauen","datenschutz-und-informationssicherheit-schaffen-vertrauen"]
