[{"_1":2,"_21":22},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_19":20},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/vorpruefung._preCheckNavigation.$questionId",{"_3":23},{"_24":25,"_26":27},"questionIdx",0,"question",{"_28":29,"_30":31,"_26":32,"_33":34,"_35":36,"_37":38,"_39":40,"_43":44,"_45":46,"_47":48},"id","it-system","title","IT-System","Muss durch die Regelung ein IT-System angepasst oder neu entwickelt werden?","positiveResult","einer Anpassung oder Neuentwicklung einer IT-Lösung.","negativeResult","keiner Anpassung oder Neuentwicklung einer IT-Lösung.","text","**Praxisbeispiel**: Eine Regelung schreibt vor, dass eine Datenbank potentielle Schadstoffe in Lebensmitteln erfasst. Nun kommen neue Inhaltsstoffe dazu. Oder pro Inhaltsstoff müssen weitere Daten zur langfristigen Schädlichkeit erfasst werden. Dafür muss die Datenbank (das IT-System) angepasst werden.","hint",{"_30":41,"_37":42},"Was ist ein IT-System?","IT-Systeme sind technische Lösungen, die aus Hardware (wie Computer, Kartenlesegeräte, Router) oder Software (Programme wie ELSTER und Word, Websiten, Apps) bestehen, um Informationen zu speichern, zu verarbeiten und zu übertragen. \n\nMit ihnen können Aufgaben ausgeführt werden, wie das Übermitteln der Einkommenssteuererklärung mit ELSTER.","url","/vorpruefung/it-system","prevLink","/vorpruefung/hinweise","nextLink","/vorpruefung/verpflichtungen-fuer-beteiligte"]
