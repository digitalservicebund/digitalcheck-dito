[{"_1":2,"_21":22},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_19":20},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/methoden.fuenf-prinzipien.$prinzip",{"_3":23},{"_24":25,"_272":273},"prinzip",{"_26":27,"_28":29,"_30":31,"_49":50,"_51":52,"_53":54,"_55":56,"_92":93},"documentId","habu0yjh39lc5wug5mqsqzaj","Name","Etablierte Technologien ermöglichen effiziente Umsetzung","Beschreibung",[32],{"_33":34,"_35":36},"type","paragraph","children",[37,40,47],{"_38":39,"_33":38},"text","Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_41":42,"_33":43,"_35":44},"url","/#datenschutz-und-informationssicherheit-schaffen-vertrauen","link",[45],{"_38":46,"_33":38},"Sicherheit der Angebote",{"_38":48,"_33":38}," und fördern die Interoperabilität.","order",3,"Nummer",6,"URLBezeichnung","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Beispiel",{"_26":57,"_51":58,"_59":60,"_68":69,"_79":80},"qa6whcwveoqofa32go7qv776",1,"Text",[61],{"_33":34,"_35":62},[63,66],{"_38":64,"_33":38,"_65":13},"Die digitalen Eingabesysteme nach § 1124 Absatz 1 und 2 werden vom Bundesministerium der Justiz als Referenzimplementierung entwickelt und den Ländern zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitgestellt. Die Länder können weitere digitale Eingabesysteme entwickeln und zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitstellen.[6]","underline",{"_38":67,"_33":38}," Das Bundesministerium der Justiz regelt durch Rechtsverordnung mit Zustimmung des Bundesrates die technischen, organisatorischen und datenschutzrechtlichen Rahmenbedingungen für Entwicklung, Betrieb, Pflege und Weiterentwicklung der digitalen Eingabesysteme nach Satz 2.","Paragraph",{"_51":70,"_71":72,"_73":74,"_75":76},"1125","Gesetz","ZPO","Titel","Digitale Eingabesysteme im Online-Verfahren; Verordnungsermächtigung","Beispielvorhaben",{"_53":77,"_73":78},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit","PrinzipErfuellungen",[81],{"_82":83,"_84":85,"_90":91},"id","1358","Erklaerung",[86],{"_33":34,"_35":87},[88],{"_38":89,"_33":38},"Die Entwicklung und bundeseinheitliche Bereitstellung von Referenzimplementierungen fördert die Nutzung etablierter und standardisierter Lösungen.","Prinzip",{"_51":52,"_28":29},"Aspekte",[94,217],{"_51":95,"_73":96,"_97":98,"_30":99,"_59":100,"_116":117,"_168":169,"_187":188,"_55":189},"3.1","Ermöglichen Sie die Nutzung etablierter, öffentlicher Lösungen","Kurzbezeichnung","Vorhandene Lösungen","Ermöglichen Sie die Nutzung etablierter, öffentlicher Lösungen: Nutzen Sie existierende und bewährte technologische Fundamente, um die Entwicklung digitaler Angebote zu beschleunigen und ihre Wirtschaftlichkeit zu steigern.",[101,112],{"_33":34,"_35":102},[103,105,110],{"_38":104,"_33":38},"Lösungen sind u. a. öffentliche Basisdienste, Softwarearchitekturen oder Komponentenbibliotheken. ",{"_41":106,"_33":43,"_35":107},"https://www.digitale-verwaltung.de/Webs/DV/DE/onlinezugangsgesetz/rahmenarchitektur/basisdienste-basiskomponenten/basisdienste-basiskomponenten-node.html",[108],{"_38":109,"_33":38},"Eine Übersicht finden Sie im Rahmen des OZG",{"_38":111,"_33":38},". Die Wiederverwendung existierender Lösungen spart Zeit und verringert den Erfüllungsaufwand für Entwicklung und Betrieb. Einheitliche Systeme, wie z. B. ein nationales Postfach, sind für Nutzende oft einfacher zu bedienen und erleichtern die Zusammenarbeit zwischen Behörden.",{"_33":34,"_35":113},[114],{"_38":115,"_33":38},"Gestalten Sie die Regelung so, dass Sie die Nutzung dieser Lösungen ermöglichen oder sogar vorschreiben. Sollte es keine etablierte Lösung geben, formulieren Sie die Regelung technologieoffen.","Leitfragen",[118],{"_33":119,"_120":121,"_35":122},"list","format","unordered",[123,128,132,157],{"_33":124,"_35":125},"list-item",[126],{"_38":127,"_33":38},"Wie viel Spielraum bzw. Standardisierung brauchen die umsetzenden Akteurinnen und Akteuren? Das hängt auch davon ab, ob Sie an einem Gesetz oder einer Verordnung arbeiten.",{"_33":124,"_35":129},[130],{"_38":131,"_33":38},"Existieren für die beschriebenen digitalen Prozesse bereits etablierte, technische Lösungen? Ermöglicht die Regelung die Nutzung dieser Systeme bzw. den Anschluss an sie?",{"_33":124,"_35":133},[134,136,141,143,148,150,155],{"_38":135,"_33":38},"Sind EU-Vorgaben – wie ",{"_41":137,"_33":43,"_35":138},"https://www.personalausweisportal.de/Webs/PA/DE/verwaltung/eIDAS-verordnung-der-EU/eidas-verordnung-der-eu-node.html",[139],{"_38":140,"_33":38},"eIDAS",{"_38":142,"_33":38}," oder ",{"_41":144,"_33":43,"_35":145},"https://www.bsi.bund.de/DE/Themen/Regulierte-Wirtschaft/NIS-2-regulierte-Unternehmen/NIS-2-FAQ/FAQ-zu-NIS-2_node.html",[146],{"_38":147,"_33":38},"NIS2",{"_38":149,"_33":38}," – oder ",{"_41":151,"_33":43,"_35":152},"https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/Technische-Richtlinien/technische-richtlinien_node.html",[153],{"_38":154,"_33":38},"technische Richtlinien des BSI",{"_38":156,"_33":38}," relevant?",{"_33":124,"_35":158},[159,161,166],{"_38":160,"_33":38},"Wurde untersucht, ob bereits ",{"_41":162,"_33":43,"_35":163},"https://interoperable-europe.ec.europa.eu/solutions",[164],{"_38":165,"_33":38},"existierende europäische Interoperabilitätslösungen",{"_38":167,"_33":38}," wiederverwendet werden könnten?","Formulierungsbeispiel",[170],{"_33":119,"_120":121,"_35":171},[172,176],{"_33":124,"_35":173},[174],{"_38":175,"_33":38},"Sie können die Technologie bereits im Gesetz festschreiben und in der Verordnung ausdefinieren. Tauschen Sie sich dafür mit den umsetzenden Akteurinnen und Akteuren aus und nutzen Sie unseren Support.",{"_33":124,"_35":177},[178,180,185],{"_38":179,"_33":38},"Beispiele für technologieoffene Formulierungen finden Sie z. B. im Handbuch der Rechtsförmlichkeit (",{"_41":181,"_33":43,"_35":182},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=95",[183],{"_38":184,"_33":38},"4. Auflage, Teil B, 3.4. Verweisungen auf technische Regeln",{"_38":186,"_33":38},")","Anwendung",[],{"_26":190,"_51":58,"_59":191,"_68":213},"g6pdcvhx2a4cleuywyb0fbuu",[192,198,209],{"_33":34,"_35":193},[194,196],{"_38":195,"_33":38,"_65":13},"Eine in diesem Gesetz angeordnete Schriftform kann durch unmittelbare Eingabe von Anträgen und Erklärungen der Verfahrensbeteiligten über die Kommunikationsplattform nach § 1130 ersetzt werden[1]",{"_38":197,"_33":38},", sofern hierfür digitale Eingabesysteme zur Verfügung stehen und eines der folgenden Identifizierungsverfahren genutzt wird:",{"_33":119,"_120":199,"_35":200},"ordered",[201,205],{"_33":124,"_35":202},[203],{"_38":204,"_33":38,"_65":13},"für die Identifizierung von Rechtsanwälten: das Verfahren zum Zugang zum besonderen elektronischen Anwaltspostfach nach § 31a Absatz 3 Satz 1 der Bundesrechtsanwaltsordnung;",{"_33":124,"_35":206},[207],{"_38":208,"_33":38,"_65":13},"für die Identifizierung anderer Verfahrensbeteiligter: ein Verfahren über ein Nutzerkonto nach § 2 Absatz 5 in Verbindung mit § 3 Absatz 4 des Onlinezugangsgesetzes.[6]",{"_33":34,"_35":210},[211],{"_38":212,"_33":38},"Wurde der Nachweis der Identität nach Satz 1 erbracht, so kann die spätere Authentisierung des Inhabers des Identitätsnachweises auch durch andere geeignete Authentisierungsmittel erfolgen.",{"_51":214,"_71":72,"_73":215,"_75":216},"1131","Kommunikations-, Austausch- und Übermittlungsformen",{"_53":77,"_73":78},{"_51":218,"_73":219,"_97":220,"_30":221,"_59":222,"_116":247,"_168":-5,"_187":258,"_55":259},"3.2","Bevorzugen Sie Open-Source-Software und offene Spezifikationen","Open-Source-Software","Bevorzugen Sie Open-Source-Software und offene Spezifikationen: Setzen Sie auf Transparenz und Zugänglichkeit bei Code und Standards, um die Zusammenarbeit zu fördern und die Austauschbarkeit von Systemen zu gewährleisten.",[223],{"_33":34,"_35":224},[225,227,232,233,238,240,245],{"_38":226,"_33":38},"Open-Source bedeutet, dass der Quellcode eines IT-Systems veröffentlicht ist. Offene Spezifikationen beschreiben öffentlich, was ein IT-System genau leistet. Beide stärken Transparenz und Wiederverwendbarkeit (vgl. ",{"_41":228,"_33":43,"_35":229},"https://www.bundestag.de/resource/blob/194886/696f36f795961df200fb27fb6803d83e/koalitionsvertrag-data.pdf#page=152",[230],{"_38":231,"_33":38},"Koalitionsvertrag 18. Legislaturperiode",{"_38":142,"_33":38},{"_41":234,"_33":43,"_35":235},"https://servicestandard.gov.de/",[236],{"_38":237,"_33":38},"Servicestandard",{"_38":239,"_33":38},"). Dies ermöglicht die Nachvollziehbarkeit der technischen Lösung und verhindert die Abhängigkeit von einzelnen Software-Anbietern. Weitere Informationen erhalten Sie beim ",{"_41":241,"_33":43,"_35":242},"https://www.zendis.de/",[243],{"_38":244,"_33":38},"Zentrum für digitale Souveränität",{"_38":246,"_33":38},".",[248],{"_33":119,"_120":121,"_35":249},[250,254],{"_33":124,"_35":251},[252],{"_38":253,"_33":38},"Wird der Einsatz von Open-Source-Software ermöglicht und gefördert?",{"_33":124,"_35":255},[256],{"_38":257,"_33":38},"Werden gegebenenfalls bei Neuentwicklung Quelloffenheit und offene Spezifikationen vorgeschrieben?",[],{"_26":260,"_51":58,"_59":261,"_68":268},"u3sg1zismobz1t707uo3xav8",[262],{"_33":34,"_35":263},[264,266],{"_38":265,"_33":38,"_65":13},"Das Bundesministerium der Justiz kann digitale Eingabesysteme als Referenzimplementierung entwickeln und bundeseinheitlich zur Erprobung bereitstellen, soweit diese dem elektronischen Erstellen von Anträgen oder Erklärungen nach § 129a Absatz 1 dienen.[6]",{"_38":267,"_33":38}," Satz 1 gilt nicht im Anwendungsbereich des Online-Verfahrens nach Abschnitt 2 dieses Buchs.",{"_51":269,"_71":72,"_73":270,"_75":271},"1134","Umfang der Erprobung",{"_53":77,"_73":78},"prinzipList",[274,277,281,282,286],{"_28":275,"_53":276,"_49":58},"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",{"_28":278,"_53":279,"_49":280},"Datenwiederverwendung benötigt einheitliches Recht","datenwiederverwendung-benoetigt-einheitliches-recht",2,{"_28":29,"_53":54,"_49":50},{"_28":283,"_53":284,"_49":285},"Automatisierung basiert auf eindeutigen Regelungen","automatisierung-basiert-auf-eindeutigen-regelungen",4,{"_28":287,"_53":288,"_49":289},"Datenschutz und Informationssicherheit schaffen Vertrauen","datenschutz-und-informationssicherheit-schaffen-vertrauen",5]
