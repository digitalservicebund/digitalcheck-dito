[{"_1":2,"_21":22},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_19":20},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/methoden.fuenf-prinzipien.$prinzip",{"_3":23},{"_24":25,"_477":478},"prinzip",{"_26":27,"_28":29,"_30":31,"_72":73,"_74":75,"_76":77,"_78":79,"_127":128},"documentId","got436pv8femeqmv6ee8wlm1","Name","Automatisierung basiert auf eindeutigen Regelungen","Beschreibung",[32,56],{"_33":34,"_35":36},"type","paragraph","children",[37,40,47,49,54],{"_38":39,"_33":38},"text","Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_41":42,"_33":43,"_35":44},"url","https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.","link",[45],{"_38":46,"_33":38},"GGO",{"_38":48,"_33":38}," und das ",{"_41":50,"_33":43,"_35":51},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[52],{"_38":53,"_33":38},"Handbuch der Rechtsförmlichkeit",{"_38":55,"_33":38}," vorgeschrieben.",{"_33":34,"_35":57},[58,60,63,65,70],{"_38":59,"_33":38},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_38":61,"_33":38,"_62":13},"Verwaltungsakt","italic",{"_38":64,"_33":38}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_41":66,"_33":43,"_35":67},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[68],{"_38":69,"_33":38},"§ 35a VwVfG",{"_38":71,"_33":38},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","order",4,"Nummer",5,"URLBezeichnung","automatisierung-basiert-auf-eindeutigen-regelungen","Beispiel",{"_26":80,"_74":81,"_82":83,"_93":94,"_104":105},"uvun402oruwdnjke6epwd5qt",3,"Text",[84],{"_33":34,"_35":85},[86,88,91],{"_38":87,"_33":38},"Betreiber von unbemannten Fluggeräten nach Absatz 1 Satz 1 haben dem Luftfahrt-Bundesamt vor der erstmaligen Aufnahme des Betriebs die für die Registrierung zu speichernden Daten nach Absatz 2 zu übermitteln und deren Richtigkeit auf Verlangen zu belegen, soweit dies für die Registrierung durch das Luftfahrt-Bundesamt erforderlich ist. Registrierte Betreiber haben dem Luftfahrt-Bundesamt unverzüglich jede Änderung der Voraussetzungen für eine Registrierung nach Absatz 1 und jede Änderung der Daten nach Absatz 2 zu übermitteln. ",{"_38":89,"_33":38,"_90":13},"Das Luftfahrt-Bundesamt kann Verwaltungsakte hinsichtlich der Registrierung eines Betreibers sowie Gebührenbescheide für die Registrierung durch automatische Einrichtungen erlassen. Betreiber haben das Recht auf Darlegung des eigenen Standpunktes und das Recht auf Entscheidung durch einen Amtsträger.[5]","underline",{"_38":92,"_33":38}," Satz 3 gilt nicht, wenn ein Betreiber Rechte nach Satz 4 geltend macht oder wenn aus anderen Gründen Anlass besteht, den Einzelfall durch Amtsträger zu bearbeiten. Setzt das Luftfahrt-Bundesamt automatische Einrichtungen zum Erlass von Verwaltungsakten ein, muss es Angaben des Betreibers berücksichtigen, die für den Einzelfall bedeutsam sind und im automatischen Verfahren nicht ermittelt würden.","Paragraph",{"_74":95,"_96":97,"_98":99,"_100":101},"66a","Gesetz","LuftVG","Titel","Register über Betreiber von unbemannten Fluggeräten","Beispielvorhaben",{"_76":102,"_98":103},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","Register über Betreiber von unbemannten Fluggeräten – LuftVG","PrinzipErfuellungen",[106],{"_107":108,"_109":110,"_125":126},"id","1286","Erklaerung",[111],{"_33":112,"_113":114,"_35":115},"list","format","unordered",[116,121],{"_33":117,"_35":118},"list-item",[119],{"_38":120,"_33":38},"Schafft die Rechtsgrundlage zur potenziellen Automatisierung.",{"_33":117,"_35":122},[123],{"_38":124,"_33":38},"Neben der Automatisierung besteht das Recht auf Entscheidung durch einen Amtsträger.","Prinzip",{"_74":75,"_28":29},"Aspekte",[129,203,233,305,361],{"_74":130,"_98":131,"_132":133,"_30":134,"_82":135,"_140":141,"_171":-5,"_172":173,"_78":174},"4.1","Beachten Sie bestehende Prozesse und Verantwortlichkeiten","Kurzbezeichnung","Bestehende Prozesse","Beachten Sie bestehende Prozesse und Verantwortlichkeiten: Integrieren Sie neue Regelungen harmonisch in die vorhandenen Arbeitsabläufe und klären Sie die Zuständigkeiten, um eine reibungslose Umsetzung zu sichern.",[136],{"_33":34,"_35":137},[138],{"_38":139,"_33":38},"Um eine effektive Umsetzung zu gewährleisten, sollten existierende Prozesse und Verantwortlichkeiten beachtet und, wenn möglich, angeglichen werden. Dabei helfen Ihnen Visualisierungen.","Leitfragen",[142],{"_33":112,"_113":114,"_35":143},[144,155,159,163,167],{"_33":117,"_35":145},[146,148,153],{"_38":147,"_33":38},"Gibt es bereits Prozess-Visualisierungen im ",{"_41":149,"_33":43,"_35":150},"https://fimportal.de/search?resource=process&page=1&page_size=20",[151],{"_38":152,"_33":38},"FIM-Portal",{"_38":154,"_33":38},", auf denen Sie aufsetzen können?",{"_33":117,"_35":156},[157],{"_38":158,"_33":38},"Haben Sie bestehende Prozesse in Deutschland und anderen EU-Mitgliedsstaaten berücksichtigt",{"_33":117,"_35":160},[161],{"_38":162,"_33":38},"Bekommt oder verliert eine Behörde Kompetenzen? Wie wirkt sich das aus?",{"_33":117,"_35":164},[165],{"_38":166,"_33":38},"Können bestehende Prozesse vereinfacht werden?",{"_33":117,"_35":168},[169],{"_38":170,"_33":38},"Falls ein Verwaltungsprozess betroffen ist: Lassen sich die Teilschritte in einer chronologischen Reihenfolge abbilden?","Formulierungsbeispiel","Anwendung",[],{"_26":175,"_74":176,"_82":177,"_93":201},"aws985sev373qzjm9gagbjyl",7,[178,186,197],{"_33":34,"_35":179},[180,182,184],{"_38":181,"_33":38},"Die Übermittlung nach Absatz 6 Satz 1 ",{"_38":183,"_33":38,"_90":13},"aus dem Register darf durch Abruf im automatisierten Verfahren[5]",{"_38":185,"_33":38}," an die Polizeien des Bundes und der Länder erfolgen",{"_33":112,"_113":187,"_35":188},"ordered",[189,193],{"_33":117,"_35":190},[191],{"_38":192,"_33":38},"zur Verfolgung von Straftaten oder",{"_33":117,"_35":194},[195],{"_38":196,"_33":38},"zur Abwehr von Gefahren für die öffentliche Sicherheit,",{"_33":34,"_35":198},[199],{"_38":200,"_33":38},"wenn diese Daten auf andere Weise nicht oder nicht rechtzeitig oder nur mit unverhältnismäßigem Aufwand zu erlangen sind. Die Verantwortung für die Zulässigkeit des einzelnen automatisierten Abrufs trägt die abrufende Stelle. Das Luftfahrt-Bundesamt überprüft die Zulässigkeit des Abrufs nur, wenn dazu Anlass besteht.",{"_74":95,"_96":97,"_98":99,"_100":202},{"_76":102,"_98":103},{"_74":204,"_98":205,"_132":206,"_30":207,"_82":208,"_140":213,"_171":-5,"_172":232,"_78":-5},"4.2","Bündeln Sie Aufgaben im Vollzug","Aufgabenbündelung","Bündeln Sie Aufgaben im Vollzug: Fassen Sie ähnliche oder zusammenhängende Tätigkeiten in der Umsetzung zusammen, um Effizienz zu steigern und die Übersichtlichkeit zu verbessern.",[209],{"_33":34,"_35":210},[211],{"_38":212,"_33":38},"Vereinfachen Sie, wie die Aufgaben zwischen Bund und Ländern verteilt sind. Aufgaben oder Teilaufgaben können gebündelt werden: Sie müssen nicht mehr in jeder Kommune oder jeder Behörde individuell erfüllt werden. Gerade bei Aufgaben mit hohen Fallzahlen und hohem Standardisierungspotenzial können Automatisierung und Aufgabenneuorganisation die Vollzugsbehörden spürbar entlasten.",[214],{"_33":112,"_113":114,"_35":215},[216,220,224,228],{"_33":117,"_35":217},[218],{"_38":219,"_33":38},"Ermöglicht die Regelung, dass andere, möglichst übergeordnete oder ressortübergreifende, Behörden Aufgaben automatisieren können? Ist es ausreichend, wenn die zuständige Behörde das Ergebnis erhält?",{"_33":117,"_35":221},[222],{"_38":223,"_33":38},"Können Sie vermeiden, dass dieselben Aufgaben in jeder Kommunen erfüllt werden müssen?",{"_33":117,"_35":225},[226],{"_38":227,"_33":38},"Kann eine gemeinsame technische Lösung für alle Behörden entwickelt werden?",{"_33":117,"_35":229},[230],{"_38":231,"_33":38},"Können Sie Spezialisierungsvorteile nutzen, in dem Sie fachlich anspruchsvolle Aufgaben, die selten anfallen, bündeln?",[],{"_74":234,"_98":235,"_132":236,"_30":237,"_82":238,"_140":243,"_171":-5,"_172":273,"_78":274},"4.3","Nutzen Sie das Potenzial von Automatisierung","Automatisierung","Nutzen Sie das Potenzial von Automatisierung: Legen Sie Entscheidungsstrukturen so fest, dass sie durch eindeutige Logik maschinell verarbeitet werden können, um Zeit und Ressourcen zu sparen.",[239],{"_33":34,"_35":240},[241],{"_38":242,"_33":38},"Automatisierung wirkt sich besonders effizienzsteigernd auf Prozesse mit großen Bearbeitungsfallzahlen aus, die als gebundene Entscheidungen geregelt werden können.",[244],{"_33":112,"_113":114,"_35":245},[246,250,254,258,262],{"_33":117,"_35":247},[248],{"_38":249,"_33":38},"Wie groß ist die erwartete Fallzahl pro Jahr? Sind in den Behörden genug Ressourcen vorhanden, um z. B. Anträge fristgerecht zu bearbeiten?",{"_33":117,"_35":251},[252],{"_38":253,"_33":38},"Gibt es bereits Vorschläge für Automatisierungspotenziale aus der Umsetzung?",{"_33":117,"_35":255},[256],{"_38":257,"_33":38},"Handelt es sich um eine gebundene Entscheidung?",{"_33":117,"_35":259},[260],{"_38":261,"_33":38},"Erlaubt die Regelung eine automatisierte Fallbearbeitung?",{"_33":117,"_35":263},[264,266,271],{"_38":265,"_33":38},"Ist ein komplett antragsloses Verfahren möglich? Beachten Sie hierfür auch das Prinzip „",{"_41":267,"_33":43,"_35":268},"/#datenwiederverwendung-ben-tigt-einheitliches-recht",[269],{"_38":270,"_33":38},"Datenwiederverwendung benötigt einheitliches Recht",{"_38":272,"_33":38},"“.",[],{"_26":275,"_74":276,"_82":277,"_93":298},"fvj31s0fav5aw2vlu65q0arw",2,[278,284],{"_33":34,"_35":279},[280,282],{"_38":281,"_33":38,"_90":13},"Eine in diesem Gesetz angeordnete Schriftform kann auch durch Übermittlung elektronischer Dokumente oder strukturierter Datensätze über die Kommunikationsplattform ersetzt werden[1]",{"_38":283,"_33":38},", sofern",{"_33":112,"_113":187,"_35":285},[286,290,294],{"_33":117,"_35":287},[288],{"_38":289,"_33":38},"ein Identifizierungsverfahren nach Absatz 1 genutzt wird,",{"_33":117,"_35":291},[292],{"_38":293,"_33":38,"_90":13},"bei der Datenübermittlung ein sicheres Verfahren verwendet wird, das die Authentizität und Integrität der Daten gewährleistet, und [3]",{"_33":117,"_35":295},[296],{"_38":297,"_33":38,"_90":13},"für die elektronischen Dokumente oder strukturierten Datensätze auf der Kommunikationsplattform eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[5]",{"_74":299,"_96":300,"_98":301,"_100":302},"1131","ZPO","Kommunikations-, Austausch- und Übermittlungsformen",{"_76":303,"_98":304},"entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit",{"_74":306,"_98":307,"_132":308,"_30":309,"_82":310,"_140":315,"_171":-5,"_172":338,"_78":339},"4.4","Unterscheiden Sie zwischen genereller Regel, Ausnahmen und Ermessensspielräumen","Unterscheidungen","Unterscheiden Sie zwischen genereller Regel, Ausnahmen und Ermessensspielräumen: Definieren Sie klare Abgrenzungen zwischen Standardfällen, Sonderfällen und Ermessensentscheidungen, um die Automatisierbarkeit zu ermöglichen.",[311],{"_33":34,"_35":312},[313],{"_38":314,"_33":38},"Sachverhalte sollten durch das Zusammenspiel von Gesetzen und Verordnungen möglichst abschließend geregelt werden. Finden Sie die Balance zwischen notwendigen Ausnahmen für eine gerechte Regelung, Spielraum in der Umsetzung und klar geregelten Prozessen, die sich gut digitalisieren lassen.",[316],{"_33":112,"_113":114,"_35":317},[318,322,326,330,334],{"_33":117,"_35":319},[320],{"_38":321,"_33":38},"Basieren Entscheidungslogiken auf objektiven Kriterien?",{"_33":117,"_35":323},[324],{"_38":325,"_33":38},"Können Pauschalen die Regelung und Umsetzung vereinfachen?",{"_33":117,"_35":327},[328],{"_38":329,"_33":38},"Wird in der Regelung klar zwischen grundlegender Regel und Ausnahmen unterschieden? Sind die Ausnahmen klar definiert?",{"_33":117,"_35":331},[332],{"_38":333,"_33":38},"Sind Ermessensspielräume nötig? Können für bestimmte Fallgruppen gebundene Entscheidungen festgelegt werden?",{"_33":117,"_35":335},[336],{"_38":337,"_33":38},"Ist trotz verbleibendem Ermessen eine Automatisierung anderer Prozessschritte möglich?",[],{"_26":340,"_74":81,"_82":341,"_93":354},"xu1tjdat5q94xbjqhqtqjw9g",[342],{"_33":34,"_35":343},[344,346,348,350,352],{"_38":345,"_33":38,"_90":13},"Innerhalb von vier Wochen nach Eingang eines vollständigen Antrags prüft die Bundesnetzagentur, ob Gründe nach Absatz 4 für die Versagung der Eintragung vorliegen.[5]",{"_38":347,"_33":38}," Liegen keine Gründe für die Versagung der Eintragung vor, ",{"_38":349,"_33":38,"_90":13},"trägt die Bundesnetzagentur den Antragsteller in das Anbieterverzeichnis ein.[5]",{"_38":351,"_33":38}," Die erfolgte Eintragung ist dem Anbieter mitzuteilen. Liegen Gründe für die Versagung der Eintragung vor, versagt die Bundesnetzagentur die Eintragung. ",{"_38":353,"_33":38,"_90":13},"Ist die Frist nach Satz 1 abgelaufen, ohne dass eine Eintragung oder Versagung erfolgt ist, gilt der Antragsteller als in das Anbieterverzeichnis eingetragen; die Bundesnetzagentur hat die Eintragung umgehend zu veranlassen.[5]",{"_74":355,"_96":356,"_98":357,"_100":358},"4","PostG","Anbieterverzeichnis",{"_76":359,"_98":360},"modernisierung-des-postrechts","Modernisierung des Postrechts – PostG",{"_74":362,"_98":363,"_132":364,"_30":365,"_82":366,"_140":371,"_171":-5,"_172":386,"_78":387},"4.5","Schreiben Sie einfach, eindeutig und widerspruchsfrei","Schreibstil","Schreiben Sie einfach, eindeutig und widerspruchsfrei: Formulieren Sie Normen klar und verständlich, damit sie eine unmissverständliche Grundlage für die digitale und menschliche Anwendung bilden.",[367],{"_33":34,"_35":368},[369],{"_38":370,"_33":38},"Logische Konsistenz und präzise Sprache sind notwendige Bedingungen für die Automatisierung der Umsetzung. Dass eine Regelung eindeutig formuliert ist, kann auch einen längeren Regelungstext zur Folge haben.",[372],{"_33":112,"_113":114,"_35":373},[374,378,382],{"_33":117,"_35":375},[376],{"_38":377,"_33":38},"Sind Begriffe und Abläufe eindeutig definiert?",{"_33":117,"_35":379},[380],{"_38":381,"_33":38},"Ist die Regelung möglichst einfach formuliert?",{"_33":117,"_35":383},[384],{"_38":385,"_33":38},"Sind Entscheidungslogiken widerspruchsfrei?",[],{"_26":388,"_74":389,"_82":390,"_93":473},"ooxbst8o2pc70zu1ggl130rf",1,[391,395,466,470],{"_33":34,"_35":392},[393],{"_38":394,"_33":38,"_90":13},"Die nach § 4 Absatz 4 Nummer 1 erforderliche Zuverlässigkeit liegt in der Regel nicht vor, wenn[5]",{"_33":112,"_113":187,"_35":396},[397,401,420,424,462],{"_33":117,"_35":398},[399],{"_38":400,"_33":38},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 wegen Versuchs oder Vollendung eines Verbrechens im Sinne von § 12 Absatz 1 des Strafgesetzbuches oder einer der nachstehend aufgeführten Straftaten zu einer Freiheitsstrafe, Jugendstrafe, auch wenn deren Verhängung ausgesetzt worden ist, Geldstrafe von mindestens 90 Tagessätzen oder mindestens zweimal zu einer geringeren Geldstrafe rechtskräftig verurteilt worden ist, wenn seit dem Eintritt der Rechtskraft der letzten erstinstanzlichen Verurteilung fünf Jahre und seit dem Eintritt der Rechtskraft der vorletzten erstinstanzlichen Verurteilung zehn Jahre noch nicht verstrichen sind:",{"_33":112,"_113":187,"_35":402,"_419":389},[403,407,411,415],{"_33":117,"_35":404},[405],{"_38":406,"_33":38},"§§ 15 oder 15a des Arbeitnehmerüberlassungsgesetzes,",{"_33":117,"_35":408},[409],{"_38":410,"_33":38},"§ 23 des Arbeitszeitgesetzes,",{"_33":117,"_35":412},[413],{"_38":414,"_33":38},"§§ 10, 10a oder 11 des Schwarzarbeitsbekämpfungsgesetzes,",{"_33":117,"_35":416},[417],{"_38":418,"_33":38},"§§ 202, 206, 263, 266a oder 267 des Strafgesetzbuches,","indentLevel",{"_33":117,"_35":421},[422],{"_38":423,"_33":38,"_90":13},"gegen den Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 bei Antragstellern mit bis zu zehn Beschäftigten mindestens zwei, bei Antragstellern mit bis zu 250 Beschäftigten mindestens zehn, bei Antragstellern mit bis zu 500 Beschäftigten mindestens 20 und bei Antragstellern mit mehr als 500 Beschäftigten mindestens 25 unanfechtbare Bußgeldentscheidungen wegen einer der nachstehend aufgeführten Ordnungswidrigkeiten in Höhe von jeweils mindestens 1 500 Euro ergangen sind:[5]",{"_33":112,"_113":187,"_35":425,"_419":389},[426,430,434,438,442,446,450,454,458],{"_33":117,"_35":427},[428],{"_38":429,"_33":38},"§ 23 des Arbeitnehmerentsendegesetzes,",{"_33":117,"_35":431},[432],{"_38":433,"_33":38},"§ 16 des Arbeitnehmerüberlassungsgesetzes,",{"_33":117,"_35":435},[436],{"_38":437,"_33":38},"§ 25 des Arbeitsschutzgesetzes,",{"_33":117,"_35":439},[440],{"_38":441,"_33":38},"§ 22 Absatz 1 Nummer 1 bis 7, 9 oder 10 des Arbeitszeitgesetzes,",{"_33":117,"_35":443},[444],{"_38":445,"_33":38},"§ 21 des Mindestlohngesetzes,",{"_33":117,"_35":447},[448],{"_38":449,"_33":38},"§ 8 Absatz 1 Nummer 2, Absatz 2 bis 4 des Schwarzarbeitsbekämpfungsgesetzes,",{"_33":117,"_35":451},[452],{"_38":453,"_33":38},"§ 404 Absatz 1 oder Absatz 2 Nummer 4 des Dritten Buches Sozialgesetzbuch,",{"_33":117,"_35":455},[456],{"_38":457,"_33":38},"§ 209 Absatz 1 Nummer 1 bis 7, 8, 9 oder Absatz 2 des Siebten Buches Sozialgesetzbuch,",{"_33":117,"_35":459},[460],{"_38":461,"_33":38},"§ 111 dieses Gesetzes,",{"_33":117,"_35":463},[464],{"_38":465,"_33":38},"der Antragsteller oder eine mit der Leitung des Betriebs oder einer Zweigniederlassung beauftragte Person in den letzten fünf Jahren vor Stellung des Antrags nach § 4 Absatz 2 schwerwiegend oder wiederholt gegen Vorgaben dieses Gesetzes verstoßen hat und die Verstöße durch bestandskräftige Entscheidungen der Bundesnetzagentur festgestellt sind.",{"_33":34,"_35":467},[468],{"_38":469,"_33":38},"Im Einzelfall kann auch eine Gesamtabwägung von Umständen, die nicht in Satz 1 genannt sind und denen in ihrer Gesamtheit ein vergleichbares Gewicht wie den in Satz 1 genannten Umständen zuzumessen ist, die Annahme rechtfertigen, dass der Antragsteller nicht über die erforderliche Zuverlässigkeit verfügt.",{"_33":34,"_35":471},[472],{"_38":20,"_33":38},{"_74":474,"_96":356,"_98":475,"_100":476},"5","Zuverlässigkeit, Leistungsfähigkeit, Fachkunde",{"_76":359,"_98":360},"prinzipList",[479,482,484,487,488],{"_28":480,"_76":481,"_72":389},"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",{"_28":270,"_76":483,"_72":276},"datenwiederverwendung-benoetigt-einheitliches-recht",{"_28":485,"_76":486,"_72":81},"Etablierte Technologien ermöglichen effiziente Umsetzung","etablierte-technologien-ermoeglichen-effiziente-umsetzung",{"_28":29,"_76":77,"_72":73},{"_28":489,"_76":490,"_72":75},"Datenschutz und Informationssicherheit schaffen Vertrauen","datenschutz-und-informationssicherheit-schaffen-vertrauen"]
