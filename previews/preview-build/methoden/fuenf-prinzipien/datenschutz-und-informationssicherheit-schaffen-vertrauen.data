[{"_1":2,"_20":21},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_18":19},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":8,"_13":8,"_14":8,"_15":8,"_16":8,"_17":8},"showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/methoden.fuenf-prinzipien.$prinzip",{"_3":22},{"_23":24,"_261":262},"prinzip",{"_25":26,"_27":28,"_29":30,"_56":57,"_58":59,"_60":61,"_62":63,"_102":103},"documentId","bnx9lmblnceu1m3uy3rziy0i","Name","Datenschutz und Informationssicherheit schaffen Vertrauen","Beschreibung",[31,48,52],{"_32":33,"_34":35},"type","paragraph","children",[36,39,46],{"_37":38,"_32":37},"text","Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_40":41,"_32":42,"_34":43},"url","https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de","link",[44],{"_37":45,"_32":37},"DSGVO",{"_37":47,"_32":37}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_32":33,"_34":49},[50],{"_37":51,"_32":37},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_32":33,"_34":53},[54],{"_37":55,"_32":37},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","order",5,"Nummer",3,"URLBezeichnung","datenschutz-und-informationssicherheit-schaffen-vertrauen","Beispiel",{"_25":64,"_58":65,"_66":67,"_78":79,"_89":90},"zcso7sdqfumq9dymth3dfssp",4,"Text",[68],{"_32":33,"_34":69},[70,72,76],{"_37":71,"_32":37},"Abweichend von Absatz 3 Satz 1 können Luftsportverbände die für die Registrierung zu speichernden Daten ihrer Mitglieder, die unbemannte Fluggeräte nach Absatz 1 Satz 1 betreiben, dem Luftfahrt-Bundesamt ",{"_37":73,"_32":37,"_74":75},"unter Beachtung der Verordnung (EU) 2016/679 des Europäischen Parlaments und des Rates vom 27. April 2016 zum Schutz natürlicher Personen bei der Verarbeitung personenbezogener Daten[3]","underline",true,{"_37":77,"_32":37},", zum freien Datenverkehr und zur Aufhebung der Richtlinie 95/46/EG (ABl. L 119 vom 4.5.2016, S. 1; L 314 vom 22.11.2016, S. 72; L 127 vom 23.5.2018, S. 2) übermitteln. Absatz 3 Satz 2 gilt entsprechend.","Paragraph",{"_58":80,"_81":82,"_83":84,"_85":86},"66a","Gesetz","LuftVG","Titel","Register über Betreiber von unbemannten Fluggeräten","Beispielvorhaben",{"_60":87,"_83":88},"register-ueber-betreiber-von-unbemannten-fluggeraeten-luft-vg","Register über Betreiber von unbemannten Fluggeräten – LuftVG","PrinzipErfuellungen",[91],{"_92":93,"_94":95,"_100":101},"id","1288","Erklaerung",[96],{"_32":33,"_34":97},[98],{"_37":99,"_32":37},"Verweist auf die DSGVO.","Prinzip",{"_58":59,"_27":28},"Aspekte",[104,199],{"_58":105,"_83":106,"_107":108,"_29":109,"_66":110,"_129":130,"_157":-5,"_158":159,"_62":160},"5.1","Stellen Sie den Datenschutz sicher","Kurzbezeichnung","Datenschutz","Stellen Sie den Datenschutz sicher: Gewährleisten Sie, dass die Verarbeitung personenbezogener Daten jederzeit den geltenden Anforderungen entspricht und das Erfordernis der Datensparsamkeit beachtet wird.",[111],{"_32":33,"_34":112},[113,115,120,122,127],{"_37":114,"_32":37},"Für den Datenschutz sind nur personenbezogene Daten relevant. Um diese zu verarbeiten, muss eine geeignete Rechtsgrundlage existieren. \"Datenverarbeitung\" umfasst u. a. das Erheben, Speichern, Abfragen, Übermitteln, Verknüpfen oder Löschen von Daten (",{"_40":116,"_32":42,"_34":117},"https://eur-lex.europa.eu/legal-content/DE/TXT/?qid=1532348683434&uri=CELEX%3A02016R0679-20160504",[118],{"_37":119,"_32":37},"s. Art. 4 Abs. 2 DSGVO",{"_37":121,"_32":37},"). Tauschen Sie sich mit Ihren Datenschutzbeauftragten aus oder kontaktieren Sie die ",{"_40":123,"_32":42,"_34":124},"https://www.bfdi.bund.de/DE/Home/home_node.html",[125],{"_37":126,"_32":37},"BfDI",{"_37":128,"_32":37},".","Leitfragen",[131],{"_32":132,"_133":134,"_34":135},"list","format","unordered",[136,141,145,149,153],{"_32":137,"_34":138},"list-item",[139],{"_37":140,"_32":37},"Werden personenbezogene Daten verarbeitet? Sind diese besonders schützenswert, etwa Daten zur ethnischen Herkunft oder Gesundheitsdaten?",{"_32":137,"_34":142},[143],{"_37":144,"_32":37},"Werden nur notwendige Daten verarbeitet?",{"_32":137,"_34":146},[147],{"_37":148,"_32":37},"Haben Sie die rechtliche Basis geschaffen, um Daten zu verarbeiten? Ist der Zweck der Datenverarbeitung dargelegt?",{"_32":137,"_34":150},[151],{"_37":152,"_32":37},"Können überholte Datenschutzbedürfnisse abgeschafft werden?",{"_32":137,"_34":154},[155],{"_37":156,"_32":37},"Genügt die Regelung den Anforderungen an den Datenschutz in allen beteiligten Ländern und Institutionen, gegebenenfalls auch in anderen EU-Staaten?","Formulierungsbeispiel","Anwendung",[],{"_25":161,"_58":65,"_66":162,"_78":192},"i9t6l6by44lbcecptjuzclfe",[163,167,186],{"_32":33,"_34":164},[165],{"_37":166,"_32":37},"Das Umweltbundesamt kann den Betreibern der Datenbanken und der Register nach Absatz 2 sowie den Behörden nach Absatz 3 über elektronische Schnittstellen den Zugang zu den in einem Herkunftsnachweisregister nach § 3 gespeicherten Daten, einschließlich personenbezogener Daten, ermöglichen. Das Umweltbundesamt als übermittelnde Stelle hat über die Abrufe nach Satz 1 Aufzeichnungen zu fertigen, die die folgenden Daten enthalten müssen:",{"_32":132,"_133":168,"_34":169},"ordered",[170,174,178,182],{"_32":137,"_34":171},[172],{"_37":173,"_32":37},"die bei der Durchführung der Abrufe verwendeten Daten,",{"_32":137,"_34":175},[176],{"_37":177,"_32":37},"den Tag und die Uhrzeit der Abrufe,",{"_32":137,"_34":179},[180],{"_37":181,"_32":37},"die Kennung der abrufenden Dienststelle und",{"_32":137,"_34":183},[184],{"_37":185,"_32":37},"die abgerufenen Daten.",{"_32":33,"_34":187},[188,190],{"_37":189,"_32":37},"Die protokollierten Daten dürfen nur für Zwecke der Datenschutzkontrolle oder Datensicherung oder zur Sicherstellung eines ordnungsgemäßen Betriebs der Datenverarbeitungsanlage verwendet werden. ",{"_37":191,"_32":37,"_74":75},"Die protokollierten Daten sind durch geeignete Vorkehrungen gegen zweckfremde Verwendung und gegen sonstigen Missbrauch zu schützen. Die protokollierten Daten sind sechs Monate nach der Protokollierung zu löschen.[3]",{"_58":193,"_81":194,"_83":195,"_85":196},"39","GWKH","Überprüfung der gespeicherten Daten; Datenübermittlung",{"_60":197,"_83":198},"einrichtung-herkunftsnachweisregister-fuer-gas-waerme-und-kaelte-gwkhv","Einrichtung Herkunftsnachweisregister für Gas, Wärme und Kälte  - GWKHV",{"_58":200,"_83":201,"_107":202,"_29":203,"_66":204,"_129":215,"_157":-5,"_158":248,"_62":249},"5.2","Gewährleisten Sie die Informationssicherheit","Informationssicherheit","Gewährleisten Sie die Informationssicherheit: Ergreifen Sie notwendige technische und organisatorische Maßnahmen, um die Vertraulichkeit, Integrität und Verfügbarkeit aller relevanten Informationen zu schützen.",[205],{"_32":33,"_34":206},[207,209,214],{"_37":208,"_32":37},"Informationssicherheit betrifft alle Arten von Daten, vor allem wirtschafts- oder sicherheitsrelevante. Alle Daten müssen sicher gespeichert und übertragen werden. Dies erschwert den missbräuchlichen Zugriff, etwa zum Erschleichen von Leistungen. Folgen Sie den ",{"_40":210,"_32":42,"_34":211},"https://www.bsi.bund.de/DE/Themen/Oeffentliche-Verwaltung/oeffentliche-verwaltung_node.html",[212],{"_37":213,"_32":37},"Empfehlungen des BSI",{"_37":128,"_32":37},[216],{"_32":132,"_133":134,"_34":217},[218,222,226,230],{"_32":137,"_34":219},[220],{"_37":221,"_32":37},"Werden eine geeignete, sichere Datenhaltung und sichere Übertragungswege vorgeschrieben?",{"_32":137,"_34":223},[224],{"_37":225,"_32":37},"Wurden Maßnahmen vorgeschrieben, um Betrugsversuche zu erschweren?",{"_32":137,"_34":227},[228],{"_37":229,"_32":37},"Wurden veraltete Informationssicherheitsbedürfnisse identifiziert und abgeschafft?",{"_32":137,"_34":231},[232,234,239,241,246],{"_37":233,"_32":37},"Gibt es passende, anerkannte ",{"_40":235,"_32":42,"_34":236},"https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/standards-und-zertifizierung_node.html",[237],{"_37":238,"_32":37},"Nachweise oder Zertifizierungen",{"_37":240,"_32":37},", z. B. ",{"_40":242,"_32":42,"_34":243},"https://www.bsi.bund.de/DE/Themen/Unternehmen-und-Organisationen/Standards-und-Zertifizierung/IT-Grundschutz/Zertifizierte-Informationssicherheit/zertifizierte-informationssicherheit.html",[244],{"_37":245,"_32":37},"ISO 27001",{"_37":247,"_32":37},"?",[],{"_25":250,"_58":251,"_66":252,"_78":259},"wcxx3x3bzdzfsrkr0fxlr7bi",10,[253],{"_32":33,"_34":254},[255,257],{"_37":256,"_32":37},"Das Luftfahrt-Bundesamt legt im ",{"_37":258,"_32":37,"_74":75},"Einvernehmen mit dem Bundesamt für Sicherheit in der Informationstechnik insbesondere unter Beachtung der Vorgaben der Artikel 24, 25 und 32 der Verordnung (EU) 2016/679 nähere Anforderungen an das Datenformat sowie die Anforderungen an die Sicherheit gegen unbefugte Zugriffe auf das Register und bei der Datenübertragung fest. Sie haben dem Stand der Technik zu entsprechen und sind vom Luftfahrt-Bundesamt im Einvernehmen mit dem Bundesamt für Sicherheit in der Informationstechnik fortlaufend anzupassen[3].",{"_58":80,"_81":82,"_83":84,"_85":260},{"_60":87,"_83":88},"prinzipList",[263,267,271,274,277],{"_27":264,"_60":265,"_56":266},"Digitale Angebote für alle nutzbar gestalten","digitale-angebote-fuer-alle-nutzbar-gestalten",1,{"_27":268,"_60":269,"_56":270},"Datenwiederverwendung benötigt einheitliches Recht","datenwiederverwendung-benoetigt-einheitliches-recht",2,{"_27":272,"_60":273,"_56":59},"Etablierte Technologien ermöglichen effiziente Umsetzung","etablierte-technologien-ermoeglichen-effiziente-umsetzung",{"_27":275,"_60":276,"_56":65},"Automatisierung basiert auf eindeutigen Regelungen","automatisierung-basiert-auf-eindeutigen-regelungen",{"_27":28,"_60":61,"_56":57}]
