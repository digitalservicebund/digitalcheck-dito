[{"_1":2,"_21":22,"_174":175},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_19":20},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":23},[24,68,88,107,149],{"_25":26,"_27":28,"_29":30,"_31":32,"_63":64,"_65":66,"_67":28},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[33,41,45],{"_34":35,"_36":37},"type","paragraph","children",[38],{"_39":40,"_34":39},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_34":35,"_36":42},[43],{"_39":44,"_34":39},"Erfahren Sie in diesem Abschnitt,",{"_34":46,"_47":48,"_36":49},"list","format","unordered",[50,55,59],{"_34":51,"_36":52},"list-item",[53],{"_39":54,"_34":39},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_34":51,"_36":56},[57],{"_39":58,"_34":39},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_34":51,"_36":60},[61],{"_39":62,"_34":39},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_25":69,"_27":70,"_29":71,"_31":72,"_63":86,"_65":87,"_67":70},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[73],{"_34":35,"_36":74},[75,77,84],{"_39":76,"_34":39},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_78":79,"_34":80,"_36":81},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[82],{"_39":83,"_34":39},"Once-Only-Prinzip",{"_39":85,"_34":39}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_25":89,"_27":90,"_29":91,"_31":92,"_63":104,"_65":105,"_67":106},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[93],{"_34":35,"_36":94},[95,97,102],{"_39":96,"_34":39},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_78":98,"_34":80,"_36":99},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[100],{"_39":101,"_34":39},"Sicherheit der Angebote",{"_39":103,"_34":39}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_25":108,"_27":109,"_29":110,"_31":111,"_63":146,"_65":147,"_67":148},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[112,130],{"_34":35,"_36":113},[114,116,121,123,128],{"_39":115,"_34":39},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_78":117,"_34":80,"_36":118},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[119],{"_39":120,"_34":39},"GGO",{"_39":122,"_34":39}," und das ",{"_78":124,"_34":80,"_36":125},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[126],{"_39":127,"_34":39},"Handbuch der Rechtsförmlichkeit",{"_39":129,"_34":39}," vorgeschrieben.",{"_34":35,"_36":131},[132,134,137,139,144],{"_39":133,"_34":39},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_39":135,"_34":39,"_136":13},"Verwaltungsakt","italic",{"_39":138,"_34":39}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_78":140,"_34":80,"_36":141},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[142],{"_39":143,"_34":39},"§ 35a VwVfG",{"_39":145,"_34":39},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_25":150,"_27":106,"_29":151,"_31":152,"_63":172,"_65":173,"_67":109},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[153,164,168],{"_34":35,"_36":154},[155,157,162],{"_39":156,"_34":39},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_78":158,"_34":80,"_36":159},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[160],{"_39":161,"_34":39},"DSGVO",{"_39":163,"_34":39}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_34":35,"_36":165},[166],{"_39":167,"_34":39},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_34":35,"_36":169},[170],{"_39":171,"_34":39},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":176},{"_25":177,"_178":179,"_180":181,"_182":-5,"_183":184,"_63":185,"_186":187,"_188":189,"_190":-5,"_191":192,"_193":194,"_1021":1022,"_1078":1079},"zvgbik091narl46uko7syc67","Titel","Entwurf eines Gesetzes zur Entwicklung und Erprobung eines Online-Verfahrens in der Zivilgerichtsbarkeit","NKRNummer",7065,"Rechtsgebiet","Ressort","BMJV","entwurf-eines-gesetzes-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit","VeroeffentlichungsDatum","2024-09-30","LinkRegelungstext","https://dip.bundestag.de/vorgang/gesetz-zur-entwicklung-und-erprobung-eines-online-verfahrens-in-der-zivilgerichtsbarkeit/315283","NKRStellungnahmeLink","GesetzStatus","Text_im_Parlament","Paragraphen",[195,354,446,543,714,982],{"_25":196,"_27":197,"_178":198,"_199":200,"_201":-5,"_202":203},"asey83r4r5lquyulmqrcht5m","1125","Digitale Eingabesysteme im Online-Verfahren; Verordnungsermächtigung","Gesetz","ZPO","Artikel","Absaetze",[204,236,278,314],{"_25":205,"_206":207,"_27":28,"_215":216},"qa6whcwveoqofa32go7qv776","Text",[208],{"_34":35,"_36":209},[210,213],{"_39":211,"_34":39,"_212":13},"Die digitalen Eingabesysteme nach § 1124 Absatz 1 und 2 werden vom Bundesministerium der Justiz als Referenzimplementierung entwickelt und den Ländern zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitgestellt. Die Länder können weitere digitale Eingabesysteme entwickeln und zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitstellen.[6]","underline",{"_39":214,"_34":39}," Das Bundesministerium der Justiz regelt durch Rechtsverordnung mit Zustimmung des Bundesrates die technischen, organisatorischen und datenschutzrechtlichen Rahmenbedingungen für Entwicklung, Betrieb, Pflege und Weiterentwicklung der digitalen Eingabesysteme nach Satz 2.","PrinzipErfuellungen",[217],{"_218":219,"_220":221,"_226":227},"id","1357","Erklaerung",[222],{"_34":35,"_36":223},[224],{"_39":225,"_34":39},"Die Entwicklung und bundeseinheitliche Bereitstellung von Referenzimplementierungen fördert die Nutzung etablierter und standardisierter Lösungen.","Prinzip",{"_25":89,"_27":90,"_29":91,"_31":228,"_63":104,"_65":105,"_67":106},[229],{"_34":35,"_36":230},[231,232,235],{"_39":96,"_34":39},{"_78":98,"_34":80,"_36":233},[234],{"_39":101,"_34":39},{"_39":103,"_34":39},{"_25":237,"_206":238,"_27":70,"_215":245},"u0ckfjpr9xr37um16815aq9u",[239],{"_34":35,"_36":240},[241,243],{"_39":242,"_34":39},"Die nach Absatz 1 entwickelten digitalen Eingabesysteme sind über ein Justizportal des Bundes und der Länder für die Nutzer bereitzustellen. ",{"_39":244,"_34":39,"_212":13},"Sie sind nach Maßgabe der Barrierefreie-Informationstechnik-Verordnung barrierefrei zu gestalten. Ferner ist bei der Gestaltung der digitalen Eingabesysteme deren Nutzerfreundlichkeit sowie eine einfache und intuitive Bedienbarkeit sicherzustellen.[1]",[246],{"_218":247,"_220":248,"_226":259},"1365",[249],{"_34":46,"_47":48,"_36":250},[251,255],{"_34":51,"_36":252},[253],{"_39":254,"_34":39},"Die digitale Eingabesysteme und die Kommunikationsplattform werden gemäß der Barrierefreie-Informationstechnik-Verordnung barrierefrei gestaltet, um die Inklusivität digitaler Angebote zu gewährleisten.",{"_34":51,"_36":256},[257],{"_39":258,"_34":39},"Schreibt Nutzerfreundlichkeit für die Kommunikationsplattform vor.",{"_25":26,"_27":28,"_29":30,"_31":260,"_63":64,"_65":66,"_67":28},[261,264,267],{"_34":35,"_36":262},[263],{"_39":40,"_34":39},{"_34":35,"_36":265},[266],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":268},[269,272,275],{"_34":51,"_36":270},[271],{"_39":54,"_34":39},{"_34":51,"_36":273},[274],{"_39":58,"_34":39},{"_34":51,"_36":276},[277],{"_39":62,"_34":39},{"_25":279,"_206":280,"_27":106,"_215":285},"hxksok3ze7ao3bvrxgiei5nx",[281],{"_34":35,"_36":282},[283],{"_39":284,"_34":39,"_212":13},"Die Stelle, die digitale Eingabesysteme nach Absatz 1 bereitstellt, darf personenbezogene Daten nur verarbeiten, soweit dies für die Zwecke der Unterstützung der digitalen Kommunikation nach § 1124 Absatz 1 und 2 erforderlich ist. Die Daten dürfen in den digitalen Eingabesystemen zwischengespeichert werden, um dem Nutzer zu ermöglichen, sie zu einem späteren Zeitpunkt zu vervollständigen, zu korrigieren oder zu löschen. Die zwischengespeicherten Daten sind spätestens 30 Tage nach der letzten Bearbeitung der digitalen Eingabesysteme automatisch zu löschen.[3]",[286],{"_218":287,"_220":288,"_226":299},"1359",[289],{"_34":46,"_47":48,"_36":290},[291,295],{"_34":51,"_36":292},[293],{"_39":294,"_34":39},"Legt die Zwecke fest, wann personenbezogene Daten verarbeitet werden können.",{"_34":51,"_36":296},[297],{"_39":298,"_34":39},"Schreibt die Löschung personenbezogener Daten vor, was die Privatsphäre der Nutzer schützt und die Speicherung von Daten minimiert.",{"_25":150,"_27":106,"_29":151,"_31":300,"_63":172,"_65":173,"_67":109},[301,308,311],{"_34":35,"_36":302},[303,304,307],{"_39":156,"_34":39},{"_78":158,"_34":80,"_36":305},[306],{"_39":161,"_34":39},{"_39":163,"_34":39},{"_34":35,"_36":309},[310],{"_39":167,"_34":39},{"_34":35,"_36":312},[313],{"_39":171,"_34":39},{"_25":315,"_206":316,"_27":148,"_215":321},"gjn22iuco2wjihcrtefxcvdr",[317],{"_34":35,"_36":318},[319],{"_39":320,"_34":39,"_212":13},"Elektronische Dokumente, die mithilfe digitaler Eingabesysteme erzeugt wurden, können abweichend von § 2 Absatz 1 der Elektronischer-Rechtsverkehr-Verordnung als strukturierter Datensatz übermittelt werden, sofern für diesen im Online-Verfahren eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[1]",[322],{"_218":323,"_220":324,"_226":335},"1361",[325],{"_34":46,"_47":48,"_36":326},[327,331],{"_34":51,"_36":328},[329],{"_39":330,"_34":39},"Ermöglicht die strukturierte Datenübermittlung und die gemeinsame digitale Bearbeitung von Dokumenten, wodurch Verwaltungsprozesse effizienter werden und manuelle Arbeitsschritte entfallen.",{"_34":51,"_36":332},[333],{"_39":334,"_34":39},"Nicht nur für die Verfahrensbeteiligten, sondern auch für die Gerichte wird ein digitales Verfahren geschaffen.",{"_25":26,"_27":28,"_29":30,"_31":336,"_63":64,"_65":66,"_67":28},[337,340,343],{"_34":35,"_36":338},[339],{"_39":40,"_34":39},{"_34":35,"_36":341},[342],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":344},[345,348,351],{"_34":51,"_36":346},[347],{"_39":54,"_34":39},{"_34":51,"_36":349},[350],{"_39":58,"_34":39},{"_34":51,"_36":352},[353],{"_39":62,"_34":39},{"_25":355,"_27":356,"_178":357,"_199":200,"_201":-5,"_202":358},"ykl903yprafl57twhoivw8gi","1126","Digitale Strukturierung",[359,397],{"_25":360,"_206":361,"_27":28,"_215":368},"bvmw4a7bjjekz9auqjg0p02k",[362],{"_34":35,"_36":363},[364,366],{"_39":365,"_34":39},"Das Gericht kann Maßnahmen der Prozessleitung ergreifen, um den Streitstoff zu strukturieren. ",{"_39":367,"_34":39,"_212":13},"Für die Strukturierung nach Satz 1 können digitale Eingabesysteme nach § 1124 Absatz 2, strukturierte Datensätze oder elektronische Dokumente genutzt werden.[1]",[369],{"_218":370,"_220":371,"_226":378},"1421",[372],{"_34":46,"_47":48,"_36":373},[374],{"_34":51,"_36":375},[376],{"_39":377,"_34":39},"Ermöglicht den Einsatz digitaler Eingabesysteme zur Aufbereitung des Streitstoffs.",{"_25":26,"_27":28,"_29":30,"_31":379,"_63":64,"_65":66,"_67":28},[380,383,386],{"_34":35,"_36":381},[382],{"_39":40,"_34":39},{"_34":35,"_36":384},[385],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":387},[388,391,394],{"_34":51,"_36":389},[390],{"_39":54,"_34":39},{"_34":51,"_36":392},[393],{"_39":58,"_34":39},{"_34":51,"_36":395},[396],{"_39":62,"_34":39},{"_25":398,"_206":399,"_27":70,"_215":417},"bbeox0j5wu1lo0vl6fze2f5h",[400,404],{"_34":35,"_36":401},[402],{"_39":403,"_34":39},"Das Gericht kann insbesondere",{"_34":46,"_47":405,"_36":406},"ordered",[407,413],{"_34":51,"_36":408},[409,411],{"_39":410,"_34":39,"_212":13},"anordnen, dass die Parteien ihren jeweiligen weiteren Vortrag demjenigen der anderen Partei in digitaler Form gegenüberstellen[1]",{"_39":412,"_34":39},", und",{"_34":51,"_36":414},[415],{"_39":416,"_34":39},"den Parteien die Ergänzung oder Erläuterung ihres Vortrags durch Zuordnung von Eingabefeldern zum jeweiligen Streitstoff aufgeben; hiermit kann eine Frist zur Erklärung über bestimmte klärungsbedürftige Punkte verbunden werden.",[418],{"_218":419,"_220":420,"_226":427},"1427",[421],{"_34":46,"_47":48,"_36":422},[423],{"_34":51,"_36":424},[425],{"_39":426,"_34":39},"Erlaubt den Gerichten, digitale Kommunikation anzuordnen.",{"_25":26,"_27":28,"_29":30,"_31":428,"_63":64,"_65":66,"_67":28},[429,432,435],{"_34":35,"_36":430},[431],{"_39":40,"_34":39},{"_34":35,"_36":433},[434],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":436},[437,440,443],{"_34":51,"_36":438},[439],{"_39":54,"_34":39},{"_34":51,"_36":441},[442],{"_39":58,"_34":39},{"_34":51,"_36":444},[445],{"_39":62,"_34":39},{"_25":447,"_27":448,"_178":449,"_199":200,"_201":-5,"_202":450},"ee2edmkcxhrx7nz62ocyi4wx","1128","Beweisaufnahme",[451,493,535],{"_25":452,"_206":453,"_27":28,"_215":460},"b13utzg69rjc3esc0x9d7xgj",[454],{"_34":35,"_36":455},[456,458],{"_39":457,"_34":39,"_212":13},"In geeigneten Fällen kann das Gericht auf Antrag oder von Amts wegen abweichend von § 284 Absatz 2 Satz 1 in Verbindung mit § 495 die Beweisaufnahme auch durch Tonübertragung oder mithilfe anderer geeigneter digitaler Kommunikationsmittel gestatten[1]",{"_39":459,"_34":39}," oder anordnen. § 284 Absatz 2 Satz 2 bis 5 und Absatz 3 in Verbindung mit § 495 bleibt unberührt.",[461],{"_218":462,"_220":463,"_226":474},"1413",[464],{"_34":46,"_47":48,"_36":465},[466,470],{"_34":51,"_36":467},[468],{"_39":469,"_34":39},"Beweisaufnahme wird durch digitale Kommunikationsmittel ermöglicht. ",{"_34":51,"_36":471},[472],{"_39":473,"_34":39},"Gewährleistet Technologieoffenheit durch die Verwendung breiter Begriffe wie „andere geeignete digitale Kommunikationsmittel” anstelle spezifischer Technologien.",{"_25":26,"_27":28,"_29":30,"_31":475,"_63":64,"_65":66,"_67":28},[476,479,482],{"_34":35,"_36":477},[478],{"_39":40,"_34":39},{"_34":35,"_36":480},[481],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":483},[484,487,490],{"_34":51,"_36":485},[486],{"_39":54,"_34":39},{"_34":51,"_36":488},[489],{"_39":58,"_34":39},{"_34":51,"_36":491},[492],{"_39":62,"_34":39},{"_25":494,"_206":495,"_27":70,"_215":502},"g6gde7i5hb4827m0zfobti44",[496],{"_34":35,"_36":497},[498,500],{"_39":499,"_34":39,"_212":13},"Das Gericht kann abweichend von § 357 Absatz 1 in Verbindung mit § 495 entscheidungserhebliche Tatsachen auch durch Aussagen von Zeugen und Auskünfte von Sachverständigen feststellen, die mittels Bild- und Tonübertragung, schriftlich, elektronisch, telefonisch oder mithilfe anderer geeigneter digitaler Kommunikationsmittel erfolgen.[1]",{"_39":501,"_34":39}," Eines Beweisbeschlusses nach § 358 bis § 360 in Verbindung mit § 495 bedarf es nicht. Den Parteien ist Gelegenheit zu geben, zu dem Ergebnis der Beweisaufnahme Stellung zu nehmen.",[503],{"_218":504,"_220":505,"_226":516},"1415",[506],{"_34":46,"_47":48,"_36":507},[508,512],{"_34":51,"_36":509},[510],{"_39":511,"_34":39},"Erlaubt digitale Kommunikationsmittel für Aussagen",{"_34":51,"_36":513},[514],{"_39":515,"_34":39},"Erlaubt weiterhin nicht digitale Alternativen, um allen Menschen die Teilnahme zu ermöglichen",{"_25":26,"_27":28,"_29":30,"_31":517,"_63":64,"_65":66,"_67":28},[518,521,524],{"_34":35,"_36":519},[520],{"_39":40,"_34":39},{"_34":35,"_36":522},[523],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":525},[526,529,532],{"_34":51,"_36":527},[528],{"_39":54,"_34":39},{"_34":51,"_36":530},[531],{"_39":58,"_34":39},{"_34":51,"_36":533},[534],{"_39":62,"_34":39},{"_25":536,"_206":537,"_27":106,"_215":542},"l9zscmsi39oase3o43o3uypr",[538],{"_34":35,"_36":539},[540],{"_39":541,"_34":39},"Für die Parteivernehmung gilt Absatz 2 Satz 1 und 3 entsprechend. Eines Beweisbeschlusses nach § 450 in Verbindung mit § 495 bedarf es nicht.",[],{"_25":544,"_27":545,"_178":546,"_199":200,"_201":-5,"_202":547},"frp23027s2orsp17fxi5owym","1130","Entwicklung und Bereitstellung; Verordnungsermächtigungen",[548,589,614,654,690],{"_25":549,"_206":550,"_27":28,"_215":557},"ya20w3ujaqacq8tl254r8q5g",[551],{"_34":35,"_36":552},[553,555],{"_39":554,"_34":39},"Im Online-Verfahren kann eine Kommunikationsplattform genutzt werden, die der bundeseinheitlichen Erprobung digitaler Kommunikations-, Austausch- und Übermittlungsformen zwischen den Verfahrensbeteiligten und mit dem Gericht dient.",{"_39":556,"_34":39,"_212":13}," Die Kommunikationsplattform kann auch zur Bereitstellung oder gemeinschaftlichen Bearbeitung elektronischer Dokumente durch die Verfahrensbeteiligten und das Gericht genutzt werden. Das Gericht kann in entsprechender Anwendung des § 1126 Maßnahmen der Prozessleitung ergreifen, um den Streitstoff unter Nutzung der Kommunikationsplattform zu strukturieren.[1]",[558],{"_218":559,"_220":560,"_226":570},"1369",[561],{"_34":46,"_47":48,"_36":562},[563,567],{"_34":51,"_36":564},[565],{"_39":566,"_34":39},"Es wird die strukturierte Datenübermittlung und die gemeinsame digitale Bearbeitung von Dokumenten ermöglicht, wodurch Verwaltungsprozesse effizienter werden und manuelle Arbeitsschritte entfallen.",{"_34":51,"_36":568},[569],{"_39":334,"_34":39},{"_25":26,"_27":28,"_29":30,"_31":571,"_63":64,"_65":66,"_67":28},[572,575,578],{"_34":35,"_36":573},[574],{"_39":40,"_34":39},{"_34":35,"_36":576},[577],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":579},[580,583,586],{"_34":51,"_36":581},[582],{"_39":54,"_34":39},{"_34":51,"_36":584},[585],{"_39":58,"_34":39},{"_34":51,"_36":587},[588],{"_39":62,"_34":39},{"_25":590,"_206":591,"_27":70,"_215":598},"km96qmspgbqzjcnyds8bywmv",[592],{"_34":35,"_36":593},[594,596],{"_39":595,"_34":39,"_212":13},"Die Kommunikationsplattform wird vom Bundesministerium der Justiz als Referenzimplementierung entwickelt und den Ländern zur Anwendung bei den nach § 1123 bestimmten Gerichten bundeseinheitlich bereitgestellt. Die Länder können die Entwicklung und die bundeseinheitliche Bereitstellung der Kommunikationsplattform nach Satz 1 zur Anwendung bei den nach § 1123 bestimmten Gerichten übernehmen; entsprechendes gilt für die Bereitstellung weiterer Anwendungsmodule für die Zwecke nach Absatz 1.[6]",{"_39":597,"_34":39}," Das Bundesministerium der Justiz regelt durch Rechtsverordnung mit Zustimmung des Bundesrates die technischen, organisatorischen und datenschutzrechtlichen Rahmenbedingungen für Entwicklung, Betrieb, Pflege und Weiterentwicklung der Kommunikationsplattform nach Satz 2 und ihrer Anwendungsmodule.",[599],{"_218":600,"_220":601,"_226":605},"1371",[602],{"_34":35,"_36":603},[604],{"_39":225,"_34":39},{"_25":89,"_27":90,"_29":91,"_31":606,"_63":104,"_65":105,"_67":106},[607],{"_34":35,"_36":608},[609,610,613],{"_39":96,"_34":39},{"_78":98,"_34":80,"_36":611},[612],{"_39":101,"_34":39},{"_39":103,"_34":39},{"_25":615,"_206":616,"_27":106,"_215":623},"yaa803r10yjs4h9ay4srsb84",[617],{"_34":35,"_36":618},[619,621],{"_39":620,"_34":39},"Die nach Absatz 2 entwickelte Kommunikationsplattform ist über ein Justizportal des Bundes und der Länder für die Nutzer bereitzustellen. ",{"_39":622,"_34":39,"_212":13},"Sie ist nach Maßgabe der Barrierefreie-Informationstechnik-Verordnung barrierefrei zu gestalten. Ferner ist bei der Gestaltung der Kommunikationsplattform deren Nutzerfreundlichkeit sowie eine einfache und intuitive Bedienbarkeit sicherzustellen.[1]",[624],{"_218":625,"_220":626,"_226":635},"1373",[627],{"_34":46,"_47":48,"_36":628},[629,632],{"_34":51,"_36":630},[631],{"_39":254,"_34":39},{"_34":51,"_36":633},[634],{"_39":258,"_34":39},{"_25":26,"_27":28,"_29":30,"_31":636,"_63":64,"_65":66,"_67":28},[637,640,643],{"_34":35,"_36":638},[639],{"_39":40,"_34":39},{"_34":35,"_36":641},[642],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":644},[645,648,651],{"_34":51,"_36":646},[647],{"_39":54,"_34":39},{"_34":51,"_36":649},[650],{"_39":58,"_34":39},{"_34":51,"_36":652},[653],{"_39":62,"_34":39},{"_25":655,"_206":656,"_27":148,"_215":663},"lwppx62h2r3ci8i26jighqp5",[657],{"_34":35,"_36":658},[659,661],{"_39":660,"_34":39,"_212":13},"Die Stelle, die die Kommunikationsplattform nach Absatz 2 bereitstellt, darf personenbezogene Daten nur verarbeiten, soweit dies für die Zwecke nach Absatz 1 erforderlich ist. Die Daten sind spätestens nach rechtskräftigem Abschluss oder nach sonstiger Beendigung des Verfahrens von der Kommunikationsplattform zu löschen.[3]",{"_39":662,"_34":39}," Elektronische Dokumente, Datensätze und sonstige Informationen aus dem über die Kommunikationsplattform geführten Verfahren sind zu den elektronisch geführten Prozessakten nach § 298a zu nehmen.",[664],{"_218":665,"_220":666,"_226":675},"1367",[667],{"_34":46,"_47":48,"_36":668},[669,672],{"_34":51,"_36":670},[671],{"_39":294,"_34":39},{"_34":51,"_36":673},[674],{"_39":298,"_34":39},{"_25":150,"_27":106,"_29":151,"_31":676,"_63":172,"_65":173,"_67":109},[677,684,687],{"_34":35,"_36":678},[679,680,683],{"_39":156,"_34":39},{"_78":158,"_34":80,"_36":681},[682],{"_39":161,"_34":39},{"_39":163,"_34":39},{"_34":35,"_36":685},[686],{"_39":167,"_34":39},{"_34":35,"_36":688},[689],{"_39":171,"_34":39},{"_25":691,"_206":692,"_27":109,"_215":697},"fwmioex4hhujydsvsveiw9h7",[693],{"_34":35,"_36":694},[695],{"_39":696,"_34":39,"_212":13},"Das Bundesministerium der Justiz wird ermächtigt, durch Rechtsverordnung mit Zustimmung des Bundesrates die für die Datenübermittlung geltenden Standards und Dateiformate und die Ausgestaltung des Datenschutzes bei Nutzung der Kommunikationsplattform festzulegen.[2]",[698],{"_218":699,"_220":700,"_226":705},"1375",[701],{"_34":35,"_36":702},[703],{"_39":704,"_34":39},"Ermöglicht die Festlegung von Standards für die Datenübermittlung der Kommunikationsplattform durch Rechtsverordnung. Dadurch werden Interoperabilität und Datenaustausch begünstigt.",{"_25":69,"_27":70,"_29":71,"_31":706,"_63":86,"_65":87,"_67":70},[707],{"_34":35,"_36":708},[709,710,713],{"_39":76,"_34":39},{"_78":79,"_34":80,"_36":711},[712],{"_39":83,"_34":39},{"_39":85,"_34":39},{"_25":715,"_27":716,"_178":717,"_199":200,"_201":-5,"_202":718},"vqxve0zgrejbf0za0x2ye8gn","1131","Kommunikations-, Austausch- und Übermittlungsformen",[719,791,900,930,941],{"_25":720,"_206":721,"_27":28,"_215":742},"g6pdcvhx2a4cleuywyb0fbuu",[722,728,738],{"_34":35,"_36":723},[724,726],{"_39":725,"_34":39,"_212":13},"Eine in diesem Gesetz angeordnete Schriftform kann durch unmittelbare Eingabe von Anträgen und Erklärungen der Verfahrensbeteiligten über die Kommunikationsplattform nach § 1130 ersetzt werden[1]",{"_39":727,"_34":39},", sofern hierfür digitale Eingabesysteme zur Verfügung stehen und eines der folgenden Identifizierungsverfahren genutzt wird:",{"_34":46,"_47":405,"_36":729},[730,734],{"_34":51,"_36":731},[732],{"_39":733,"_34":39,"_212":13},"für die Identifizierung von Rechtsanwälten: das Verfahren zum Zugang zum besonderen elektronischen Anwaltspostfach nach § 31a Absatz 3 Satz 1 der Bundesrechtsanwaltsordnung;",{"_34":51,"_36":735},[736],{"_39":737,"_34":39,"_212":13},"für die Identifizierung anderer Verfahrensbeteiligter: ein Verfahren über ein Nutzerkonto nach § 2 Absatz 5 in Verbindung mit § 3 Absatz 4 des Onlinezugangsgesetzes.[6]",{"_34":35,"_36":739},[740],{"_39":741,"_34":39},"Wurde der Nachweis der Identität nach Satz 1 erbracht, so kann die spätere Authentisierung des Inhabers des Identitätsnachweises auch durch andere geeignete Authentisierungsmittel erfolgen.",[743,759],{"_218":744,"_220":745,"_226":750},"1323",[746],{"_34":35,"_36":747},[748],{"_39":749,"_34":39},"Mit dem elektronischen Anwaltspostfach und den OZG-Nutzerkonten können bewährte Identifizierungsverfahren und bestehende Systeme genutzt werden.",{"_25":89,"_27":90,"_29":91,"_31":751,"_63":104,"_65":105,"_67":106},[752],{"_34":35,"_36":753},[754,755,758],{"_39":96,"_34":39},{"_78":98,"_34":80,"_36":756},[757],{"_39":101,"_34":39},{"_39":103,"_34":39},{"_218":760,"_220":761,"_226":772},"1324",[762],{"_34":46,"_47":48,"_36":763},[764,768],{"_34":51,"_36":765},[766],{"_39":767,"_34":39},"Ermöglicht die Ersetzung angeordneter Schriftformerfordernisse durch die Kommunikationsplattform. ",{"_34":51,"_36":769},[770],{"_39":771,"_34":39},"Diese Ersetzung erfolgt durch die Eingabe von Anträgen und Erklärungen der Verfahrensbeteiligten.",{"_25":26,"_27":28,"_29":30,"_31":773,"_63":64,"_65":66,"_67":28},[774,777,780],{"_34":35,"_36":775},[776],{"_39":40,"_34":39},{"_34":35,"_36":778},[779],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":781},[782,785,788],{"_34":51,"_36":783},[784],{"_39":54,"_34":39},{"_34":51,"_36":786},[787],{"_39":58,"_34":39},{"_34":51,"_36":789},[790],{"_39":62,"_34":39},{"_25":792,"_206":793,"_27":70,"_215":814},"fvj31s0fav5aw2vlu65q0arw",[794,800],{"_34":35,"_36":795},[796,798],{"_39":797,"_34":39,"_212":13},"Eine in diesem Gesetz angeordnete Schriftform kann auch durch Übermittlung elektronischer Dokumente oder strukturierter Datensätze über die Kommunikationsplattform ersetzt werden[1]",{"_39":799,"_34":39},", sofern",{"_34":46,"_47":405,"_36":801},[802,806,810],{"_34":51,"_36":803},[804],{"_39":805,"_34":39},"ein Identifizierungsverfahren nach Absatz 1 genutzt wird,",{"_34":51,"_36":807},[808],{"_39":809,"_34":39,"_212":13},"bei der Datenübermittlung ein sicheres Verfahren verwendet wird, das die Authentizität und Integrität der Daten gewährleistet, und [3]",{"_34":51,"_36":811},[812],{"_39":813,"_34":39,"_212":13},"für die elektronischen Dokumente oder strukturierten Datensätze auf der Kommunikationsplattform eine automatisierte Bearbeitung durch das Gericht eröffnet ist.[5]",[815,847,878],{"_218":816,"_220":817,"_226":828},"1333",[818],{"_34":46,"_47":48,"_36":819},[820,824],{"_34":51,"_36":821},[822],{"_39":823,"_34":39},"Die digitale Übermittlung von Dokumenten ermöglicht eine Kommunikation über die digitale Kommunikationsplattform.",{"_34":51,"_36":825},[826],{"_39":827,"_34":39},"Schriftformerfordernisse werden durch die digitale Übermittlung ersetzt.",{"_25":26,"_27":28,"_29":30,"_31":829,"_63":64,"_65":66,"_67":28},[830,833,836],{"_34":35,"_36":831},[832],{"_39":40,"_34":39},{"_34":35,"_36":834},[835],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":837},[838,841,844],{"_34":51,"_36":839},[840],{"_39":54,"_34":39},{"_34":51,"_36":842},[843],{"_39":58,"_34":39},{"_34":51,"_36":845},[846],{"_39":62,"_34":39},{"_218":848,"_220":849,"_226":856},"1334",[850],{"_34":46,"_47":48,"_36":851},[852],{"_34":51,"_36":853},[854],{"_39":855,"_34":39},"Geht von einer automatisierten Bearbeitung der Daten aus.",{"_25":108,"_27":109,"_29":110,"_31":857,"_63":146,"_65":147,"_67":148},[858,869],{"_34":35,"_36":859},[860,861,864,865,868],{"_39":115,"_34":39},{"_78":117,"_34":80,"_36":862},[863],{"_39":120,"_34":39},{"_39":122,"_34":39},{"_78":124,"_34":80,"_36":866},[867],{"_39":127,"_34":39},{"_39":129,"_34":39},{"_34":35,"_36":870},[871,872,873,874,877],{"_39":133,"_34":39},{"_39":135,"_34":39,"_136":13},{"_39":138,"_34":39},{"_78":140,"_34":80,"_36":875},[876],{"_39":143,"_34":39},{"_39":145,"_34":39},{"_218":879,"_220":880,"_226":885},"1335",[881],{"_34":35,"_36":882},[883],{"_39":884,"_34":39},"Stellt die Informationssicherheit sicher, indem sie die Anforderung eines sicheren Verfahrens stellt, das die Authentizität und Integrität der Daten gewährleistet.",{"_25":150,"_27":106,"_29":151,"_31":886,"_63":172,"_65":173,"_67":109},[887,894,897],{"_34":35,"_36":888},[889,890,893],{"_39":156,"_34":39},{"_78":158,"_34":80,"_36":891},[892],{"_39":161,"_34":39},{"_39":163,"_34":39},{"_34":35,"_36":895},[896],{"_39":167,"_34":39},{"_34":35,"_36":898},[899],{"_39":171,"_34":39},{"_25":901,"_206":902,"_27":106,"_215":907},"mwwaz6co63k51t39bytz8p98",[903],{"_34":35,"_36":904},[905],{"_39":906,"_34":39,"_212":13},"Die Gerichte haben bei der digitalen Kommunikation mit den Verfahrensbeteiligten und bei der Bereitstellung von elektronischen Dokumenten zum Abruf ein sicheres Verfahren zu verwenden, das die Authentizität und Integrität der Daten gewährleistet.[3]",[908],{"_218":909,"_220":910,"_226":915},"1339",[911],{"_34":35,"_36":912},[913],{"_39":914,"_34":39},"Sichere Übermittlungswege und Verfahren gewährleisten, dass die Daten authentisch sind und nicht verändert wurden.",{"_25":150,"_27":106,"_29":151,"_31":916,"_63":172,"_65":173,"_67":109},[917,924,927],{"_34":35,"_36":918},[919,920,923],{"_39":156,"_34":39},{"_78":158,"_34":80,"_36":921},[922],{"_39":161,"_34":39},{"_39":163,"_34":39},{"_34":35,"_36":925},[926],{"_39":167,"_34":39},{"_34":35,"_36":928},[929],{"_39":171,"_34":39},{"_25":931,"_206":932,"_27":148,"_215":940},"tjm6vubta7iq89gcl5qi9kws",[933,937],{"_34":35,"_36":934},[935],{"_39":936,"_34":39},"Bei der Bereitstellung eines elektronischen Dokuments über die Kommunikationsplattform ist der Empfänger über das von ihm zu diesem Zweck angegebene Postfach oder die von ihm zu diesem Zweck angegebene Adresse spätestens am Tag der Bereitstellung des elektronischen Dokuments darüber zu benachrichtigen, dass dieses abgerufen werden kann. Satz 1 gilt entsprechend für die weitere digitale Kommunikation zwischen dem Gericht und den Verfahrensbeteiligten über die Kommunikationsplattform.",{"_34":35,"_36":938},[939],{"_39":20,"_34":39},[],{"_25":942,"_206":943,"_27":109,"_215":952},"sbmjz7pqq3o5va1wjxgdyc5z",[944],{"_34":35,"_36":945},[946,948,950],{"_39":947,"_34":39},"Mit Zustimmung des Empfängers, die für das jeweilige Verfahren erteilt wird und nur mit Wirkung für die Zukunft widerruflich ist, kann abweichend von § 173 Absatz 1 ein elektronisches Dokument auch zugestellt werden, indem es zum Datenabruf über die Kommunikationsplattform bereitgestellt wird. Der Empfänger hat sich beim Datenabruf zu authentisieren. ",{"_39":949,"_34":39,"_212":13},"Die Zeitpunkte der Bereitstellung und des Abrufs sind dem Empfänger und dem Gericht automatisiert zu bestätigen.[5]",{"_39":951,"_34":39}," § 173 Absatz 4 Satz 4 und 5 ist entsprechend anzuwenden.",[953],{"_218":954,"_220":955,"_226":960},"1341",[956],{"_34":35,"_36":957},[958],{"_39":959,"_34":39},"Schreibt automatisierte Bestätigung der Zustellung und des Abrufs vor.",{"_25":108,"_27":109,"_29":110,"_31":961,"_63":146,"_65":147,"_67":148},[962,973],{"_34":35,"_36":963},[964,965,968,969,972],{"_39":115,"_34":39},{"_78":117,"_34":80,"_36":966},[967],{"_39":120,"_34":39},{"_39":122,"_34":39},{"_78":124,"_34":80,"_36":970},[971],{"_39":127,"_34":39},{"_39":129,"_34":39},{"_34":35,"_36":974},[975,976,977,978,981],{"_39":133,"_34":39},{"_39":135,"_34":39,"_136":13},{"_39":138,"_34":39},{"_78":140,"_34":80,"_36":979},[980],{"_39":143,"_34":39},{"_39":145,"_34":39},{"_25":983,"_27":984,"_178":985,"_199":200,"_201":-5,"_202":986},"vdbj7ukv75e2m8qj8n5k52m4","1134","Umfang der Erprobung",[987,1013],{"_25":988,"_206":989,"_27":28,"_215":996},"u3sg1zismobz1t707uo3xav8",[990],{"_34":35,"_36":991},[992,994],{"_39":993,"_34":39,"_212":13},"Das Bundesministerium der Justiz kann digitale Eingabesysteme als Referenzimplementierung entwickeln und bundeseinheitlich zur Erprobung bereitstellen, soweit diese dem elektronischen Erstellen von Anträgen oder Erklärungen nach § 129a Absatz 1 dienen.[6]",{"_39":995,"_34":39}," Satz 1 gilt nicht im Anwendungsbereich des Online-Verfahrens nach Abschnitt 2 dieses Buchs.",[997],{"_218":998,"_220":999,"_226":1004},"1423",[1000],{"_34":35,"_36":1001},[1002],{"_39":1003,"_34":39},"Durch die Entwicklung und bundeseinheitliche Bereitstellung von Referenzimplementierungen kann eine standardisierte Lösung zur Nachnutzung bereitgestellt werden.",{"_25":89,"_27":90,"_29":91,"_31":1005,"_63":104,"_65":105,"_67":106},[1006],{"_34":35,"_36":1007},[1008,1009,1012],{"_39":96,"_34":39},{"_78":98,"_34":80,"_36":1010},[1011],{"_39":101,"_34":39},{"_39":103,"_34":39},{"_25":1014,"_206":1015,"_27":70,"_215":1020},"kvqblclxkwodab6ffl3qexid",[1016],{"_34":35,"_36":1017},[1018],{"_39":1019,"_34":39},"§ 1125 Absatz 2 bis 4 gilt entsprechend.",[],"Visualisierungen",[1023],{"_25":1024,"_178":1025,"_31":1026,"_1064":1065,"_1066":1067,"_1068":-5,"_183":-5,"_1069":1070,"_1076":1077},"e92syjtajombxqgan8ygq9i7","Ablauf eines Online-Verfahrens",[1027,1031],{"_34":35,"_36":1028},[1029],{"_39":1030,"_34":39,"_136":13},"Ablauf eines Online-Verfahrens in der Zivilgerichtsbarkeit nach ZPO",{"_34":46,"_47":48,"_36":1032},[1033,1040,1046,1052],{"_34":51,"_36":1034},[1035,1038],{"_1036":13,"_39":1037,"_34":39},"bold","Unterteilt den Gesamtprozess in drei abgegrenzte Bereiche ",{"_39":1039,"_34":39},"und erleichtert so die Orientierung im Prozess.",{"_34":51,"_36":1041},[1042,1044],{"_39":1043,"_34":39},"Erleichtert das Auffinden der relevanten Textpassagen durch ",{"_1036":13,"_39":1045,"_34":39},"explizite Nennung der Regelungen, Paragraphen, Absätze und Sätze.",{"_34":51,"_36":1047},[1048,1050],{"_1036":13,"_39":1049,"_34":39},"Markiert den Kernaspekt der Regelung",{"_39":1051,"_34":39}," durch Verwendung einheitlicher Symbole. ",{"_34":51,"_36":1053},[1054,1056,1058,1060,1062],{"_39":1055,"_34":39},"Verwendet Rauten als ",{"_1036":13,"_39":1057,"_34":39},"geläufige Darstellung für Entscheidungen in Flussdiagrammen, ",{"_39":1059,"_34":39},"um",{"_1036":13,"_39":1061,"_34":39}," ",{"_39":1063,"_34":39},"schnelles Verständnis zu gewährleisten.","Visualisierungsart","Flussdiagramm","Visualisierungstool","draw.io","Aufwand","Bild",{"_25":1071,"_78":1072,"_1073":-5,"_1074":1075},"mfnncvpa89wdjbd4k1wcvky3","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/BMJ_7065_Visualisierung_OV_Erp_G_DB_3_BMJ_0c71f91453.png","previewUrl","alternativeText","Die Abbildung zeigt das Online-Verfahren in der Zivilgerichtsbarkeit, welches nach § 1124 I ZPO eröffnet ist.","Beispielvorhaben",{"_63":185,"_186":187,"_182":-5,"_178":179,"_183":184},"Digitalchecks",[1080],{"_25":1081,"_178":179,"_1082":1083,"_1084":1083,"_1085":1083,"_1086":-5,"_1087":1083,"_1088":-5},"nd0p9jrzh3amn085aqpu8g4z","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText"]
