[{"_1":2,"_21":22,"_174":175},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_19":20},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":23},[24,68,88,107,149],{"_25":26,"_27":28,"_29":30,"_31":32,"_63":64,"_65":66,"_67":28},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[33,41,45],{"_34":35,"_36":37},"type","paragraph","children",[38],{"_39":40,"_34":39},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_34":35,"_36":42},[43],{"_39":44,"_34":39},"Erfahren Sie in diesem Abschnitt,",{"_34":46,"_47":48,"_36":49},"list","format","unordered",[50,55,59],{"_34":51,"_36":52},"list-item",[53],{"_39":54,"_34":39},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_34":51,"_36":56},[57],{"_39":58,"_34":39},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_34":51,"_36":60},[61],{"_39":62,"_34":39},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_25":69,"_27":70,"_29":71,"_31":72,"_63":86,"_65":87,"_67":70},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[73],{"_34":35,"_36":74},[75,77,84],{"_39":76,"_34":39},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_78":79,"_34":80,"_36":81},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[82],{"_39":83,"_34":39},"Once-Only-Prinzip",{"_39":85,"_34":39}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_25":89,"_27":90,"_29":91,"_31":92,"_63":104,"_65":105,"_67":106},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[93],{"_34":35,"_36":94},[95,97,102],{"_39":96,"_34":39},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_78":98,"_34":80,"_36":99},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[100],{"_39":101,"_34":39},"Sicherheit der Angebote",{"_39":103,"_34":39}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_25":108,"_27":109,"_29":110,"_31":111,"_63":146,"_65":147,"_67":148},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[112,130],{"_34":35,"_36":113},[114,116,121,123,128],{"_39":115,"_34":39},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_78":117,"_34":80,"_36":118},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[119],{"_39":120,"_34":39},"GGO",{"_39":122,"_34":39}," und das ",{"_78":124,"_34":80,"_36":125},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[126],{"_39":127,"_34":39},"Handbuch der Rechtsförmlichkeit",{"_39":129,"_34":39}," vorgeschrieben.",{"_34":35,"_36":131},[132,134,137,139,144],{"_39":133,"_34":39},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_39":135,"_34":39,"_136":13},"Verwaltungsakt","italic",{"_39":138,"_34":39}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_78":140,"_34":80,"_36":141},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[142],{"_39":143,"_34":39},"§ 35a VwVfG",{"_39":145,"_34":39},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_25":150,"_27":106,"_29":151,"_31":152,"_63":172,"_65":173,"_67":109},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[153,164,168],{"_34":35,"_36":154},[155,157,162],{"_39":156,"_34":39},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_78":158,"_34":80,"_36":159},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[160],{"_39":161,"_34":39},"DSGVO",{"_39":163,"_34":39}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_34":35,"_36":165},[166],{"_39":167,"_34":39},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_34":35,"_36":169},[170],{"_39":171,"_34":39},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":176},{"_25":177,"_178":179,"_180":181,"_182":-5,"_183":184,"_63":185,"_186":-5,"_187":188,"_189":-5,"_190":191,"_192":193,"_194":195,"_232":233},"hd9l569cf26ovo1pfav5fke4","Titel","Entwurf eines Gesetzes zur Einführung einer elektronischen Präsenzbeurkundung","NKRNummer",7621,"Rechtsgebiet","Ressort","BMJV","entwurf-eines-gesetzes-zur-einfuehrung-einer-elektronischen-praesenzbeurkundung","VeroeffentlichungsDatum","LinkRegelungstext","https://dip.bundestag.de/vorgang/gesetz-zur-einf%C3%BChrung-einer-elektronischen-pr%C3%A4senzbeurkundung/324805","NKRStellungnahmeLink","GesetzStatus","Regelungsentwurf","Paragraphen",[],"Visualisierungen",[196],{"_25":197,"_178":198,"_31":199,"_218":219,"_220":221,"_222":-5,"_183":-5,"_223":224,"_230":231},"xvtg21ye68vdd2fmh07enhgj","Visualisierung unterschiedlicher Handlungsoptionen",[200],{"_34":46,"_47":48,"_36":201},[202,206,210,214],{"_34":51,"_36":203},[204],{"_39":205,"_34":39},"Visualisiert unterschiedliche rechtliche Handlungsoptionen als klare Verzweigungen im Ablauf.",{"_34":51,"_36":207},[208],{"_39":209,"_34":39},"Grenzt die Rollen der Beteiligten und des Notars durch \"Schwimmbahnen\" voneinander ab.",{"_34":51,"_36":211},[212],{"_39":213,"_34":39},"Verknüpft jeden Handlungsschritt direkt mit dem konkreten Absatz-Verweis zur einfachen Überprüfbarkeit.",{"_34":51,"_36":215},[216],{"_39":217,"_34":39},"Zeigt den vollständigen \"End-to-End\"-Prozess von der Initiierung bis zur final signierten Niederschrift.","Visualisierungsart","Flussdiagramm","Visualisierungstool","Bizagi","Aufwand","Bild",{"_25":225,"_78":226,"_227":-5,"_228":229},"avdz9w5qo9tufkncvu1y0pr8","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/250624_NKR_7621_Vorschlag_fbed061e1f.PNG","previewUrl","alternativeText","Das vorliegende Diagramm veranschaulicht zwei alternative Optionen für die Signatur durch Beteiligte, nämlich eine qualifizierte elektronische Signatur oder eine eigenhändige Signatur auf einem Gerät. Zudem wird der abschließende Schritt der qualifizierten elektronischen Signatur durch den Notar dargestellt. ","Beispielvorhaben",{"_63":185,"_186":-5,"_182":-5,"_178":179,"_183":184},"Digitalchecks",[234],{"_25":235,"_178":179,"_236":-5,"_237":-5,"_238":-5,"_239":-5,"_240":-5,"_241":-5},"qm5lbua8ez0gyx93g3l87mv4","EinschaetzungAutomatisierung","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText"]
