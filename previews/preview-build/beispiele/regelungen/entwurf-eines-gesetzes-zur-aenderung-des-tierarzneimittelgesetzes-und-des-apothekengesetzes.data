[{"_1":2,"_20":21,"_174":175},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_18":19},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":8,"_13":8,"_14":8,"_15":8,"_16":8,"_17":8},"showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":22},[23,67,87,106,149],{"_24":25,"_26":27,"_28":29,"_30":31,"_62":63,"_64":65,"_66":27},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[32,40,44],{"_33":34,"_35":36},"type","paragraph","children",[37],{"_38":39,"_33":38},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_33":34,"_35":41},[42],{"_38":43,"_33":38},"Erfahren Sie in diesem Abschnitt,",{"_33":45,"_46":47,"_35":48},"list","format","unordered",[49,54,58],{"_33":50,"_35":51},"list-item",[52],{"_38":53,"_33":38},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_33":50,"_35":55},[56],{"_38":57,"_33":38},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_33":50,"_35":59},[60],{"_38":61,"_33":38},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_24":68,"_26":69,"_28":70,"_30":71,"_62":85,"_64":86,"_66":69},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[72],{"_33":34,"_35":73},[74,76,83],{"_38":75,"_33":38},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_77":78,"_33":79,"_35":80},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[81],{"_38":82,"_33":38},"Once-Only-Prinzip",{"_38":84,"_33":38}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_24":88,"_26":89,"_28":90,"_30":91,"_62":103,"_64":104,"_66":105},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[92],{"_33":34,"_35":93},[94,96,101],{"_38":95,"_33":38},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_77":97,"_33":79,"_35":98},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[99],{"_38":100,"_33":38},"Sicherheit der Angebote",{"_38":102,"_33":38}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_24":107,"_26":108,"_28":109,"_30":110,"_62":146,"_64":147,"_66":148},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[111,129],{"_33":34,"_35":112},[113,115,120,122,127],{"_38":114,"_33":38},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_77":116,"_33":79,"_35":117},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[118],{"_38":119,"_33":38},"GGO",{"_38":121,"_33":38}," und das ",{"_77":123,"_33":79,"_35":124},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[125],{"_38":126,"_33":38},"Handbuch der Rechtsförmlichkeit",{"_38":128,"_33":38}," vorgeschrieben.",{"_33":34,"_35":130},[131,133,137,139,144],{"_38":132,"_33":38},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_38":134,"_33":38,"_135":136},"Verwaltungsakt","italic",true,{"_38":138,"_33":38}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_77":140,"_33":79,"_35":141},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[142],{"_38":143,"_33":38},"§ 35a VwVfG",{"_38":145,"_33":38},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_24":150,"_26":105,"_28":151,"_30":152,"_62":172,"_64":173,"_66":108},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[153,164,168],{"_33":34,"_35":154},[155,157,162],{"_38":156,"_33":38},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_77":158,"_33":79,"_35":159},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[160],{"_38":161,"_33":38},"DSGVO",{"_38":163,"_33":38}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_33":34,"_35":165},[166],{"_38":167,"_33":38},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_33":34,"_35":169},[170],{"_38":171,"_33":38},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":176},{"_24":177,"_178":179,"_180":181,"_182":-5,"_183":184,"_62":185,"_186":-5,"_187":188,"_189":-5,"_190":191,"_192":193,"_194":195,"_231":232},"o49nll6wt1f8nl39tfh4jnpv","Titel","Entwurf eines Gesetzes zur Änderung des Tierarzneimittelgesetzes und des Apothekengesetzes","NKRNummer",7563,"Rechtsgebiet","Ressort","BMELH","entwurf-eines-gesetzes-zur-aenderung-des-tierarzneimittelgesetzes-und-des-apothekengesetzes","VeroeffentlichungsDatum","LinkRegelungstext","https://dip.bundestag.de/vorgang/gesetz-zur-%C3%A4nderung-des-tierarzneimittelgesetzes-und-des-apothekengesetzes/324742","NKRStellungnahmeLink","GesetzStatus","Regelungsentwurf","Paragraphen",[],"Visualisierungen",[196],{"_24":197,"_178":198,"_30":199,"_218":219,"_220":-5,"_221":-5,"_183":-5,"_222":223,"_229":230},"dv16mmtbauw4vddjc2dxofcf","Akteure und ihre Handlungsschritte",[200],{"_33":45,"_46":47,"_35":201},[202,206,210,214],{"_33":50,"_35":203},[204],{"_38":205,"_33":38},"Identifiziert die relevanten Akteure (Tierärztin/Tierarzt, Apotheken, Tierhalter/in) durch klare Icons und ordnet ihnen die spezifischen Handlungsschritte zu.",{"_33":50,"_35":207},[208],{"_38":209,"_33":38},"Macht den komplexen rechtlichen Prüfprozess sofort nachvollziehbar, indem die gesetzlichen Voraussetzungen in eindeutige binäre Entscheidungspunkten (\"ja\"/\"nein\") übersetzt werden",{"_33":50,"_35":211},[212],{"_38":213,"_33":38},"Konsolidiert die verschiedenen rechtlichen Zugangswege (über Apotheke oder Tierarzt) in einen einzigen, übersichtlichen Gesamtfluss, der transparent zum Ergebnis (\"Versand erlaubt\" oder \"Versand verboten\") führt.",{"_33":50,"_35":215},[216],{"_38":217,"_33":38},"Legt die festen Prüfregeln offen und macht sichtbar, wo standardisierte Abfragen  im Prozess ansetzen können.","Visualisierungsart","Entscheidungsbaum","Visualisierungstool","Aufwand","Bild",{"_24":224,"_77":225,"_226":-5,"_227":228},"qvjia4vodjv9phd7p9pkddi6","https://secure-dinosaurs-1a634d1a3d.media.strapiapp.com/7563_Prozessvisualisierung_GE_Aend_G_TAMG_Apo_G_Seite_1_edf2c06154.jpg","previewUrl","alternativeText","Flussdiagramm, das den Entscheidungsprozess für den Versand verschreibungspflichtiger Tierarzneimittel gemäß § 44a visualisiert. Es zeigt die unterschiedlichen Prüfwege für Tierärzte und Apotheken, die je nach Erfüllung der gesetzlichen Voraussetzungen zu einem erlaubten oder verbotenen Versand an den Tierhalter führen.","Beispielvorhaben",{"_62":185,"_186":-5,"_182":-5,"_178":179,"_183":184},"Digitalchecks",[]]
