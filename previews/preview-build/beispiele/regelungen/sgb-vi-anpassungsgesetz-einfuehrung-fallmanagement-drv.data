[{"_1":2,"_20":21,"_174":175},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_18":19},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":8,"_13":8,"_14":8,"_15":8,"_16":8,"_17":8},"showGesetzgebungsprozessOverview","showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":22},[23,67,87,106,149],{"_24":25,"_26":27,"_28":29,"_30":31,"_62":63,"_64":65,"_66":27},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[32,40,44],{"_33":34,"_35":36},"type","paragraph","children",[37],{"_38":39,"_33":38},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_33":34,"_35":41},[42],{"_38":43,"_33":38},"Erfahren Sie in diesem Abschnitt,",{"_33":45,"_46":47,"_35":48},"list","format","unordered",[49,54,58],{"_33":50,"_35":51},"list-item",[52],{"_38":53,"_33":38},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_33":50,"_35":55},[56],{"_38":57,"_33":38},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_33":50,"_35":59},[60],{"_38":61,"_33":38},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_24":68,"_26":69,"_28":70,"_30":71,"_62":85,"_64":86,"_66":69},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[72],{"_33":34,"_35":73},[74,76,83],{"_38":75,"_33":38},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_77":78,"_33":79,"_35":80},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[81],{"_38":82,"_33":38},"Once-Only-Prinzip",{"_38":84,"_33":38}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_24":88,"_26":89,"_28":90,"_30":91,"_62":103,"_64":104,"_66":105},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[92],{"_33":34,"_35":93},[94,96,101],{"_38":95,"_33":38},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_77":97,"_33":79,"_35":98},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[99],{"_38":100,"_33":38},"Sicherheit der Angebote",{"_38":102,"_33":38}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_24":107,"_26":108,"_28":109,"_30":110,"_62":146,"_64":147,"_66":148},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[111,129],{"_33":34,"_35":112},[113,115,120,122,127],{"_38":114,"_33":38},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_77":116,"_33":79,"_35":117},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[118],{"_38":119,"_33":38},"GGO",{"_38":121,"_33":38}," und das ",{"_77":123,"_33":79,"_35":124},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[125],{"_38":126,"_33":38},"Handbuch der Rechtsförmlichkeit",{"_38":128,"_33":38}," vorgeschrieben.",{"_33":34,"_35":130},[131,133,137,139,144],{"_38":132,"_33":38},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_38":134,"_33":38,"_135":136},"Verwaltungsakt","italic",true,{"_38":138,"_33":38}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_77":140,"_33":79,"_35":141},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[142],{"_38":143,"_33":38},"§ 35a VwVfG",{"_38":145,"_33":38},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_24":150,"_26":105,"_28":151,"_30":152,"_62":172,"_64":173,"_66":108},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[153,164,168],{"_33":34,"_35":154},[155,157,162],{"_38":156,"_33":38},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_77":158,"_33":79,"_35":159},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[160],{"_38":161,"_33":38},"DSGVO",{"_38":163,"_33":38}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_33":34,"_35":165},[166],{"_38":167,"_33":38},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_33":34,"_35":169},[170],{"_38":171,"_33":38},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":176},{"_24":177,"_178":179,"_180":-5,"_181":-5,"_182":183,"_62":184,"_185":-5,"_186":187,"_188":189,"_190":191,"_192":193,"_370":371,"_372":373},"pr0wygso9gfpl1w2n2aw9wyy","Titel","SGB VI-Anpassungsgesetz – Einführung Fallmanagement DRV","NKRNummer","Rechtsgebiet","Ressort","BMAS","sgb-vi-anpassungsgesetz-einfuehrung-fallmanagement-drv","VeroeffentlichungsDatum","LinkRegelungstext","https://dserver.bundestag.de/brd/2025/0423-25.pdf#page=8","NKRStellungnahmeLink","https://dserver.bundestag.de/brd/2025/0423-25.pdf#page=93","GesetzStatus","Text_im_Parlament","Paragraphen",[194],{"_24":195,"_26":196,"_178":-5,"_197":198,"_199":-5,"_200":201},"bzgq2ra9m59ho4v47c7j463w","13a","Gesetz","SGB VI-AnpG","Artikel","Absaetze",[202,212,278,311,354,362],{"_24":203,"_204":205,"_26":27,"_210":211},"qwo941h8neny30kalf2rg3rz","Text",[206],{"_33":34,"_35":207},[208],{"_38":209,"_33":38},"Die Träger der Rentenversicherung können Versicherte mit gesundheitlichen Beeinträchtigungen und besonderem Unterstützungsbedarf in Bezug auf die berufliche Teilhabe, die die versicherungsrechtlichen Voraussetzungen nach § 11 Absatz 1 oder 2 erfüllen, mit einem Fallmanagement aktivierend und koordinierend bei ihrer beruflichen Wiedereingliederung begleiten und unterstützen.","PrinzipErfuellungen",[],{"_24":213,"_204":214,"_26":69,"_210":226},"vprp8kkrc02n0wj6f5yc9k5q",[215],{"_33":34,"_35":216},[217,219,222,224],{"_38":218,"_33":38},"Zur frühzeitigen Erkennung eines Rehabilitationsbedarfs nach § 13 des Neunten Buches können die Träger der Rentenversicherung bereits vor der Entscheidung über die Durchführung eines Fallmanagements Kontakt mit Versicherten aufnehmen. Das Fallmanagement ist nur mit Einwilligung der Versicherten zulässig. ",{"_38":220,"_33":38,"_221":136},"Die Einwilligung ist zu dokumentieren.[1]","underline",{"_38":223,"_33":38}," ",{"_38":225,"_33":38,"_221":136},"Für die Durchführung des Fallmanagements erforderliche Datenverarbeitungen dürfen nur mit dem Einverständnis des Versicherten erfolgen.[3]",[227,256],{"_228":229,"_230":231,"_236":237},"id","1439","Erklaerung",[232],{"_33":34,"_35":233},[234],{"_38":235,"_33":38},"Die Art der Dokumentation ist technologieoffen formuliert. So können bestehende IT-Verfahren weiterhin genutzt und weiterentwickelt werden. ","Prinzip",{"_24":25,"_26":27,"_28":29,"_30":238,"_62":63,"_64":65,"_66":27},[239,242,245],{"_33":34,"_35":240},[241],{"_38":39,"_33":38},{"_33":34,"_35":243},[244],{"_38":43,"_33":38},{"_33":45,"_46":47,"_35":246},[247,250,253],{"_33":50,"_35":248},[249],{"_38":53,"_33":38},{"_33":50,"_35":251},[252],{"_38":57,"_33":38},{"_33":50,"_35":254},[255],{"_38":61,"_33":38},{"_228":257,"_230":258,"_236":263},"1445",[259],{"_33":34,"_35":260},[261],{"_38":262,"_33":38},"Erforderliche Daten werden nur im Rahmen der DSGVO und mit Zustimmung der Betroffenen verarbeitet.",{"_24":150,"_26":105,"_28":151,"_30":264,"_62":172,"_64":173,"_66":108},[265,272,275],{"_33":34,"_35":266},[267,268,271],{"_38":156,"_33":38},{"_77":158,"_33":79,"_35":269},[270],{"_38":161,"_33":38},{"_38":163,"_33":38},{"_33":34,"_35":273},[274],{"_38":167,"_33":38},{"_33":34,"_35":276},[277],{"_38":171,"_33":38},{"_24":279,"_204":280,"_26":105,"_210":310},"gntx5sev60gkil9gwne73y44",[281,285],{"_33":34,"_35":282},[283],{"_38":284,"_33":38},"Das Fallmanagement kann Folgendes umfassen:",{"_33":45,"_46":286,"_35":287},"ordered",[288,292,296,302,306],{"_33":50,"_35":289},[290],{"_38":291,"_33":38},"die Erkennung, Ermittlung und Feststellung des individuellen Rehabilitationsbedarfs nach § 13 des Neunten Buches einschließlich der Dokumentation des Bedarfs,",{"_33":50,"_35":293},[294],{"_38":295,"_33":38},"die Entwicklung und Koordinierung eines individuellen Rehabilitationsprozesses gemeinsam mit den Versicherten und unter Einbindung weiterer Beteiligter sowie die Erstellung eines individuellen Teilhabeplans nach § 19 des Neunten Buches soweit die gesetzlichen Voraussetzungen vorliegen,",{"_33":50,"_35":297},[298,300],{"_38":299,"_33":38},"die rechtskreisübergreifende Unterstützung der Versicherten bei der Beantragung von in Betracht kommenden Sozialleistungen und bei der Inanspruchnahme weiterer unterstützender Angebote",{"_38":301,"_33":38,"_221":136},",",{"_33":50,"_35":303},[304],{"_38":305,"_33":38},"die Begleitung der Versicherten mit dem Ziel des Erhalts zügiger und aufeinander abgestimmter Leistungen, soweit die Versicherten Ansprüche gegen Träger von Sozialleistungen haben oder haben könnten, die die berufliche Wiedereingliederung fördern und unterstützen können,",{"_33":50,"_35":307},[308],{"_38":309,"_33":38},"die begleitende Bewertung und mögliche Anpassung des individuellen Rehabilitationsprozesses gemeinsam mit den Versicherten.",[],{"_24":312,"_204":313,"_26":148,"_210":318},"xbg6ti3hebt0xc0dp4iqfvcr",[314],{"_33":34,"_35":315},[316],{"_38":317,"_33":38,"_221":136},"Das Fallmanagement kann vollständig oder in Teilen durch die Träger der Rentenversicherung oder durch beauftragte Dritte durchgeführt werden.[5]",[319],{"_228":320,"_230":321,"_236":332},"1434",[322],{"_33":45,"_46":47,"_35":323},[324,328],{"_33":50,"_35":325},[326],{"_38":327,"_33":38},"Die Regelung geht auf die Bedürfnisse der betroffenen Vollzugsbehörde ein.",{"_33":50,"_35":329},[330],{"_38":331,"_33":38},"Die betroffene Vollzugsbehörde kann sich je nach Kompetenz- und Ressourcenausstattung von Dritten entlasten lassen.",{"_24":107,"_26":108,"_28":109,"_30":333,"_62":146,"_64":147,"_66":148},[334,345],{"_33":34,"_35":335},[336,337,340,341,344],{"_38":114,"_33":38},{"_77":116,"_33":79,"_35":338},[339],{"_38":119,"_33":38},{"_38":121,"_33":38},{"_77":123,"_33":79,"_35":342},[343],{"_38":126,"_33":38},{"_38":128,"_33":38},{"_33":34,"_35":346},[347,348,349,350,353],{"_38":132,"_33":38},{"_38":134,"_33":38,"_135":136},{"_38":138,"_33":38},{"_77":140,"_33":79,"_35":351},[352],{"_38":143,"_33":38},{"_38":145,"_33":38},{"_24":355,"_204":356,"_26":108,"_210":361},"t7owi2bmnaj8ynqv5no3c5fs",[357],{"_33":34,"_35":358},[359],{"_38":360,"_33":38},"Sind bei der Durchführung des Fallmanagements spezifische Anforderungen erforderlich, so können die Träger der Rentenversicherung Dritte damit beauftragen, das Fallmanagement als Leistung durchzuführen. Die spezifischen Anforderungen dieser Leistung bestimmt die Deutsche Rentenversicherung Bund in einem gemeinsamen Rahmenkonzept der Träger der Rentenversicherung.",[],{"_24":363,"_204":364,"_26":89,"_210":369},"ns7110jjy753fe6jq5q46q6s",[365],{"_33":34,"_35":366},[367],{"_38":368,"_33":38},"Führt ein Träger der Rentenversicherung ein Fallmanagement durch, werden die Bedarfsermittlung und, sofern die Voraussetzungen für ein Teilhabeplanverfahren nach Teil 1 Kapitel 2 bis 4 des Neunten Buches vorliegen, das Teilhabeplanverfahren als Bestandteil des Fallmanagements erbracht.",[],"Visualisierungen",[],"Digitalchecks",[]]
