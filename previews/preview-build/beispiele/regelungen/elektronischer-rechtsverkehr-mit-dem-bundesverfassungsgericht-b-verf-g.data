[{"_1":2,"_21":22,"_174":175},"root",{"_3":4},"data",{"_5":6,"_7":8,"_9":8,"_10":11,"_19":20},"BASE_URL","https://localhost","trackingEnabled",false,"posthogEnabled","featureFlags",{"_12":13,"_14":13,"_15":13,"_16":13,"_17":13,"_18":13},"showGesetzgebungsprozessOverview",true,"showInterviewLeitfaden","showDCATAP","showIOEuRechtContent","simplifiedPrincipleFlow","showStrapiDrafts","posthogKey","","routes/beispiele",{"_3":23},[24,68,88,107,149],{"_25":26,"_27":28,"_29":30,"_31":32,"_63":64,"_65":66,"_67":28},"documentId","r57rc9d82ulv2bsc3gdbnj73","Nummer",1,"Name","Digitale Angebote für alle nutzbar gestalten","Beschreibung",[33,41,45],{"_34":35,"_36":37},"type","paragraph","children",[38],{"_39":40,"_34":39},"text","Eine Regelung ist dann erfolgreich digitalisiert, wenn sie ohne Medienbrüche und unnötige Behördengänge funktioniert. Konkret bedeutet das: Bürgerinnen, Bürger und Unternehmen können Anträge intuitiv online stellen, während Behörden die Daten ohne manuelle Nacherfassung systemübergreifend verarbeiten. Dies erfordert, dass Digitaltauglichkeit von Anfang an mitgedacht wird.",{"_34":35,"_36":42},[43],{"_39":44,"_34":39},"Erfahren Sie in diesem Abschnitt,",{"_34":46,"_47":48,"_36":49},"list","format","unordered",[50,55,59],{"_34":51,"_36":52},"list-item",[53],{"_39":54,"_34":39},"mit welchen Formulierungen Sie eine effiziente digitale Umsetzung ermöglichen,",{"_34":51,"_36":56},[57],{"_39":58,"_34":39},"wie Sie digitale Möglichkeiten für einen effizienten Vollzug nutzen,",{"_34":51,"_36":60},[61],{"_39":62,"_34":39},"wie Barrierefreiheit zu bedenken ist.","URLBezeichnung","digitale-angebote-fuer-alle-nutzbar-gestalten","Kurzbezeichnung","Digitale Angebote","order",{"_25":69,"_27":70,"_29":71,"_31":72,"_63":86,"_65":87,"_67":70},"s18bibg9sdf0jt8up7h8btup",2,"Datenwiederverwendung benötigt einheitliches Recht",[73],{"_34":35,"_36":74},[75,77,84],{"_39":76,"_34":39},"Normadressatinnen und -adressaten sowie umsetzende Behörden sparen Kosten und Zeit, wenn das ",{"_78":79,"_34":80,"_36":81},"url","https://www.digitale-verwaltung.de/Webs/DV/DE/registermodernisierung/registermodernisierung-node.html","link",[82],{"_39":83,"_34":39},"Once-Only-Prinzip",{"_39":85,"_34":39}," konsequent angewendet wird – also wenn Daten nur einmal angegeben und dann wiederverwendet werden. Die Grundlage dafür sind harmonisierte Rechtsbegriffe, ein datenschutzkonformer Austausch und die Berücksichtigung etablierter technischer Standards.","datenwiederverwendung-benoetigt-einheitliches-recht","Datenwiederverwendung",{"_25":89,"_27":90,"_29":91,"_31":92,"_63":104,"_65":105,"_67":106},"habu0yjh39lc5wug5mqsqzaj",6,"Etablierte Technologien ermöglichen effiziente Umsetzung",[93],{"_34":35,"_36":94},[95,97,102],{"_39":96,"_34":39},"Digitale Angebote können schneller bereitgestellt sowie günstiger entwickelt und betrieben werden, wenn sie auf bestehenden Technologien aufbauen. Offene, standardisierte Schnittstellen und Open-Source erhöhen die ",{"_78":98,"_34":80,"_36":99},"/#datenschutz-und-informationssicherheit-schaffen-vertrauen",[100],{"_39":101,"_34":39},"Sicherheit der Angebote",{"_39":103,"_34":39}," und fördern die Interoperabilität.","etablierte-technologien-ermoeglichen-effiziente-umsetzung","Etablierte Technologien",3,{"_25":108,"_27":109,"_29":110,"_31":111,"_63":146,"_65":147,"_67":148},"got436pv8femeqmv6ee8wlm1",5,"Automatisierung basiert auf eindeutigen Regelungen",[112,130],{"_34":35,"_36":113},[114,116,121,123,128],{"_39":115,"_34":39},"Logische und verständliche Regelungen und transparente Verfahren erleichtern den Zugang zum Recht und stärken das Vertrauen in den Staat. Einfachheit und verständliche Sprache sind durch die ",{"_78":117,"_34":80,"_36":118},"https://www.verwaltungsvorschriften-im-internet.de/bsvwvbund_21072009_O11313012.htm#paragraph42:~:text=Gesetzentw%C3%BCrfe%20m%C3%BCssen%20sprachlich,hat%20empfehlenden%20Charakter.",[119],{"_39":120,"_34":39},"GGO",{"_39":122,"_34":39}," und das ",{"_78":124,"_34":80,"_36":125},"https://www.bmj.de/SharedDocs/Publikationen/DE/Fachpublikationen/Handbuch_der_Rechtsfoermlichkeit_4.pdf?__blob=publicationFile&v=1#page=147",[126],{"_39":127,"_34":39},"Handbuch der Rechtsförmlichkeit",{"_39":129,"_34":39}," vorgeschrieben.",{"_34":35,"_36":131},[132,134,137,139,144],{"_39":133,"_34":39},"Klarheit und Logik bilden die Grundlage für automatisierte Prozesse. Ein ",{"_39":135,"_34":39,"_136":13},"Verwaltungsakt","italic",{"_39":138,"_34":39}," kann vollständig durch automatische Einrichtungen erlassen werden, sofern dies durch Rechtsvorschrift zugelassen ist und weder ein Ermessen noch ein Beurteilungsspielraum besteht (",{"_78":140,"_34":80,"_36":141},"https://www.gesetze-im-internet.de/vwvfg/__35a.html",[142],{"_39":143,"_34":39},"§ 35a VwVfG",{"_39":145,"_34":39},"). Wenn Begriffe eindeutig definiert sowie Entscheidungsstrukturen bestimmt sind, können Teile des Vollzugs (Regeln und klare Ausnahmen) automatisiert werden. Das spart Zeit auf Seiten der Nutzenden und der Verwaltung. Mit diesen Ressourcen können kritischere Einzelfälle bearbeitet oder Normadressatinnen und -adressaten beraten werden.","automatisierung-basiert-auf-eindeutigen-regelungen","Automatisierung",4,{"_25":150,"_27":106,"_29":151,"_31":152,"_63":172,"_65":173,"_67":109},"bnx9lmblnceu1m3uy3rziy0i","Datenschutz und Informationssicherheit schaffen Vertrauen",[153,164,168],{"_34":35,"_36":154},[155,157,162],{"_39":156,"_34":39},"Alle Menschen haben ein Recht darauf, dass ihre Daten vor unbefugten Zugriffen geschützt werden. Der Schutz personenbezogener Daten ist in der ",{"_78":158,"_34":80,"_36":159},"https://eur-lex.europa.eu/eli/reg/2016/679/oj?locale=de",[160],{"_39":161,"_34":39},"DSGVO",{"_39":163,"_34":39}," geregelt. Informationssicherheit umfasst alle Daten und wird je nach Bereich spezifiziert.",{"_34":35,"_36":165},[166],{"_39":167,"_34":39},"Eine datenschutzkonforme Regelung erhebt nur das Minimum an Daten. Datensparsamkeit ist einfach umzusetzen und verringert den Erfüllungsaufwand. Wenn weniger Daten vorliegen, müssen auch weniger Informationen geschützt werden.",{"_34":35,"_36":169},[170],{"_39":171,"_34":39},"Wenn Informationen den ihnen gebührenden Schutz erhalten, schafft das Vertrauen in den Staat. Die Gefahr von Missbrauch und negativen wirtschaftlichen oder sicherheitsrelevanten Konsequenzen wird verringert.","datenschutz-und-informationssicherheit-schaffen-vertrauen","Informationssicherheit und Datenschutz","routes/beispiele.regelungen.$regelung",{"_3":176},{"_25":177,"_178":179,"_180":181,"_182":183,"_184":185,"_63":186,"_187":188,"_189":190,"_191":-5,"_192":193,"_194":195,"_597":598,"_599":600},"wdb62i9iybimrbzxtfkm02v2","Titel","Elektronischer Rechtsverkehr mit dem Bundesverfassungsgericht – BVerfGG","NKRNummer",6773,"Rechtsgebiet","TBD","Ressort","BMJV","elektronischer-rechtsverkehr-mit-dem-bundesverfassungsgericht-b-verf-g","VeroeffentlichungsDatum","2024-08-01","LinkRegelungstext","https://www.gesetze-im-internet.de/bverfgg/BJNR002430951.html","NKRStellungnahmeLink","GesetzStatus","Verkuendetes_Gesetz_aktuelle_Fassung","Paragraphen",[196,400,442,494,545],{"_25":197,"_27":198,"_178":-5,"_199":200,"_201":-5,"_202":203},"c2k4ab7v50lt2ox7hwm6m6uy","23a","Gesetz","BVerfGG","Artikel","Absaetze",[204,244,276,314,353,392],{"_25":205,"_206":207,"_27":28,"_213":214},"rdfocmyt6wqirzqsmwjgz9vo","Text",[208],{"_34":35,"_36":209},[210],{"_39":211,"_34":39,"_212":13},"Schriftlich einzureichende Anträge und Erklärungen sowie sonstige Schriftsätze und deren Anlagen können nach Maßgabe der folgenden Absätze als elektronische Dokumente beim Bundesverfassungsgericht eingereicht werden.[1]","underline","PrinzipErfuellungen",[215],{"_216":217,"_218":219,"_224":225},"id","1311","Erklaerung",[220],{"_34":35,"_36":221},[222],{"_39":223,"_34":39},"Ermöglicht elektronisches Einreichen der Dokumente.","Prinzip",{"_25":26,"_27":28,"_29":30,"_31":226,"_63":64,"_65":66,"_67":28},[227,230,233],{"_34":35,"_36":228},[229],{"_39":40,"_34":39},{"_34":35,"_36":231},[232],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":234},[235,238,241],{"_34":51,"_36":236},[237],{"_39":54,"_34":39},{"_34":51,"_36":239},[240],{"_39":58,"_34":39},{"_34":51,"_36":242},[243],{"_39":62,"_34":39},{"_25":245,"_206":246,"_27":70,"_213":251},"t0037mojhj4ibwqs1d5zleq9",[247],{"_34":35,"_36":248},[249],{"_39":250,"_34":39,"_212":13},"Das elektronische Dokument muss für die Bearbeitung durch das Bundesverfassungsgericht geeignet sein. Für die Übermittlung und die Eignung zur Bearbeitung durch das Bundesverfassungsgericht gelten die in der Elektronischer-Rechtsverkehr-Verordnung geregelten technischen Rahmenbedingungen des elektronischen Rechtsverkehrs entsprechend.[2]",[252],{"_216":253,"_218":254,"_224":267},"1301",[255,261],{"_34":46,"_47":48,"_36":256},[257],{"_34":51,"_36":258},[259],{"_39":260,"_34":39},"Begünstigt eine effiziente technische Umsetzung, indem es die Nutzung oder Wiederverwendung eines geeigneten Datenstandards vorschreibt.",{"_34":46,"_47":48,"_36":262},[263],{"_34":51,"_36":264},[265],{"_39":266,"_34":39},"Verweist mit der Elektronischer-Rechtsverkehr-Verordnung auf eine Regelung, die technische und rechtliche Aspekte zentral steuert.",{"_25":69,"_27":70,"_29":71,"_31":268,"_63":86,"_65":87,"_67":70},[269],{"_34":35,"_36":270},[271,272,275],{"_39":76,"_34":39},{"_78":79,"_34":80,"_36":273},[274],{"_39":83,"_34":39},{"_39":85,"_34":39},{"_25":277,"_206":278,"_27":106,"_213":285},"kqsgu93abtz4s3i69gidyyps",[279],{"_34":35,"_36":280},[281,283],{"_39":282,"_34":39,"_212":13},"Das elektronische Dokument muss mit einer qualifizierten elektronischen Signatur der verantwortenden Person versehen sein oder von der verantwortenden Person signiert und auf einem sicheren Übermittlungsweg eingereicht werden.[3]",{"_39":284,"_34":39}," Satz 1 gilt nicht für Anlagen. Soll ein schriftlich einzureichender Antrag oder eine schriftlich einzureichende Erklärung eines Beteiligten oder eines Dritten als elektronisches Dokument eingereicht werden, so kann der unterschriebene Antrag oder die unterschriebene Erklärung in ein elektronisches Dokument übertragen und durch den Bevollmächtigten, den Vertreter oder den Beistand nach Satz 1 übermittelt werden.",[286],{"_216":287,"_218":288,"_224":299},"1313",[289],{"_34":46,"_47":48,"_36":290},[291,295],{"_34":51,"_36":292},[293],{"_39":294,"_34":39},"Steigert den Schutz vor Fälschungen durch Verwendung eines geeigneten kryptografischen Verfahrens (qualifizierte elektronische Signatur).",{"_34":51,"_36":296},[297],{"_39":298,"_34":39},"Führt zu erhöhter Informationssicherheit durch die Nutzung eines sicheren Übermittlungsweges (siehe Absatz 3). Dies schützt die Daten vor Veränderung und unerlaubter Einsicht während der Übertragung.",{"_25":150,"_27":106,"_29":151,"_31":300,"_63":172,"_65":173,"_67":109},[301,308,311],{"_34":35,"_36":302},[303,304,307],{"_39":156,"_34":39},{"_78":158,"_34":80,"_36":305},[306],{"_39":161,"_34":39},{"_39":163,"_34":39},{"_34":35,"_36":309},[310],{"_39":167,"_34":39},{"_34":35,"_36":312},[313],{"_39":171,"_34":39},{"_25":315,"_206":316,"_27":148,"_213":352},"pw00bksnv634vgzyivplxbyf",[317,321,348],{"_34":35,"_36":318},[319],{"_39":320,"_34":39},"Sichere Übermittlungswege sind",{"_34":46,"_47":322,"_36":323},"ordered",[324,328,332,336,340,344],{"_34":51,"_36":325},[326],{"_39":327,"_34":39},"der Postfach- und Versanddienst eines De-Mail-Kontos, wenn der Absender bei Versand der Nachricht sicher im Sinne des § 4 Absatz 1 Satz 2 des De-Mail-Gesetzes angemeldet ist und er sich die sichere Anmeldung gemäß § 5 Absatz 5 des De-Mail-Gesetzes bestätigen lässt,",{"_34":51,"_36":329},[330],{"_39":331,"_34":39},"der Übermittlungsweg zwischen den besonderen elektronischen Anwaltspostfächern nach den §§ 31a und 31b der Bundesrechtsanwaltsordnung oder einem entsprechenden, auf gesetzlicher Grundlage errichteten elektronischen Postfach und der elektronischen Poststelle des Bundesverfassungsgerichts,",{"_34":51,"_36":333},[334],{"_39":335,"_34":39},"der Übermittlungsweg zwischen einem nach Durchführung eines Identifizierungsverfahrens eingerichteten Postfach einer Behörde oder einer juristischen Person des öffentlichen Rechts und der elektronischen Poststelle des Bundesverfassungsgerichts,",{"_34":51,"_36":337},[338],{"_39":339,"_34":39},"der Übermittlungsweg zwischen einem nach Durchführung eines Identifizierungsverfahrens eingerichteten elektronischen Postfach einer natürlichen oder juristischen Person oder einer sonstigen Vereinigung und der elektronischen Poststelle des Bundesverfassungsgerichts,",{"_34":51,"_36":341},[342],{"_39":343,"_34":39},"der Übermittlungsweg zwischen einem nach Durchführung eines Identifizierungsverfahrens genutzten Postfach- und Versanddienst eines Nutzerkontos im Sinne des § 2 Absatz 5 des Onlinezugangsgesetzes und der elektronischen Poststelle des Bundesverfassungsgerichts,",{"_34":51,"_36":345},[346],{"_39":347,"_34":39},"sonstige bundeseinheitliche Übermittlungswege, die durch Rechtsverordnung der Bundesregierung mit Zustimmung des Bundesrates festgelegt werden, bei denen die Authentizität und Integrität der Daten sowie die Barrierefreiheit gewährleistet sind.",{"_34":35,"_36":349},[350],{"_39":351,"_34":39,"_212":13},"Für die Übermittlungswege gemäß Satz 1 Nummer 3 bis 5 gelten die näheren Regelungen der Elektronischer-Rechtsverkehr-Verordnung entsprechend.[3]",[],{"_25":354,"_206":355,"_27":109,"_213":362},"dkrepldx3f00evybq7hdz4na",[356],{"_34":35,"_36":357},[358,360],{"_39":359,"_34":39},"Ein elektronisches Dokument ist eingegangen, sobald es auf der für den Empfang bestimmten Einrichtung des Bundesverfassungsgerichts gespeichert ist. ",{"_39":361,"_34":39,"_212":13},"Dem Absender ist eine automatisierte Bestätigung über den Zeitpunkt des Eingangs zu erteilen.[5]",[363],{"_216":364,"_218":365,"_224":370},"1315",[366],{"_34":35,"_36":367},[368],{"_39":369,"_34":39},"Entlastet die Verwaltung durch automatische Bestätigungen; eine Funktionalität, die von Nutzenden erwartet wird.",{"_25":108,"_27":109,"_29":110,"_31":371,"_63":146,"_65":147,"_67":148},[372,383],{"_34":35,"_36":373},[374,375,378,379,382],{"_39":115,"_34":39},{"_78":117,"_34":80,"_36":376},[377],{"_39":120,"_34":39},{"_39":122,"_34":39},{"_78":124,"_34":80,"_36":380},[381],{"_39":127,"_34":39},{"_39":129,"_34":39},{"_34":35,"_36":384},[385,386,387,388,391],{"_39":133,"_34":39},{"_39":135,"_34":39,"_136":13},{"_39":138,"_34":39},{"_78":140,"_34":80,"_36":389},[390],{"_39":143,"_34":39},{"_39":145,"_34":39},{"_25":393,"_206":394,"_27":90,"_213":399},"ta578ilke4gqe4fh671a19xz",[395],{"_34":35,"_36":396},[397],{"_39":398,"_34":39},"Ist ein elektronisches Dokument für das Bundesverfassungsgericht zur Bearbeitung nicht geeignet, ist dies dem Absender unter Hinweis auf die Unwirksamkeit des Eingangs unverzüglich mitzuteilen. Das Dokument gilt als zum Zeitpunkt der früheren Einreichung eingegangen, sofern der Absender es unverzüglich in einer für das Bundesverfassungsgericht zur Bearbeitung geeigneten Form nachreicht und glaubhaft macht, dass es mit dem zuerst eingereichten Dokument inhaltlich übereinstimmt.",[],{"_25":401,"_27":402,"_178":-5,"_199":200,"_201":-5,"_202":403},"xnhtsk5lselwhds4vlaspi6j","23b",[404],{"_25":405,"_206":406,"_27":28,"_213":415},"l9hl26wi4tp25ggof4we95as",[407],{"_34":35,"_36":408},[409,411,413],{"_39":410,"_34":39},"Soweit die handschriftliche Unterzeichnung durch den Richter, den Rechtspfleger oder den Urkundsbeamten der Geschäftsstelle vorgeschrieben ist, ",{"_39":412,"_34":39,"_212":13},"genügt dieser Form die Aufzeichnung als elektronisches Dokument[1]",{"_39":414,"_34":39},", wenn die verantwortenden Personen am Ende des Dokuments ihren Namen hinzufügen und das Dokument mit einer qualifizierten elektronischen Signatur versehen. Der in Satz 1 genannten Form genügt auch ein elektronisches Dokument, in welches das handschriftlich unterzeichnete Schriftstück gemäß § 23e Absatz 2 Satz 4 übertragen worden ist.",[416],{"_216":417,"_218":418,"_224":423},"1317",[419],{"_34":35,"_36":420},[421],{"_39":422,"_34":39},"Verhindert einen Medienbruch und erhöht die Nutzerfreundlichkeit durch das Ermöglichen von Alternativen zur handschriftlichen Unterzeichnung.",{"_25":26,"_27":28,"_29":30,"_31":424,"_63":64,"_65":66,"_67":28},[425,428,431],{"_34":35,"_36":426},[427],{"_39":40,"_34":39},{"_34":35,"_36":429},[430],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":432},[433,436,439],{"_34":51,"_36":434},[435],{"_39":54,"_34":39},{"_34":51,"_36":437},[438],{"_39":58,"_34":39},{"_34":51,"_36":440},[441],{"_39":62,"_34":39},{"_25":443,"_27":444,"_178":-5,"_199":200,"_201":-5,"_202":445},"knqwnc9dpra9uq488n9ovzxe","23c",[446],{"_25":447,"_206":448,"_27":28,"_213":461},"b381cyonkcztn9jq5ujtp4de",[449],{"_34":35,"_36":450},[451,453,455,457,459],{"_39":452,"_34":39},"Schriftlich einzureichende Anträge und Erklärungen sowie sonstige Schriftsätze und deren Anlagen, die durch einen Rechtsanwalt, durch eine Behörde oder durch eine juristische Person des öffentlichen Rechts einschließlich der von ihr zur Erfüllung ihrer öffentlichen Aufgaben gebildeten Zusammenschlüsse eingereicht werden, ",{"_39":454,"_34":39,"_212":13},"sind als elektronische Dokumente zu übermitteln[1]",{"_39":456,"_34":39},". Ist dies aus technischen Gründen vorübergehend nicht möglich, bleibt die Übermittlung nach den allgemeinen Vorschriften zulässig. Die vorübergehende Unmöglichkeit ist bei der Ersatzeinreichung oder unverzüglich danach glaubhaft zu machen; ",{"_39":458,"_34":39,"_212":13},"auf Anforderung ist ein elektronisches Dokument nachzureichen[1]",{"_39":460,"_34":39},".",[462],{"_216":463,"_218":464,"_224":475},"1331",[465],{"_34":46,"_47":48,"_36":466},[467,471],{"_34":51,"_36":468},[469],{"_39":470,"_34":39},"Macht elektronische Datenübermittlung zum Regelfall.",{"_34":51,"_36":472},[473],{"_39":474,"_34":39},"Da der Normenadressat eine besonders befähigte Gruppe darstellt, kann hier im Regelfall komplett auf die Papierform verzichtet werden.",{"_25":26,"_27":28,"_29":30,"_31":476,"_63":64,"_65":66,"_67":28},[477,480,483],{"_34":35,"_36":478},[479],{"_39":40,"_34":39},{"_34":35,"_36":481},[482],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":484},[485,488,491],{"_34":51,"_36":486},[487],{"_39":54,"_34":39},{"_34":51,"_36":489},[490],{"_39":58,"_34":39},{"_34":51,"_36":492},[493],{"_39":62,"_34":39},{"_25":495,"_27":496,"_178":-5,"_199":497,"_201":-5,"_202":498},"ymmhasort2iyswlya1phwpvr","23d","BverfGG",[499,507,515,537],{"_25":500,"_206":501,"_27":28,"_213":506},"nj5nxhrkdsl6xmc5kcgqj12r",[502],{"_34":35,"_36":503},[504],{"_39":505,"_34":39},"Werden die Akten in Papierform geführt, ist von einem elektronischen Dokument ein Ausdruck für die Akte zu fertigen. Kann dies bei Anlagen nicht oder nur mit unverhältnismäßigem Aufwand erfolgen, so kann ein Ausdruck unterbleiben. Die Daten sind in diesem Fall dauerhaft zu speichern; der Speicherort ist aktenkundig zu machen.",[],{"_25":508,"_206":509,"_27":70,"_213":514},"mqcc85hes13uxwovtogdzagp",[510],{"_34":35,"_36":511},[512],{"_39":513,"_34":39},"Wird das elektronische Dokument auf einem sicheren Übermittlungsweg eingereicht, so ist dies aktenkundig zu machen.",[],{"_25":516,"_206":517,"_27":106,"_213":536},"hrl9g1vby9ncan3nztre6qua",[518,522],{"_34":35,"_36":519},[520],{"_39":521,"_34":39},"Ist das elektronische Dokument mit einer qualifizierten elektronischen Signatur versehen und nicht auf einem sicheren Übermittlungsweg eingereicht, muss der Ausdruck einen Vermerk darüber enthalten,",{"_34":46,"_47":322,"_36":523},[524,528,532],{"_34":51,"_36":525},[526],{"_39":527,"_34":39},"welches Ergebnis die Integritätsprüfung des Dokumentes ausweist,",{"_34":51,"_36":529},[530],{"_39":531,"_34":39},"wen die Signaturprüfung als Inhaber der Signatur ausweist,",{"_34":51,"_36":533},[534],{"_39":535,"_34":39},"welchen Zeitpunkt die Signaturprüfung für die Anbringung der Signatur ausweist.",[],{"_25":538,"_206":539,"_27":148,"_213":544},"l9ky7vbw13tb46ffdicfjlkp",[540],{"_34":35,"_36":541},[542],{"_39":543,"_34":39},"Ein eingereichtes elektronisches Dokument kann nach Ablauf von sechs Monaten gelöscht werden.",[],{"_25":546,"_27":547,"_178":-5,"_199":200,"_201":-5,"_202":548},"j7phpdnr7iwnwqo8w69v2od1","23e",[549,557],{"_25":550,"_206":551,"_27":28,"_213":556},"vgja8ibdmx6adzyi6szkqq2k",[552],{"_34":35,"_36":553},[554],{"_39":555,"_34":39},"Die Verfahrensakten können elektronisch geführt werden. Sie können auch teilweise elektronisch geführt werden.",[],{"_25":558,"_206":559,"_27":70,"_213":570},"n6mao42pkhqktfjibwx4lwae",[560],{"_34":35,"_36":561},[562,564,566,568],{"_39":563,"_34":39,"_212":13},"Werden die Verfahrensakten elektronisch geführt, sind in Papierform vorliegende Schriftstücke und sonstige Unterlagen nach dem Stand der Technik zur Ersetzung der Urschrift in ein elektronisches Dokument zu übertragen.[1]",{"_39":565,"_34":39}," Es ist sicherzustellen, dass das elektronische Dokument mit den vorliegenden Schriftstücken und sonstigen Unterlagen bildlich und inhaltlich übereinstimmt. Das elektronische Dokument ist mit einem Übertragungsnachweis zu versehen, der das bei der Übertragung angewandte Verfahren und die bildliche und inhaltliche Übereinstimmung dokumentiert. ",{"_39":567,"_34":39,"_212":13},"Wird ein von den verantwortenden Personen handschriftlich unterzeichnetes gerichtliches Schriftstück übertragen, ist der Übertragungsnachweis mit einer qualifizierten elektronischen Signatur des Urkundsbeamten der Geschäftsstelle zu versehen.[1]",{"_39":569,"_34":39}," Die in Papierform vorliegenden Schriftstücke und sonstigen Unterlagen können sechs Monate nach der Übertragung vernichtet werden, sofern sie nicht rückgabepflichtig sind.",[571],{"_216":572,"_218":573,"_224":578},"1379",[574],{"_34":35,"_36":575},[576],{"_39":577,"_34":39},"Ermöglicht eine ganzheitliche digitale Aktenführung.",{"_25":26,"_27":28,"_29":30,"_31":579,"_63":64,"_65":66,"_67":28},[580,583,586],{"_34":35,"_36":581},[582],{"_39":40,"_34":39},{"_34":35,"_36":584},[585],{"_39":44,"_34":39},{"_34":46,"_47":48,"_36":587},[588,591,594],{"_34":51,"_36":589},[590],{"_39":54,"_34":39},{"_34":51,"_36":592},[593],{"_39":58,"_34":39},{"_34":51,"_36":595},[596],{"_39":62,"_34":39},"Visualisierungen",[],"Digitalchecks",[601],{"_25":602,"_178":603,"_604":605,"_606":605,"_607":605,"_608":605,"_609":605,"_610":-5},"onf6a4hlnxmbq2nvf3mhdkkj","Zehntes Gesetz zur Änderung des Bundesverfassungsgerichtsgesetzes","EinschaetzungAutomatisierung","Ja","EinschaetzungDatenschutz","EinschaetzungKlareRegelungen","EinschaetzungKommunikation","EinschaetzungWiederverwendung","NKRStellungnahmeDCText"]
